  .hero-meta .dot { display: inline-block; width: 7px; height: 7px; margin-right: 0.4rem; border-radius: 50%; background: var(--ok); box-shadow: 0 0 8px var(--ok); }

  .ds-sec { padding: clamp(3rem, 8vh, 5rem) 0; border-top: 1px solid var(--line); scroll-margin-top: 118px; }
