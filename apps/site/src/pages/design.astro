  .spec { min-height: 150px; display: grid; place-items: center; gap: 0.4rem; padding-top: 2rem; }
  .spec .big { font-family: var(--display); font-weight: 600; font-size: 3.2rem; letter-spacing: -0.03em; }
  .spec .big.mono { font-family: var(--mono); font-size: 2.4rem; }
  .spec .cap { font-family: var(--mono); font-size: 0.58rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-4); }
