  <script>
    // The force browser's Icon / Symbol / Name toggle — swaps a `view-*` class on
    // the browser root; the tile faces show/hide via CSS. Re-binds on client nav.
    function initForceBrowsers() {
      document.querySelectorAll<HTMLElement>('[data-force-browser]').forEach((br) => {
        const seg = br.querySelector('.seg-toggle');
        if (!seg || (br as any)._wired) return;
        (br as any)._wired = true;
        seg.addEventListener('click', (e) => {
          const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('button[data-view]');
          if (!btn) return;
          const view = btn.dataset.view!;
          br.classList.remove('view-icon', 'view-symbol', 'view-name');
          br.classList.add('view-' + view);
          seg.querySelectorAll('button').forEach((b) => b.classList.toggle('on', b === btn));
        });
      });
    }
    // The instrument controls — slider, stepper, angle dial, dual range, select.
    // Vanilla port of the design system's ds-inputs; the whole set tints via --cc.
    function initControls() {
      const root = document.querySelector<HTMLElement>('[data-controls]');
      if (!root || (root as any)._wired) return;
      (root as any)._wired = true;

      const clamp = (v: number, lo: number, hi: number) => Math.max(lo, Math.min(hi, v));
      const snap = (v: number, lo: number, hi: number, step: number) => {
        v = clamp(v, lo, hi);
        if (step) v = Math.round((v - lo) / step) * step + lo;
        return clamp(v, lo, hi);
      };
      const fmt = (v: number, step: number) => {
        const d = step && step < 1 ? (String(step).split('.')[1] || '').length : 0;
        return Number(v).toFixed(d);
      };
      const dragVal = (e: PointerEvent, track: HTMLElement, lo: number, hi: number, step: number) => {
        const r = track.getBoundingClientRect();
        const R = 9;
        const p = clamp((e.clientX - r.left - R) / (r.width - 2 * R), 0, 1);
        return snap(lo + p * (hi - lo), lo, hi, step);
      };
      const drag = (onMove: (e: PointerEvent) => void) => {
        const move = (e: PointerEvent) => onMove(e);
        const up = () => { window.removeEventListener('pointermove', move); window.removeEventListener('pointerup', up); };
        window.addEventListener('pointermove', move); window.addEventListener('pointerup', up);
      };

      // tint picker — re-tints every control
      const tintName = root.querySelector<HTMLElement>('[data-tint-name]');
      root.querySelectorAll<HTMLElement>('[data-tint]').forEach((t) => t.addEventListener('click', () => {
        root.style.setProperty('--cc', t.style.getPropertyValue('--cc'));
        root.querySelectorAll<HTMLElement>('[data-tint]').forEach((o) => {
          o.classList.toggle('on', o === t); o.setAttribute('aria-pressed', String(o === t));
        });
        if (tintName) tintName.textContent = t.dataset.name || '';
      }));

      // sliders (track + meter)
      root.querySelectorAll<HTMLElement>('[data-slider]').forEach((sl) => {
        const lo = +sl.dataset.min!, hi = +sl.dataset.max!, step = +sl.dataset.step!, unit = sl.dataset.unit || '';
        const track = sl.querySelector<HTMLElement>('.ds-slider-track')!;
        const out = sl.querySelector<HTMLElement>('[data-out]');
        const bubble = sl.querySelector<HTMLElement>('[data-bubble]');
        let val = +sl.dataset.value!;
        const set = (v: number) => {
          val = v;
          sl.style.setProperty('--pct', String((v - lo) / (hi - lo)));
          if (out) out.textContent = fmt(v, step);
          if (bubble) bubble.textContent = fmt(v, step) + unit;
          track.setAttribute('aria-valuenow', String(v));
        };
        track.addEventListener('pointerdown', (e) => { e.preventDefault(); track.focus(); set(dragVal(e, track, lo, hi, step)); drag((ev) => set(dragVal(ev, track, lo, hi, step))); });
        track.addEventListener('keydown', (e) => {
          const big = e.shiftKey ? 5 : 1; let nv = val;
          if (e.key === 'ArrowRight' || e.key === 'ArrowUp') nv = val + step * big;
          else if (e.key === 'ArrowLeft' || e.key === 'ArrowDown') nv = val - step * big;
          else return;
          e.preventDefault(); set(snap(nv, lo, hi, step));
        });
      });

      // steppers
      root.querySelectorAll<HTMLElement>('[data-stepper]').forEach((st) => {
        const lo = +st.dataset.min!, hi = +st.dataset.max!, step = +st.dataset.step! || 1;
        const input = st.querySelector<HTMLInputElement>('[data-step-input]')!;
        let val = +st.dataset.value!;
        const set = (v: number) => { val = snap(v, lo, hi, step); input.value = fmt(val, step); };
        st.querySelector<HTMLElement>('[data-step-dec]')!.addEventListener('click', () => set(val - step));
        st.querySelector<HTMLElement>('[data-step-inc]')!.addEventListener('click', () => set(val + step));
        input.addEventListener('change', () => { const v = parseFloat(input.value); if (!isNaN(v)) set(v); });
      });

      // angle dial
      root.querySelectorAll<HTMLElement>('[data-dial]').forEach((d) => {
        const hubOut = d.querySelector<HTMLElement>('[data-out]');
        const sideOut = d.closest<HTMLElement>('.frame')?.querySelector<HTMLElement>('[data-dial-out]');
        let val = +d.dataset.value!;
        const set = (v: number) => {
          val = ((Math.round(v) % 360) + 360) % 360;
          d.style.setProperty('--ang', val + 'deg');
          if (hubOut) hubOut.textContent = String(val);
          if (sideOut) sideOut.textContent = String(val);
          d.setAttribute('aria-valuenow', String(val));
        };
        const fromEvent = (e: PointerEvent) => {
          const r = d.getBoundingClientRect();
          set(Math.atan2(e.clientY - (r.top + r.height / 2), e.clientX - (r.left + r.width / 2)) * 180 / Math.PI);
        };
        d.addEventListener('pointerdown', (e) => { e.preventDefault(); d.focus(); fromEvent(e); drag(fromEvent); });
        d.addEventListener('keydown', (e) => {
          let nv = val;
          if (e.key === 'ArrowRight' || e.key === 'ArrowUp') nv = val + (e.shiftKey ? 15 : 1);
          else if (e.key === 'ArrowLeft' || e.key === 'ArrowDown') nv = val - (e.shiftKey ? 15 : 1);
          else return;
          e.preventDefault(); set(nv);
        });
      });

      // dual range
      root.querySelectorAll<HTMLElement>('[data-range]').forEach((rg) => {
        const lo = +rg.dataset.min!, hi = +rg.dataset.max!, step = +rg.dataset.step!;
        const track = rg.querySelector<HTMLElement>('.ds-range-track')!;
        const loEl = rg.querySelector<HTMLElement>('.ds-range-thumb.lo')!, hiEl = rg.querySelector<HTMLElement>('.ds-range-thumb.hi')!;
        const loOut = rg.querySelector<HTMLElement>('[data-lo-out]'), hiOut = rg.querySelector<HTMLElement>('[data-hi-out]');
        let vlo = +rg.dataset.lo!, vhi = +rg.dataset.hi!;
        const draw = () => {
          rg.style.setProperty('--lo', String((vlo - lo) / (hi - lo)));
          rg.style.setProperty('--hi', String((vhi - lo) / (hi - lo)));
          if (loOut) loOut.textContent = fmt(vlo, step);
          if (hiOut) hiOut.textContent = fmt(vhi, step);
          loEl.setAttribute('aria-valuenow', String(vlo)); hiEl.setAttribute('aria-valuenow', String(vhi));
        };
        loEl.addEventListener('pointerdown', (e) => { e.preventDefault(); e.stopPropagation(); drag((ev) => { vlo = Math.min(dragVal(ev, track, lo, hi, step), vhi); draw(); }); });
        hiEl.addEventListener('pointerdown', (e) => { e.preventDefault(); e.stopPropagation(); drag((ev) => { vhi = Math.max(dragVal(ev, track, lo, hi, step), vlo); draw(); }); });
      });

      // selects
      root.querySelectorAll<HTMLElement>('[data-select]').forEach((sel) => {
        const btn = sel.querySelector<HTMLElement>('.ds-select-btn')!;
        const menu = sel.querySelector<HTMLElement>('.ds-select-menu')!;
        const label = sel.querySelector<HTMLElement>('[data-select-label]');
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const open = !sel.classList.contains('open');
          sel.classList.toggle('open', open); menu.hidden = !open; btn.setAttribute('aria-expanded', String(open));
        });
        menu.querySelectorAll<HTMLElement>('.ds-select-opt').forEach((opt) => opt.addEventListener('click', () => {
          menu.querySelectorAll<HTMLElement>('.ds-select-opt').forEach((o) => { o.classList.toggle('on', o === opt); o.setAttribute('aria-selected', String(o === opt)); });
          if (label) label.textContent = opt.dataset.value || '';
          sel.classList.remove('open'); menu.hidden = true; btn.setAttribute('aria-expanded', 'false');
        }));
      });
    }

    // outside-click closes any open select — registered once, queries live DOM
    if (!(window as any)._dsSelClose) {
      (window as any)._dsSelClose = true;
      document.addEventListener('pointerdown', (e) => {
        document.querySelectorAll<HTMLElement>('.ds-select.open').forEach((s) => {
          if (!s.contains(e.target as Node)) {
            s.classList.remove('open');
            const m = s.querySelector<HTMLElement>('.ds-select-menu'); if (m) m.hidden = true;
            s.querySelector('.ds-select-btn')?.setAttribute('aria-expanded', 'false');
          }
        });
      });
    }

    initForceBrowsers();
    initControls();
    document.addEventListener('astro:page-load', () => { initForceBrowsers(); initControls(); });
  </script>
</Base>

<style>
  .ds-shell { position: relative; z-index: 2; width: 100%; align-self: flex-start; padding-top: 58px; }
