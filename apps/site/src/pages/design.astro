  .sec-head h2 { margin: 0.5rem 0 0; font-family: var(--display); font-weight: 600; font-size: clamp(1.8rem, 4vw, 2.8rem); letter-spacing: -0.03em; line-height: 1.04; }
  .sec-head h2 em { font-style: normal; color: var(--accent); }
  .sec-desc { margin: 0.9rem 0 0; max-width: 60ch; color: var(--text-2); font-size: 1.02rem; line-height: 1.6; }
  .sec-desc a { color: var(--accent); text-decoration: none; }
  .sub { display: block; font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-3); margin: 1.8rem 0 0.8rem; }

  .grid { display: grid; gap: clamp(0.8rem, 1.5vw, 1.2rem); }
