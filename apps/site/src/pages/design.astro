  .ds-main { max-width: 1360px; margin: 0 auto; padding: 0 clamp(1.25rem, 3vw, 2.75rem) 5rem; }

  .ds-hero { padding: clamp(3rem, 9vh, 6rem) 0 clamp(2rem, 5vh, 3.5rem); }
  .hero-eyebrow { display: flex; align-items: center; gap: 0.8rem; font-family: var(--mono); font-size: 0.64rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--accent); }
  .hero-eyebrow .rule { flex: 1; max-width: 120px; height: 1px; background: linear-gradient(90deg, var(--accent), transparent); }
  .hero-eyebrow .ct { color: var(--text-4); }
  .ds-hero h1 { margin: 1.2rem 0 0; font-family: var(--display); font-weight: 600; font-size: clamp(2.4rem, 6vw, 4.6rem); letter-spacing: -0.03em; line-height: 0.98; text-wrap: balance; }
