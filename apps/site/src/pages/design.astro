---
import Base from '../layouts/Base.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { MANUAL_FORCES, MANUAL_PRESETS } from 'field-ui';
import CellGallery from '../components/CellGallery.astro';
import '../styles/ds-tokens.css';
import '../styles/force-glyphs.css';
import '../styles/instrument.css';

// Forces — Design System. The documentation grounded in this project's real
// implementation: the §20.2 force palette, the catalog, the glyphs, the tokens.

const PRESET_COLORS: Record<string, string> = {
  blackhole: '#fbbf24', whitehole: '#e0f2fe', star: '#6366f1', quasar: '#fbbf24',
  galaxy: '#a78bfa', nebula: '#38bdf8', tornado: '#2dd4bf', fountain: '#7dd3fc',
};
const DISCIPLINE: Record<string, string> = {
  attract: 'Product strategy', jet: 'AI systems', tether: 'Software architecture',
  wall: 'Experience design', stream: 'Motion', repel: 'Commerce',
  viscosity: 'Physical production', swirl: 'Creative technology', sink: 'Attention',
};
const families = [
  { key: 'canonical', label: 'Canonical nine' },
  { key: 'natural', label: 'Natural & derived' },
  { key: 'extended', label: 'Designed-extended' },
] as const;
const inFamily = (k: string) => MANUAL_FORCES.filter((f) => f.family === k);
const forceNo = (token: string) => MANUAL_FORCES.findIndex((f) => f.token === token) + 1;
const z2 = (n: number) => String(n).padStart(2, '0');

// The seven cell-renderable forces, for the live demo grid (cell-force.ts supports only these).
const CELL_CAPTIONS: Record<string, string> = {
  attract: 'pulls matter in', repel: 'pushes it away', swirl: 'orbits it around',
  gravity: 'a true 1/d² fall-in', stream: 'a uniform current', buoyancy: 'a steady lift',
  tether: 'a spring to a rest shell',
};
const liveCells = ['attract', 'repel', 'swirl', 'gravity', 'stream', 'buoyancy', 'tether'].map((t) => {
  const f = MANUAL_FORCES.find((x) => x.token === t);
  return { force: t, label: f?.label ?? t, color: f?.color, caption: CELL_CAPTIONS[t] };
});

const surfaces = [
  { n: 'Page', v: '#04050a' }, { n: 'Surface', v: '#0a0d14' }, { n: 'Subtle', v: '#0e121b' },
  { n: 'Card', v: '#0b0e16' }, { n: 'Canvas', v: '#07090e' },
];
const ink = [
  { n: 'Ink 900', v: '#f3f6fc' }, { n: 'Ink 700', v: '#b4bdcd' }, { n: 'Ink 500', v: '#8793a6' },
  { n: 'Ink 400', v: '#5b6678' }, { n: 'Ink 300', v: '#39404e' },
];
const radii = [
  { n: 'sm', v: '6px' }, { n: 'md', v: '10px' }, { n: 'lg', v: '14px' }, { n: 'xl', v: '20px' }, { n: 'pill', v: '999px' },
];
const space = [4, 8, 12, 16, 24, 32, 48, 64];
const typescale = [
  { l: 'Display', s: 'clamp(2.4rem,6vw,4.6rem)', spec: '600 · −0.04em · 0.98', use: 'Hero statements', t: 'A system you can feel.' },
  { l: 'H1', s: '2.6rem', spec: '600 · −0.035em · 1.0', use: 'Page titles', t: 'Things made real.' },
  { l: 'H2', s: '1.9rem', spec: '600 · −0.03em · 1.04', use: 'Section titles', t: 'One reciprocal field.' },
  { l: 'H3', s: '1.35rem', spec: '600 · −0.02em · 1.1', use: 'Card titles', t: 'Executable design systems' },
  { l: 'Body', s: '1.02rem', spec: '400 · −0.011em · 1.6', use: 'Running text', t: 'The visible surface and the invisible system that holds it up.' },
  { l: 'Small', s: '0.85rem', spec: '400 · 0 · 1.5', use: 'Secondary text', t: 'On the systems behind the screen.' },
];
const weights = [
  { w: 300, n: 'Light' }, { w: 400, n: 'Regular' }, { w: 500, n: 'Medium' },
  { w: 600, n: 'Semibold' }, { w: 700, n: 'Bold' }, { w: 800, n: 'Extrabold' },
];
const formations = [
  { id: 'ambient', t: 'Ambient', section: 'Hero', c: '#4da3ff', cue: 'resting drift', d: 'Gentle curl-noise drift — nothing pulls; matter just breathes. The default everywhere.' },
  { id: 'wells', t: 'Wells', section: 'Work', c: '#2dd4bf', cue: 'matter pools', d: 'Matter pools into a few gravity wells. Bodies gain weight where they gather.' },
  { id: 'lanes', t: 'Lanes', section: 'Writing', c: '#ff9d5c', cue: 'a current carries', d: 'A directional current carries particles sideways in bands.' },
  { id: 'scatter', t: 'Scatter', section: 'Practice', c: '#a78bfa', cue: 'energy dispersed', d: 'Brownian dispersal — energy without direction.' },
  { id: 'accretion', t: 'Accretion', section: 'Contact', c: '#ffce6b', cue: 'everything gathers', d: 'Everything gathers toward one mass — the closing pull.' },
];
const motions = [
  { n: 'Reveal', d: '0.9s', note: 'opacity + 28px rise' },
  { n: 'Engage', d: '0.45s', note: 'lit / dim cross-fade' },
  { n: 'Formation ease', d: '~2s', note: 'lerp 0.03 / frame' },
  { n: 'Accent journey', d: 'continuous', note: 'lerp 0.08 / frame' },
];
const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
---

<Base
  title="field-ui — Design System"
  description="The Design System — the tokens, the 34-force palette, the glyphs, and the type that document the reciprocal field. A design language you can operate, with the physics live behind it."
>
  <SiteNav current="design" />
  <div class="ds-shell">
    <header class="ds-top">
      <div class="ds-top-inner">
        <span class="ds-here">Design System · v0.2</span>
        <nav class="ds-nav" aria-label="On this page">
          <a href="#brand">Brand</a>
          <a href="#palette">Palette</a>
          <a href="#surfaces">Surfaces</a>
          <a href="#type">Type</a>
          <span class="ds-sep"></span>
          <a href="#forces">Forces</a>
          <a href="#formations">Formations</a>
          <span class="ds-sep"></span>
          <a href="#library">Library</a>
        </nav>
      </div>
    </header>

    <main class="ds-main">
      <section class="ds-hero">
        <div class="hero-eyebrow"><span>Forces · Design System</span><span class="rule"></span><span class="ct">v0.2</span></div>
        <h1>A system you can <em>feel.</em></h1>
        <p class="hero-lede">Every element is a body — it bends the field, and the field bends it back.
          This is that thesis as a design language: the tokens, the {MANUAL_FORCES.length} forces, the
          glyphs, and the type that document it.</p>
        <div class="hero-meta">
          <span><i class="dot"></i>Reciprocal field · live</span>
          <span>Zach Shallbetter</span>
          <span>v0.2 · 2026</span>
        </div>
      </section>

      <!-- BRAND -->
      <section class="ds-sec" id="brand">
        <div class="sec-head"><span class="idl">01 — Brand</span><h2>The page is the idea made literal.</h2>
          <p class="sec-desc">Everything you touch moves the field, and the field moves it back. The
            interface is the visible surface of one reciprocal system.</p></div>
        <div class="grid cols-3">
          <article class="card pillar" style="--c:#4da3ff"><i class="fg fg-attract"></i><h3>Reciprocal</h3><p>Elements bend the field; the field bends them back. Nothing is inert.</p></article>
          <article class="card pillar" style="--c:#c4b5fd"><i class="fg fg-wall"></i><h3>Felt before understood</h3><p>The visible surface and the invisible system are designed as one. People feel coherence before they can name it.</p></article>
          <article class="card pillar" style="--c:#86e57f"><i class="fg fg-tether"></i><h3>Structured, not stiff</h3><p>Load-bearing systems that still give. Constraints are forces, not walls.</p></article>
        </div>
        <div class="grid cols-2 voice">
          <div class="card"><span class="vl ok">We say</span><ul><li>Everything you touch moves the field.</li><li>The interface is only the visible surface.</li><li>The goal is coherence.</li></ul></div>
          <div class="card"><span class="vl err">We avoid</span><ul><li>Hype, metrics theater, buzzwords.</li><li>“Synergy”, “revolutionary”, “game-changing”.</li><li>Decoration without behavior.</li></ul></div>
        </div>
      </section>

      <!-- PALETTE -->
      <section class="ds-sec" id="palette">
        <div class="sec-head"><span class="idl">02 — Force palette</span><h2>Every accent is a force.</h2>
          <p class="sec-desc">The palette is the catalog. Each of the {MANUAL_FORCES.length} forces is an
            accent with a canonical colour (§20.2), a glyph, and — for the nine — a discipline it maps to.</p></div>
        {families.map((fam) => (
          <>
            <span class="sub">{fam.label}</span>
            <div class="grid cols-3 swatches">
              {inFamily(fam.key).map((f) => (
                <article class="card swatch">
                  <div class="band" style={`background:${f.color}`}><i class={`fg fg-${f.token}`} style="--fc:rgba(0,0,0,0.6)" /></div>
                  <div class="sw-meta"><b>{cap(f.label)}</b><code>{f.color}</code>
                    <span>{DISCIPLINE[f.token] ?? f.family}</span></div>
                </article>
              ))}
            </div>
          </>
        ))}
        <span class="sub">Presets</span>
        <div class="grid cols-3 swatches">
          {MANUAL_PRESETS.map((p) => (
            <article class="card swatch">
              <div class="band" style={`background:${PRESET_COLORS[p.name]}`}><i class={`fgp fgp-${p.name}`} style="--fc:rgba(0,0,0,0.6)" /></div>
              <div class="sw-meta"><b>{cap(p.name)}</b><code>{PRESET_COLORS[p.name]}</code><span>{p.tokens.length} forces</span></div>
            </article>
          ))}
        </div>
      </section>

      <!-- SURFACES + INK -->
      <section class="ds-sec" id="surfaces">
        <div class="sec-head"><span class="idl">03 — Surfaces &amp; ink</span><h2>A deep, near-black field.</h2>
          <p class="sec-desc">Colour is an accent, never a flood — pure hue lives on the mark and the
            glyph; surfaces stay deep, ink stays legible.</p></div>
        <span class="sub">Surfaces</span>
        <div class="grid cols-5 swatches">
          {surfaces.map((s) => (<article class="card swatch"><div class="band sm" style={`background:${s.v}; box-shadow:inset 0 0 0 1px var(--line)`} /><div class="sw-meta"><b>{s.n}</b><code>{s.v}</code></div></article>)) }
        </div>
        <span class="sub">Ink</span>
        <div class="grid cols-5 swatches">
          {ink.map((s) => (<article class="card swatch"><div class="band sm" style={`background:${s.v}`} /><div class="sw-meta"><b>{s.n}</b><code>{s.v}</code></div></article>)) }
        </div>
        <span class="sub">Spacing — 4px scale</span>
        <div class="frame canvas spacing">
          {space.map((v) => (<div class="sp"><div class="box" style={`width:${v}px;height:${v}px`} /><code>{v}</code></div>)) }
        </div>
        <div class="grid cols-2">
          <div><span class="sub">Radii</span><div class="grid cols-5 swatches">
            {radii.map((r) => (<article class="card swatch"><div class="band sm rad" style={`border-radius:${r.v === '999px' ? '12px' : r.v}; background:var(--accent-soft); box-shadow:inset 0 0 0 1px var(--accent)`} /><div class="sw-meta"><b>{r.n}</b><code>{r.v}</code></div></article>)) }
          </div></div>
          <div><span class="sub">Elevation</span><div class="grid cols-3 swatches">
            <article class="card swatch"><div class="band sm" style="background:var(--bg-card); box-shadow:var(--shadow-md)" /><div class="sw-meta"><b>Resting</b></div></article>
            <article class="card swatch"><div class="band sm" style="background:var(--bg-card); box-shadow:var(--shadow-lg)" /><div class="sw-meta"><b>Raised</b></div></article>
            <article class="card swatch"><div class="band sm" style="background:var(--bg-card); box-shadow:0 0 30px -6px var(--accent)" /><div class="sw-meta"><b>Charged</b></div></article>
          </div></div>
        </div>
      </section>

      <!-- TYPE -->
      <section class="ds-sec" id="type">
        <div class="sec-head"><span class="idl">04 — Type</span><h2>Bricolage &amp; <em>Martian Mono.</em></h2>
          <p class="sec-desc">Two families: Bricolage Grotesque handles prose and display; Martian Mono
            handles every label, counter, and measurement.</p></div>
        <div class="grid cols-2">
          <div class="frame canvas spec"><span class="frame-label">Display · Bricolage</span><div class="big">Aa Gg</div><span class="cap">Variable · 300–800 · opsz 12–96</span></div>
          <div class="frame canvas spec"><span class="frame-label">Mono · Martian Mono</span><div class="big mono">Aa Gg</div><span class="cap">Variable · 300–700 · tabular</span></div>
        </div>
        <span class="sub">Weights</span>
        <div class="frame canvas weights">
          {weights.map((w) => (<div class="wt"><span style={`font-weight:${w.w}`}>Forces</span><code>{w.w} · {w.n}</code></div>)) }
        </div>
        <span class="sub">Scale</span>
        <div class="hr-table">
          {typescale.map((t) => (
            <div class="row">
              <code class="rl">{t.l}</code>
              <div class="spec" style={`font-size:${t.s}`}>{t.t}</div>
              <code class="rs">{t.spec} · {t.use}</code>
            </div>
          ))}
        </div>
      </section>

      <!-- FORCES -->
      <section class="ds-sec" id="forces">
        <div class="sec-head"><span class="idl">05 — Forces</span><h2>{MANUAL_FORCES.length} forces. One reciprocal field.</h2>
          <p class="sec-desc">The vocabulary is verbs — what a body does to the matter around it. Each
            is a glyph, a two-letter symbol, a colour, and a per-frame law. <a href="/">Read the full manual →</a></p></div>

        <span class="sub">The force set</span>
        <div class="frame canvas">
          <div class="force-browser view-icon" data-force-browser>
            <div class="fb-head">
              <span class="fb-label">{MANUAL_FORCES.length} forces</span>
              <div class="seg-toggle" role="group" aria-label="Tile display">
                <button type="button" data-view="icon" class="on">Icon</button>
                <button type="button" data-view="symbol">Symbol</button>
                <button type="button" data-view="name">Name</button>
              </div>
            </div>
            {families.map((fam) => (
              <div class="fb-group">
                <span class="glabel">{fam.label}</span>
                <div class="force-grid">
                  {inFamily(fam.key).map((f) => (
                    <div
                      class="force-tile calib"
                      style={`--fc:${f.color}`}
                      title={`${cap(f.label)} — ${f.effect}`}
                    >
                      <span class="z">{z2(forceNo(f.token))}</span>
                      <span class="picon as-icon"><i class={`fg fg-${f.token}`} /></span>
                      <span class="sym as-symbol">{f.symbol}</span>
                      <span class="nameBig as-name">{cap(f.label)}</span>
                      <span class="pname">{cap(f.label)}</span>
                    </div>
                  ))}
                </div>
              </div>
            ))}
            <p class="fb-foot"><b>{MANUAL_FORCES.length} forces</b> · conformance-backed · every one fires in <a href="/lab">the Lab →</a></p>
          </div>
        </div>

        <span class="sub">Live — move your cursor through a frame</span>
        <CellGallery cells={liveCells} hint="Seven of the forces render as in-frame poster cells. Move your cursor through one and it pushes back." />

        <span class="sub">Formulas</span>
        <div class="grid cols-2 formulas">
          {MANUAL_FORCES.map((f) => (
            <article class="card formula-card" style={`--c:${f.color}`}>
              <h3><i class={`fg fg-${f.token}`} /><code class="ftok">{f.symbol}</code><code class="ftok dim">{f.token}</code></h3>
              <code class="expr">{f.formula}</code>
              <p>{f.summary}</p>
            </article>
          ))}
        </div>
      </section>

      <!-- FORMATIONS -->
      <section class="ds-sec" id="formations">
        <div class="sec-head"><span class="idl">06 — Formations</span><h2>The whole field can change its mind.</h2>
          <p class="sec-desc">Forces act locally; a formation is a single global bias over every particle.
            Five of them, one per section of the journey.</p></div>
        <div class="hr-table">
          {formations.map((fm) => (
            <div class="row form">
              <i class="dot" style={`background:${fm.c}; box-shadow:0 0 8px ${fm.c}`} />
              <code class="rl" style={`color:${fm.c}`}>{fm.t}</code>
              <div class="fd"><b>{fm.section} · {fm.cue}</b><span>{fm.d}</span></div>
            </div>
          ))}
        </div>
      </section>

      <!-- LIBRARY -->
      <section class="ds-sec" id="library">
        <div class="sec-head"><span class="idl">07 — Library</span><h2>Glyphs &amp; motion.</h2>
          <p class="sec-desc">The force glyphs are pure CSS shapes — they double as the icon set and the
            system vocabulary. One easing curve drives all motion.</p></div>
        <span class="sub">Force glyphs</span>
        <div class="frame canvas glyphs">
          {MANUAL_FORCES.map((f) => (<div class="gl"><i class={`fg fg-${f.token}`} style={`--fc:${f.color}`} /><code>{f.token}</code></div>)) }
        </div>
        <span class="sub">Preset glyphs</span>
        <div class="frame canvas glyphs">
          {MANUAL_PRESETS.map((p) => (<div class="gl"><i class={`fgp fgp-${p.name}`} style={`--fc:${PRESET_COLORS[p.name]}`} /><code>{p.name}</code></div>)) }
        </div>
        <span class="sub">Instrument components</span>
        <p class="sec-desc" style="margin-top:0">The shared parts the Lab and the design system both run on — a status pill, a
          segmented toggle, force-tinted tabs, and a mono readout. Each tints to the active force via <code class="ftok">--fc</code>.</p>
        <div class="grid cols-2">
          <div class="frame canvas inst-demo">
            <span class="frame-label">Status pill</span>
            <div class="verdict resolving" style="--fc:#4da3ff">Resolving — 2/3 passed</div>
            <div class="verdict confirmed">Confirmed — 3/3 passed</div>
            <div class="verdict mismatch">Mismatch — 1 failed</div>
          </div>
          <div class="frame canvas inst-demo">
            <span class="frame-label">Segmented · tabs · readout</span>
            <div class="seg-toggle"><button type="button" class="on">Icon</button><button type="button">Symbol</button><button type="button">Name</button></div>
            <div class="readout-tabs" style="--fc:#2dd4bf"><button type="button" class="on">Expectations<i>2/3</i></button><button type="button">Tune</button></div>
            <div class="ds-readout" style="--fc:#2dd4bf">
              <div class="hud-row"><span class="k">dist</span><b>80</b><span class="u">px</span></div>
              <div class="hud-row"><span class="k">speed</span><b>0.00</b><span class="u">px/f</span></div>
              <div class="hud-row"><span class="k">force</span><b>0.080</b><span class="u">|Δv|</span></div>
            </div>
          </div>
        </div>
        <span class="sub">Instrument controls</span>
        <p class="sec-desc" style="margin-top:0">The Lab's advanced inputs, drawn properly — slider, stepper, angle dial,
          dual range, and styled select. Pick a force to re-tint the whole set via <code class="ftok">--cc</code>.</p>
        <div class="ds-ctrls" data-controls style="--cc:#4da3ff">
          <div class="ds-tint-row">
            <span class="ctrl-sub">Tint · active force</span>
            <button type="button" class="ds-tint on" data-tint data-name="Attract" style="--cc:#4da3ff" aria-pressed="true" title="Attract" />
            <button type="button" class="ds-tint" data-tint data-name="Swirl" style="--cc:#2dd4bf" aria-pressed="false" title="Swirl" />
            <button type="button" class="ds-tint" data-tint data-name="Jet" style="--cc:#a78bfa" aria-pressed="false" title="Jet" />
            <button type="button" class="ds-tint" data-tint data-name="Tether" style="--cc:#86e57f" aria-pressed="false" title="Tether" />
            <button type="button" class="ds-tint" data-tint data-name="Repel" style="--cc:#ff9d5c" aria-pressed="false" title="Repel" />
            <button type="button" class="ds-tint" data-tint data-name="Sink" style="--cc:#ff6e9c" aria-pressed="false" title="Sink" />
            <button type="button" class="ds-tint" data-tint data-name="Magnetism" style="--cc:#c084fc" aria-pressed="false" title="Magnetism" />
            <button type="button" class="ds-tint" data-tint data-name="Pigment" style="--cc:#d6529e" aria-pressed="false" title="Pigment" />
            <span class="ctrl-sub" data-tint-name style="margin-left:auto;color:var(--cc)">Attract</span>
          </div>

          <div class="frame canvas" style="padding:1.6rem 1.4rem">
            <span class="frame-label">Slider · two treatments</span>
            <div style="display:grid;gap:1.9rem;max-width:480px">
              <div class="ds-slider" data-slider data-min="0" data-max="3" data-step="0.05" data-value="1.4" style="--pct:0.4667">
                <div class="ctrl-head"><span class="ctrl-label">strength</span><span class="ctrl-val"><span data-out>1.40</span></span></div>
                <div class="ds-slider-track" tabindex="0" role="slider" aria-label="strength" aria-valuenow="1.4" aria-valuemin="0" aria-valuemax="3">
                  <div class="ds-slider-rail"><div class="ds-slider-fill" /></div>
                  <div class="ds-slider-thumb" />
                </div>
                <div class="ds-slider-ticks"><span /><span /><span /><span /><span /><span /><span /></div>
              </div>
              <div class="ds-slider ds-meter" data-slider data-min="0" data-max="100" data-step="1" data-value="62" data-unit="%" style="--pct:0.62">
                <div class="ctrl-head"><span class="ctrl-label">charge</span><span class="ctrl-val"><span data-out>62</span><span class="unit">%</span></span></div>
                <div class="ds-slider-track" tabindex="0" role="slider" aria-label="charge" aria-valuenow="62" aria-valuemin="0" aria-valuemax="100">
                  <div class="ds-slider-rail"><div class="ds-slider-fill" /></div>
                  <div class="ds-slider-bubble" data-bubble>62%</div>
                  <div class="ds-slider-thumb" />
                </div>
              </div>
            </div>
          </div>

          <div class="grid cols-2">
            <div class="frame canvas" style="padding:1.6rem 1.4rem">
              <span class="frame-label">Stepper</span>
              <div style="display:grid;gap:1.2rem">
                <div>
                  <div class="ctrl-head"><span class="ctrl-label">particles</span></div>
                  <div class="ds-stepper" data-stepper data-min="0" data-max="200" data-step="1" data-value="24">
                    <button type="button" data-step-dec aria-label="decrease">−</button>
                    <span class="ds-stepper-mid"><input data-step-input value="24" inputmode="decimal" aria-label="value" /></span>
                    <button type="button" data-step-inc aria-label="increase">+</button>
                  </div>
                </div>
                <div>
                  <div class="ctrl-head"><span class="ctrl-label">thickness</span></div>
                  <div class="ds-stepper" data-stepper data-min="1" data-max="32" data-step="1" data-value="8" data-unit="px">
                    <button type="button" data-step-dec aria-label="decrease">−</button>
                    <span class="ds-stepper-mid"><input data-step-input value="8" inputmode="decimal" aria-label="value" /><span class="unit">px</span></span>
                    <button type="button" data-step-inc aria-label="increase">+</button>
                  </div>
                </div>
              </div>
            </div>
            <div class="frame canvas" style="padding:1.6rem 1.4rem">
              <span class="frame-label">Angle dial</span>
              <div style="display:flex;align-items:center;gap:1.4rem">
                <div class="ds-dial" data-dial data-value="35" style="--ang:35deg" tabindex="0" role="slider" aria-label="angle" aria-valuenow="35" aria-valuemin="0" aria-valuemax="359">
                  {Array.from({ length: 12 }).map((_, i) => (
                    <span class={`ds-dial-tick${i % 3 === 0 ? ' major' : ''}`} style={`transform:translate(-50%,-50%) rotate(${i * 30}deg) translateY(-43px)`} />
                  ))}
                  <div class="ds-dial-needle" />
                  <div class="ds-dial-hub"><span class="deg"><span data-out>35</span>°</span><span class="cap">deg</span></div>
                </div>
                <div style="display:grid;gap:0.35rem">
                  <span class="ctrl-label">heading</span>
                  <span class="ctrl-val" style="font-size:1.3rem"><span data-dial-out>35</span>°</span>
                  <span class="ctrl-sub" style="text-transform:none;letter-spacing:0">drag · or ←/→ · shift = 15°</span>
                </div>
              </div>
            </div>
          </div>

          <div class="frame canvas" style="padding:1.8rem 1.6rem">
            <span class="frame-label">Dual range · sweep bounds</span>
            <div class="ds-range" data-range data-min="40" data-max="520" data-step="4" data-lo="120" data-hi="380" data-unit="px" style="--lo:0.1667;--hi:0.7083;max-width:480px">
              <div class="ctrl-head"><span class="ctrl-label">sweep bounds</span><span class="ctrl-val"><span data-lo-out>120</span><span class="unit">→</span><span data-hi-out>380</span><span class="unit">px</span></span></div>
              <div class="ds-range-track">
                <div class="ds-range-rail" />
                <div class="ds-range-span" />
                <div class="ds-range-thumb lo" data-thumb="lo" role="slider" aria-label="minimum" aria-valuenow="120" tabindex="0" />
                <div class="ds-range-thumb hi" data-thumb="hi" role="slider" aria-label="maximum" aria-valuenow="380" tabindex="0" />
              </div>
            </div>
          </div>

          <div class="frame canvas" style="padding:1.6rem 1.4rem">
            <span class="frame-label">Select</span>
            <div style="display:grid;gap:0.6rem;max-width:240px">
              <span class="ctrl-label">falloff curve</span>
              <div class="ds-select" data-select>
                <button type="button" class="ds-select-btn" aria-haspopup="listbox" aria-expanded="false"><span data-select-label>Inverse-square</span><span class="ds-select-chev">▾</span></button>
                <div class="ds-select-menu" role="listbox" hidden>
                  <button type="button" role="option" class="ds-select-opt" data-value="Linear"><span class="dot" />Linear</button>
                  <button type="button" role="option" class="ds-select-opt on" data-value="Inverse-square" aria-selected="true"><span class="dot" />Inverse-square</button>
                  <button type="button" role="option" class="ds-select-opt" data-value="Smoothstep"><span class="dot" />Smoothstep</button>
                  <button type="button" role="option" class="ds-select-opt" data-value="Constant"><span class="dot" />Constant</button>
                </div>
              </div>
            </div>
          </div>
        </div>

        <span class="sub">Motion</span>
        <div class="grid cols-4 swatches">
          {motions.map((m) => (<article class="card mo"><b>{m.n}</b><code>{m.d}</code><span>{m.note}</span></article>)) }
        </div>
        <p class="ease-note">Easing: <code>cubic-bezier(0.16, 1, 0.3, 1)</code> — everywhere.</p>
      </section>

    </main>
  </div>
