---
import Base from '../../layouts/Base.astro';
import SiteNav from '../../components/SiteNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { writingCat } from '../../lib/writings-meta.ts';
import '../../styles/ds-tokens.css';
import '../../styles/writings.css';

const BLURBS: Record<string, string> = {
  research: 'Longer-form papers on the ideas behind Fundamental.',
  release: 'What shipped, and what it means.',
  feature: 'New capabilities, explained.',
  note: 'Shorter thoughts and updates.',
};
const CATS = ['research', 'release', 'feature', 'note'].map((key) => ({
  ...writingCat(key)!,
  blurb: BLURBS[key],
}));
const sortEntries = (a: CollectionEntry<'writings'>, b: CollectionEntry<'writings'>) => {
  if (a.data.order != null && b.data.order != null) return a.data.order - b.data.order;
  return +b.data.date - +a.data.date;
};
const all = (await getCollection('writings', (e) => !e.data.draft)).sort(sortEntries);
const byCat = (k: string) => all.filter((e) => e.data.category === k);
const fmt = (d: Date) => new Intl.DateTimeFormat('en', { year: 'numeric', month: 'short', day: 'numeric' }).format(d);
const num = (e: CollectionEntry<'writings'>) =>
  e.data.category === 'research' && e.data.order != null && e.data.order < 90 ? `${e.data.order}. ` : '';
---

<Base
  title="Writings · Fundamental"
  description="Fundamental writings — features, releases, and research on a relational field runtime for the DOM."
>
  <SiteNav current="writings" />
  <main id="main" class="writings-index">
    <header class="wi-hero">
      <h1 data-body="attract" data-strength="0.6" data-feedback>Writings</h1>
      <p class="lede">
        What we are building and thinking about — <strong>features</strong>, <strong>releases</strong>,
        and longer-form <strong>research</strong> — written in markdown. The first things going in are
        the research papers on the ideas behind Fundamental.
      </p>
    </header>

    {
      CATS.filter((c) => byCat(c.key).length > 0).map((c) => (
        <section class="wi-section" aria-labelledby={`wi-${c.key}`} style={`--cat-color: ${c.color}`}>
          <div class="wi-section-head">
            <h2 id={`wi-${c.key}`}>
              <span class="wi-glyph" aria-hidden="true">{c.glyph}</span>
              {c.label}
            </h2>
            <p class="wi-blurb">{c.blurb}</p>
          </div>
          <ul class="wi-cards">
            {byCat(c.key).map((e) => (
              <li class="wi-card">
                <a class="wi-card-link" href={`/writings/${e.id}`}>
                  <span class={`w-badge w-${e.data.category}`}>{e.data.category}</span>
                  <h3>{num(e)}{e.data.title}</h3>
                  {e.data.summary && <p class="wi-summary">{e.data.summary}</p>}
                  <time class="wi-date" datetime={e.data.date.toISOString()}>{fmt(e.data.date)}</time>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </main>
  <SiteFooter />
</Base>

<style>
  /* per-category wayfinding color — the section heading carries its category's color + glyph */
  .wi-section-head h2 {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .wi-section-head .wi-glyph {
    color: var(--cat-color, var(--accent));
    font-size: 0.9em;
    line-height: 1;
  }
  .wi-section {
    border-left: 2px solid color-mix(in srgb, var(--cat-color, var(--accent)) 45%, transparent);
    padding-left: clamp(0.8rem, 2vw, 1.4rem);
    margin-left: calc(-1 * clamp(0.8rem, 2vw, 1.4rem));
  }
</style>
