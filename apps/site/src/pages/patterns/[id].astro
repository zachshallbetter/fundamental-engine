---
import Base from '../../layouts/Base.astro';
import SiteNav from '../../components/SiteNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import VocabBadge from '../../components/VocabBadge.astro';
import CodeTabs from '../../components/CodeTabs.astro';
import {
  FIELD_PATTERNS, EXPERIMENTAL_PATTERNS, FIRST_RELEASE_PATTERN_IDS, explainScene, serializePattern, patternAuthoring, passportFor, type FieldPattern,
} from '@fundamental-engine/core';
import { metricTitle, designedMetrics } from '../../lib/metric-lanes.ts';
import { taxonomyFor } from '../../lib/recipe-taxonomy.ts';
import '../../styles/workbench.css';

// One page per recipe (getStaticPaths over the 64 FIELD_PATTERNS + the experimental set): a large live
// preview, the full five-lane breakdown + render + a11y + notes + plain-language explanation, copyable
// HTML / web component / React / JSON (patternAuthoring), and "see also" siblings (same field/tier).
export function getStaticPaths() {
  return [...FIELD_PATTERNS, ...EXPERIMENTAL_PATTERNS].map((r) => ({ params: { id: r.id }, props: { recipe: r } }));
}
interface Props { recipe: FieldPattern }
const { recipe: r } = Astro.props;

const FIELD_COLOR: Record<string, string> = {
  gravity: '#4da3ff', electromagnetic: '#2dd4bf', strong: '#a78bfa', weak: '#ff9d5c', diagnostic: '#9aa7b4', platform: '#9aa7b4',
};
const fieldKey = r.naturalField ?? 'other';
const color = FIELD_COLOR[fieldKey] ?? '#9aa7b4';
const fieldLabel = r.naturalField != null ? r.naturalField[0]!.toUpperCase() + r.naturalField.slice(1) : 'Diagnostic / platform';
const isFirst = new Set(FIRST_RELEASE_PATTERN_IDS).has(r.id);
const auth = patternAuthoring(r);
const exports = { html: auth.html, wc: auth.webComponent, react: auth.react, json: serializePattern(r) };
const seeAlso = FIELD_PATTERNS.filter((x) => x.id !== r.id && (x.naturalField === r.naturalField || x.tier === r.tier)).slice(0, 6);
// which metric lanes need the host to ground them (else --field-<m> stays inert) — see lintInertFeedback
const designed = designedMetrics(r.metrics);
// discovery metadata for the shared workbench preview (scaffold + the render stack it wakes into)
const tax = taxonomyFor(r.id);
const primaryRender = tax.primaryRender ?? r.render[0] ?? 'dots';
// per-token / per-metric one-liners — tokens from the engine's own ForcePassport.designUse (the
// authored "what it does" verb); metrics from the support-lane description (metricTitle).
const tokenDef = (t: string): string => passportFor(t as never)?.designUse ?? '';
const metricDef = (m: string): string => metricTitle(m).replace(/^[^—]*—\s*/, '');
---

<Base title={`${r.name} Pattern — Fundamental`} description={`${r.name}: ${r.intent}. A live, validated Fundamental Pattern — runs in your browser, with runtime tokens, metrics, diagnostics, and an accessibility equivalent.`}>
  <SiteNav />
  <main id="main" class="rp-shell" style={`--rc: ${color}`}>
    <p class="rp-back"><a href="/patterns">← all recipes</a></p>
    <header class="rp-hero">
      <div class="rc-tags">
        <span class="rc-field">{fieldLabel}</span>
        {r.tier && <span class="rc-tier">{r.tier}</span>}
        {isFirst && <span class="rc-first">First release</span>}
        {r.status && r.status !== 'shipped' && <span class="rc-status">{r.status}</span>}
      </div>
      <h1>{r.name}</h1>
      <p class="intent">{r.intent}</p>
      {r.translation && <p class="translation">{r.translation}</p>}
    </header>

    <section class="rp-stage" aria-label="Live preview">
      <div
        class="rp-preview"
        data-recipe-mount={r.id}
        data-scaffold={tax.scaffoldId ?? ''}
        data-primary-render={primaryRender}
        data-render-layers={r.render.join(',')}
        data-reduced={r.accessibility.meaningWithoutMotion}
        aria-hidden="true"
      ></div>
      <p class="rp-note">Running the actual recipe live via <code>applyPattern()</code> — switch the substrate, stack overlays, watch the signals, or reverse the dynamics. Not a mock.</p>
    </section>

    <p class="explain">{explainScene(r)}</p>
    {r.notes && <p class="notes">{r.notes}</p>}

    <dl class="rp-meta">
      <div><dt>Runtime tokens</dt><dd class="rp-defs">{r.primitives.map((p) => (
        <span class="rp-def"><VocabBadge kind="token" label={p} title={`${p} — ${tokenDef(p)}`} /><span class="rp-def-text">{tokenDef(p)}</span></span>
      ))}</dd></div>
      {r.concepts && r.concepts.length > 0 && <div><dt>Concepts</dt><dd>{r.concepts.map((c) => <VocabBadge kind="concept" label={c} />)}</dd></div>}
      <div><dt>Metrics</dt><dd class="rp-defs">
        {r.metrics.map((m) => (
          <span class="rp-def"><VocabBadge kind="metric" label={m} title={metricTitle(m)} /><span class="rp-def-text">{metricDef(m)}</span></span>
        ))}
        {designed.length > 0 && (
          <span class="ml-note">
            {designed.join(', ')} {designed.length === 1 ? 'is a host-supplied lane' : 'are host-supplied lanes'} —
            drive {designed.length === 1 ? 'it' : 'them'} with <code>data-field-&lt;metric&gt;</code> (or a domain model);
            without that, {designed.length === 1 ? 'its' : 'their'} <code>--field-*</code> stays inert.
          </span>
        )}
      </dd></div>
      <div><dt>Diagnostics</dt><dd>{r.diagnostics.map((d) => <VocabBadge kind="diagnostic" label={d} />)}</dd></div>
      {r.conditions && r.conditions.length > 0 && <div><dt>Conditions</dt><dd>{r.conditions.map((c) => <VocabBadge kind="condition" label={c} />)}</dd></div>}
      <div><dt>Render</dt><dd class="rc-render">{r.render.join(' · ')}</dd></div>
      <div><dt>Reduced motion</dt><dd class="a11y">{r.accessibility.reducedMotion}</dd></div>
      <div><dt>Without motion</dt><dd class="a11y">{r.accessibility.meaningWithoutMotion}</dd></div>
    </dl>

    <section class="rp-export">
      <h2>Copy this recipe</h2>
      <CodeTabs variants={[
        { label: 'HTML', lang: 'html', code: exports.html },
        { label: 'Web component', lang: 'html', code: exports.wc },
        { label: 'React', lang: 'tsx', code: exports.react },
        { label: 'JSON', lang: 'json', code: exports.json },
      ]} />
    </section>

    {seeAlso.length > 0 && (
      <section class="rp-seealso">
        <h2>See also</h2>
        <ul>{seeAlso.map((x) => <li><a href={`/patterns/${x.id}`}>{x.name}</a> <span>{x.intent}</span></li>)}</ul>
      </section>
    )}
  </main>
  <SiteFooter />
</Base>

<script>
  import { mountRecipePreview, type PreviewHandle } from '../../lib/explore-preview.ts';

  let preview: PreviewHandle | undefined;
  function init() {
    // the full workbench preview — substrate/overlay/dynamics controls + live signal readout, the
    // same component the Explore detail uses (mountRecipePreview reads the recipe metadata off the
    // mount element's data-* attributes, set server-side).
    const el = document.querySelector<HTMLElement>('[data-recipe-mount]');
    preview?.destroy();
    if (el) {
      preview = mountRecipePreview(el, {
        recipeId: el.dataset.recipeMount ?? '',
        scaffoldId: el.dataset.scaffold || null,
        primaryRender: el.dataset.primaryRender ?? 'dots',
        reducedMotionText: el.dataset.reduced ?? '',
        renderLayers: (el.dataset.renderLayers ?? '').split(',').filter(Boolean),
      });
    }

    // the copy-this-recipe block is now <CodeTabs> — it owns its own tab + copy behaviour.
  }
  if (document.readyState !== 'loading') init();
  else document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('astro:page-load', init);
  document.addEventListener('astro:before-swap', () => { preview?.destroy(); preview = undefined; });
</script>

<style>
  .rp-shell { position: relative; z-index: 2; width: 100%; max-width: var(--content-max); margin: 0 auto; padding: 5.5rem 1.5rem 4rem; }
  .rp-back { margin: 0 0 1rem; }
  .rp-back a, .rp-build a { color: #4da3ff; text-decoration: none; font-size: 0.88rem; }
  .rc-tags { display: flex; gap: 0.45rem; align-items: center; flex-wrap: wrap; font-size: 0.74rem; }
  .rc-field { color: var(--rc, #4da3ff); font-weight: 600; }
  .rc-tier { color: var(--muted, #9aa); text-transform: capitalize; }
  .rc-first { color: #ffd479; border: 1px solid color-mix(in srgb, #ffd479 40%, transparent); border-radius: 999px; padding: 0 0.4rem; }
  .rc-status { color: #ff9d5c; text-transform: capitalize; }
  .rp-hero h1 { font-size: clamp(2rem, 5vw, 3rem); margin: 0.5rem 0 0.4rem; line-height: 1.05; }
  .intent { color: var(--muted, #c3c9d4); font-size: 1.05rem; margin: 0 0 0.3rem; }
  .translation { color: var(--muted, #9aa); font-style: italic; margin: 0; }
  /* --detail-accent drives the workbench signal bars + active-pill glow to the recipe's field colour */
  .rp-stage { margin: 1.6rem 0; border: 1px solid var(--line, #2a2a35); border-radius: 14px; overflow: hidden; --detail-accent: var(--rc); background: radial-gradient(120% 120% at 50% 30%, color-mix(in srgb, var(--rc) 9%, transparent), transparent 70%); }
  /* host for the shared workbench preview: positioned + clipped, tall enough for the control rows */
  .rp-preview { position: relative; overflow: hidden; min-height: 440px; display: grid; place-items: center; }
  .rp-note { font-size: 0.8rem; color: var(--muted, #9aa); padding: 0.6rem 1rem 0.7rem; margin: 0; border-top: 1px solid var(--line, #2a2a35); }
  .explain { font-size: 1.02rem; line-height: 1.6; }
  .notes { color: var(--muted, #c3c9d4); font-size: 0.92rem; border-left: 2px solid var(--rc, #4da3ff); padding-left: 0.9rem; }
  .rp-meta { display: grid; gap: 0.5rem; margin: 1.6rem 0; }
  .rp-meta > div { display: grid; grid-template-columns: 10rem 1fr; gap: 0.7rem; align-items: baseline; }
  .rp-meta dt { color: var(--muted, #9aa); font-size: 0.74rem; text-transform: uppercase; letter-spacing: 0.04em; margin: 0; }
  .rp-meta dd { margin: 0; display: flex; flex-wrap: wrap; gap: 0.3rem; }
  /* token/metric chip + its one-liner, one per row, so meanings read at a glance */
  .rp-meta dd.rp-defs { flex-direction: column; gap: 0.35rem; }
  .rp-def { display: flex; align-items: baseline; gap: 0.6rem; }
  .rp-def > :first-child { flex: none; min-width: 6.5rem; }
  .rp-def-text { color: var(--muted, #c3c9d4); font-size: 0.88rem; line-height: 1.4; }
  .rp-meta dd.a11y { display: block; color: var(--muted, #c3c9d4); font-size: 0.9rem; }
  .rp-meta dd .ml-note { flex-basis: 100%; margin-top: 0.35rem; color: var(--muted, #9aa); font-size: 0.8rem; line-height: 1.5; }
  .rp-meta dd .ml-note code { font-size: 0.92em; color: var(--text-2, #c3c9d4); }
  .rc-render { font-family: ui-monospace, monospace; font-size: 0.82rem; color: var(--muted, #c3c9d4); }
  .rp-export { margin: 1.8rem 0; }
  .rp-seealso { margin-top: 2rem; border-top: 1px solid var(--line, #2a2a35); padding-top: 1.2rem; }
  .rp-seealso ul { list-style: none; padding: 0; display: grid; gap: 0.45rem; }
  .rp-seealso a { color: var(--rc, #4da3ff); text-decoration: none; }
  .rp-seealso span { color: var(--muted, #9aa); font-size: 0.85rem; }
  @media (max-width: 560px) { .rp-meta > div { grid-template-columns: 1fr; } }
</style>
