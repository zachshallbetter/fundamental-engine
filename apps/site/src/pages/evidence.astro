---
import { logNormalize, weightToStrength } from "@fundamental-engine/core";
import ExampleShell from "../components/examples/ExampleShell.astro";
import CodeTabs from "../components/CodeTabs.astro";
import evidence from "../data/evidence.json";
import { categoryColors } from "../lib/palette.ts";
import { fmtDate, fmtInt } from "../lib/fmt.ts";
import "../styles/docs.css";

// The Evidence Field — Fundamental as an invisible measurement layer over real research data.
// No particle swarm: the trust shows in the type. Each finding is a real OpenAlex work. The
// controls (Field on/off, Weight by) make the transformation legible — off, the same data is a
// plain list; change the weighting and the field re-settles. data-* in, --field-* out.
const slugify = (q: string) => q.replace(/[^a-z0-9]+/gi, "-").toLowerCase().replace(/^-|-$/g, "");
const topics = evidence.topics.map((t) => {
  const cmax = Math.max(...t.works.map((w) => w.citedBy));
  const ids = new Set(t.works.map((w) => w.id));
  // map each distinct research subfield to a palette color (the discipline lens).
  const fieldColor = categoryColors(
    t.works.map((w) => w.topic).filter((tp): tp is string => Boolean(tp)),
  );
  const works = t.works
    .map((w) => ({
      ...w,
      trust: logNormalize(w.citedBy, cmax), // 0..1 consensus proxy (the default size signal)
      supports: w.refs.filter((r) => ids.has(r)), // intra-set citation edges → threads
      cat: (w.topic && fieldColor.get(w.topic)) || "#60a5fa", // default color lens = field/discipline
    }))
    .sort((a, b) => b.trust - a.trust);
  return { ...t, slug: slugify(t.question), works };
});
const authorLine = (a: string[]) => (a.length > 2 ? `${a[0]} et al.` : a.join(" & ")) || "—";
const linkFor = (w: { doi: string | null; id: string }) =>
  w.doi ? w.doi : `https://openalex.org/${w.id}`;
// the provenance chip's baseline: the snapshot date when the data carries one
// (snapshot-examples.mjs stamps snapshotAt on refresh), the source name otherwise.
const snapshotLabel = (evidence as { snapshotAt?: string }).snapshotAt
  ? fmtDate((evidence as { snapshotAt?: string }).snapshotAt!)
  : "OpenAlex";

// How-it's-built snippets — highlighted at build time via CodeTabs (Shiki).
const snippetBody = `<li id="finding-W2042"
  data-body="attract"
  data-strength="0.87"
  data-field-color="#4da3ff"
  data-feedback
  data-hot
  style="--trust: 0.87; --cat: #4da3ff;"
>
  <!-- a citation edge as a REAL platform
       relationship: the registry discovers it,
       and --field-coherence reads how much of
       this finding's graph resolves on-page -->
  <span hidden
    data-field-relation="supports"
    data-field-target="#finding-W1480"></span>

  <!-- your ordinary HTML here -->
  <span class="ev-bar" aria-hidden="true"
    data-field-visual-for="#finding-W2042"
    data-field-visual-role="measurement"></span>
</li>`;

const snippetCss = `.ev-finding {
  /* --trust is server-set (0..1 log-normalized
     citation score). CSS reads it directly. */
  --w: var(--trust, 0.5);

  /* --d is LIVE — the engine's local particle
     density, written back every frame. data-hot
     makes it gather toward 1 while you hold. */
  --live: var(--d, 0);

  opacity: calc(0.58 + var(--w) * 0.42);
  border-left: 3px solid
    color-mix(in srgb,
      var(--cat) calc(18% + var(--w) * 82%),
      var(--line));
  box-shadow: 0 0 calc(var(--live) * 16px) -6px
    color-mix(in srgb,
      var(--cat) calc(var(--live) * 55%),
      transparent);
}
.ev-title {
  font-variation-settings:
    'wght' calc(380 + var(--w) * 360);
}`;

const snippetLive = `// trust itself updates: ONCE per visit
// (~4s in), one batched request per topic
// asks OpenAlex for current counts —
fetch('https://api.openalex.org/works'
  + '?filter=ids.openalex:W301…|W204…'
  + '&select=id,cited_by_count');

// each finding updates IN PLACE
// (data-cites + the figure + a quiet
// "+N since snapshot" when it moved),
// then the SAME reweight path re-runs:
// --trust, data-strength, the bar,
// the FLIP re-sort — trust re-settles
// in front of you. Once, not a poll:
// citations move slowly; polling
// would be theater.`;
---

<ExampleShell
  title="Fundamental — Evidence"
  description="The same research, run as a field. Fundamental measures real OpenAlex citation data and writes trust back into the type — heavier, brighter, more anchored — with no particle swarm. Toggle the field off and it collapses to a plain list; that gap is what Fundamental adds. data-* in, --field-* out."
  current="evidence"
  mainAttrs={{ "data-field": "on", "data-weight": "consensus", "data-lens": "field" }}
>
    <header class="ev-hero">
      <p class="ev-kicker">Fundamental · invisible fields · evidence</p>
      <h1>Trust you can <span class="accent">feel</span>, not read.</h1>
      <p class="ev-lede">
        Research is typically served as a sorted column. Citation count compresses three things
        into one number — how much the field has engaged a work, whether it still holds, how many
        others build on it — then sorts descending. The top row wins. That's a ranking, not trust.
      </p>
      <p class="ev-lede">
        This is the same data from <a href="https://openalex.org" rel="noopener">OpenAlex</a> run as a <strong>field</strong>.
        Each paper is a body; its citation weight becomes gravitational mass — heavier works pull
        without asserting a verdict. Cross-citations thread each work to what it builds on.
        The field is <strong>invisible</strong> — no particle swarm, no overlay — only its effect
        shows in the type: weight, ink, and a left anchor that intensifies with consensus.
        <strong>Toggle it off</strong> and the data collapses to a plain list — the live glow
        goes dark with it. Change the weighting and watch the field re-settle.
      </p>
    </header>

    <!-- Controls — make the transformation legible. -->
    <div class="ev-controls" role="group" aria-label="Field controls">
      <div class="ev-ctl">
        <span class="ev-ctl-l">Field</span>
        <button type="button" class="ev-switch" data-ev-field aria-pressed="true">
          <span class="ev-switch-dot" aria-hidden="true"></span>
          <span class="ev-switch-txt">on</span>
        </button>
      </div>
      <div class="ev-ctl">
        <span class="ev-ctl-l">Weight by</span>
        <div class="ev-seg" role="group" aria-label="Weighting signal">
          <button type="button" data-ev-weight="consensus" aria-pressed="true">consensus</button>
          <button type="button" data-ev-weight="recency" aria-pressed="false">recency</button>
          <button type="button" data-ev-weight="balanced" aria-pressed="false">balanced</button>
        </div>
      </div>
      <div class="ev-ctl">
        <span class="ev-ctl-l">Color by</span>
        <div class="ev-seg" role="group" aria-label="Color lens">
          <button type="button" data-ev-lens="field" aria-pressed="true">field</button>
          <button type="button" data-ev-lens="recency" aria-pressed="false">recency</button>
          <button type="button" data-ev-lens="trust" aria-pressed="false">trust</button>
        </div>
      </div>
      <div class="ev-ctl">
        <span class="ev-ctl-l">Data</span>
        <span class="ev-live" data-ev-live data-snapshot-label={snapshotLabel}
          >snapshot · {snapshotLabel}</span
        >
      </div>
      <p class="ev-ctl-hint">
        <span data-ev-hint><b>size</b> = citations — how much the field leans on each work</span>
        <span class="ev-hint-sep">·</span>
        <span data-ev-lens-hint><b>color</b> = research subfield — the discipline each work binds to</span>
        <span class="ev-hint-sep">·</span>
        <span><b>hold</b> a finding — the field gathers</span>
      </p>
    </div>

    <!-- Legend — reading the field. -->
    <ul class="ev-legend" aria-label="How to read the field">
      <li><span class="ev-k ev-k-weight">Aa</span> <b>size</b> = the weighting signal</li>
      <li><span class="ev-k ev-k-anchor"></span> <b>color</b> = the lens (a second dimension)</li>
      <li>
        <span class="ev-k ev-k-shape">
          <span class="ev-mk ev-mk-article"></span><span class="ev-mk ev-mk-review"></span>
        </span>
        <b>shape</b> = study type (● primary · ◆ review)
      </li>
      <li><span class="ev-k ev-k-thread"></span> hover → threads to the work it builds on</li>
      <li><span class="ev-k ev-k-live"></span> <b>glow</b> = the engine's live density (<code>--d</code>) — hold a finding and the field gathers</li>
    </ul>

    <nav class="ev-tabs" data-ev-tabs aria-label="Questions">
      {
        topics.map((t, i) => (
          <button type="button" data-ev-tab={t.slug} aria-pressed={i === 0 ? "true" : "false"}>
            {t.question}
          </button>
        ))
      }
    </nav>

    {
      topics.map((t, ti) => (
        <section class="ev-topic" data-ev-topic={t.slug} hidden={ti !== 0}>
          <p class="ev-answer">
            <b>{t.works.length}</b> works address <em>"{t.question}"</em>. With the field on, the
            heaviest are near-consensus and the faint ones are still finding their footing; hover one
            to light the work it builds on. Change the weighting and watch them re-settle.
          </p>
          <ol class="ev-list" data-ev-list>
            {t.works.map((w, i) => (
              <li
                class="ev-finding"
                id={`${t.slug}--${w.id}`}
                data-body="attract"
                data-feedback
                data-hot
                data-cites={w.citedBy}
                data-year={w.year}
                data-topic={w.topic ?? ""}
                data-type={w.type}
                data-field-color={w.cat}
                data-strength={weightToStrength(w.trust).toFixed(2)}
                data-range="200"
                data-supports={w.supports.map((s) => `${t.slug}--${s}`).join(" ")}
                style={`--trust:${w.trust.toFixed(3)}; --cat:${w.cat};`}
                hidden={i >= 8}
                data-ev-deferred={i >= 8 ? "" : undefined}
              >
                {/* the citation edges as REAL platform relationships: the registry discovers
                    these (data-field-relation + data-field-target), the recipe pipeline counts
                    them per finding, and --field-coherence stops reading zero — the same edges
                    the hover threads draw. */}
                {w.supports.map((s) => (
                  <span
                    hidden
                    data-field-relation="supports"
                    data-field-target={`#${t.slug}--${s}`}
                  ></span>
                ))}
                <span class="ev-rank">{String(i + 1).padStart(2, "0")}</span>
                <div class="ev-body">
                  <a class="ev-title" href={linkFor(w)} target="_blank" rel="noopener">
                    {w.title}
                  </a>
                  <span class="ev-meta">
                    <span class="ev-field" title={w.topic ?? undefined}>
                      <span class="ev-lens" aria-hidden="true"></span>
                      <span class="ev-field-name">{w.topic ?? "—"}</span>
                    </span>
                    <span class="ev-meta-sep">·</span>
                    {authorLine(w.authors)} · <span class="ev-year">{w.year}</span>
                    {w.oa && <span class="ev-oa">open access</span>}
                  </span>
                </div>
                <div class="ev-trust" aria-label={`${w.citedBy} citations`}>
                  <span class="ev-cites">{fmtInt(w.citedBy)}</span>
                  <span class="ev-cites-l" data-ev-unit>citations</span>
                  <span
                    class="ev-bar"
                    aria-hidden="true"
                    data-field-visual-for={`#${t.slug}--${w.id}`}
                    data-field-visual-role="measurement"
                  ><i style={`width:${Math.round(w.trust * 100)}%`} /></span>
                </div>
              </li>
            ))}
            {t.works.length > 8 && (
              <li
                class="ev-sentinel"
                data-ev-sentinel
                data-body="sink"
                data-absorb
                data-max="8"
                data-feedback
                aria-hidden="true"
              ></li>
            )}
          </ol>
        </section>
      ))
    }
    <!-- without JS the deferred findings can never be revealed — show them all. -->
    <noscript>
      <style is:inline>
        .ev-finding[data-ev-deferred] {
          display: grid;
        }
      </style>
    </noscript>

    <!-- How it's built — the data-* pattern made concrete. -->
    <section class="ev-how" aria-labelledby="ev-how-h">
      <h2 id="ev-how-h">How it's built</h2>
      <p class="ev-how-lede">
        Every finding is ordinary semantic HTML — a <code>&lt;li&gt;</code> with a few data
        attributes. Fundamental reads them, runs a spatial field over the list, and writes measured
        state back as CSS custom properties each frame. No canvas. No particle swarm. No JS event
        listeners on individual elements. Four channels do the work: <code>--w</code> is the
        server-computed weight, <code>--cat</code> the lens color, <code>--d</code> the engine's
        live local density (hold a finding and the field gathers), and
        <code>--field-attention</code> the recipe's eased attention metric.
      </p>

      <div class="ev-how-cols">
        <div class="ev-how-col">
          <p class="ev-how-label">1 — mark each finding as a field body</p>
          <CodeTabs variants={[{ label: "HTML", lang: "html", code: snippetBody }]} />
          <ul class="ev-how-attrs">
            <li><code>data-body="attract"</code> — registers as a field participant</li>
            <li><code>data-strength</code> — gravitational mass (0 → faint, 2 → heavy anchor)</li>
            <li><code>data-field-color</code> — accent hue for the color lens</li>
            <li><code>data-feedback</code> — opt in to receive <code>--field-*</code> writebacks</li>
            <li><code>data-hot</code> — the engine's live density (<code>--d</code>) gathers toward 1 while held</li>
            <li><code>data-field-visual-for</code> — declares the bar as this record's measurement (inspectable, lintable)</li>
          </ul>
        </div>

        <div class="ev-how-col">
          <p class="ev-how-label">2 — CSS reads the field's output</p>
          <CodeTabs variants={[{ label: "CSS", lang: "css", code: snippetCss }]} />
          <p class="ev-how-note">Weight, ink, font heft, and border intensity all read from one
          normalized trust score; the halo reads the engine's live <code>--d</code> — the field
          drives the measurement; CSS drives the presentation.</p>
        </div>

        <div class="ev-how-col">
          <p class="ev-how-label">3 — the snapshot upgrades itself</p>
          <CodeTabs variants={[{ label: "TS", lang: "ts", code: snippetLive }]} />
          <p class="ev-how-note">
            The refresh covers every work on the page, deferred ones included — findings the
            accretion reveal surfaces later already carry refreshed counts, because each reveal
            folds in through the same reweight. Works the API doesn't return keep their snapshot
            values; the delta note only appears where a count actually moved.
          </p>
          <div class="ev-how-ctas">
            <a href="/docs" class="ev-how-link">Read the docs →</a>
            <a href="/recipes" class="ev-how-link ev-how-link--dim">See recipes →</a>
          </div>
        </div>
      </div>
    </section>

    <footer class="ev-fineprint">
      <p>
        Trust here is <strong>consensus, not correctness</strong> — citation count says how much the
        field has engaged a work, not whether it's right. Making that signal legible without faking a
        verdict is the point. Data: <a href="https://openalex.org" rel="noopener">OpenAlex</a> (CC0),
        snapshotted — and the snapshot is what ships in the HTML. In the browser the page
        <strong>upgrades itself to current OpenAlex counts once per visit</strong> when the API is
        reachable: each finding updates in place, counts that moved carry a quiet
        "since snapshot" delta, and the trust re-settles through the same weighting that built the
        page. Once, not a poll — citations move slowly, and polling them would be theater. If the
        API can't be reached, the snapshot stands.
      </p>
      <p class="ev-built">
        <a href="/">See the field with its particles →</a>
      </p>
    </footer>
</ExampleShell>

<script>
  import "../components/EvidenceRuntime.ts";
</script>
