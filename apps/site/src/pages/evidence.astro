---
import Base from "../layouts/Base.astro";
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
import evidence from "../data/evidence.json";
import "../styles/evidence.css";
import { EVIDENCE } from "../lib/copy.ts";

// The Evidence Field — field-ui as an invisible measurement layer over real research data.
// No particle swarm: the trust shows in the type. Each finding is a real OpenAlex work. The
// controls (Field on/off, Weight by) make the transformation legible — off, the same data is a
// plain list; change the weighting and the field re-settles. data-* in, --field-* out.
const slugify = (q: string) => q.replace(/[^a-z0-9]+/gi, "-").toLowerCase().replace(/^-|-$/g, "");
// field-ui's force palette — used for the "field" (discipline) color lens.
const FIELD_PALETTE = [
  "#4da3ff", "#2dd4bf", "#ff9d5c", "#a78bfa",
  "#86e57f", "#fbbf24", "#f0abfc", "#38bdf8",
];
const topics = evidence.topics.map((t) => {
  const lmax = Math.log(Math.max(...t.works.map((w) => w.citedBy), 1) + 1);
  const ids = new Set(t.works.map((w) => w.id));
  // map each distinct research subfield to a palette color (the discipline lens).
  const fieldColor = new Map<string, string>();
  [...new Set(t.works.map((w) => w.topic).filter(Boolean))].forEach((tp, i) =>
    fieldColor.set(tp!, FIELD_PALETTE[i % FIELD_PALETTE.length]!),
  );
  const works = t.works
    .map((w) => ({
      ...w,
      trust: Math.log(w.citedBy + 1) / lmax, // 0..1 consensus proxy (the default size signal)
      supports: w.refs.filter((r) => ids.has(r)), // intra-set citation edges → threads
      cat: (w.topic && fieldColor.get(w.topic)) || "#60a5fa", // default color lens = field/discipline
    }))
    .sort((a, b) => b.trust - a.trust);
  return { ...t, slug: slugify(t.question), works };
});
const authorLine = (a: string[]) => (a.length > 2 ? `${a[0]} et al.` : a.join(" & ")) || "—";
const linkFor = (w: { doi: string | null; id: string }) =>
  w.doi ? w.doi : `https://openalex.org/${w.id}`;
---

<Base
  title="field-ui — The Evidence Field"
  description="The same research, run as a field. field-ui measures real OpenAlex citation data and writes trust back into the type — heavier, brighter, more anchored — with no particle swarm. Toggle the field off and it collapses to a plain list; that gap is what field-ui adds. data-* in, --field-* out."
>
  <SiteNav current="evidence" />
  <main class="ev-page" data-field="on" data-weight="consensus" data-lens="field">
    <header class="ev-hero">
      <p class="ev-kicker">field-ui · the evidence field</p>
      <h1>Trust you can <span class="accent">feel</span>, not read.</h1>
      <p class="ev-lede">
        Research is typically served as a sorted column. Citation count compresses three things
        into one number — how much the field has engaged a work, whether it still holds, how many
        others build on it — then sorts descending. The top row wins. That's a ranking, not trust.
      </p>
      <p class="ev-lede">
        This is the same data from <a href="https://openalex.org" rel="noopener">OpenAlex</a> run as a <strong>field</strong>.
        Each paper is a body; its citation weight becomes gravitational mass — heavier works pull
        without asserting a verdict. Cross-citations thread each work to what it builds on.
        The field is <strong>invisible</strong> — no particle swarm, no overlay — only its effect
        shows in the type: weight, ink, and a left anchor that intensifies with consensus.
        <strong>Toggle it off</strong> and the data collapses to a plain list.
        Change the weighting and watch the field re-settle.
      </p>
    </header>

    <!-- Controls — make the transformation legible. -->
    <div class="ev-controls" role="group" aria-label="Field controls">
      <div class="ev-ctl">
        <span class="ev-ctl-l">Field</span>
        <button type="button" class="ev-switch" data-ev-field aria-pressed="true">
          <span class="ev-switch-dot" aria-hidden="true"></span>
          <span class="ev-switch-txt">on</span>
        </button>
      </div>
      <div class="ev-ctl">
        <span class="ev-ctl-l">Weight by</span>
        <div class="ev-seg" role="group" aria-label="Weighting signal">
          <button type="button" data-ev-weight="consensus" aria-pressed="true">consensus</button>
          <button type="button" data-ev-weight="recency" aria-pressed="false">recency</button>
          <button type="button" data-ev-weight="balanced" aria-pressed="false">balanced</button>
        </div>
      </div>
      <div class="ev-ctl">
        <span class="ev-ctl-l">Color by</span>
        <div class="ev-seg" role="group" aria-label="Color lens">
          <button type="button" data-ev-lens="field" aria-pressed="true">field</button>
          <button type="button" data-ev-lens="recency" aria-pressed="false">recency</button>
          <button type="button" data-ev-lens="trust" aria-pressed="false">trust</button>
        </div>
      </div>
      <p class="ev-ctl-hint">
        <span data-ev-hint set:html={EVIDENCE.hints.consensus} />
        <span class="ev-hint-sep">·</span>
        <span data-ev-lens-hint set:html={EVIDENCE.lensHints.field} />
      </p>
    </div>

    <!-- Legend — reading the field. -->
    <ul class="ev-legend" aria-label="How to read the field">
      <li><span class="ev-k ev-k-weight">Aa</span> <b>size</b> = the weighting signal</li>
      <li><span class="ev-k ev-k-anchor"></span> <b>color</b> = the lens (a second dimension)</li>
      <li>
        <span class="ev-k ev-k-shape">
          <span class="ev-mk ev-mk-article"></span><span class="ev-mk ev-mk-review"></span>
        </span>
        <b>shape</b> = study type (● primary · ◆ review)
      </li>
      <li><span class="ev-k ev-k-thread"></span> hover → threads to the work it builds on</li>
    </ul>

    <nav class="ev-tabs" data-ev-tabs aria-label="Questions">
      {
        topics.map((t, i) => (
          <button type="button" data-ev-tab={t.slug} aria-pressed={i === 0 ? "true" : "false"}>
            {t.question}
          </button>
        ))
      }
    </nav>

    {
      topics.map((t, ti) => (
        <section class="ev-topic" data-ev-topic={t.slug} hidden={ti !== 0}>
          <p class="ev-answer">
            <b>{t.works.length}</b> works address <em>"{t.question}"</em>. With the field on, the
            heaviest are near-consensus and the faint ones are still finding their footing; hover one
            to light the work it builds on. Change the weighting and watch them re-settle.
          </p>
          <ol class="ev-list" data-ev-list>
            {t.works.map((w, i) => (
              <li
                class="ev-finding"
                id={`${t.slug}--${w.id}`}
                data-body="attract"
                data-feedback
                data-cites={w.citedBy}
                data-year={w.year}
                data-topic={w.topic ?? ""}
                data-type={w.type}
                data-field-color={w.cat}
                data-strength={(0.4 + w.trust * 1.6).toFixed(2)}
                data-range="200"
                data-supports={w.supports.map((s) => `${t.slug}--${s}`).join(" ")}
                style={`--trust:${w.trust.toFixed(3)}; --cat:${w.cat};`}
              >
                <span class="ev-rank">{String(i + 1).padStart(2, "0")}</span>
                <div class="ev-body">
                  <a class="ev-title" href={linkFor(w)} target="_blank" rel="noopener">
                    {w.title}
                  </a>
                  <span class="ev-meta">
                    <span class="ev-field" title={w.topic ?? undefined}>
                      <span class="ev-lens" aria-hidden="true"></span>
                      <span class="ev-field-name">{w.topic ?? "—"}</span>
                    </span>
                    <span class="ev-meta-sep">·</span>
                    {authorLine(w.authors)} · <span class="ev-year">{w.year}</span>
                    {w.oa && <span class="ev-oa">open access</span>}
                  </span>
                </div>
                <div class="ev-trust" aria-label={`${w.citedBy} citations`}>
                  <span class="ev-cites">{w.citedBy.toLocaleString()}</span>
                  <span class="ev-cites-l" data-ev-unit>citations</span>
                  <span class="ev-bar"><i style={`width:${Math.round(w.trust * 100)}%`} /></span>
                </div>
              </li>
            ))}
          </ol>
        </section>
      ))
    }

    <!-- How it's built — the data-* pattern made concrete. -->
    <section class="ev-how" aria-labelledby="ev-how-h">
      <h2 id="ev-how-h">How it's built</h2>
      <p class="ev-how-lede">
        Every finding is ordinary semantic HTML — a <code>&lt;li&gt;</code> with three data
        attributes. field-ui reads them, runs a spatial field over the list, and writes measured
        state back as CSS custom properties each frame. No canvas. No particle swarm. No JS event
        listeners on individual elements.
      </p>

      <div class="ev-how-cols">
        <div class="ev-how-col">
          <p class="ev-how-label">1 — mark each finding as a field body</p>
          <pre class="ev-code"><code>&lt;li
  data-body="attract"
  data-strength="0.87"
  data-field-color="#4da3ff"
  data-feedback
  style="--trust: 0.87; --cat: #4da3ff;"
&gt;
  &lt;!-- your ordinary HTML here --&gt;
&lt;/li&gt;</code></pre>
          <ul class="ev-how-attrs">
            <li><code>data-body="attract"</code> — registers as a field participant</li>
            <li><code>data-strength</code> — gravitational mass (0 → faint, 2 → heavy anchor)</li>
            <li><code>data-field-color</code> — accent hue for the color lens</li>
            <li><code>data-feedback</code> — opt in to receive <code>--field-*</code> writebacks</li>
          </ul>
        </div>

        <div class="ev-how-col">
          <p class="ev-how-label">2 — CSS reads the field's output</p>
          <pre class="ev-code"><code>.ev-finding {
  /* --trust is server-set (0..1 log-normalised
     citation score). CSS reads it directly. */
  --w: var(--trust, 0.5);

  opacity: calc(0.58 + var(--w) * 0.42);
  border-left: 3px solid
    color-mix(in srgb,
      var(--cat) calc(18% + var(--w) * 82%),
      var(--line));
}
.ev-title {
  font-variation-settings:
    'wght' calc(380 + var(--w) * 360);
}</code></pre>
          <p class="ev-how-note">Weight, ink, font heft, and border intensity all read from one
          normalised trust score — the field drives the layout; CSS drives the presentation.</p>
        </div>

        <div class="ev-how-col">
          <p class="ev-how-label">3 — add field-ui to any project</p>
          <pre class="ev-code"><code>// npm
import { createField } from '@field-ui/vanilla';

// or: the web component, zero config
&lt;script type="module"
  src="https://esm.sh/@field-ui/elements"&gt;
&lt;/script&gt;
&lt;field-root&gt;&lt;/field-root&gt;

// data-* in → --field-* out.
// The rest is CSS.</code></pre>
          <div class="ev-how-ctas">
            <a href="/docs" class="ev-how-link">Read the docs →</a>
            <a href="/recipes" class="ev-how-link ev-how-link--dim">See recipes →</a>
          </div>
        </div>
      </div>
    </section>

    <footer class="ev-fineprint">
      <p>
        Trust here is <strong>consensus, not correctness</strong> — citation count says how much the
        field has engaged a work, not whether it's right. Making that signal legible without faking a
        verdict is the point. Data: <a href="https://openalex.org" rel="noopener">OpenAlex</a> (CC0),
        snapshotted.
      </p>
      <p class="ev-built">
        <a href="/">See the field with its particles →</a>
      </p>
    </footer>
  </main>
  <SiteFooter />
</Base>

<script>
  import "../components/EvidenceRuntime.ts";
</script>
