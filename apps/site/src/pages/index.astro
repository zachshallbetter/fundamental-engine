---
import Base from "../layouts/Base.astro";
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
import ManualHero from "../components/ManualHero.astro";
import ChapterRail from "../components/ChapterRail.astro";
import ChapterHeader from "../components/ChapterHeader.astro";
import Concept from "../components/Concept.astro";
import ManualFoot from "../components/ManualFoot.astro";
import Button from "../components/ui/Button.astro";
import NaturalFieldsSection from "../components/home/NaturalFieldsSection.astro";
import InvisibleFieldsStrip from "../components/home/InvisibleFieldsStrip.astro";
import ManualForceRow from "../components/home/ManualForceRow.astro";
import PresetRow from "../components/home/PresetRow.astro";
import { MANUAL_FORCES, MANUAL_PRESETS, NATURAL_FIELDS, FORCE_FIELD, type ManualEntry, type ManualPreset } from "@fundamental-engine/core";
import { RENDER_MODES, OVERLAY_MODES } from "../lib/docs-api.ts";
import contours from "../data/contours.json";
import "../styles/manual.css";
import "../styles/force-glyphs.css";
import "../styles/landing.css";

// The Field Manual — the chapter-based explainer, rebuilt on the typed engine and extended
// to the full catalog. This page is a composition file: the shared manual chrome (ManualHero,
// ChapterRail, ChapterHeader, Concept, ManualFoot) lives in src/components/ and is reused by
// /eli5; the catalog rows + the natural-field picker live in components/home/; page behaviour
// (interaction runtime + field-line overlay + picker) is wired by the shared orchestrator
// src/components/manual-page.ts (imported by the script tag at the bottom). Each numbered concept
// is unique prose, declared via <Concept> with its stage in the `stage` slot.
//
// The demo attributes (DEFAULTS / OVERRIDES / BODY_TOKENS / attrsFor) live in lib/demo-forces.ts —
// the single source the field-line traces and the accuracy test (field-probe.test.ts) read too,
// so the on-screen body and its traced path can't drift.

const PRESET_COLORS: Record<string, string> = {
  blackhole: "#fbbf24",
  whitehole: "#e0f2fe",
  star: "#6366f1",
  quasar: "#fbbf24",
  galaxy: "#a78bfa",
  nebula: "#38bdf8",
  tornado: "#2dd4bf",
  fountain: "#7dd3fc",
};
// Chapter II groups by the four FUNDAMENTAL FIELDS, pulling expressions across families (strong/weak
// live in the extended family). NATURAL_FIELDS carries each field's label/translation/summary + its
// token list (derived live from FORCE_FIELD), so this can't drift from the catalog.
const byToken = new Map(MANUAL_FORCES.map((f) => [f.token, f]));
const fieldGroups = NATURAL_FIELDS.map((nf) => ({
  ...nf,
  forces: nf.expressions.map((t) => byToken.get(t)).filter((f): f is ManualEntry => !!f),
}));
// natural-family tokens with no fundamental-field parent (derived forces + the memory metric) — kept
// in a residual group so nothing drops off the page.
const derived = MANUAL_FORCES.filter((f) => f.family === "natural" && !FORCE_FIELD[f.token]);
// the extended chapter excludes forces now shown under a fundamental field, to avoid duplication.
const extended = MANUAL_FORCES.filter((f) => f.family === "extended" && !FORCE_FIELD[f.token]);
let n = 3; // running concept number; Substrate is 01–03 (hardcoded below), then every
// chapter after it increments this in render order (Natural, Forces, Extended, Presets, …).

const chapters = [
  { id: "ch-substrate", no: "I", label: "Substrate" },
  { id: "ch-natural", no: "II", label: "Natural" },
  { id: "ch-forces", no: "III", label: "Forces" },
  { id: "ch-extended", no: "IV", label: "Extended" },
  { id: "ch-presets", no: "V", label: "Presets" },
  { id: "ch-conditions", no: "VI", label: "Conditions" },
  { id: "ch-system", no: "VII", label: "System" },
  { id: "ch-gallery", no: "VIII", label: "Gallery" },
];
---

<Base
  title="Fundamental — a renderer-agnostic relational field engine"
  description="Most UI frameworks let you declare importance; Fundamental is the first that enforces it — physically. Add a data-* attribute and the runtime measures the element and writes importance, attention, and relationships back as --field-* CSS variables you style with — so your interface shows what matters, what's connected, and where focus is going, without hand-coding badges, spinners, or one-off animation. Framework-agnostic (vanilla · web component · React); the core engine has zero runtime dependencies. 0.x preview."
>
  <SiteNav current="home" />
  <div id="main" class="manual-shell">
    <ManualHero kicker="Fundamental · a renderer-agnostic relational field engine">
      <h1 slot="title">Elements have <span
          class="hero-mass"
          data-hot
          data-feedback
          data-body="gravity swirl pigment"
          data-shaped
          data-strength="1.6"
          data-range="340"
          data-spin="1"
          data-color="#4da3ff"
          style="--cat:#4da3ff;">mass</span><span
          class="hero-antimass"
          data-body="repel pigment"
          data-strength="0.7"
          data-range="150"
          data-color="#ff9d5c"
          style="--cat:#ff9d5c;">.</span></h1>
      <p slot="standfirst" class="standfirst"
        data-body="attract pigment" data-shaped data-strength="0.5" data-range="260" data-color="#ffce6b" style="--cat:#ffce6b">
        Importance is gravity. Signal is charge. Relation is binding. Change is decay. The
        forces that order the physical world translate an interface — its elements and its
        data alike — better than any system built for either. Fundamental returns what your
        markup already carries as live <code>--field-*</code> variables you style with:
        every element a body in one field, where what matters pulls, what’s related binds,
        and what you attend to charges. The DOM is the first surface — not the only one:
        the same zero-DOM core runs in a WebGL scene and natively on Apple platforms.
      </p>
      <p slot="thesis" class="thesis"
        data-body="attract swirl pigment" data-strength="0.45" data-range="280" data-spin="1.1" data-color="#f0628e" style="--cat:#f0628e">
        <strong>Most UI frameworks let you declare importance. Fundamental is the first
        that enforces it — physically.</strong> You can’t style everything as urgent.
      </p>
      <Fragment slot="cta">
        {/* Resting mass: ungate the default attention-gated vessel (data-when="") and lead with a
            continuous attract so the CTAs pull the field at rest — they read as live, moving call-to-
            actions, not inert until hovered. Engagement still amplifies on hover. */}
        <Button href="#engine" variant="primary" data-color="#4da3ff" data-body="attract pigment" data-when="" data-strength="0.95" data-range="230">See it work →</Button>
        <Button href="#install" data-color="#a78bfa" data-body="attract pigment" data-when="" data-strength="0.8" data-range="210">Install →</Button>
      </Fragment>
      <div slot="meta" class="meta">
        <span><b>Category</b> &nbsp;add a data-* attribute, get --field-* back</span>
        <span><b>For</b> &nbsp;design engineers · AI-product builders · component-library authors</span>
        <span><b>Maturity</b> &nbsp;0.x preview — a substrate to build on, no external users yet</span>
      </div>
    </ManualHero>

    <!-- ============================================================
         ORIENTATION BLOCK — property → install → real interface →
         why-different → AI wedge → the engine. Reuses the existing
         manual demos by anchor-link; the 55-section manual below is
         intact and unduplicated. Copy is the reorg canon. -->

    <!-- Install — one scroll below the hero; mirrors /docs exactly. -->
    <section class="lp lp-install" id="install">
      <div class="wrap">
        <span class="concept-no">Install</span>
        <h2>Add it to the stack you already have.</h2>
        <p class="lp-lede">
          One package per framework — pick the one for your stack and you’re done. Each bundles the
          engine (<code>core</code> + the DOM binding) for you; there’s nothing to wire together.
        </p>
        <div class="lp-pkgs">
          <!-- the 'start here' card spans the row and is a live accretion vessel: `sink attract` gathers
               the field's matter, `--load` fills it from the base, and it supernovas + resets on saturation. -->
          <div class="lp-pkg lp-pkg--hero" data-body="sink attract pigment" data-feedback data-absorb="44" data-max="90" data-strength="0.7" data-range="300" data-color="#ff8a5c" style="--cat:#ff8a5c">
            <span class="lp-pkg-tag">Start here</span>
            <code class="install" data-copy="npm i @fundamental-engine/vanilla">npm i @fundamental-engine/vanilla</code>
            <span class="lp-pkg-desc"><b>Plain TS / JS</b>, no framework — the typed <code>FieldField</code> class; one call mounts a field. This card is itself a live field body: it accretes the swarm and fills as it gathers. <a href="/docs/guides/typescript">Guide →</a></span>
          </div>
          <div class="lp-pkg" data-body="wall pigment" data-feedback data-color="#f0628e" data-strength="0.55" data-range="170" style="--cat:#f0628e">
            <code class="install" data-copy="npm i @fundamental-engine/react">npm i @fundamental-engine/react</code>
            <span class="lp-pkg-desc"><b>React</b> — the <code>&lt;FieldField&gt;</code> component + <code>useFieldField</code> hook. <a href="/docs/guides/react">Guide →</a></span>
          </div>
          <div class="lp-pkg" data-body="wall pigment" data-feedback data-color="#c084fc" data-strength="0.55" data-range="170" style="--cat:#c084fc">
            <code class="install" data-copy="npm i @fundamental-engine/elements">npm i @fundamental-engine/elements</code>
            <span class="lp-pkg-desc"><b>Any framework or plain HTML</b> — the <code>&lt;field-root&gt;</code> web component. <a href="/docs/guides/web-component">Guide →</a></span>
          </div>
          <div class="lp-pkg" data-body="wall pigment" data-feedback data-color="#ffce6b" data-strength="0.55" data-range="170" style="--cat:#ffce6b">
            <code class="install" data-copy="npm i @fundamental-engine/three">npm i @fundamental-engine/three</code>
            <span class="lp-pkg-desc"><b>Three.js / WebGL</b> — the swarm as a <code>THREE.Points</code> layer. <a href="/docs/guides/three">Guide →</a></span>
          </div>
        </div>
        <p class="lp-note">
          Own the canvas / building your own renderer? <code>@fundamental-engine/core</code> is the
          renderer-agnostic engine — you supply a host (<a href="/docs/guides/core">Core guide</a>). You
          don’t install <code>@fundamental-engine/dom</code> directly — the packages above already
          bundle it for you.
        </p>
        <p class="lp-note">
          No build step? Import from a CDN (playground / prototyping only):
          <code>import {'{'} createField {'}'} from 'https://esm.sh/@fundamental-engine/vanilla'</code>
        </p>
        <p class="lp-note">
          The full package map and an install-to-reacting-headline walkthrough live in the
          <a href="/docs">docs</a>.
        </p>
      </div>
    </section>

    <!-- One engine, many surfaces — the renderer-agnostic story (Web · Native · your renderer). -->
    <section class="lp lp-surfaces" id="surfaces">
      <div class="wrap">
        <span class="concept-no">Surfaces</span>
        <h2>One engine, many surfaces.</h2>
        <p class="lp-lede">
          The core computes the field against plain data and imports zero DOM. A thin host binds it to
          a surface — so the same physics runs three ways:
        </p>
        <ul class="model">
          <li>
            <b>Web</b> — <code>@fundamental-engine/dom</code> binds the engine to the page: every
            <code>[data-body]</code> element a body, feedback returned as <code>--field-*</code>
            variables. The primary surface — and what this page runs on.
          </li>
          <li>
            <b>Native</b> — a Swift port runs the same field on Apple platforms (Metal / SwiftUI), and a
            Kotlin port runs it on Android (Jetpack Compose, plus a non-Compose <code>View</code>/<code>Canvas</code>
            host) — both free of the browser’s compositing ceiling. The <a href="/docs/implementations">Field Lab</a>
            is the showcase: a native app to explore every force live.
          </li>
          <li>
            <b>Your renderer</b> — <code>@fundamental-engine/three</code> drives a
            <code>THREE.Points</code> swarm in your own WebGL scene; the read primitives
            (<code>sample</code>, <code>readParticles</code>, <code>addField</code>) bind the engine to
            anything that draws.
          </li>
        </ul>
        <p class="lp-note">
          How the surfaces relate — and what’s at parity across them — in
          <a href="/docs/implementations">Implementations</a>.
        </p>
      </div>
    </section>

    <!-- §2 · Apply — a real interface you'd build, surfaced with a preview + live link
         to /evidence/inbox (a no-swarm, real-data field). -->
    <section class="lp lp-apply">
      <div class="wrap">
        <span class="concept-no">A real interface</span>
        <h2>A real interface you’d actually build.</h2>
        <p class="lp-lede">
          An inbox of real unanswered questions, ranked by urgency — recency, votes, and
          views become mass. But the page holds one fixed attention budget, so brightening
          one ask dims the rest. No particle swarm; the measurement comes back as type and
          ink.
        </p>
        <div class="lp-inbox" aria-hidden="true">
          <div class="lp-inbox-head"><span>Inbox · attention is conserved</span><span>urgency → mass</span></div>
          <div class="lp-ask" style="--u:1;"><span class="lp-bar"></span><span class="lp-title">Production outage — auth tokens expiring early</span><span class="lp-meta">2h · 48▲</span></div>
          <div class="lp-ask" style="--u:0.72;"><span class="lp-bar"></span><span class="lp-title">Why does my migration deadlock under load?</span><span class="lp-meta">9h · 21▲</span></div>
          <div class="lp-ask" style="--u:0.46;"><span class="lp-bar"></span><span class="lp-title">Best way to debounce a resize observer?</span><span class="lp-meta">1d · 7▲</span></div>
          <div class="lp-ask" style="--u:0.24;"><span class="lp-bar"></span><span class="lp-title">Preferred naming for boolean props?</span><span class="lp-meta">4d · 2▲</span></div>
        </div>
        <Button href="/evidence/inbox" variant="primary">Open this example →</Button>
      </div>
    </section>

    <!-- §3 · Differentiate — the spine, the mental model, the eliminated-work band
         (SHIP claims only), and the calibration band. Demos referenced by anchor. -->
    <section class="lp lp-diff">
      <div class="wrap">
        <span class="concept-no">Why it’s different</span>
        <h2>Most frameworks let you <em>declare</em> importance. Fundamental <em>enforces</em> it.</h2>
        <p class="lp-lede">
          You can’t style everything as urgent — the attention budget is conserved.
          Express “these are related,” “the user has dwelled here,” or “this is unstable”
          as first-class runtime state, instead of hand-rolling badges, spinners, and
          bespoke animation for each. <a href="#concept-conserved">See conserved attention →</a>
        </p>

        <figure class="lp-model">
          <div class="lp-flow">
            <span class="lp-step"><code>data-*</code><span>you author</span></span>
            <span class="lp-arrow">→</span>
            <span class="lp-step"><code>measure</code><span>runtime</span></span>
            <span class="lp-arrow">→</span>
            <span class="lp-step"><code>--field-*</code><span>runtime writes back</span></span>
            <span class="lp-arrow">→</span>
            <span class="lp-step"><code>you style</code><span>CSS</span></span>
          </div>
          <figcaption>You author meaning; the field returns measurement.</figcaption>
        </figure>

        <div class="lp-elim">
          <h3>Stop building the systems that exist because the DOM is blind.</h3>
          <p>
            The DOM can’t see what matters, what’s related, or what’s gone stale — so
            teams build that sight by hand, again and again. Fundamental gives the DOM a
            continuous answer, and a whole category of code stops being yours to write
            and maintain.
          </p>
          <ul>
            <li><b>Priority you don’t store or sort.</b> Importance is a measurement the field reads each frame (<code>--field-density</code>), not state you keep in a store and re-sort on every change. <a href="#concept-material">See it work →</a></li>
            <li><b>“Everything is P1,” solved by a law.</b> Attention is one conserved budget — emphasize one thing and the rest necessarily yield. The normalization pass teams enforce with scoring schemes and meetings becomes something the runtime cannot violate. <a href="#concept-conserved">See it work →</a></li>
            <li><b>Relationships you don’t model.</b> Connection emerges from proximity and conservation — threads, cross-boundary spill — instead of adjacency lists and graph traversal you maintain. <a href="#concept-threads">See it work →</a></li>
            <li><b>Staleness without timers.</b> Recency and decay are a force in the runtime, continuous, not a cron job or a computed column you babysit. <a href="/evidence/memory">See it work →</a></li>
            <li><b>One model, always current.</b> The field re-resolves every frame, so a priority shift doesn’t fire a sort-and-re-render pass — the readout is simply already current. <a href="#concept-layout">See it work →</a></li>
          </ul>
          <p class="lp-elim-close">
            Fundamental doesn’t hand you a better abstraction over these jobs. It makes the
            question each one answered — what matters, what’s related, what’s stale —
            answerable by the field, so the job itself goes away.
          </p>
        </div>

        <ul class="lp-calib">
          <li><b>Zero runtime dependencies.</b> The core engine ships with none.</li>
          <li><b>Costs almost nothing to run.</b> Not main-thread-bound; sub-millisecond at real-page scale (~130 particles, 0.25 ms/frame). The live homepage runs 42 field instances at 120 fps with no long tasks on desktop. <a href="/docs/performance">The measurements →</a></li>
          <li><b>Accessible by construction.</b> Semantic HTML stays the source of truth; reduced-motion equivalents are enforced and linted.</li>
          <li><b>Auditable.</b> Code-verified docs, conformance tests, a frozen 0.x API.</li>
        </ul>
      </div>
    </section>

    <!-- §4 · Wedge — trust UI for AI output, pointing at the Evidence + Search studies. -->
    <section class="lp lp-ai">
      <div class="wrap">
        <span class="concept-no">The wedge</span>
        <h2>Make model output you can read at a glance.</h2>
        <p class="lp-lede">
          A model hands you answers; it rarely shows how sure it is. Make each claim a body in the
          field, and confidence becomes weight, agreement becomes proximity, and contradictions pull
          apart — so a shaky answer <em>looks</em> shaky and its sources are one hop away, before anyone
          acts on it. The same deterministic field math drives the Evidence and Search studies.
        </p>
        <div class="lp-cta-row">
          <Button href="/evidence" variant="primary">See it on real data →</Button>
          <Button href="/docs/studies/evidence-field">How it works →</Button>
        </div>
      </div>
    </section>

    <!-- The gate into the deep dive — the 55-section manual, intact, below. -->
    <section class="lp lp-engine-gate" id="engine">
      <div class="wrap">
        <span class="concept-no">The full engine, end to end</span>
        <h2>Now — how it works, live over the running engine.</h2>
        <p class="lp-lede">
          Everything above is built from one contract: <code>data-*</code> in,
          <code>--field-*</code> out. Below is the complete, executable manual —
          {MANUAL_FORCES.length} forces, the presets, and the system behaviour, each demo
          running on the real engine.
        </p>
        <Button href="/lab" variant="primary">Open the Lab →</Button>
      </div>
    </section>

    <ChapterRail chapters={chapters} />

    <!-- I · Substrate -->
    <ChapterHeader no="I" id="ch-substrate" title="Substrate">What the field is made of — and how it locks to the page. See the <a href="/docs/platform">platform layer</a>.</ChapterHeader>

    <aside class="atom-note">
      <p>
        And it's made of <strong>this project</strong>. Every particle drifting behind the page
        carries a real piece of Fundamental — <b>133 atoms</b>: 36 forces, 64 recipes, 8 presets, 10
        metrics, the truth modes, the natural fields, the packages. The ones that know more about
        themselves are heavier and bigger. <strong>Hover the field to inspect any dot.</strong>
      </p>
    </aside>

    <Concept stageHidden>
      <span class="concept-no">01 — Synchronization</span>
          <h2>The platform maps semantic elements into field coordinates.</h2>
          <p>
            The runtime measures registered bodies through the
            <strong>host / platform boundary</strong> and maps each element’s box
            into the field — so the field and the page describe the same space.
          </p>
          <p class="note">
            Because it re-measures as the page changes, the field stays locked to
            the visible boxes through scroll, resize, and reflow.
          </p>
          <div class="formula">
            <span class="c">measure:</span> rect(el) <span class="c">→</span>
            <span class="v">field(x, y)</span>
          </div>
      <Fragment slot="stage">
        <span class="stage-label">DOM → field</span>
          <svg class="diagram" viewBox="0 0 420 300" fill="none">
            <rect x="60" y="70" width="180" height="90" rx="10" class="dim"
            ></rect>
            <text x="70" y="60" class="lbl">measure(el)</text>
            <circle cx="150" cy="115" r="3" class="accf"></circle>
            <line
              x1="150"
              y1="115"
              x2="340"
              y2="210"
              class="acc"
              stroke-dasharray="3 4"></line>
            <circle cx="340" cy="210" r="4" class="accf"></circle>
            <text x="300" y="240" class="lbl">field (x, y)</text>
          </svg>
      </Fragment>
    </Concept>

    <Concept reverse stageHidden>
      <span class="concept-no">02 — Mass &amp; damping</span>
          <h2>Particles are point-masses in a medium.</h2>
          <p>
            Each particle carries a velocity and a nominal mass — m = 1 by
            default. Every frame its velocity is multiplied by a friction
            factor — momentum bleeds off instead of accumulating.
          </p>
          <div class="formula">
            <span class="v">v</span><span class="c">ₜ₊₁</span> = <span class="v"
              >v</span
            ><span class="c">ₜ</span> · <span class="v">f</span>
            <span class="c">(f ≈ 0.95)</span> · <span class="c">m ∝ size</span>
          </div>
          <p class="note">
            Damping is why the field settles into calm swarms rather than
            scattering. The formula shows the opt-in mode — <span class="c">mass: true</span>
            — where m scales with size; default particles run at nominal mass m = 1.
          </p>
      <Fragment slot="stage">
        <span class="stage-label">momentum decay</span>
          <svg class="diagram" viewBox="0 0 420 300" fill="none">
            <circle cx="80" cy="150" r="10" class="accf" opacity="0.9"></circle>
            <line x1="95" y1="150" x2="175" y2="150" class="acc"></line>
            <circle cx="210" cy="150" r="7" class="accf" opacity="0.7"></circle>
            <line x1="222" y1="150" x2="272" y2="150" class="acc"></line>
            <circle cx="305" cy="150" r="5" class="accf" opacity="0.5"></circle>
            <circle cx="378" cy="150" r="3.5" class="accf" opacity="0.35"
            ></circle>
            <text x="60" y="210" class="lbl"
              >velocity bleeds off each frame</text
            >
          </svg>
      </Fragment>
    </Concept>

    <Concept stageHidden>
      <span class="concept-no">03 — Currents</span>
          <h2>The waves are a flow field.</h2>
          <p>
            Near a wave line, particles pick up a drag vector along the slope of
            the curve — the derivative of the sine — so they drift like debris
            carried down a river.
          </p>
          <div class="formula">
            slope(x) = cos(x · <span class="v">freq</span> + φ) · freq · amp · <span
              class="v">vₓ</span
            > += slope · influence
          </div>
          <p class="note">
            It’s why the resting field feels alive without any input.
          </p>
      <Fragment slot="stage">
        <span class="stage-label">wave slope → drift</span>
          <svg class="diagram" viewBox="0 0 420 300" fill="none">
            <path
              d="M20 170 Q110 90 200 170 T380 170"
              class="acc"
              stroke-width="1.5"></path>
            <circle cx="200" cy="170" r="4" class="accf"></circle>
            <line
              x1="200"
              y1="170"
              x2="270"
              y2="140"
              class="acc"
              stroke-dasharray="3 4"></line>
            <text x="150" y="230" class="lbl"
              >tangent drift along the curve</text
            >
          </svg>
      </Fragment>
    </Concept>

    <!-- Below the substrate: play the four fields live, then meet a body that holds matter.
         The interactive lead-in to the natural-field translations + the Body Interaction Model. -->
    <NaturalFieldsSection
      translationKicker="Live — the four fields"
      bodyKicker="Live — a body as a vessel"
    />

    <!-- II · Natural-field translations -->
    <ChapterHeader no="II" id="ch-natural" title="Natural-field translations">Every interface already has priority, polarity, binding, and
          transformation. Fundamental translates the four forces of nature into
          those relations — gravity becomes priority, electromagnetism becomes
          polarity and signal, strong becomes binding, weak becomes
          transformation. The runtime tokens below are engine expressions of that
          grammar (true 1/d², Lorentz, Langevin, diffusion, waves) —
          translations, not additional fundamental fields. See the
          <a href="/docs/natural-fields">Natural Fields</a> model.</ChapterHeader>
    {
      fieldGroups.map((g) => (
        <>
          <h3 class="field-group-label">
            <span class="fgl-title">{g.title}</span>
            <span class="fgl-trans">{g.translation}</span>
          </h3>
          {g.forces.map((f, i) => {
            n += 1;
            return <ManualForceRow f={f} num={n} reverse={i % 2 === 1} />;
          })}
        </>
      ))
    }
    {derived.length > 0 && (
      <>
        <h3 class="field-group-label">
          <span class="fgl-title">Derived &amp; supporting</span>
          <span class="fgl-trans">behaviors that compose from the four</span>
        </h3>
        {derived.map((f: ManualEntry, i) => {
          n += 1;
          return <ManualForceRow f={f} num={n} reverse={i % 2 === 1} />;
        })}
      </>
    )}

    <!-- III · Forces (canonical nine) -->
    <ChapterHeader no="III" id="ch-forces" title="Forces">What a single body can do to the matter around it — designed UI verbs,
          stable and bounded. A designed verb is not a natural field: an attractor
          is not gravity, a repeller is not charge. See the full <a href="/docs/api/forces">force catalog</a>.</ChapterHeader>

    <Concept reverse data-form="wells">
      <span class="concept-no"
            ><i class="fg fg-attract" style="--fc:#4da3ff"></i>{String((n += 1)).padStart(2, "0")} — Attraction</span
          >
          <h2>A body can pull the field into orbit.</h2>
          <a class="force-ref" href="/docs/api/forces#force-attract"><code>attract</code> in the force catalog →</a>
          <p>
            An <strong>attractor</strong> defines a gravity well. The pull grows as
            distance falls, and a tangential component bends incoming particles into
            stable spirals.
          </p>
          <div class="formula">
            F = (1 − <span class="v">d</span> / d<span class="c">max</span>)² · <span
              class="v">S</span
            >
          </div>
          <p class="note">
            Drag the attractor — the force is bound to the element, not the
            cursor.
          </p>
          <button class="agitate" data-agitate="#c-attract"
            >↯ Agitate the field</button
          >
      <Fragment slot="stage">
        <span class="stage-label">attractor — drag me</span>
          <span
            class="body-chip"
            id="c-attract"
            data-drag
            data-body="attract"
            data-strength="1"
            data-range="300"
            style="--cc:#4da3ff; position:absolute; left:50%; top:50%; transform:translate(-50%,-50%);"
            ><i class="fg fg-attract"></i>attractor</span
          >
          <span class="hintline"
            >force follows the element across the field</span
          >
      </Fragment>
    </Concept>

    <Concept data-form="scatter">
      <span class="concept-no"
            ><i class="fg fg-repel" style="--fc:#ff9d5c"></i>{String((n += 1)).padStart(2, "0")} — Repulsion</span
          >
          <h2>A body can push the field away.</h2>
          <a class="force-ref" href="/docs/api/forces#force-repel"><code>repel</code> in the force catalog →</a>
          <p>
            A <strong>repeller</strong> is an inverted well — the force points <strong
              >outward</strong
            >, carving a clean void the rest of the field flows around.
          </p>
          <div class="formula">
            F = −(1 − <span class="v">d</span> / d<span class="c">max</span>)² · <span
              class="v">S</span
            >
          </div>
          <p class="note">
            Drag the repeller and watch a clearing open around it.
          </p>
          <button class="agitate" data-agitate="#c-repel"
            >↯ Agitate the field</button
          >
      <Fragment slot="stage">
        <span class="stage-label">repeller — drag me</span>
          <span
            class="body-chip"
            id="c-repel"
            data-drag
            data-body="repel"
            data-strength="1.1"
            data-range="300"
            style="--cc:#ff9d5c; position:absolute; left:50%; top:50%; transform:translate(-50%,-50%);"
            ><i class="fg fg-repel"></i>repel</span
          >
          <span class="hintline"
            >force points outward — a void opens in the field</span
          >
      </Fragment>
    </Concept>

    <Concept reverse>
      <span class="concept-no"
            ><i class="fg fg-wall" style="--fc:#c4b5fd"></i>{String((n += 1)).padStart(2, "0")} — Reflection</span
          >
          <h2>A body can be a wall.</h2>
          <a class="force-ref" href="/docs/api/forces#force-wall"><code>wall</code> in the force catalog →</a>
          <p>
            A <strong>wall</strong> is an axis-aligned box. A crossing particle has
            its perpendicular velocity reversed and scaled by elasticity, then is
            projected back out — a hard hit throws a <strong>spark</strong>.
          </p>
          <div class="formula">
            <span class="c">vertical edge:</span>
            <span class="v">vₓ</span> ← −Cᵣ · <span class="v">vₓ</span>
          </div>
          <p class="note">
            Drag the wall into the drifting particles to deflect them.
          </p>
      <Fragment slot="stage">
        <span class="stage-label">wall — drag me</span>
          <div
            class="body-wall"
            data-drag
            data-body="wall"
            style="position:absolute; left:50%; top:50%; transform:translate(-50%,-50%);"
          >
            wall
          </div>
          <span class="hintline">particles bounce off the bounding box</span>
      </Fragment>
    </Concept>

    <Concept data-form="wells">
      <span class="concept-no"
            ><i class="fg fg-swirl" style="--fc:#2dd4bf"></i>{String((n += 1)).padStart(2, "0")} — Swirl</span
          >
          <h2>A body can spin the field.</h2>
          <a class="force-ref" href="/docs/api/forces#force-swirl"><code>swirl</code> in the force catalog →</a>
          <p>
            A <strong>swirl</strong> applies a dominantly <strong
              >tangential</strong
            > force — a swirl, not a drain. The inward pull is light (the swirl dominates
            it roughly eightfold), so matter wheels around the body instead of falling
            in. A tight inward spiral is a preset (<code>whirlpool</code>),
            never the canonical verb.
          </p>
          <div class="formula">
            <span class="v">v</span> += (−<span class="v">d̂_y</span>, <span
              class="v">d̂_x</span
            >) · <span class="v">S</span> · spin <span class="c">+</span>
            <span class="v">d̂</span> · <span class="v">S</span> · <span
              class="c">0.12</span
            >
          </div>
          <p class="note">
            Drag the swirl into the swarm — particles orbit rather than fall in.
          </p>
          <button class="agitate" data-agitate="#c-swirl"
            >↯ Agitate the field</button
          >
      <Fragment slot="stage">
        <span class="stage-label">swirl — drag me</span>
          <span
            class="body-chip"
            id="c-swirl"
            data-drag
            data-body="swirl"
            data-spin="1"
            data-strength="1"
            data-range="320"
            style="--cc:#2dd4bf; position:absolute; left:50%; top:50%; transform:translate(-50%,-50%);"
            ><i class="fg fg-swirl"></i>swirl</span
          >
          <span class="hintline"
            >tangential force — the field circles, never collapses</span
          >
      </Fragment>
    </Concept>

    <Concept reverse data-form="lanes">
      <span class="concept-no"
            ><i class="fg fg-stream" style="--fc:#7dd3fc"></i>{String((n += 1)).padStart(2, "0")} — Stream</span
          >
          <h2>A body can blow a current.</h2>
          <a class="force-ref" href="/docs/api/forces#force-stream"><code>stream</code> in the force catalog →</a>
          <p>
            A <strong>stream</strong> emits a constant force along a heading — a fan,
            a jet, a prevailing wind. The swarm combs into parallel flow.
          </p>
          <div class="formula">
            <span class="v">v</span> += (cos θ, sin θ) · <span class="v">S</span
            > · (1 − <span class="v">d</span>/d<span class="c">max</span>)
          </div>
          <p class="note">
            Drag the jet and watch matter streak into lanes downwind.
          </p>
          <button class="agitate" data-agitate="#c-stream"
            >↯ Agitate the field</button
          >
      <Fragment slot="stage">
        <span class="stage-label">stream — drag me</span>
          <span
            class="body-chip"
            id="c-stream"
            data-drag
            data-body="stream"
            data-angle="0"
            data-strength="1"
            data-range="340"
            style="--cc:#7dd3fc; position:absolute; left:50%; top:50%; transform:translate(-50%,-50%);"
            ><i class="fg fg-stream"></i>stream</span
          >
          <span class="hintline"
            >directional current — particles comb downwind</span
          >
      </Fragment>
    </Concept>

    <Concept data-form="wells">
      <span class="concept-no"
            ><i class="fg fg-tether" style="--fc:#86e57f"></i>{String((n += 1)).padStart(2, "0")} — Tether</span
          >
          <h2>A body can tether the field at a fixed distance.</h2>
          <a class="force-ref" href="/docs/api/forces#force-tether"><code>tether</code> in the force catalog →</a>
          <p>
            A <strong>tether</strong> has a <strong>rest length</strong>. Matter
            that crowds in is pushed out; matter that strays is reeled in — the
            swarm settles into an orbiting shell.
          </p>
          <div class="formula">
            <span class="v">v</span> += û · (<span class="v">d</span> − <span
              class="v">r</span
            ><span class="c">est</span>) · <span class="v">k</span>
          </div>
          <p class="note">
            Drag the tether — matter springs back to its radius.
          </p>
          <button class="agitate" data-agitate="#c-tether"
            >↯ Agitate the field</button
          >
      <Fragment slot="stage">
        <span class="stage-label">tether — drag me</span>
          <span
            class="body-chip"
            id="c-tether"
            data-drag
            data-body="tether"
            data-strength="1"
            data-range="260"
            style="--cc:#86e57f; position:absolute; left:50%; top:50%; transform:translate(-50%,-50%);"
            ><i class="fg fg-tether"></i>tether</span
          >
          <span class="hintline"
            >a tether — matter holds a shell at the rest radius</span
          >
      </Fragment>
    </Concept>

    <Concept reverse data-form="lanes">
      <span class="concept-no"
            ><i class="fg fg-viscosity" style="--fc:#8da2c0"></i>{String((n += 1)).padStart(2, "0")} — Viscosity</span
          >
          <h2>A body can thicken the medium.</h2>
          <a class="force-ref" href="/docs/api/forces#force-viscosity"><code>viscosity</code> in the force catalog →</a>
          <p>
            A <strong>viscosity</strong> body neither pulls nor pushes — it <strong
              >bleeds momentum</strong
            >, as if the field turned to honey. Paired with an attractor it
            turns a slingshot into a settled orbit.
          </p>
          <div class="formula">
            <span class="v">v</span> ← <span class="v">v</span> · (1 − <span
              class="v">k</span
            >), <span class="c">k ∝ (1 − d/d_max)·S</span>
          </div>
          <p class="note">Agitate, then watch the rush die inside the zone.</p>
          <button class="agitate" data-agitate="#c-drag"
            >↯ Agitate the field</button
          >
      <Fragment slot="stage">
        <span class="stage-label">viscosity — move me</span>
          <span
            class="body-chip"
            id="c-drag"
            data-drag
            data-body="viscosity"
            data-strength="1"
            data-range="300"
            style="--cc:#8da2c0; position:absolute; left:50%; top:50%; transform:translate(-50%,-50%);"
            ><i class="fg fg-viscosity"></i>viscosity</span
          >
          <span class="hintline"
            >a viscous zone — momentum bleeds off, the swarm settles</span
          >
      </Fragment>
    </Concept>

    <Concept data-form="accretion">
      <span class="concept-no"
            ><i class="fg fg-sink" style="--fc:#ff6e9c"></i>{String((n += 1)).padStart(2, "0")} — Accretion &amp;
            release</span
          >
          <h2>A body can hold matter — and give it back.</h2>
          <a class="force-ref" href="/docs/api/forces#force-sink"><code>sink</code> in the force catalog →</a>
          <p>
            A <strong>sink</strong> captures particles at its core. They aren’t deleted
            — they’re
            <strong>held inside</strong>, and the element inflates as it fills.
            When it saturates it goes supernova: the exact particles are <strong
              >released radially</strong
            >.
          </p>
          <div class="formula">
            <span class="c">scale =</span> 1 + (<span class="v">accreted</span> /
            <span class="v">capacity</span>) · 0.45 · <span class="v"
              >captured = released</span
            >
          </div>
          <p class="note">
            Nothing is conjured from thin air, and nothing vanishes. Matter
            changes hands.
          </p>
      <Fragment slot="stage">
        <span class="stage-label">sink — fills, then pops</span>
          <div
            class="body-core"
            data-drag
            data-body="sink attract"
            data-absorb="64"
            data-max="8"
            data-feedback
            data-strength="0.8"
            data-range="180"
            style="--cc:#ff9d5c; position:absolute; left:50%; top:50%; transform:translate(-50%,-50%);"
          >
            core
          </div>
          <div class="meter" style="--cc:#ff9d5c;"><i></i></div>
          <span class="hintline"
            >matter accumulates, then releases on supernova</span
          >
      </Fragment>
    </Concept>

    <Concept reverse data-form="lanes">
      <span class="concept-no"
            ><i class="fg fg-jet" style="--fc:#a78bfa"></i>{String((n += 1)).padStart(2, "0")} — Emission</span
          >
          <h2>A body can be a fountain.</h2>
          <a class="force-ref" href="/docs/api/forces#force-jet"><code>jet</code> in the force catalog →</a>
          <p>
            A <strong>jet</strong> draws surrounding matter into its nozzle and relaunches
            it as a hot jet — the field is <strong
              >recycled into a stream</strong
            >, nothing conjured.
          </p>
          <div class="formula">
            <span class="c">feed:</span>
            <span class="v">v</span> += d̂ · S · <span class="c">at nozzle:</span
            >
            <span class="v">v</span> = (cos θ, sin θ) · spd
          </div>
          <p class="note">
            Agitate to feed it, then watch the jet stream off along its heading.
          </p>
          <button class="agitate" data-agitate="#c-jet"
            >↯ Feed the fountain</button
          >
      <Fragment slot="stage">
        <span class="stage-label">jet — move me · jets →</span>
          <span
            class="body-chip"
            id="c-jet"
            data-drag
            data-body="jet"
            data-angle="0"
            data-strength="1"
            data-range="300"
            style="--cc:#a78bfa; position:absolute; left:50%; top:50%; transform:translate(-50%,-50%);"
            ><i class="fg fg-jet"></i>jet</span
          >
          <span class="hintline"
            >a fountain — matter is drawn in and jetted back out</span
          >
      </Fragment>
    </Concept>

    <!-- IV · Designed-extended -->
    <ChapterHeader no="IV" id="ch-extended" title="Designed-extended">Further designed forces, and the modifiers that wrap a sibling. See the full <a href="/docs/api/forces">force catalog</a>.</ChapterHeader>
    {
      extended.map((f: ManualEntry, i) => {
        n += 1;
        return <ManualForceRow f={f} num={n} reverse={i % 2 === 1} />;
      })
    }

    <!-- V · Presets -->
    <ChapterHeader no="V" id="ch-presets" title="Presets">Cosmology as composition — named arrangements of the primitives. See the <a href="/docs/api/presets">preset reference</a>.</ChapterHeader>
    {
      MANUAL_PRESETS.map((p: ManualPreset, i) => {
        n += 1;
        const color = PRESET_COLORS[p.name] ?? "#4da3ff";
        return <PresetRow p={p} num={n} color={color} reverse={i % 2 === 1} />;
      })
    }

    <!-- VI · Conditions -->
    <ChapterHeader no="VI" id="ch-conditions" title="Conditions">When a force decides to act, and on which matter. See <a href="/docs/authoring">authoring &amp; conditions</a>.</ChapterHeader>
    <Concept data-form="scatter">
      <span class="concept-no"
            >{String((n += 1)).padStart(2, "0")} — Conditional</span
          >
          <h2>A force can choose what it touches.</h2>
          <p>
            Any body can carry a <strong>condition</strong> — gated on being engaged,
            or on a particle’s
            <strong>speed</strong> or <strong>heat</strong>. A selective force
            reads every free agent and acts only on those that match.
          </p>
          <div class="formula">
            <span class="c">when</span> = active · fast · slow · hot · cool · scrolling
          </div>
          <p class="note">
            The catcher below only grips <strong>hot</strong> particles. Heat the
            field and the excited matter is pulled in while the calm passes through.
          </p>
          <button class="agitate" data-agitate="#c-cond"
            >↯ Heat the field</button
          >
      <Fragment slot="stage">
        <span class="stage-label">conditional — catches heat only</span>
          <span
            class="body-chip"
            id="c-cond"
            data-drag
            data-body="attract"
            data-when="hot"
            data-strength="1.2"
            data-range="320"
            style="--cc:#ff6e9c; position:absolute; left:50%; top:50%; transform:translate(-50%,-50%);"
            ><i class="fg fg-attract"></i>when&nbsp;hot</span
          >
          <span class="hintline"
            >selective attractor — grips excited matter, ignores the calm</span
          >
      </Fragment>
    </Concept>

    <!-- VII · System -->
    <ChapterHeader no="VII" id="ch-system" title="System">What emerges when the parts interact. See the <a href="/docs/concepts">concepts</a> and <a href="/docs/reading-field">reading the field</a>.</ChapterHeader>
    <Concept reverse>
      <span class="concept-no"
            >{String((n += 1)).padStart(2, "0")} — Reciprocity</span
          >
          <h2>The field changes the element back.</h2>
          <p>
            The element bends the field — and the field’s <strong
              >local density</strong
            > bends the element in return. As particles gather on a word, it gains
            weight, brightness, and lift.
          </p>
          <div class="formula">
            --field-density = density(body) <span class="c">→</span>
            <span class="v">weight</span>, glow, rise
          </div>
          <p class="note">
            Hover the word — it pulls the field, the field piles up, and the
            pile makes the word heavier. A closed loop. (<code>--d</code> is the canonical raw
            density channel; <code>--field-density</code> is its field-namespaced form.)
          </p>
      <Fragment slot="stage">
        <span class="stage-label">density → weight</span>
          <span
            class="live-demo"
            data-hot
            data-color="#a78bfa"
            data-feedback
            data-body="attract"
            data-strength="1"
            data-range="300"
            style="--cat:#a78bfa;">density</span
          >
          <span class="hintline"
            >gathered particles raise the element’s weight</span
          >
      </Fragment>
    </Concept>
    <Concept reverse data-attention-demo id="concept-conserved">
      <span class="concept-no"
            >{String((n += 1)).padStart(2, "0")} — Conserved attention</span
          >
          <h2>The page can’t emphasize two things at once.</h2>
          <p>
            There is one finite budget of force for the whole page. Engage a
            word and it pulls force off every other — so as one gathers matter
            and grows heavier, the rest give theirs up. Focus isn’t styled; it’s <strong
              >conserved</strong
            >.
          </p>
          <div class="formula">
            Σ Sᵢ · effortᵢ = <span class="v">constant</span>
          </div>
          <p class="note">
            Hover one word — watch the others surrender their weight to it.
          </p>
      <Fragment slot="stage">
        <span class="stage-label">one budget, redistributed</span>
          <div class="attn-set">
            <span
              class="attn-word"
              data-hot
              data-feedback
              data-body="attract"
              data-strength="1.5"
              data-range="240"
              data-color="#4da3ff"
              style="--cat:#4da3ff;">focus</span
            >
            <span
              class="attn-word"
              data-hot
              data-feedback
              data-body="attract"
              data-strength="1.5"
              data-range="240"
              data-color="#2dd4bf"
              style="--cat:#2dd4bf;">depth</span
            >
            <span
              class="attn-word"
              data-hot
              data-feedback
              data-body="attract"
              data-strength="1.5"
              data-range="240"
              data-color="#ff9d5c"
              style="--cat:#ff9d5c;">weight</span
            >
          </div>
          <span class="hintline"
            >one finite budget — engaging one starves the rest</span
          >
      </Fragment>
    </Concept>
    <Concept id="concept-threads">
      <span class="concept-no"
            >{String((n += 1)).padStart(2, "0")} — Threads</span
          >
          <h2>Engaging one body wires the set.</h2>
          <p>
            Engage an element in a group and the field draws living threads
            between it and its siblings. A list stops being a list and shows
            itself as a <strong>connected system</strong>.
          </p>
          <p class="note">Hover any line.</p>
      <Fragment slot="stage">
        <span class="stage-label">a connected set</span>
          <div class="thread-set" data-index data-threads>
            <span
              class="ti"
              data-hot
              data-color="#4da3ff"
              data-body="attract"
              data-strength="0.5"
              data-range="220"
              style="--cat:#4da3ff;">Product</span
            >
            <span
              class="ti"
              data-hot
              data-color="#2dd4bf"
              data-body="attract"
              data-strength="0.5"
              data-range="220"
              style="--cat:#2dd4bf;">System</span
            >
            <span
              class="ti"
              data-hot
              data-color="#a78bfa"
              data-body="attract"
              data-strength="0.5"
              data-range="220"
              style="--cat:#a78bfa;">Interface</span
            >
            <span
              class="ti"
              data-hot
              data-color="#ff9d5c"
              data-body="attract"
              data-strength="0.5"
              data-range="220"
              style="--cat:#ff9d5c;">Material</span
            >
          </div>
          <span class="hintline"
            >threads connect the engaged body to its set</span
          >
      </Fragment>
    </Concept>
    <Concept reverse data-causality-demo>
      <span class="concept-no"
            >{String((n += 1)).padStart(2, "0")} — Cross-boundary causality</span
          >
          <h2>Density doesn’t stop at the edge.</h2>
          <p>
            When a body saturates, the excess <strong
              >spills to its neighbours</strong
            > — weighted by nearness, and conserved. Engage one tile and the ones
            beside it light up on their own. The wiring between elements appears because
            matter actually flows between them.
          </p>
          <div class="formula">
            Φᵢⱼ = κ · excessᵢ · <span class="v">wᵢⱼ</span> ⁄ Σ wᵢₖ
          </div>
          <p class="note">
            Hover the middle tile — watch its neighbours catch, the far ones
            faintly.
          </p>
      <Fragment slot="stage">
        <span class="stage-label">spill → neighbours light</span>
          <div class="causal-set">
            <span
              class="causal-node"
              data-hot
              data-feedback
              data-body="attract"
              data-strength="1.4"
              data-range="200"
              data-color="#a78bfa"
              style="--cat:#a78bfa;"></span>
            <span
              class="causal-node"
              data-hot
              data-feedback
              data-body="attract"
              data-strength="1.4"
              data-range="200"
              data-color="#7dd3fc"
              style="--cat:#7dd3fc;"></span>
            <span
              class="causal-node"
              data-hot
              data-feedback
              data-body="attract"
              data-strength="1.4"
              data-range="200"
              data-color="#4da3ff"
              style="--cat:#4da3ff;"></span>
            <span
