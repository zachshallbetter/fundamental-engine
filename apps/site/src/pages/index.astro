---
import Base from "../layouts/Base.astro";
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
import ManualHero from "../components/ManualHero.astro";
import Button from "../components/ui/Button.astro";
import ForceCarousel from "../components/home/ForceCarousel.astro";
import InvisibleFieldsStrip from "../components/home/InvisibleFieldsStrip.astro";
import TryItField from "../components/home/TryItField.astro";
import { MANUAL_FORCES } from "@fundamental-engine/core";
import { currentVersion } from "../lib/changelog";
import "../styles/manual.css";
import "../styles/force-glyphs.css";
import "../styles/landing.css";

// The homepage — proves the substrate, then routes to the right proof. The full force-by-force
// executable manual lives on /engine-tour (moved off-home in the restructure); this page keeps the
// hero, install, hosts, the real-interface proof, the why-different doctrine, the AI wedge, and a
// compressed engine-tour card. Interaction runtime is still wired by manual-page.ts (bottom).

// The inbox proof is a REAL reading (#973). Each ask is a declared body on the page field
// (<field-root> in Base.astro — the "one fixed attention budget" the copy names): urgency maps to
// mass (data-strength = urgency, data-range widens with it), and the engine writes the gathered
// local density back as --d on the data-feedback rows. The CSS composes the two honest lanes the
// invisible-fields canon names (§2): --u0, the authored urgency (the data lane — the same number
// that feeds data-strength; the --w of /evidence/inbox), and --d, the field's live reading — so
// the weight you see brightens as attention gathers and dims as it drains (hover one ask via
// data-hot and the others yield). With the field off, --d never registers and the rows hold the
// pure authored look. No contained field and no script: --d is the page engine's lane, and a
// second field would fight it for the same var.
const ASKS = [
  { title: 'Production outage — auth tokens expiring early', meta: '2h · 48▲', urgency: 1 },
  { title: 'Why does my migration deadlock under load?', meta: '9h · 21▲', urgency: 0.72 },
  { title: 'Best way to debounce a resize observer?', meta: '1d · 7▲', urgency: 0.46 },
  { title: 'Preferred naming for boolean props?', meta: '4d · 2▲', urgency: 0.24 },
];

// Product structured data — Fundamental is a dev library, so SoftwareApplication is the right
// schema (richer than the site-wide WebSite graph). softwareVersion tracks the changelog so it
// never goes stale.
const softwareLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Fundamental',
  alternateName: 'Fundamental Engine',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Web, iOS, macOS, Android',
  programmingLanguage: ['TypeScript', 'Swift', 'Kotlin'],
  description:
    'A relational field runtime: elements, records, and views become bodies in a shared field that measures importance, attention, and relationships, and writes them back as CSS variables and agent-readable queries.',
  url: 'https://fundamental-engine.com',
  softwareVersion: currentVersion(),
  author: {
    '@type': 'Person',
    name: 'Zach Shallbetter',
    url: 'https://zachshallbetter.com',
    sameAs: [
      'https://zachshallbetter.com',
      'https://x.com/zachshallbetter',
      'https://github.com/zachshallbetter',
    ],
  },
  sameAs: [
    'https://github.com/zachshallbetter/fundamental-engine',
    'https://x.com/usefundamental',
    'https://www.npmjs.com/org/fundamental-engine',
  ],
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  license: 'https://opensource.org/licenses/MIT',
};
// The source-code entity carries the repository + language facts search engines use to
// disambiguate "Fundamental Engine" (the software) from engines of the combustion kind.
const sourceLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareSourceCode',
  name: 'Fundamental',
  alternateName: 'Fundamental Engine',
  codeRepository: 'https://github.com/zachshallbetter/fundamental-engine',
  programmingLanguage: ['TypeScript', 'Swift', 'Kotlin'],
  runtimePlatform: ['Web (DOM)', 'Three.js / WebGL', 'iOS / macOS / visionOS', 'Android / JVM', 'Headless'],
  license: 'https://opensource.org/licenses/MIT',
  author: { '@type': 'Person', name: 'Zach Shallbetter', url: 'https://zachshallbetter.com' },
};
---

<Base
  title="Fundamental — a readable behavior layer for host objects"
  description="A readable behavior layer for host objects: elements and data become bodies in a live field, and importance, attention, and relationships come back as readable state."
  jsonLd={[softwareLd, sourceLd]}
>
  <SiteNav current="home" />
  <main id="main" class="manual-shell">
    <ManualHero kicker="Fundamental · a readable behavior layer for host objects">
      <h1 slot="title">Elements have <span
          class="hero-mass"
          data-hot
          data-feedback
          data-body="gravity swirl pigment"
          data-shaped
          data-strength="1.6"
          data-range="340"
          data-spin="1"
          data-color="#4da3ff"
          style="--cat:#4da3ff;">mass</span><span
          class="hero-antimass"
          data-body="repel pigment"
          data-strength="0.7"
          data-range="150"
          data-color="#ff9d5c"
          style="--cat:#ff9d5c;">.</span></h1>
      <p slot="standfirst" class="standfirst"
        data-body="attract swirl pigment" data-shaped data-strength="0.5" data-range="260" data-spin="1.1" data-color="#ffce6b" style="--cat:#ffce6b">
        Fundamental is a readable behavior layer for host objects. It turns elements, records,
        views, and relationships into bodies in a shared field — where importance pulls, signal
        routes, relation binds, and change decays. The DOM is the first host, not the boundary:
        the same renderer-agnostic core runs on the web, in WebGL, natively on Apple and Android,
        and headlessly. You author semantic structure; the field returns measurement — live
        <code>--field-*</code> variables you style with.
      </p>
      <p slot="thesis" class="thesis"
        data-body="attract swirl pigment" data-strength="0.45" data-range="280" data-spin="1.1" data-color="#f0628e" style="--cat:#f0628e">
        <strong>You can label everything urgent. You cannot make everything heavy.</strong>
        Priority becomes a force, not a flag — emphasize one thing, and the rest yield.
      </p>
      <Fragment slot="cta">
        {/* Resting mass: ungate the default attention-gated vessel (data-when="") and lead with a
            continuous attract so the CTAs pull the field at rest — they read as live, moving call-to-
            actions, not inert until hovered. Engagement still amplifies on hover. */}
        <Button href="#proof" variant="primary" data-color="#4da3ff" data-body="attract swirl pigment" data-when="" data-strength="0.95" data-range="230" data-spin="1.1">See it work →</Button>
        <Button href="#install" data-color="#a78bfa" data-body="attract swirl pigment" data-when="" data-strength="0.8" data-range="210" data-spin="1.1">Install →</Button>
      </Fragment>
      <div slot="meta" class="meta">
        <span><b>Category</b> &nbsp;add a data-* attribute, get --field-* back</span>
        <span><b>For</b> &nbsp;design engineers · AI-product builders · component-library authors</span>
        <span><b>Maturity</b> &nbsp;0.x preview — a substrate to build on, no external users yet</span>
      </div>
      <Fragment slot="flow">
        {/* The substrate, made visible — a live reading of THIS page's field (density/bodies/particles
            from field.query()) plus the read/reveal/govern facts. No particle swarm required. */}
        <div class="field-readout" aria-label="Live reading of this page's field">
          <span class="fr"><b>density</b> <i data-fr="density">·</i></span>
          <span class="fr"><b>bodies</b> <i data-fr="bodies">·</i></span>
          <span class="fr"><b>particles</b> <i data-fr="particles">·</i></span>
          <span class="fr fr-static"><b>query</b> <i>readable</i></span>
          <span class="fr fr-static"><b>projection</b> <i>css · json</i></span>
          <span class="fr fr-static"><b>policy</b> <i>limited</i></span>
        </div>
      </Fragment>
    </ManualHero>

    <section class="lp lp-apply" id="proof">
      <div class="wrap">
        <span class="concept-no">A real interface</span>
        <h2>A real interface you’d actually build.</h2>
        <p class="lp-lede">
          An inbox of real unanswered questions, ranked by urgency — recency, votes, and
          views become mass. But the page holds one fixed attention budget, so brightening
          one ask dims the rest. No particle swarm; the measurement comes back as type and
          ink.
        </p>
        <div class="lp-inbox" aria-hidden="true">
          <div class="lp-inbox-head"><span>Inbox · attention is conserved</span><span>urgency → mass</span></div>
          {ASKS.map((a) => (
            <div
              class="lp-ask"
              data-body="attract"
              data-feedback
              data-hot
              data-strength={a.urgency.toFixed(2)}
              data-range={String(Math.round(120 + a.urgency * 80))}
              style={`--u0:${a.urgency};`}
            ><span class="lp-bar"></span><span class="lp-title">{a.title}</span><span class="lp-meta">{a.meta}</span></div>
          ))}
        </div>
        <Button href="/evidence/inbox" variant="primary">Open this example →</Button>
      </div>
    </section>

    {/* Hands-on: touch the engine — rewrite a body's data-* and watch the field answer live. */}
    <TryItField />

    <section class="lp lp-ai">
      <div class="wrap lp-ai-grid">
        <div class="lp-col">
          <span class="concept-no">The wedge</span>
          <h2>Make model output you can read at a glance.</h2>
          <p class="lp-lede">
            A model hands you answers; it rarely shows how sure it is. Make each claim a body in the
            field, and confidence becomes weight, agreement becomes proximity, and contradictions pull
            apart — so a shaky answer <em>looks</em> shaky and its sources are one hop away, before anyone
            acts on it. The interface projects that state as type and layout; an agent reads the same field as JSON through <code>field.query()</code>. The same deterministic math drives the Evidence and Search studies.
          </p>
          <div class="lp-cta-row">
            <Button href="/ai-evidence" variant="primary">See AI Evidence →</Button>
            <Button href="/docs/studies/evidence-field">How it works →</Button>
          </div>
        </div>

        {/* Live claims field — each chip is a REAL body the page field measures. Confidence sets
            weight (data-strength + the --conf style), and --d (live field density, written back by
            the engine onto data-feedback) drives the glow: a well-supported claim accretes field and
            reads heavy; the contradiction uses `repel`, opening a visible gap. Honors the Wallpaper
            Rule — no fake decoration; the chips are bodies and the emphasis is measured. */}
        <div class="wedge-field" aria-hidden="true">
          <div class="wf-plane">
            <span class="claim claim-hi" data-body="attract swirl" data-feedback data-strength="1.3" data-range="150" data-spin="1.1"
              style="--x:16%; --y:20%; --conf:0.94"><b>Confirmed</b><i>0.94</i></span>
            <span class="claim claim-hi" data-body="attract swirl" data-feedback data-strength="1.1" data-range="140" data-spin="1.1"
              style="--x:36%; --y:42%; --conf:0.87"><b>Corroborated</b><i>0.87</i></span>
            <span class="claim claim-mid" data-body="attract swirl" data-feedback data-strength="0.6" data-range="120" data-spin="1.1"
              style="--x:58%; --y:26%; --conf:0.41"><b>One source</b><i>0.41</i></span>
            <span class="claim claim-lo" data-body="repel" data-feedback data-strength="0.95" data-range="165"
              style="--x:74%; --y:70%; --conf:0.18"><b>Contradicted</b><i>0.18</i></span>
          </div>
          <p class="wf-legend"><span class="wf-k">weight</span> = confidence · <span class="wf-k">proximity</span> = agreement · <span class="wf-k">repel</span> = contradiction</p>
        </div>
      </div>
    </section>

    <!-- §How it works — the five verbs (Declare -> Influence -> Read -> Reveal -> Govern). -->
    <section class="lp lp-how" id="how">
      <div class="wrap">
        <span class="concept-no">How it works</span>
        <h2>Declare, influence, read, reveal, govern.</h2>
        <p class="lp-lede">
          Five verbs are the whole loop. You declare host objects into the field; forces influence them
          through declared channels; you read the state back; projections reveal it; policy governs what
          may run and what an agent may read.
        </p>
        {/* The five verbs are five bodies, each carrying the force that embodies it — so the row
            demonstrates the loop it describes: declare pulls matter in (attract), influence pushes a
            current (stream), read gathers weight (gravity), reveal spins it out (swirl), govern damps
            it (viscosity). attract/gravity carry swirl+spin so they don't freeze matter into a clump;
            the ambient field keeps them all circulating. */}
        <ol class="lp-verbs">
          <li data-body="attract swirl" data-feedback data-strength="0.7" data-range="150" data-spin="1.1" data-color="#4da3ff" style="--cat:#4da3ff"><b>Declare</b><span>Host objects become bodies — a <code>data-body</code> attribute, <code>addBody()</code>, or a declared edge.</span></li>
          <li data-body="stream" data-feedback data-strength="0.8" data-range="160" data-color="#a78bfa" style="--cat:#a78bfa"><b>Influence</b><span>Forces act through declared channels, accumulated centrally — deterministic and replayable.</span></li>
          <li data-body="gravity swirl" data-feedback data-strength="0.8" data-range="150" data-spin="1" data-color="#2dd4bf" style="--cat:#2dd4bf"><b>Read</b><span><code>query()</code> and <code>snapshot()</code> expose the field as plain, serializable state.</span></li>
          <li data-body="swirl" data-feedback data-strength="0.75" data-range="150" data-spin="1.2" data-color="#ffce6b" style="--cat:#ffce6b"><b>Reveal</b><span>Projections express that state through CSS variables, DOM attributes, JSON, native views, or overlays.</span></li>
          <li data-body="viscosity" data-feedback data-strength="0.9" data-range="160" data-color="#f0628e" style="--cat:#f0628e"><b>Govern</b><span>Policies, budgets, redactions, lane lints, and reduced-motion rules constrain what runs and what an agent reads.</span></li>
        </ol>
        <p class="lp-note">
          Want the exact API? <a href="/docs/api">Read the docs</a>. Want the live engine?
          <a href="/engine-tour">Open the manual</a>. Want the substrate proof?
          <a href="/demo">One field, two readings →</a>
        </p>
      </div>
    </section>

    <section class="lp lp-diff">
      <div class="wrap">
        <span class="concept-no">Why it’s different</span>
        <h2>Most interfaces <em>store</em> meaning, then <em>fake</em> its effects.</h2>
        <p class="lp-lede">
          You can’t style everything as urgent — the attention budget is conserved.
          Express “these are related,” “the user has dwelled here,” or “this is unstable”
          as first-class runtime state, instead of hand-rolling badges, spinners, and
          bespoke animation for each. <a href="/engine-tour#concept-conserved">See conserved attention →</a>
        </p>

        {/* The pipeline is a literal current: each step is a `stream` body heading right (data-angle=0),
            so matter runs data-* → measure → --field-* → style, left to right, the way the sentence reads. */}
        <figure class="lp-model">
          <div class="lp-flow">
            <span class="lp-step" data-body="stream" data-angle="0" data-feedback data-strength="0.7" data-range="120" data-color="#4da3ff" style="--cat:#4da3ff"><code>data-*</code><span>you author</span></span>
            <span class="lp-arrow">→</span>
            <span class="lp-step" data-body="stream" data-angle="0" data-feedback data-strength="0.7" data-range="120" data-color="#a78bfa" style="--cat:#a78bfa"><code>measure</code><span>runtime</span></span>
            <span class="lp-arrow">→</span>
            <span class="lp-step" data-body="stream" data-angle="0" data-feedback data-strength="0.7" data-range="120" data-color="#2dd4bf" style="--cat:#2dd4bf"><code>--field-*</code><span>runtime writes back</span></span>
            <span class="lp-arrow">→</span>
            <span class="lp-step" data-body="stream" data-angle="0" data-feedback data-strength="0.7" data-range="120" data-color="#ffce6b" style="--cat:#ffce6b"><code>you style</code><span>CSS</span></span>
          </div>
          <figcaption>You author meaning; the field returns measurement.</figcaption>
        </figure>

        <div class="lp-elim">
          <h3>Stop building the systems that exist because the DOM is blind.</h3>
          <p>
            The DOM can’t see what matters, what’s related, or what’s gone stale — so
            teams build that sight by hand, again and again. Fundamental gives the DOM a
            continuous answer, and a whole category of code stops being yours to write
            and maintain.
          </p>
          <ul>
            <li><b>Priority you don’t store or sort.</b> Importance is a live field reading (<code>--d</code>, with <code>--field-density</code> as the field-namespaced alias), not state you keep in a store and re-sort on every change. <a href="/engine-tour#concept-material">See it work →</a></li>
            <li><b>“Everything is P1,” solved by a law.</b> Attention is one conserved budget — emphasize one thing and the rest necessarily yield. The normalization pass teams enforce with scoring schemes and meetings becomes something the runtime cannot violate. <a href="/engine-tour#concept-conserved">See it work →</a></li>
            <li><b>Relationships you can read.</b> Declared associations become field-visible structure — a Field Formation decides when association becomes coupling, not adjacency lists and graph traversal you maintain by hand. <a href="/engine-tour#concept-threads">See it work →</a></li>
            <li><b>Staleness without timers.</b> Recency and decay are a force in the runtime, continuous, not a cron job or a computed column you babysit. <a href="/evidence/memory">See it work →</a></li>
            <li><b>One model, always current.</b> The field re-resolves every frame, so a priority shift doesn’t fire a sort-and-re-render pass — the readout is simply already current. <a href="/engine-tour#concept-layout">See it work →</a></li>
          </ul>
          <p class="lp-elim-close">
            Fundamental doesn’t hand you a better abstraction over these jobs. It makes the
            question each one answered — what matters, what’s related, what’s stale —
            answerable by the field, so the job itself goes away.
          </p>
        </div>

      </div>
    </section>

    <section class="lp lp-install" id="install">
      <div class="wrap">
        <span class="concept-no">Install</span>
        <h2>Add it to the stack you already have.</h2>
        <p class="lp-lede">
          One package per framework — pick the one for your stack and you’re done. Each bundles the
          engine (<code>core</code> + the DOM binding) for you; there’s nothing to wire together.
        </p>
        <div class="lp-pkgs">
          <!-- the 'start here' card spans the row and is a live accretion vessel: `sink attract` gathers
               the field's matter, `--load` fills it from the base, and it supernovas + resets on saturation. -->
          <div class="lp-pkg lp-pkg--hero" data-body="sink attract pigment" data-feedback data-absorb="44" data-max="90" data-strength="0.7" data-range="300" data-color="#ff8a5c" style="--cat:#ff8a5c">
            <span class="lp-pkg-tag">Start here</span>
            <code class="install" data-copy="npm i @fundamental-engine/vanilla">npm i @fundamental-engine/vanilla</code>
            <span class="lp-pkg-desc"><b>Plain TS / JS</b>, no framework — the typed <code>FieldField</code> class; one call mounts a field. This card is itself a live field body: it accretes the swarm and fills as it gathers. <a href="/docs/guides/typescript">Guide →</a></span>
          </div>
          <div class="lp-pkg" data-body="wall pigment" data-feedback data-color="#f0628e" data-strength="0.55" data-range="170" style="--cat:#f0628e">
            <code class="install" data-copy="npm i @fundamental-engine/react">npm i @fundamental-engine/react</code>
            <span class="lp-pkg-desc"><b>React</b> — the <code>&lt;FieldField&gt;</code> component + <code>useFieldField</code> hook. <a href="/docs/guides/react">Guide →</a></span>
          </div>
          <div class="lp-pkg" data-body="wall pigment" data-feedback data-color="#c084fc" data-strength="0.55" data-range="170" style="--cat:#c084fc">
            <code class="install" data-copy="npm i @fundamental-engine/elements">npm i @fundamental-engine/elements</code>
            <span class="lp-pkg-desc"><b>Any framework or plain HTML</b> — the <code>&lt;field-root&gt;</code> web component. <a href="/docs/guides/web-component">Guide →</a></span>
          </div>
          <div class="lp-pkg" data-body="wall pigment" data-feedback data-color="#ffce6b" data-strength="0.55" data-range="170" style="--cat:#ffce6b">
            <code class="install" data-copy="npm i @fundamental-engine/three">npm i @fundamental-engine/three</code>
            <span class="lp-pkg-desc"><b>Three.js / WebGL</b> — the swarm as a <code>THREE.Points</code> layer. <a href="/docs/guides/three">Guide →</a></span>
          </div>
        </div>
        <p class="lp-note">
          Own the canvas / building your own renderer? <code>@fundamental-engine/core</code> is the
          renderer-agnostic engine — you supply a host (<a href="/docs/guides/core">Core guide</a>). You
          don’t install <code>@fundamental-engine/dom</code> directly — the packages above already
          bundle it for you.
        </p>
        <p class="lp-note">
          No build step? Import from a CDN (playground / prototyping only):
          <code>import {'{'} createField {'}'} from 'https://esm.sh/@fundamental-engine/vanilla'</code>
        </p>
        <p class="lp-note">
          The full package map and an install-to-reacting-headline walkthrough live in the
          <a href="/docs">docs</a>.
        </p>
      </div>
    </section>

    <section class="lp lp-hosts" id="hosts">
      <div class="wrap">
        <span class="concept-no">Hosts</span>
        <h2>One engine, many hosts.</h2>
        <p class="lp-lede">
          The core computes the field against plain data and imports zero DOM. A thin host binds it to
          a host — so the same physics runs on the web, natively, in your renderer, or headless:
        </p>
        {/* One engine, many hosts — so the four bind as one: each host is a `cohesion` body, and the
            field's matter coheres across them (binding, not a single well). */}
        <ul class="model">
          <li data-body="cohesion" data-feedback data-strength="0.5" data-range="150" data-color="#4da3ff" style="--cat:#4da3ff">
            <b>Web</b> — <code>@fundamental-engine/dom</code> binds the engine to the page: every
            <code>[data-body]</code> element a body, feedback returned as <code>--field-*</code>
            variables. The primary surface — and what this page runs on.
          </li>
          <li data-body="cohesion" data-feedback data-strength="0.5" data-range="150" data-color="#86e57f" style="--cat:#86e57f">
            <b>Native</b> — a Swift port runs the same field on Apple platforms (Metal / SwiftUI), and a
            Kotlin port runs it on Android (Jetpack Compose, plus a non-Compose <code>View</code>/<code>Canvas</code>
            host) — both free of the browser’s compositing ceiling. The <a href="/docs/implementations">Field Lab</a>
            is the showcase: a native app to explore every force live.
          </li>
          <li data-body="cohesion" data-feedback data-strength="0.5" data-range="150" data-color="#ffce6b" style="--cat:#ffce6b">
            <b>Your renderer</b> — <code>@fundamental-engine/three</code> drives a
            <code>THREE.Points</code> swarm in your own WebGL scene; the read primitives
            (<code>sample</code>, <code>readParticles</code>, <code>addField</code>) bind the engine to
            anything that draws.
          </li>
          <li data-body="cohesion" data-feedback data-strength="0.5" data-range="150" data-color="#c084fc" style="--cat:#c084fc">
            <b>Headless</b> — no DOM, no canvas: records become bodies and relationships become edges,
            and a tool reads the field through <code>query()</code> and <code>snapshot()</code>. The
            smallest conformant host — for servers, tests, and agents.
          </li>
        </ul>
        <p class="lp-note">
          How the hosts relate — and what’s at parity across them — in
          <a href="/docs/implementations">Implementations</a>.
        </p>
      </div>
    </section>

    <!-- §Trust — built to be inspected (promoted out of the why-different calibration band). -->
    <section class="lp lp-trust" id="trust">
      <div class="wrap">
        <span class="concept-no">Trust</span>
        <h2>Built to be inspected.</h2>
        <ul class="lp-calib">
          <li><b>Zero runtime dependencies.</b> The core engine ships with none.</li>
          <li><b>Signals-first by default.</b> A field renders nothing unless you ask for it — the invisible field is the baseline.</li>
          <li><b>Accessible by construction.</b> Semantic HTML stays the source of meaning; reduced motion removes motion, not meaning — enforced and linted.</li>
          <li><b>Measured, not guessed.</b> Sub-millisecond <em>compute</em> per frame at real-page scale; fill-rate is the real budget and is <a href="/docs/performance">measured on real hardware</a>.</li>
          <li><b>Stable 0.x surface, cross-plane conformance.</b> Code-verified docs, a frozen public API, and shared-physics conformance across web, Apple, and Android.</li>
