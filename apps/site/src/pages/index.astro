<script>
  // The hero "field reading" strip — reads THIS page's field live via field.query() and streams
  // density/bodies/particles into the chips. Updated ~4×/sec (calm, not flickering). Static chips
  // (query/projection/policy) state the substrate facts. Rebinds on SPA nav; torn down on swap.
  type FieldEl = Element & { query?: (q?: unknown) => { metrics: Record<string, number> } };
  function initFieldReadout() {
    const el = document.querySelector(".field-readout") as HTMLElement | null;
    const field = document.querySelector("field-root") as FieldEl | null;
    if (!el || !field || el.dataset.bound) return;
    if (typeof field.query !== "function") { window.setTimeout(initFieldReadout, 150); return; }
    el.dataset.bound = "1";
    const set = (k: string, v: string) => {
      const t = el.querySelector(`[data-fr="${k}"]`);
      if (t) t.textContent = v;
    };
    let raf = 0, n = 0;
    const tick = () => {
      if (n++ % 15 === 0) {
        const m = field.query!({ include: ["metrics"] } as unknown).metrics ?? {};
        set("density", (m.meanDensity ?? 0).toFixed(2));
        set("bodies", String(m.bodies ?? 0));
        set("particles", String(m.particles ?? 0));
      }
      raf = window.requestAnimationFrame(tick);
    };
    tick();
    document.addEventListener("astro:before-swap", () => window.cancelAnimationFrame(raf), { once: true });
  }
  initFieldReadout();
  document.addEventListener("astro:page-load", initFieldReadout);
</script>

<script>
  // Trust · "built to be inspected" — render a live field.query() of THIS page's field into the
  // lp-inspect panel: the same serializable payload an agent reads (frame, counts, density, and the
  // live force histogram from each body's tokens). Calm 1.2s cadence; rebinds on SPA nav.
  type FQEl = Element & {
    query?: (q?: unknown) => {
      frame?: number;
      metrics?: Record<string, number>;
      bodies?: { tokens?: string[] }[];
    };
  };
  function initInspect() {
    const pre = document.querySelector("[data-inspect-json]") as HTMLElement | null;
    const field = document.querySelector("field-root") as FQEl | null;
    if (!pre || !field || pre.dataset.bound) return;
    if (typeof field.query !== "function") { window.setTimeout(initInspect, 150); return; }
    pre.dataset.bound = "1";
    const r = (v: number | undefined) => (v == null ? 0 : Math.round(v * 100) / 100);
    const paint = () => {
      try {
        const q = field.query!({ include: ["bodies", "metrics"] });
        const m = q.metrics ?? {};
        const forces: Record<string, number> = {};
        for (const b of q.bodies ?? []) for (const t of b.tokens ?? []) forces[t] = (forces[t] ?? 0) + 1;
        pre.textContent = JSON.stringify(
          {
            frame: q.frame ?? 0,
            bodies: m.bodies ?? (q.bodies ?? []).length,
            particles: m.particles ?? 0,
            density: r(m.meanDensity),
            forces,
          },
          null,
          2,
        );
      } catch {
        /* keep the last good reading */
      }
    };
    paint();
    const timer = window.setInterval(paint, 1200);
    document.addEventListener("astro:before-swap", () => window.clearInterval(timer), { once: true });
  }
  initInspect();
  document.addEventListener("astro:page-load", initInspect);
</script>


