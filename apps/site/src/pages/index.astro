---
import Base from "../layouts/Base.astro";
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
import ManualHero from "../components/ManualHero.astro";
import ChapterRail from "../components/ChapterRail.astro";
import ChapterHeader from "../components/ChapterHeader.astro";
import Concept from "../components/Concept.astro";
import ManualFoot from "../components/ManualFoot.astro";
import Button from "../components/ui/Button.astro";
import FlowToggle from "../components/ui/FlowToggle.astro";
import NaturalFieldsSection from "../components/home/NaturalFieldsSection.astro";
import ManualForceRow from "../components/home/ManualForceRow.astro";
import PresetRow from "../components/home/PresetRow.astro";
import { MANUAL_FORCES, MANUAL_PRESETS } from "field-ui";
import "../styles/manual.css";
import "../styles/force-glyphs.css";

// The Field Manual — the chapter-based explainer, rebuilt on the typed engine and extended
// to the full catalog. This page is a composition file: the shared manual chrome (ManualHero,
// ChapterRail, ChapterHeader, Concept, ManualFoot) lives in src/components/ and is reused by
// /eli5; the catalog rows + the natural-field picker live in components/home/; page behaviour
// (interaction runtime + field-line overlay + picker) is wired by the shared orchestrator
// src/components/manual-page.ts (imported by the <script> at the bottom). Each numbered concept
// is unique prose, declared via <Concept> with its stage in the `stage` slot.
//
// The demo attributes (DEFAULTS / OVERRIDES / BODY_TOKENS / attrsFor) live in lib/demo-forces.ts —
// the single source the field-line traces and the accuracy test (field-probe.test.ts) read too,
// so the on-screen body and its traced path can't drift.

const PRESET_COLORS: Record<string, string> = {
  blackhole: "#fbbf24",
  whitehole: "#e0f2fe",
  star: "#6366f1",
  quasar: "#fbbf24",
  galaxy: "#a78bfa",
  nebula: "#38bdf8",
  tornado: "#2dd4bf",
  fountain: "#7dd3fc",
};
const natural = MANUAL_FORCES.filter((f) => f.family === "natural");
const extended = MANUAL_FORCES.filter((f) => f.family === "extended");
let n = 3; // running concept number; Substrate is 01–03 (hardcoded below), then every
// chapter after it increments this in render order (Natural, Forces, Extended, Presets, …).

const chapters = [
  { id: "ch-substrate", no: "I", label: "Substrate" },
  { id: "ch-natural", no: "II", label: "Natural" },
  { id: "ch-forces", no: "III", label: "Forces" },
  { id: "ch-extended", no: "IV", label: "Extended" },
  { id: "ch-presets", no: "V", label: "Presets" },
  { id: "ch-conditions", no: "VI", label: "Conditions" },
  { id: "ch-system", no: "VII", label: "System" },
];
---

<Base
  title="field-ui — a platform-native relational field runtime for the DOM"
  description="Semantic HTML becomes a participant in one shared field: add a data-* attribute and the runtime measures the element, computes metrics (density, priority, memory) and writes them back as --field-* CSS variables you style with. A renderer-agnostic core with a platform layer for DOM participation (measurement, state, feedback, relationships, overlays); framework-agnostic (vanilla · web component · React), dependency-light. The complete, executable manual, live over the running engine."
>
  <SiteNav current="home" />
  <div class="manual-shell">
    <ManualHero kicker="field-ui · semantic HTML in one shared field">
      <h1 slot="title">Semantic HTML can <span class="accent">participate.</span></h1>
      <p slot="standfirst" class="standfirst">
        Words, links, and cards stay ordinary semantic HTML — but with a single
        <code>data-*</code> attribute they register as participants in one shared
        field. The runtime measures each one — its gathered density, and metrics like
        attention, priority, and memory — then writes them back as <code>--field-*</code>
        CSS variables you style with. Here’s exactly how it works, live over the real
        engine behind every example.
      </p>
      <p slot="thesis" class="thesis">
        <strong>You author meaning; the field returns measurement</strong> —
        <code>data-*</code> in, <code>--field-*</code> out. The physics is how it feels;
        the contract is how you use it.
      </p>
      <Fragment slot="cta">
        <code class="install" data-copy="npm i field-ui">npm i field-ui</code>
        <Button href="/docs" variant="primary">Read the docs →</Button>
        <Button href="/lab">Open the Lab →</Button>
      </Fragment>
      <div slot="meta" class="meta">
        <span><b>Contract</b> &nbsp;data-* in · --field-* out</span>
        <span><b>Forces</b> &nbsp;{MANUAL_FORCES.length}, composable · gated by conditions</span>
        <span><b>Platform</b> &nbsp;measurement · state · feedback · relationships · overlays</span>
        <span><b>Law</b> &nbsp;nothing created from nothing</span>
      </div>
      <FlowToggle slot="flow" label="Flow follows pointer">
        drives <code>field.flowTo(x, y)</code> — the whole field bends to your cursor</FlowToggle>
    </ManualHero>

    <ChapterRail chapters={chapters} />

    <!-- I · Substrate -->
    <ChapterHeader no="I" id="ch-substrate" title="Substrate">What the field is made of — and how it locks to the page.</ChapterHeader>

    <Concept stageHidden>
      <span class="concept-no">01 — Synchronization</span>
          <h2>The platform maps semantic elements into field coordinates.</h2>
          <p>
            The runtime measures registered bodies through the
            <strong>host / platform boundary</strong> and maps each element’s box
            into the field — so the field and the page describe the same space.
          </p>
          <p class="note">
            Because it re-measures as the page changes, the field stays locked to
            the visible boxes through scroll, resize, and reflow.
          </p>
          <div class="formula">
            <span class="c">measure:</span> rect(el) <span class="c">→</span>
            <span class="v">field(x, y)</span>
          </div>
      <Fragment slot="stage">
        <span class="stage-label">DOM → field</span>
          <svg class="diagram" viewBox="0 0 420 300" fill="none">
            <rect x="60" y="70" width="180" height="90" rx="10" class="dim"
            ></rect>
            <text x="70" y="60" class="lbl">measure(el)</text>
            <circle cx="150" cy="115" r="3" class="accf"></circle>
            <line
              x1="150"
              y1="115"
              x2="340"
              y2="210"
              class="acc"
              stroke-dasharray="3 4"></line>
            <circle cx="340" cy="210" r="4" class="accf"></circle>
            <text x="300" y="240" class="lbl">field (x, y)</text>
          </svg>
      </Fragment>
    </Concept>

    <Concept reverse stageHidden>
      <span class="concept-no">02 — Mass &amp; damping</span>
          <h2>Particles are point-masses in a medium.</h2>
          <p>
            Each particle carries a velocity and a mass proportional to its
            size. Every frame its velocity is multiplied by a friction factor —
            momentum bleeds off instead of accumulating.
          </p>
          <div class="formula">
            <span class="v">v</span><span class="c">ₜ₊₁</span> = <span class="v"
              >v</span
            ><span class="c">ₜ</span> · <span class="v">f</span>
            <span class="c">(f ≈ 0.95)</span> · <span class="c">m ∝ size</span>
          </div>
          <p class="note">
            Damping is why the field settles into calm swarms rather than
            scattering.
          </p>
      <Fragment slot="stage">
        <span class="stage-label">momentum decay</span>
          <svg class="diagram" viewBox="0 0 420 300" fill="none">
            <circle cx="80" cy="150" r="10" class="accf" opacity="0.9"></circle>
            <line x1="95" y1="150" x2="175" y2="150" class="acc"></line>
            <circle cx="210" cy="150" r="7" class="accf" opacity="0.7"></circle>
            <line x1="222" y1="150" x2="272" y2="150" class="acc"></line>
            <circle cx="305" cy="150" r="5" class="accf" opacity="0.5"></circle>
            <circle cx="378" cy="150" r="3.5" class="accf" opacity="0.35"
            ></circle>
            <text x="60" y="210" class="lbl"
              >velocity bleeds off each frame</text
            >
          </svg>
      </Fragment>
    </Concept>

    <Concept stageHidden>
      <span class="concept-no">03 — Currents</span>
          <h2>The waves are a flow field.</h2>
          <p>
            Near a wave line, particles pick up a drag vector along the slope of
            the curve — the derivative of the sine — so they drift like debris
            carried down a river.
          </p>
          <div class="formula">
            slope(x) = cos(x · <span class="v">freq</span> + φ) · freq · amp · <span
              class="v">vₓ</span
            > += slope · influence
          </div>
          <p class="note">
            It’s why the resting field feels alive without any input.
          </p>
      <Fragment slot="stage">
        <span class="stage-label">wave slope → drift</span>
          <svg class="diagram" viewBox="0 0 420 300" fill="none">
            <path
              d="M20 170 Q110 90 200 170 T380 170"
              class="acc"
              stroke-width="1.5"></path>
            <circle cx="200" cy="170" r="4" class="accf"></circle>
            <line
              x1="200"
              y1="170"
              x2="270"
              y2="140"
              class="acc"
              stroke-dasharray="3 4"></line>
            <text x="150" y="230" class="lbl"
              >tangent drift along the curve</text
            >
          </svg>
      </Fragment>
    </Concept>

    <!-- Below the substrate: play the four fields live, then meet a body that holds matter.
         The interactive lead-in to the natural-field translations + the Body Interaction Model. -->
    <NaturalFieldsSection
      translationKicker="Live — the four fields"
      bodyKicker="Live — a body as a vessel"
    />

    <!-- II · Natural-field translations -->
    <ChapterHeader no="II" id="ch-natural" title="Natural-field translations">Every interface already has priority, polarity, binding, and
          transformation. field-ui translates the four fundamental fields into
          those relations — gravity becomes priority, electromagnetism becomes
          polarity and signal, strong becomes binding, weak becomes
          transformation. The runtime tokens below are engine expressions of that
          grammar (true 1/d², Lorentz, Langevin, diffusion, waves) —
          translations, not additional fundamental fields. See the
          <a href="/docs/natural-fields">Natural Fields</a> model.</ChapterHeader>
    {
      natural.map((f, i) => {
        n += 1;
        return <ManualForceRow f={f} num={n} reverse={i % 2 === 1} />;
      })
    }

    <!-- III · Forces (canonical nine) -->
    <ChapterHeader no="III" id="ch-forces" title="Forces">What a single body can do to the matter around it — designed UI verbs,
          stable and bounded. A designed verb is not a natural field: an attractor
          is not gravity, a repeller is not charge.</ChapterHeader>

    <Concept reverse data-form="wells">
      <span class="concept-no"
            ><i class="fg fg-attract" style="--fc:#4da3ff"></i>{String((n += 1)).padStart(2, "0")} — Attraction</span
          >
          <h2>A body can pull the field into orbit.</h2>
          <p>
            An <strong>attractor</strong> defines a gravity well. The pull grows as
            distance falls, and a tangential component bends incoming particles into
            stable spirals.
          </p>
          <div class="formula">
            F = (1 − <span class="v">d</span> / d<span class="c">max</span>)² · <span
              class="v">S</span
            >
          </div>
          <p class="note">
            Drag the attractor — the force is bound to the element, not the
            cursor.
          </p>
          <button class="agitate" data-agitate="#c-attract"
            >↯ Agitate the field</button
          >
      <Fragment slot="stage">
        <span class="stage-label">attractor — drag me</span>
          <span
            class="body-chip"
            id="c-attract"
            data-drag
            data-body="attract"
            data-strength="1"
            data-range="300"
            style="--cc:#4da3ff; position:absolute; left:50%; top:50%; transform:translate(-50%,-50%);"
            ><i class="fg fg-attract"></i>attractor</span
          >
          <span class="hintline"
            >force follows the element across the field</span
          >
      </Fragment>
    </Concept>

    <Concept data-form="scatter">
      <span class="concept-no"
            ><i class="fg fg-repel" style="--fc:#ff9d5c"></i>{String((n += 1)).padStart(2, "0")} — Repulsion</span
          >
          <h2>A body can push the field away.</h2>
          <p>
            A <strong>repeller</strong> is an inverted well — the force points <strong
              >outward</strong
            >, carving a clean void the rest of the field flows around.
          </p>
          <div class="formula">
            F = −(1 − <span class="v">d</span> / d<span class="c">max</span>)² · <span
              class="v">S</span
            >
          </div>
          <p class="note">
            Drag the repeller and watch a clearing open around it.
          </p>
          <button class="agitate" data-agitate="#c-repel"
            >↯ Agitate the field</button
          >
      <Fragment slot="stage">
        <span class="stage-label">repeller — drag me</span>
          <span
            class="body-chip"
            id="c-repel"
            data-drag
            data-body="repel"
            data-strength="1.1"
            data-range="300"
            style="--cc:#ff9d5c; position:absolute; left:50%; top:50%; transform:translate(-50%,-50%);"
            ><i class="fg fg-repel"></i>repel</span
          >
          <span class="hintline"
            >force points outward — a void opens in the field</span
          >
      </Fragment>
    </Concept>

    <Concept reverse>
      <span class="concept-no"
            ><i class="fg fg-wall" style="--fc:#c4b5fd"></i>{String((n += 1)).padStart(2, "0")} — Reflection</span
          >
          <h2>A body can be a wall.</h2>
          <p>
            A <strong>wall</strong> is an axis-aligned box. A crossing particle has
            its perpendicular velocity reversed and scaled by elasticity, then is
            projected back out — a hard hit throws a <strong>spark</strong>.
          </p>
          <div class="formula">
            <span class="c">vertical edge:</span>
            <span class="v">vₓ</span> ← −Cᵣ · <span class="v">vₓ</span>
          </div>
          <p class="note">
            Drag the wall into the drifting particles to deflect them.
          </p>
      <Fragment slot="stage">
        <span class="stage-label">wall — drag me</span>
          <div
            class="body-wall"
            data-drag
            data-body="wall"
            style="position:absolute; left:50%; top:50%; transform:translate(-50%,-50%);"
          >
            wall
          </div>
          <span class="hintline">particles bounce off the bounding box</span>
      </Fragment>
    </Concept>

    <Concept data-form="wells">
      <span class="concept-no"
            ><i class="fg fg-swirl" style="--fc:#2dd4bf"></i>{String((n += 1)).padStart(2, "0")} — Swirl</span
          >
          <h2>A body can spin the field.</h2>
          <p>
            A <strong>swirl</strong> applies a dominantly <strong
              >tangential</strong
            > force — a swirl, not a drain. The inward pull is light (the swirl dominates
            it roughly eightfold), so matter wheels around the body instead of falling
            in. A tight inward spiral is a preset (<code>whirlpool</code>),
            never the canonical verb.
          </p>
          <div class="formula">
            <span class="v">v</span> += (−<span class="v">d̂_y</span>, <span
              class="v">d̂_x</span
            >) · <span class="v">S</span> · spin <span class="c">+</span>
            <span class="v">d̂</span> · <span class="v">S</span> · <span
              class="c">0.12</span
            >
          </div>
          <p class="note">
            Drag the swirl into the swarm — particles orbit rather than fall in.
          </p>
          <button class="agitate" data-agitate="#c-swirl"
            >↯ Agitate the field</button
          >
      <Fragment slot="stage">
        <span class="stage-label">swirl — drag me</span>
          <span
            class="body-chip"
            id="c-swirl"
            data-drag
            data-body="swirl"
            data-spin="1"
            data-strength="1"
            data-range="320"
            style="--cc:#2dd4bf; position:absolute; left:50%; top:50%; transform:translate(-50%,-50%);"
            ><i class="fg fg-swirl"></i>swirl</span
          >
          <span class="hintline"
            >tangential force — the field circles, never collapses</span
          >
      </Fragment>
    </Concept>

    <Concept reverse data-form="lanes">
      <span class="concept-no"
            ><i class="fg fg-stream" style="--fc:#7dd3fc"></i>{String((n += 1)).padStart(2, "0")} — Stream</span
          >
          <h2>A body can blow a current.</h2>
          <p>
            A <strong>stream</strong> emits a constant force along a heading — a fan,
            a jet, a prevailing wind. The swarm combs into parallel flow.
          </p>
          <div class="formula">
            <span class="v">v</span> += (cos θ, sin θ) · <span class="v">S</span
            > · (1 − <span class="v">d</span>/d<span class="c">max</span>)
          </div>
          <p class="note">
            Drag the jet and watch matter streak into lanes downwind.
          </p>
          <button class="agitate" data-agitate="#c-stream"
            >↯ Agitate the field</button
          >
      <Fragment slot="stage">
        <span class="stage-label">stream — drag me</span>
          <span
            class="body-chip"
            id="c-stream"
            data-drag
            data-body="stream"
            data-angle="0"
            data-strength="1"
            data-range="340"
            style="--cc:#7dd3fc; position:absolute; left:50%; top:50%; transform:translate(-50%,-50%);"
            ><i class="fg fg-stream"></i>stream</span
          >
          <span class="hintline"
            >directional current — particles comb downwind</span
          >
      </Fragment>
    </Concept>

    <Concept data-form="wells">
      <span class="concept-no"
            ><i class="fg fg-tether" style="--fc:#86e57f"></i>{String((n += 1)).padStart(2, "0")} — Tether</span
          >
          <h2>A body can tether the field at a fixed distance.</h2>
          <p>
            A <strong>tether</strong> has a <strong>rest length</strong>. Matter
            that crowds in is pushed out; matter that strays is reeled in — the
            swarm settles into an orbiting shell.
          </p>
          <div class="formula">
            <span class="v">v</span> += û · (<span class="v">d</span> − <span
              class="v">r</span
            ><span class="c">est</span>) · <span class="v">k</span>
          </div>
          <p class="note">
            Drag the tether — matter springs back to its radius.
          </p>
          <button class="agitate" data-agitate="#c-tether"
            >↯ Agitate the field</button
          >
      <Fragment slot="stage">
        <span class="stage-label">tether — drag me</span>
          <span
            class="body-chip"
            id="c-tether"
            data-drag
            data-body="tether"
            data-strength="1"
            data-range="260"
            style="--cc:#86e57f; position:absolute; left:50%; top:50%; transform:translate(-50%,-50%);"
            ><i class="fg fg-tether"></i>tether</span
          >
          <span class="hintline"
            >a tether — matter holds a shell at the rest radius</span
          >
      </Fragment>
    </Concept>

    <Concept reverse data-form="lanes">
      <span class="concept-no"
            ><i class="fg fg-viscosity" style="--fc:#8da2c0"></i>{String((n += 1)).padStart(2, "0")} — Viscosity</span
          >
          <h2>A body can thicken the medium.</h2>
          <p>
            A <strong>viscosity</strong> body neither pulls nor pushes — it <strong
              >bleeds momentum</strong
            >, as if the field turned to honey. Paired with an attractor it
            turns a slingshot into a settled orbit.
          </p>
          <div class="formula">
            <span class="v">v</span> ← <span class="v">v</span> · (1 − <span
              class="v">k</span
            >), <span class="c">k ∝ (1 − d/d_max)·S</span>
          </div>
          <p class="note">Agitate, then watch the rush die inside the zone.</p>
          <button class="agitate" data-agitate="#c-drag"
            >↯ Agitate the field</button
          >
      <Fragment slot="stage">
        <span class="stage-label">viscosity — move me</span>
          <span
            class="body-chip"
            id="c-drag"
            data-drag
            data-body="viscosity"
            data-strength="1"
            data-range="300"
            style="--cc:#8da2c0; position:absolute; left:50%; top:50%; transform:translate(-50%,-50%);"
            ><i class="fg fg-viscosity"></i>viscosity</span
          >
          <span class="hintline"
            >a viscous zone — momentum bleeds off, the swarm settles</span
          >
      </Fragment>
    </Concept>

    <Concept data-form="accretion">
      <span class="concept-no"
            ><i class="fg fg-sink" style="--fc:#ff6e9c"></i>{String((n += 1)).padStart(2, "0")} — Accretion &amp;
            release</span
          >
          <h2>A body can hold matter — and give it back.</h2>
          <p>
            A <strong>sink</strong> captures particles at its core. They aren’t deleted
            — they’re
            <strong>held inside</strong>, and the element inflates as it fills.
            When it saturates it goes supernova: the exact particles are <strong
              >released radially</strong
            >.
          </p>
          <div class="formula">
            <span class="c">scale =</span> 1 + (<span class="v">accreted</span> /
            <span class="v">capacity</span>) · 0.45 · <span class="v"
              >captured = released</span
            >
          </div>
          <p class="note">
            Nothing is conjured from thin air, and nothing vanishes. Matter
            changes hands.
          </p>
      <Fragment slot="stage">
        <span class="stage-label">sink — fills, then pops</span>
          <div
            class="body-core"
            data-drag
            data-body="sink attract"
            data-absorb="64"
            data-max="8"
            data-strength="0.8"
            data-range="180"
            style="--cc:#ff9d5c; position:absolute; left:50%; top:50%; transform:translate(-50%,-50%);"
          >
            core
          </div>
          <div class="meter" style="--cc:#ff9d5c;"><i></i></div>
          <span class="hintline"
            >matter accumulates, then releases on supernova</span
          >
      </Fragment>
    </Concept>

    <Concept reverse data-form="lanes">
      <span class="concept-no"
            ><i class="fg fg-jet" style="--fc:#a78bfa"></i>{String((n += 1)).padStart(2, "0")} — Emission</span
          >
          <h2>A body can be a fountain.</h2>
          <p>
            A <strong>jet</strong> draws surrounding matter into its nozzle and relaunches
            it as a hot jet — the field is <strong
              >recycled into a stream</strong
            >, nothing conjured.
          </p>
          <div class="formula">
            <span class="c">feed:</span>
            <span class="v">v</span> += d̂ · S · <span class="c">at nozzle:</span
            >
            <span class="v">v</span> = (cos θ, sin θ) · spd
          </div>
          <p class="note">
            Agitate to feed it, then watch the jet stream off along its heading.
          </p>
          <button class="agitate" data-agitate="#c-jet"
            >↯ Feed the fountain</button
          >
      <Fragment slot="stage">
        <span class="stage-label">jet — move me · jets →</span>
          <span
            class="body-chip"
            id="c-jet"
            data-drag
            data-body="jet"
            data-angle="0"
            data-strength="1"
            data-range="300"
            style="--cc:#a78bfa; position:absolute; left:50%; top:50%; transform:translate(-50%,-50%);"
            ><i class="fg fg-jet"></i>jet</span
          >
          <span class="hintline"
            >a fountain — matter is drawn in and jetted back out</span
          >
      </Fragment>
    </Concept>

    <!-- IV · Designed-extended -->
    <ChapterHeader no="IV" id="ch-extended" title="Designed-extended">Further designed forces, and the modifiers that wrap a sibling.</ChapterHeader>
    {
      extended.map((f, i) => {
        n += 1;
        return <ManualForceRow f={f} num={n} reverse={i % 2 === 1} />;
      })
    }

    <!-- V · Presets -->
    <ChapterHeader no="V" id="ch-presets" title="Presets">Cosmology as composition — named arrangements of the primitives.</ChapterHeader>
    {
      MANUAL_PRESETS.map((p, i) => {
        n += 1;
        const color = PRESET_COLORS[p.name] ?? "#4da3ff";
        return <PresetRow p={p} num={n} color={color} reverse={i % 2 === 1} />;
      })
    }

    <!-- VI · Conditions -->
    <ChapterHeader no="VI" id="ch-conditions" title="Conditions">When a force decides to act, and on which matter.</ChapterHeader>
    <Concept data-form="scatter">
      <span class="concept-no"
            >{String((n += 1)).padStart(2, "0")} — Conditional</span
          >
          <h2>A force can choose what it touches.</h2>
          <p>
            Any body can carry a <strong>condition</strong> — gated on being engaged,
            or on a particle’s
            <strong>speed</strong> or <strong>heat</strong>. A selective force
            reads every free agent and acts only on those that match.
          </p>
          <div class="formula">
            <span class="c">when</span> = active · fast · slow · hot · cool · scrolling
          </div>
          <p class="note">
            The catcher below only grips <strong>hot</strong> particles. Heat the
            field and the excited matter is pulled in while the calm passes through.
          </p>
          <button class="agitate" data-agitate="#c-cond"
            >↯ Heat the field</button
          >
      <Fragment slot="stage">
        <span class="stage-label">conditional — catches heat only</span>
          <span
            class="body-chip"
            id="c-cond"
            data-drag
            data-body="attract"
            data-when="hot"
            data-strength="1.2"
            data-range="320"
            style="--cc:#ff6e9c; position:absolute; left:50%; top:50%; transform:translate(-50%,-50%);"
            ><i class="fg fg-attract"></i>when&nbsp;hot</span
          >
          <span class="hintline"
            >selective attractor — grips excited matter, ignores the calm</span
          >
      </Fragment>
    </Concept>

    <!-- VII · System -->
    <ChapterHeader no="VII" id="ch-system" title="System">What emerges when the parts interact.</ChapterHeader>
    <Concept reverse>
      <span class="concept-no"
            >{String((n += 1)).padStart(2, "0")} — Reciprocity</span
          >
          <h2>The field changes the element back.</h2>
          <p>
            The element bends the field — and the field’s <strong
              >local density</strong
            > bends the element in return. As particles gather on a word, it gains
            weight, brightness, and lift.
          </p>
          <div class="formula">
            --field-density = density(body) <span class="c">→</span>
            <span class="v">weight</span>, glow, rise
          </div>
          <p class="note">
            Hover the word — it pulls the field, the field piles up, and the
            pile makes the word heavier. A closed loop. (<code>--d</code> is the compact
            compatibility alias of
            <code>--field-density</code>.)
          </p>
      <Fragment slot="stage">
        <span class="stage-label">density → weight</span>
          <span
            class="live-demo"
            data-hot
            data-color="#a78bfa"
            data-feedback
            data-body="attract"
            data-strength="1"
            data-range="300"
            style="--cat:#a78bfa;">density</span
          >
          <span class="hintline"
            >gathered particles raise the element’s weight</span
          >
      </Fragment>
    </Concept>
    <Concept reverse data-attention-demo>
      <span class="concept-no"
            >{String((n += 1)).padStart(2, "0")} — Conserved attention</span
          >
          <h2>The page can’t emphasize two things at once.</h2>
          <p>
            There is one finite budget of force for the whole page. Engage a
            word and it pulls force off every other — so as one gathers matter
            and grows heavier, the rest give theirs up. Focus isn’t styled; it’s <strong
              >conserved</strong
            >.
          </p>
          <div class="formula">
            Σ Sᵢ · effortᵢ = <span class="v">constant</span>
          </div>
          <p class="note">
            Hover one word — watch the others surrender their weight to it.
          </p>
      <Fragment slot="stage">
        <span class="stage-label">one budget, redistributed</span>
          <div class="attn-set">
            <span
              class="attn-word"
              data-hot
              data-feedback
              data-body="attract"
              data-strength="1.5"
              data-range="240"
              data-color="#4da3ff"
              style="--cat:#4da3ff;">focus</span
            >
            <span
              class="attn-word"
              data-hot
              data-feedback
              data-body="attract"
              data-strength="1.5"
              data-range="240"
              data-color="#2dd4bf"
              style="--cat:#2dd4bf;">depth</span
            >
            <span
              class="attn-word"
              data-hot
              data-feedback
              data-body="attract"
              data-strength="1.5"
              data-range="240"
              data-color="#ff9d5c"
              style="--cat:#ff9d5c;">weight</span
            >
          </div>
          <span class="hintline"
            >one finite budget — engaging one starves the rest</span
          >
      </Fragment>
    </Concept>
    <Concept>
      <span class="concept-no"
            >{String((n += 1)).padStart(2, "0")} — Threads</span
          >
          <h2>Engaging one body wires the set.</h2>
          <p>
            Engage an element in a group and the field draws living threads
            between it and its siblings. A list stops being a list and shows
            itself as a <strong>connected system</strong>.
          </p>
          <p class="note">Hover any line.</p>
      <Fragment slot="stage">
        <span class="stage-label">a connected set</span>
          <div class="thread-set" data-index data-threads>
            <span
              class="ti"
              data-hot
              data-color="#4da3ff"
              data-body="attract"
              data-strength="0.5"
              data-range="220"
              style="--cat:#4da3ff;">Product</span
            >
            <span
              class="ti"
              data-hot
              data-color="#2dd4bf"
              data-body="attract"
              data-strength="0.5"
              data-range="220"
              style="--cat:#2dd4bf;">System</span
            >
            <span
              class="ti"
              data-hot
              data-color="#a78bfa"
              data-body="attract"
              data-strength="0.5"
              data-range="220"
              style="--cat:#a78bfa;">Interface</span
            >
            <span
              class="ti"
              data-hot
              data-color="#ff9d5c"
              data-body="attract"
              data-strength="0.5"
              data-range="220"
              style="--cat:#ff9d5c;">Material</span
            >
          </div>
          <span class="hintline"
            >threads connect the engaged body to its set</span
          >
      </Fragment>
    </Concept>
    <Concept reverse data-causality-demo>
      <span class="concept-no"
            >{String((n += 1)).padStart(2, "0")} — Cross-boundary causality</span
          >
          <h2>Density doesn’t stop at the edge.</h2>
          <p>
            When a body saturates, the excess <strong
              >spills to its neighbours</strong
            > — weighted by nearness, and conserved. Engage one tile and the ones
            beside it light up on their own. The wiring between elements appears because
            matter actually flows between them.
          </p>
          <div class="formula">
            Φᵢⱼ = κ · excessᵢ · <span class="v">wᵢⱼ</span> ⁄ Σ wᵢₖ
          </div>
          <p class="note">
            Hover the middle tile — watch its neighbours catch, the far ones
            faintly.
          </p>
      <Fragment slot="stage">
        <span class="stage-label">spill → neighbours light</span>
          <div class="causal-set">
            <span
              class="causal-node"
              data-hot
              data-feedback
              data-body="attract"
              data-strength="1.4"
              data-range="200"
              data-color="#a78bfa"
              style="--cat:#a78bfa;"></span>
            <span
              class="causal-node"
              data-hot
              data-feedback
              data-body="attract"
              data-strength="1.4"
              data-range="200"
              data-color="#7dd3fc"
              style="--cat:#7dd3fc;"></span>
            <span
              class="causal-node"
              data-hot
              data-feedback
              data-body="attract"
              data-strength="1.4"
              data-range="200"
              data-color="#4da3ff"
              style="--cat:#4da3ff;"></span>
            <span
              class="causal-node"
              data-hot
              data-feedback
              data-body="attract"
              data-strength="1.4"
              data-range="200"
              data-color="#2dd4bf"
              style="--cat:#2dd4bf;"></span>
            <span
              class="causal-node"
              data-hot
              data-feedback
              data-body="attract"
              data-strength="1.4"
              data-range="200"
              data-color="#86e57f"
              style="--cat:#86e57f;"></span>
          </div>
          <span class="hintline"
            >engage one — the excess spills to whoever’s near</span
          >
      </Fragment>
    </Concept>
    <Concept reverse id="formations" stageHidden>
      <span class="concept-no"
            >{String((n += 1)).padStart(2, "0")} — Formations</span
          >
          <h2>The whole field can change its mind.</h2>
          <p>
            Forces act locally. A <strong>formation</strong> acts on every particle
            at once — a single global bias. As you scrolled, each chapter quietly
            switched it.
          </p>
          <p class="note" id="form-desc">
            Ambient — calm brownian drift, the resting state.
          </p>
          <div class="form-pills" id="formPills">
            <button class="form-pill on" data-form="ambient">Ambient</button>
            <button class="form-pill" data-form="wells">Wells</button>
            <button class="form-pill" data-form="lanes">Lanes</button>
            <button class="form-pill" data-form="scatter">Scatter</button>
            <button class="form-pill" data-form="accretion">Accretion</button>
          </div>
      <Fragment slot="stage">
        <span class="stage-label">formation — tap to reconfigure</span>
          <div class="form-readout"><span id="form-name">ambient</span></div>
          <span class="hintline"
            >a global bias on every particle — watch the field behind everything</span
          >
      </Fragment>
    </Concept>

    <Concept reverse data-form="wells">
      <span class="concept-no"
            >{String((n += 1)).padStart(2, "0")} — Material typography</span
          >
          <h2>Type is a readout of mass.</h2>
          <p>
            The word is a <strong>body</strong>. It pulls the field, matter
            pools beneath it, and its whole appearance — weight, optical size,
            tracking, bloom, colour — is a live readout of how much has
            gathered. One value, <code>--field-density</code>, drives every axis
            at once.
          </p>
          <div class="formula">
            --field-density <span class="c">→</span>
            <span class="v">wght · opsz · tracking · bloom · colour</span>
          </div>
          <p class="note">
            Disturb it — the burst scatters the pile, the type goes light and
            pale, then it thickens back as the field resettles under its own
            pull. Type as a material, not a style.
          </p>
          <button class="agitate" data-agitate="#mat-word"
            >↯ Disturb the type</button
          >
      <Fragment slot="stage">
        <span class="stage-label">density → every type axis</span>
          <span
            class="material-word"
            id="mat-word"
            data-hot
            data-feedback
            data-body="attract"
            data-strength="1.2"
            data-range="300"
            data-color="#f0abfc"
            style="--cc:#f0abfc; --cat:#f0abfc;">material</span
          >
          <span class="hintline"
            >weight, optical size, tracking, glow and colour are one density</span
          >
      </Fragment>
    </Concept>

    <Concept data-form="scatter">
      <span class="concept-no"
            >{String((n += 1)).padStart(2, "0")} — Self-laying-out</span
          >
          <h2>The page arranges itself.</h2>
          <p>
            These nodes aren’t pinned by CSS. Each one <strong
              >pushes off the others</strong
            > and drifts away from crowded field, settling into an equilibrium — and
            re-settling when the field is disturbed or the window resizes. Layout
            as a physical process, not fixed coordinates.
          </p>
          <div class="formula">
            F = anchor <span class="c">+</span> repel <span class="c">+</span>
            <span class="v">density pressure</span>
          </div>
          <p class="note">
            Drag the attractor through them, or resize the window — the
            constellation scatters and re-settles like a physical object.
          </p>
          <button class="agitate" data-agitate="#layout-seed"
            >↯ Disturb the layout</button
          >
      <Fragment slot="stage">
        <span class="stage-label">elements find their own positions</span>
          <span
            id="layout-seed"
            data-drag
            data-body="attract"
            data-strength="0.9"
            data-range="260"
            class="layout-seed"
            style="--cc:#7dd3fc; position:absolute; left:50%; top:42%; transform:translate(-50%,-50%);"
            >field</span
          >
          <div class="layout-cluster">
            <span class="layout-node" data-move="layout" style="--cn:#4da3ff;"
              >Product</span
            >
            <span class="layout-node" data-move="layout" style="--cn:#2dd4bf;"
              >System</span
            >
            <span class="layout-node" data-move="layout" style="--cn:#a78bfa;"
              >Interface</span
            >
            <span class="layout-node" data-move="layout" style="--cn:#ff9d5c;"
              >Material</span
            >
            <span class="layout-node" data-move="layout" style="--cn:#f0abfc;"
              >Motion</span
            >
          </div>
          <span class="hintline"
            >anchor + mutual repulsion + density pressure → equilibrium</span
          >
      </Fragment>
    </Concept>

    <ManualFoot>
      <Fragment slot="actions">
        <Button href="/lab" variant="primary">Open the Lab →</Button>
        <Button href="/docs">Read the docs →</Button>
      </Fragment>
    </ManualFoot>
  </div>
  <SiteFooter />
</Base>

