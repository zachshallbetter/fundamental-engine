---
import Base from '../layouts/Base.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import StatusChip from '../components/StatusChip.astro';

// /demo — the substrate proof, in one screen: ONE field, read TWO ways.
//   Left  ("as interface"): a handful of labelled bodies. The field is revealed as type + ink — each
//                            body's weight/brightness is its live density (`--d`, engine-written), and one
//                            body's *position* is engine-owned (data-authority="dynamic"), so it drifts.
//   Right ("as agent-json"): field.query() — the SAME bodies as serializable JSON (id, tokens, density,
//                            authority, x/y) + field metrics. The number on a body equals the number in
//                            the JSON — that is the whole point: an agent reads the field, not the DOM.
// Rides the persistent <field-root> from Base.astro. Legible with the field off (bodies read as labels,
// the panel reads as JSON); the field only adds live numbers + the one drifting body's motion.
---

<Base
  title="Substrate demo — one field, two readings — Fundamental"
  description="The same field state, read two ways: as interface (type + ink) and as agent-json (field.query()). An agent reads the field, not the DOM."
>
  <SiteNav current="demo" />

  <main id="main" class="demo-shell">
    <header class="demo-head">
      <p class="demo-kicker">Substrate proof</p>
      <h1>One field. Two readings.</h1>
      <StatusChip label="Demo · experimental substrate surface" tone="demo" />
      <p class="demo-lede">
        The bodies on the left <em>are</em> the field, revealed as type and ink — heavier and brighter
        where density is higher, and one body whose position the engine owns. The panel on the right is the
        same field read as JSON through <code>field.query()</code>. The number on a body equals the number
        in the JSON. That is the point: <strong>an agent reads the field, not the DOM.</strong>
      </p>
    </header>

    <div class="demo-instrument">
      <!-- LEFT: the field revealed as interface -->
      <section class="demo-panel" aria-label="The field, revealed as interface">
        <p class="panel-label">As interface <span class="panel-sub">— revealed as type &amp; ink</span></p>
        <div class="demo-stage" data-index data-threads>
          <span class="body sig" id="signal-a" data-body="attract" data-strength="1" data-range="150" data-hot data-feedback>
            <span class="body-name">signal · a</span>
            <span class="body-read" data-read="signal-a">d —</span>
          </span>
          <span class="body sig" id="signal-b" data-body="attract" data-strength="1" data-range="150" data-hot data-feedback>
            <span class="body-name">signal · b</span>
            <span class="body-read" data-read="signal-b">d —</span>
          </span>
          <span class="body sig" id="signal-c" data-body="attract" data-strength="1" data-range="150" data-hot data-feedback>
            <span class="body-name">signal · c</span>
            <span class="body-read" data-read="signal-c">d —</span>
          </span>
          <!-- a dedicated, invisible anchor in the free lane: gives the dynamic body a clear, contained
               drift toward a fixed point, well clear of the signals. Not labelled, not in the read-set,
               so it never appears in the JSON — it only shapes the free body's motion. -->
          <span class="anchor" id="free-anchor" data-body="attract" data-strength="1.3" data-range="180" aria-hidden="true"></span>
          <!-- engine-owned position: the field integrates this body's coordinates; the script mirrors
               the live query() rect delta onto its transform. Its x/y in the JSON is the same motion. -->
          <span class="body free" id="free-1" data-body="attract" data-strength="0.4" data-range="110" data-authority="dynamic" data-feedback>
            <span class="body-name">free body</span>
            <span class="body-read" data-read="free-1">engine-owned&nbsp;x/y</span>
          </span>
        </div>
        <p class="stage-hint">Hover or focus a signal — it engages, and its density climbs on both sides. The free body drifts because the engine owns its position.</p>
      </section>

      <!-- RIGHT: the same field read as agent-json -->
      <section class="demo-panel demo-readout" aria-label="The same field, read as agent-json">
        <p class="panel-label">As agent <span class="panel-sub">— <code>field.query()</code></span></p>
        <pre data-agent-json aria-live="off">{'{ binding query()… }'}</pre>
        <p class="stage-hint">A serializable read-out of the same bodies. The surface a tool or agent consumes — no DOM scraping, no second model of the page.</p>
      </section>
    </div>

    <nav class="demo-explore" aria-label="Related proof">
      <a href="/ai-evidence">AI Evidence — claims &amp; sources as a readable field →</a>
      <a href="/docs/api">The substrate read API — <code>query</code>, <code>snapshot</code>, projections →</a>
      <a href="/lab">Open the Lab — inspect the engine live →</a>
    </nav>
  </main>

  <SiteFooter />
</Base>

<style>
  .demo-shell { max-width: var(--content-max); margin: 0 auto; padding: 4rem 1.5rem 6rem; position: relative; z-index: 1; }
  .demo-kicker {
    font-family: var(--font-mono, ui-monospace, monospace); font-size: 0.72rem; letter-spacing: 0.16em;
    text-transform: uppercase; opacity: 0.55; margin: 0 0 0.5rem;
  }
  .demo-head h1 { font-size: clamp(2rem, 5vw, 3rem); margin: 0 0 0.6rem; letter-spacing: -0.01em; }
  .demo-lede { max-width: 46rem; line-height: 1.6; opacity: 0.85; margin: 0.85rem 0 0; }
  .demo-lede code, .panel-sub code { font-family: var(--font-mono, ui-monospace, monospace); font-size: 0.9em; }

  .demo-instrument {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin: 2.5rem 0 1.5rem;
    align-items: start;
  }
  @media (max-width: 860px) { .demo-instrument { grid-template-columns: 1fr; } }

  .demo-panel {
    display: flex; flex-direction: column;
    border: 1px solid color-mix(in oklch, currentColor 13%, transparent); border-radius: 1rem;
    background: color-mix(in oklch, currentColor 3%, transparent); padding: 1rem 1.1rem 1.1rem;
  }
  .panel-label {
    font-family: var(--font-mono, ui-monospace, monospace); font-size: 0.75rem; letter-spacing: 0.08em;
    text-transform: uppercase; margin: 0 0 0.85rem; opacity: 0.8;
  }
  .panel-sub { text-transform: none; letter-spacing: 0; opacity: 0.6; }

  /* LEFT stage: a calm field of labelled bodies, laid out so nothing overlaps */
  .demo-stage {
    position: relative; height: 22rem; border-radius: 0.75rem; overflow: hidden;
    /* subtle coordinate grid — the "instrument" texture */
    background-image:
      linear-gradient(color-mix(in oklch, currentColor 5%, transparent) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in oklch, currentColor 5%, transparent) 1px, transparent 1px);
    background-size: 2.25rem 2.25rem;
  }
  .body {
    position: absolute; display: inline-flex; flex-direction: column; gap: 0.15rem;
    align-items: center; justify-content: center; padding: 0.55rem 0.7rem; border-radius: 0.7rem;
    user-select: none; cursor: default; text-align: center; line-height: 1.15;
    transition: transform 0.12s ease-out, box-shadow 0.18s ease-out, border-color 0.18s ease-out;
    /* --d is engine-written onto data-feedback bodies — CONSUME it so the body visibly reacts */
    box-shadow: 0 0 calc(6px + var(--d, 0) * 34px) color-mix(in oklch, var(--fc, var(--accent, #4da3ff)) calc(30% + var(--d, 0) * 45%), transparent);
    border: 1px solid color-mix(in oklch, var(--fc, var(--accent, #4da3ff)) calc(35% + var(--d, 0) * 45%), transparent);
    background: color-mix(in oklch, var(--fc, var(--accent, #4da3ff)) calc(9% + var(--d, 0) * 16%), transparent);
  }
  .body-name { font-size: 0.8rem; font-weight: calc(420 + var(--d, 0) * 500); letter-spacing: 0.01em; }
  .body-read {
    font-family: var(--font-mono, ui-monospace, monospace); font-size: 0.68rem; opacity: 0.72;
    font-variant-numeric: tabular-nums;
  }
  .body:hover, .body:focus-visible { outline: none; transform: scale(1.04); }
  .sig { --fc: var(--accent, #4da3ff); }
  #signal-a { top: 15%; left: 20%; }
  #signal-b { top: 50%; left: 38%; }
  #signal-c { top: 80%; left: 20%; }
  .free { --fc: #f06aa8; top: 24%; left: 70%; }
  /* invisible attractor that gives the free body its contained drift (see markup) */
  .anchor { position: absolute; top: 58%; left: 84%; width: 8px; height: 8px; opacity: 0; pointer-events: none; }

  .stage-hint { font-size: 0.82rem; opacity: 0.62; line-height: 1.5; margin: 0.85rem 0 0; }

  /* RIGHT readout */
  .demo-readout pre {
    height: 22rem; margin: 0; padding: 0.9rem 1rem; border-radius: 0.75rem; overflow: auto;
    background: color-mix(in oklch, currentColor 5%, transparent);
    border: 1px solid color-mix(in oklch, currentColor 10%, transparent);
    font-family: var(--font-mono, ui-monospace, monospace); font-size: 0.78rem;
    font-variant-numeric: tabular-nums; line-height: 1.55; white-space: pre;
  }

  .demo-explore {
    display: flex; flex-wrap: wrap; gap: 1.25rem 2rem; margin-top: 1.75rem;
    padding-top: 1.5rem; border-top: 1px solid color-mix(in oklch, currentColor 10%, transparent);
  }
  .demo-explore a { font-size: 0.92rem; opacity: 0.85; text-decoration: none; border-bottom: 1px solid transparent; }
  .demo-explore a:hover { opacity: 1; border-bottom-color: currentColor; }
  .demo-explore code { font-family: var(--font-mono, ui-monospace, monospace); font-size: 0.9em; }

  @media (prefers-reduced-motion: reduce) {
    .body { transition: none; }
    /* the field runs static; the free body holds its authored position, numbers still stream */
  }
</style>

<script>
  // Wire the agent-json read-out to the page field and stream field.query() into the <pre>, while
  // mirroring each body's live density onto the body itself (proving the number is the SAME on both sides)
  // and driving the engine-owned body's on-screen position from its query() rect.
  // Runs on load AND astro:page-load (SPA nav); binds once per visit.

  type BodyReading = {
    id: string;
    tokens?: string[];
    authority?: string;
    metrics?: Record<string, number>;
    rect?: { x: number; y: number };
  };
  type FieldEl = Element & {
    query?: (q?: unknown) => { frame: number; metrics: Record<string, number>; bodies: BodyReading[] };
  };

  const r3 = (n: number) => Math.round(n * 1000) / 1000;

  function initDemo() {
    const pre = document.querySelector('pre[data-agent-json]') as HTMLElement | null;
    const field = document.querySelector('field-root') as FieldEl | null;
    if (!pre || !field || pre.dataset.bound) return;
    // wait for the field to actually start (its real query replaces the no-op stub)
    if (typeof field.query !== 'function') { window.setTimeout(initDemo, 120); return; }
    pre.dataset.bound = '1';

    const OURS = new Set(['signal-a', 'signal-b', 'signal-c', 'free-1']);
    const origin = new Map<string, { x: number; y: number }>();

    let raf = 0;
    const tick = () => {
      const q = field.query!({ include: ['bodies', 'metrics'] } as unknown);
      const mine = (q.bodies ?? []).filter((b) => OURS.has(b.id));

      // 1) drive the engine-owned body's on-screen position + mirror per-body density onto each body
      for (const b of mine) {
        const density = b.metrics?.density ?? 0;
        const readEl = document.querySelector(`[data-read="${b.id}"]`);
        if (readEl && b.id !== 'free-1') readEl.textContent = `d ${r3(density).toFixed(3)}`;

        if (b.authority === 'dynamic' && b.rect) {
          const el = document.getElementById(b.id);
          if (el) {
            if (!origin.has(b.id)) origin.set(b.id, { x: b.rect.x, y: b.rect.y });
            const o = origin.get(b.id)!;
            el.style.transform = `translate(${(b.rect.x - o.x).toFixed(1)}px, ${(b.rect.y - o.y).toFixed(1)}px)`;
          }
        }
      }

      // 2) render the same field as compact, honest agent-json
      const readout = {
        frame: q.frame,
        // show the field-level aggregates the reading exposes, minus the raw `bodies` tally (the demo's
        // hidden drift-anchor would make it read 5 while we list the 4 named bodies below).
        metrics: Object.fromEntries(
          Object.entries(q.metrics ?? {}).filter(([k]) => k !== 'bodies').map(([k, v]) => [k, r3(v)]),
        ),
        bodies: mine.map((b) => ({
          id: b.id,
          tokens: b.tokens ?? [],
          authority: b.authority ?? 'anchored',
          density: r3(b.metrics?.density ?? 0),
          ...(b.rect ? { x: Math.round(b.rect.x), y: Math.round(b.rect.y) } : {}),
        })),
      };
      pre.textContent = JSON.stringify(readout, null, 2);

      raf = window.requestAnimationFrame(tick);
    };
    tick();
    document.addEventListener('astro:before-swap', () => window.cancelAnimationFrame(raf), { once: true });
  }

  initDemo();
  document.addEventListener('astro:page-load', initDemo);
</script>
