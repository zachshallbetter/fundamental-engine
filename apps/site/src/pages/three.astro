---
import Base from '../layouts/Base.astro';

const title = 'field-ui — Three.js';
const description =
  'The same reciprocal field engine that drives the DOM, rendered headless as a volumetric THREE.Points swarm with @field-ui/three.';
---

<Base title={title} description={description}>
  <main id="three-main" class="three-demo">
    <header class="three-demo__head">
      <h1>field-ui in Three.js</h1>
      <p>
        The reciprocal field engine runs headless — no DOM canvas — and its conserved particle swarm is
        rendered as a volumetric <code>THREE.Points</code> cloud through
        <a href="https://www.npmjs.com/package/@field-ui/three"><code>@field-ui/three</code></a>. The
        engine's optional depth lane gives the swarm real depth, which the layer maps into the scene.
      </p>
      <div class="three-demo__controls">
        <button type="button" data-action="burst">Burst</button>
        <button type="button" data-action="formation">Cycle formation</button>
        <span class="three-demo__count" data-count aria-live="polite"></span>
      </div>
    </header>
    <div class="three-demo__stage">
      <canvas id="three-canvas"></canvas>
    </div>
  </main>
</Base>

<script>
  import * as THREE from 'three';
  import { createFieldLayer, VolumeProjection, type FieldLayer } from '@field-ui/three';

  const FORMATIONS = ['ambient', 'orbit', 'wells', 'spread'] as const;

  let teardown: (() => void) | null = null;

  function init(): void {
    const canvas = document.getElementById('three-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;
    if (teardown) teardown(); // client-side nav can re-run init; tear the old scene down first

    const stage = canvas.parentElement as HTMLElement;
    const size = (): { w: number; h: number } => ({
      w: stage.clientWidth || window.innerWidth,
      h: stage.clientHeight || Math.round(window.innerHeight * 0.66),
    });

    let { w, h } = size();
    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
    renderer.setSize(w, h, false);

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(55, w / h, 0.1, 100);
    camera.position.set(0, 1.1, 8);
    camera.lookAt(0, 0, 0);

    // The engine's opt-in z lane → a real volume. Bodies live on z = 0; free matter drifts in depth.
    const depth = 320;
    const layer: FieldLayer = createFieldLayer({
      projection: new VolumeProjection({ width: w, height: h, depth, scale: 0.0095, depthScale: 0.014, centerZ: true }),
      depth,
      density: 2.6,
      renderer,
      style: { base: '#3b5e8a', accent: '#9fd4ff', size: 1.9, focal: 120 },
    });
    scene.add(layer.object);

    const countEl = document.querySelector('[data-count]');
    let raf = 0;
    let t = 0;
    let formationIdx = 0;

    const loop = (): void => {
      t += 0.005;
      // a slow orbiting flow focus stirs and heats the matter, so the swarm reads as a living field
      layer.flowTo(w / 2 + Math.cos(t * 1.6) * w * 0.22, h / 2 + Math.sin(t * 1.6) * h * 0.22, {
        strength: 1.3,
        radius: Math.min(w, h) * 0.55,
      });
      layer.object.rotation.y = Math.sin(t) * 0.45; // gentle parallax so the depth reads
      const n = layer.tick();
      if (countEl && Math.floor(t * 120) % 30 === 0) countEl.textContent = `${n.toLocaleString()} particles`;
      renderer.render(scene, camera);
      raf = requestAnimationFrame(loop);
    };
    loop();

    const onResize = (): void => {
      ({ w, h } = size());
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    };
    window.addEventListener('resize', onResize);

    const onClick = (e: Event): void => {
      const action = (e.target as HTMLElement)?.closest('[data-action]')?.getAttribute('data-action');
      if (action === 'burst') layer.burst(w / 2, h / 2);
      if (action === 'formation') {
        formationIdx = (formationIdx + 1) % FORMATIONS.length;
        layer.setFormation(FORMATIONS[formationIdx]!);
      }
    };
    document.querySelector('.three-demo__controls')?.addEventListener('click', onClick);

    teardown = (): void => {
      cancelAnimationFrame(raf);
      window.removeEventListener('resize', onResize);
      document.querySelector('.three-demo__controls')?.removeEventListener('click', onClick);
      layer.destroy();
      renderer.dispose();
    };
  }

  init();
  document.addEventListener('astro:page-load', init);
  document.addEventListener('astro:before-swap', () => {
    if (teardown) teardown();
    teardown = null;
  });
</script>

<style>
  .three-demo {
    max-width: 72rem;
    margin: 0 auto;
    padding: clamp(1.5rem, 4vw, 3rem) 1.25rem 4rem;
  }
  .three-demo__head {
    max-width: 46rem;
  }
  .three-demo__head h1 {
    margin: 0 0 0.5rem;
  }
  .three-demo__head p {
    color: var(--ink-2, #9fb0c4);
    line-height: 1.6;
  }
  .three-demo__controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 1.25rem 0 0;
    flex-wrap: wrap;
  }
  .three-demo__controls button {
    font: inherit;
    color: inherit;
    background: color-mix(in oklab, var(--accent, #4da3ff) 14%, transparent);
    border: 1px solid color-mix(in oklab, var(--accent, #4da3ff) 40%, transparent);
    border-radius: 0.5rem;
    padding: 0.4rem 0.9rem;
    cursor: pointer;
  }
  .three-demo__controls button:hover {
    background: color-mix(in oklab, var(--accent, #4da3ff) 24%, transparent);
  }
  .three-demo__count {
    font-variant-numeric: tabular-nums;
    color: var(--ink-2, #9fb0c4);
    font-size: 0.9rem;
  }
  .three-demo__stage {
    margin-top: 1.5rem;
    height: 66vh;
    min-height: 22rem;
    border-radius: 0.75rem;
    overflow: hidden;
    background: radial-gradient(120% 120% at 50% 30%, #0d1422 0%, #070a11 70%);
    border: 1px solid color-mix(in oklab, var(--accent, #4da3ff) 18%, transparent);
  }
  #three-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
