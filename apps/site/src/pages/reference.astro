---
import Base from '../layouts/Base.astro';
import { MANUAL_FORCES, MANUAL_PRESETS, MANUAL_CONDITIONS } from 'forces-ui';

// The complete definition, rendered from the single catalog in core (guaranteed by
// a test to match the registered forces exactly). The manual explains the system —
// and lives inside the field it describes.
const families = [
  {
    key: 'canonical',
    title: 'The canonical nine',
    note: 'The designed core (§6) — finite range, a soft (1 − d/d_max)ⁿ falloff, tuned for legibility on content bodies.',
  },
  {
    key: 'natural',
    title: 'Natural primitives',
    note: 'Real field laws (§20.10) — a true 1/d², the Lorentz force, Langevin agitation, diffusion and waves.',
  },
  {
    key: 'extended',
    title: 'Designed extended',
    note: 'Further designed forces and the two modifiers (§20.3) that wrap a sibling force.',
  },
] as const;

const byFamily = (k: string) => MANUAL_FORCES.filter((f) => f.family === k);
const count = MANUAL_FORCES.length;
---

<Base title="forces-ui — the Field Manual">
  <main class="manual">
    <header class="head">
      <a class="back" href="/">← forces-ui</a>
      <h1>The Field Manual</h1>
      <p class="lede">
        The complete definition of the field — every force with its law, the
        <code>data-*</code> attributes it reads, and what it does. {count} forces, composable
        on any element. This page lives inside the field it describes.
      </p>
    </header>

    <section class="demo" aria-hidden="true">
      <forces-cell id="demo-cell" force="vortex" color="#4da3ff"></forces-cell>
      <div class="switch" role="group">
        {
          ['attract', 'repel', 'vortex', 'stream', 'gravity', 'spring', 'buoyancy'].map((t) => (
            <button type="button" data-force={t} class={t === 'vortex' ? 'on' : ''}>
              {t}
            </button>
          ))
        }
      </div>
    </section>

    <script is:inline>
      (() => {
        const cell = document.getElementById('demo-cell');
        const btns = document.querySelectorAll('.switch button');
        btns.forEach((b) =>
          b.addEventListener('click', () => {
            cell.setAttribute('force', b.dataset.force);
            btns.forEach((x) => x.classList.toggle('on', x === b));
          }),
        );
      })();
    </script>

    {
      families.map((fam) => (
        <section class="fam">
          <div class="fam-head">
            <h2>{fam.title}</h2>
            <p class="note">{fam.note}</p>
          </div>
          <div class="grid">
            {byFamily(fam.key).map((f) => (
              <article class="card">
                <h3>
                  <code class="tok">{f.token}</code>
                  <span class="label">{f.label}</span>
                </h3>
                <pre class="formula">{f.formula}</pre>
                <p class="desc">{f.desc}</p>
                <p class="attrs">
                  {f.attrs.length === 0 ? (
                    <span class="none">sized by the element box</span>
                  ) : (
                    f.attrs.map((a) => <code>data-{a}</code>)
                  )}
                </p>
              </article>
            ))}
          </div>
        </section>
      ))
    }

    <section class="fam">
      <div class="fam-head">
        <h2>Presets</h2>
        <p class="note">
          Cosmology and weather as named arrangements of primitives (§20.9) — no new code, just
          composition. Author with <code>data-preset</code>.
        </p>
      </div>
      <div class="grid">
        {
          MANUAL_PRESETS.map((p) => (
            <article class="card">
              <h3>
                <code class="tok">{p.name}</code>
              </h3>
              <p class="compose">
                {p.tokens.map((t) => (
                  <code>{t}</code>
                ))}
              </p>
              <p class="desc">{p.desc}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="fam">
      <div class="fam-head">
        <h2>Conditions</h2>
        <p class="note">
          Gate any force to when it should act with <code>data-when</code> (§5).
        </p>
      </div>
      <ul class="conds">
        {
          MANUAL_CONDITIONS.map((c) => (
            <li>
              <code>{c.id}</code>
              <span>{c.desc}</span>
            </li>
          ))
        }
      </ul>
    </section>

    <footer class="foot">
      <span>forces-ui · the spec is the contract · docs/forces-system.md</span>
      <a href="/">← back to the field</a>
    </footer>
  </main>
</Base>

<style>
  .manual {
    position: relative;
    z-index: 2;
    align-self: flex-start;
    width: 100%;
    max-width: 1120px;
    margin: 0 auto;
    padding: clamp(2.5rem, 7vh, 5rem) clamp(1.2rem, 5vw, 3.5rem) 5rem;
  }
  .head {
    margin-bottom: clamp(2.5rem, 6vh, 4rem);
  }
  .back {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-3);
    text-decoration: none;
  }
  .back:hover {
    color: var(--accent);
  }
  h1 {
    font-size: clamp(2.4rem, 7vw, 4rem);
    font-weight: 700;
    margin: 0.6rem 0 0.8rem;
    letter-spacing: -0.03em;
  }
  .lede {
    max-width: 46ch;
    color: var(--text-2);
    line-height: 1.55;
    font-size: 1.02rem;
  }
  .demo {
    margin-top: clamp(1.5rem, 4vh, 2.5rem);
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  .demo forces-cell {
    display: block;
    width: 100%;
    height: clamp(160px, 26vh, 240px);
    border: 1px solid var(--line);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.015);
  }
  .switch {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .switch button {
    font-family: var(--mono);
    font-size: 0.74rem;
    color: var(--text-3);
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 0.32rem 0.7rem;
    cursor: pointer;
    transition:
      color 0.15s ease,
      border-color 0.15s ease;
  }
  .switch button:hover {
    color: var(--text);
  }
  .switch button.on {
    color: var(--accent);
    border-color: var(--accent);
  }
  .fam {
    margin-top: clamp(2.5rem, 6vh, 4rem);
  }
  .fam-head h2 {
    font-size: 1.5rem;
    margin: 0 0 0.4rem;
    letter-spacing: -0.02em;
  }
  .note {
    max-width: 60ch;
    color: var(--text-3);
    font-size: 0.92rem;
    line-height: 1.5;
    margin: 0 0 1.6rem;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 0.9rem;
  }
  .card {
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 1.1rem 1.15rem 1.2rem;
    background: rgba(255, 255, 255, 0.018);
    backdrop-filter: blur(3px);
  }
  .card h3 {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    margin: 0 0 0.7rem;
    font-weight: 500;
  }
  .tok {
    font-family: var(--mono);
    font-size: 0.86rem;
    color: var(--accent);
    background: rgba(77, 163, 255, 0.1);
    padding: 0.12rem 0.45rem;
    border-radius: 5px;
  }
  .label {
    font-size: 0.82rem;
    color: var(--text-3);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  .formula {
    font-family: var(--mono);
    font-size: 0.74rem;
    line-height: 1.5;
    color: var(--text);
    background: rgba(0, 0, 0, 0.32);
    border: 1px solid var(--line);
    border-radius: 7px;
    padding: 0.6rem 0.7rem;
    margin: 0 0 0.7rem;
    white-space: pre-wrap;
    word-break: break-word;
    overflow-wrap: anywhere;
  }
  .desc {
    color: var(--text-2);
    font-size: 0.92rem;
    line-height: 1.5;
    margin: 0 0 0.7rem;
  }
  .attrs,
  .compose {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin: 0;
  }
  .attrs code,
  .compose code {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--text-3);
    border: 1px solid var(--line);
    border-radius: 5px;
    padding: 0.1rem 0.4rem;
  }
  .none {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--text-3);
    font-style: italic;
  }
  .conds {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
    max-width: 60ch;
  }
  .conds li {
    display: flex;
    align-items: baseline;
    gap: 0.8rem;
  }
  .conds code {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--accent);
    min-width: 4.5rem;
  }
  .conds span {
    color: var(--text-2);
    font-size: 0.92rem;
  }
  .foot {
    margin-top: clamp(3rem, 8vh, 5rem);
    padding-top: 1.4rem;
    border-top: 1px solid var(--line);
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: space-between;
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--text-3);
  }
  .foot a {
    color: var(--text-3);
    text-decoration: none;
  }
  .foot a:hover {
    color: var(--accent);
  }
  /* the manual is long-form: don't vertically centre it like the hero */
  :global(body:has(.manual)) {
    align-items: flex-start;
  }
</style>
