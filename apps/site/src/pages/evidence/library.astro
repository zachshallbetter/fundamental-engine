---
import { logNormalizeBetween, weightToStrength } from "@fundamental-engine/core";
import ExampleShell from "../../components/examples/ExampleShell.astro";
import CodeTabs from "../../components/CodeTabs.astro";
import library from "../../data/examples/library.json";
import { FIELD_PALETTE } from "../../lib/palette.ts";
import { fmtInt } from "../../lib/fmt.ts";
import "../../styles/docs.css";
import "../../styles/examples/library.css";

// The Library Field — what the world actually plays. Each recording in ListenBrainz's
// sitewide monthly top 30 is a body; listens are mass (log-normalized). The queue panel is
// itself a field body — a sink with data-absorb — so the engine genuinely writes --load
// back into it as matter accretes; a separate, honestly-labeled UI bar counts queued
// tracks. At 8/8 the queue releases, mirroring the engine's capture→release cycle.
// No particle swarm — mass shows only in type weight, ink, and anchor.
const QUEUE_MAX = 8;

// the artist color lens: hash the artist name → FIELD_PALETTE index. The hash stays this
// page's (`>>> 0` accumulate + unsigned modulo) — palette.ts's hashColor folds with `| 0`
// and Math.abs, which lands ~a third of this snapshot's artists on different hues, so
// swapping it in would not be behavior-identical.
const hashOf = (s: string) => {
  let h = 0;
  for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) >>> 0;
  return h;
};

// mass = log-normalized listens (min..max → 0..1 across the set).
// --bar is a SECOND, separate channel: the raw listens as a fraction of the chart
// max (linear), driving each row's background bar length. --w stays the field's
// log-normalized mass and keeps driving type weight and ink.
const listens = library.tracks.map((t) => t.listens);
const lsMin = Math.min(...listens);
const lsMax = Math.max(...listens);
const maxListens = lsMax;
const tracks = library.tracks.map((t) => ({
  ...t,
  w: logNormalizeBetween(t.listens, lsMin, lsMax, { equal: 0 }),
  bar: t.listens / maxListens,
  cat: FIELD_PALETTE[hashOf(t.artist) % FIELD_PALETTE.length]!,
}));
const linkFor = (t: { mbid: string }) =>
  t.mbid ? `https://musicbrainz.org/recording/${t.mbid}` : "https://listenbrainz.org/";
const snapshotDay = library.snapshotAt.slice(0, 10);

// How-it's-built snippets — highlighted at build time via CodeTabs (Shiki).
const snippetSink = `<aside id="queue"
  data-body="sink"
  data-absorb
  data-max="8"
  data-feedback
  data-hot
>
  <!-- the queue panel -->
  <i aria-hidden="true"
    data-field-visual-for="#queue"
    data-field-visual-role="measurement"></i>
</aside>`;

const snippetEngine = `/* channel 1 — the ENGINE. Matter accretes
   into the sink and the field writes --load
   (0..1 fill) back each frame; the page
   engine also writes --d, its LIVE local
   density (data-hot gathers it on hold).
   The glow blends both. */
.lb-queue {
  --live: var(--d, 0);
  box-shadow: 0 0
    calc(4px + (var(--load, 0)
      + var(--live) * 0.5) * 28px)
    color-mix(in srgb, var(--accent)
      calc(var(--load, 0) * 45%
        + var(--live) * 18%),
      transparent);
}`;

const snippetUi = `// channel 2 — the UI. A plain counter:
// queued / 8. Data, not the field.
fill.style.width = \`\${n / 8 * 100}%\`;`;

const snippetCss = `.lb-title {
  font-variation-settings:
    'wght' calc(380 + var(--w) * 360);
}
/* the ladder: --bar = listens / max
   (linear), set server-side */
.lb-bararea::before {
  width: calc(var(--bar) * 100%);
  background: color-mix(in srgb,
    var(--cat) calc(10% + var(--w) * 12%),
    transparent);
}
/* the rows also receive the engine's
   live density (--d) and the recipe's
   eased attention (--field-attention) */
.lb-row {
  --live: var(--d, 0);
  --att: var(--field-attention, 0);
}`;
---

<ExampleShell
  title="Fundamental — Library"
  description="A music library run as a field over real ListenBrainz data. The month's most-listened recordings become bodies; listens are mass, written into type weight, ink, and anchor. The queue is a genuine field sink — the engine writes --load into it as matter accretes, and at 8/8 it releases. data-* in, --field-* out."
  current="library"
  mainClass="ex-library"
  mainAttrs={{ "data-field": "on", "data-lens": "artist" }}
>
  <header class="ev-hero">
    <p class="ev-kicker">Fundamental · invisible fields · library</p>
    <h1>What the world actually <span class="accent">plays</span>.</h1>
    <p class="ev-lede">
      Not editorial picks, not a mood algorithm — these are the {tracks.length} most-listened
      recordings across <a href="https://listenbrainz.org" rel="noopener">ListenBrainz</a> this
      {library.range}, sitewide. Listens are <strong>mass</strong>, and the page is a ranked
      ladder: each recording's bar runs as long as its real play count, while the log-scaled
      mass sets how hard its row pulls — heavier type, fuller ink. The shortest bar on the page
      is still a top-30 track; the longest is what the world could not stop playing.
    </p>
    <p class="ev-lede">
      The queue below is not a styled div — it is a <strong>field body</strong>: a sink with
      <code>data-absorb</code>, registered in the same scoped field as the rows. The engine
      genuinely writes its accreted fill back as <code>--load</code>, and CSS turns that into a
      glow. Queue eight tracks and the sink <strong>releases</strong> — the engine's
      capture→release cycle, played out in the page. The field is invisible — no particle
      swarm; only its measurements show. <strong>Toggle the field off</strong> and the live
      channels go dark — the ladder flattens, the glow dies — while the queue keeps counting:
      that channel is data, and it is honest about it.
    </p>
  </header>

  <!-- Controls — the mass made legible. -->
  <div class="ev-controls" role="group" aria-label="Field controls">
    <div class="ev-ctl">
      <span class="ev-ctl-l">Field</span>
      <button type="button" class="ev-switch" data-lb-field aria-pressed="true">
        <span class="ev-switch-dot" aria-hidden="true"></span>
        <span class="ev-switch-txt">on</span>
      </button>
    </div>
    <div class="ev-ctl">
      <span class="ev-ctl-l">Color by</span>
      <div class="ev-seg" role="group" aria-label="Color lens">
        <button type="button" data-lb-lens="artist" aria-pressed="true">artist</button>
        <button type="button" data-lb-lens="off" aria-pressed="false">off</button>
      </div>
    </div>
    <div class="ev-ctl">
      <span class="ev-ctl-l">Data</span>
      <span class="lb-status" data-lb-status title="counts refresh once per visit">snapshot · {snapshotDay}</span>
    </div>
    <p class="ev-ctl-hint">
      <span><b>bar length</b> = listens (linear) · <b>type weight</b> = the log-scaled mass</span>
      <span class="ev-hint-sep">·</span>
      <span data-lb-lens-hint><b>color</b> = artist — one palette hue per act, hashed from the name</span>
    </p>
  </div>

  <!-- Legend — reading the field. -->
  <ul class="ev-legend" aria-label="How to read the field">
    <li><span class="ev-k lb-k-bar" aria-hidden="true"></span> <b>bar length</b> = listens (linear share of the chart max)</li>
    <li><span class="ev-k ev-k-weight">Aa</span> <b>type weight</b> = listens as log-scaled mass</li>
    <li><span class="ev-k ev-k-anchor"></span> <b>color</b> = the lens (artist, or off) — it tints the bar</li>
    <li><span class="ev-k lb-k-sink"></span> the queue is a <b>sink</b> — the engine writes <code>--load</code> into it</li>
    <li><span class="ev-k lb-k-release"></span> at {QUEUE_MAX}/{QUEUE_MAX} the sink <b>releases</b> — capture, then let go</li>
    <li><span class="ev-k ev-k-live"></span> <b>glow</b> = the engine's live density (<code>--d</code>) — hold a row and the field gathers</li>
  </ul>

  <div class="lb-field" data-lb-scope>
    <!-- The queue — a real field sink. The engine writes --load; the fill bar is UI data. -->
    <aside
      class="lb-queue"
      id="lb-queue"
      data-lb-queue
      data-body="sink"
      data-absorb
      data-max={String(QUEUE_MAX)}
      data-feedback
      data-hot
      aria-label="Queue"
    >
      <div class="lb-queue-head">
        <span class="lb-queue-title">Queue</span>
        <span class="lb-queue-count" data-lb-count aria-live="polite">0 / {QUEUE_MAX}</span>
        <span
          class="lb-fill"
          title="UI fill — queued count, not the field"
          aria-hidden="true"
          data-field-visual-for="#lb-queue"
          data-field-visual-role="measurement"
        >
          <i data-lb-fill style="width:0%"></i>
        </span>
      </div>
      <ul class="lb-chips" data-lb-chips></ul>
      <p class="lb-queue-empty" data-lb-empty>
        Queue a track — at {QUEUE_MAX} the sink releases.
      </p>
      <p class="lb-release" role="status" data-lb-release hidden></p>
    </aside>

    <ol class="lb-list" data-lb-list>
      {
        tracks.map((t) => (
          <li
            class="lb-row"
            id={`r-${t.rank}`}
            data-body="attract"
            data-feedback
            data-hot
            data-range="200"
            data-strength={weightToStrength(t.w).toFixed(2)}
            data-artist-color={t.cat}
            data-mbid={t.mbid ?? ""}
            data-track={t.track}
            data-artist={t.artist}
            data-listens={t.listens}
            style={`--w:${t.w.toFixed(3)}; --cat:${t.cat}; --bar:${t.bar.toFixed(3)};`}
          >
            <span class="lb-rank">{String(t.rank).padStart(2, "0")}</span>
            <div
              class="lb-bararea"
              data-field-visual-for={`#r-${t.rank}`}
              data-field-visual-role="measurement"
            >
              <div class="lb-body">
                <a class="lb-title" href={linkFor(t)} target="_blank" rel="noopener">
                  {t.track}
                </a>
                <span class="lb-meta">
                  <span class="lb-artist">{t.artist}</span>
                  <span class="ev-meta-sep">·</span>
                  {t.release}
                </span>
              </div>
              <span class="lb-listens">
                <b>{fmtInt(t.listens)}</b>
                <span class="lb-listens-l">listens</span>
              </span>
            </div>
            <button
              class="lb-add"
              type="button"
              data-lb-add
              aria-label={`Queue "${t.track}" by ${t.artist}`}
            >
              + queue
            </button>
          </li>
        ))
      }
    </ol>
  </div>

  <!-- How it's built — the sink's two channels, labeled honestly. -->
  <section class="ev-how" aria-labelledby="lb-how-h">
    <h2 id="lb-how-h">How it's built</h2>
    <p class="ev-how-lede">
      Every recording is ordinary semantic HTML — an <code>&lt;li&gt;</code> whose
      log-normalized listens become <code>--w</code> and <code>data-strength</code>. The queue
      panel is a second kind of body: a <strong>sink</strong>. Both join one scoped field, and
      the panel's glow and the rows' type heft are driven by two different channels — one the
      engine writes, one the page counts. Live on top of those: <code>--w</code> is the
      server-computed weight, <code>--cat</code> the lens color, <code>--d</code> the engine's
      live local density (hold a row and the field gathers), and <code>--field-attention</code>
      the recipe's eased attention metric. The bars and the fill declare their provenance with
      <code>data-field-visual-for</code>, so each measurement is bound to its record.
    </p>

    <div class="ev-how-cols">
      <div class="ev-how-col">
        <p class="ev-how-label">1 — the queue is a field sink</p>
        <CodeTabs variants={[{ label: "HTML", lang: "html", code: snippetSink }]} />
        <ul class="ev-how-attrs">
          <li><code>data-body="sink"</code> — registers as an absorbing body</li>
          <li><code>data-absorb</code> — opt in to holding matter</li>
          <li><code>data-max="8"</code> — capacity before the sink saturates</li>
          <li><code>data-feedback</code> — receive <code>--load</code> writebacks</li>
          <li><code>data-hot</code> — the engine's live density (<code>--d</code>) gathers toward 1 while held</li>
          <li><code>data-field-visual-for</code> — binds the fill bar to the panel it measures</li>
        </ul>
      </div>

      <div class="ev-how-col">
        <p class="ev-how-label">2 — two channels, labeled honestly</p>
        <CodeTabs
          variants={[
            { label: "engine (CSS)", lang: "css", code: snippetEngine },
            { label: "UI (TS)", lang: "ts", code: snippetUi },
          ]}
        />
        <p class="ev-how-note">
          The glow is the field's own measurement of accretion; the fill bar is bookkeeping.
          Keeping the two apart is the point — at 8/8 the page clears the queue the way the
          engine's sink releases captured matter.
        </p>
      </div>

      <div class="ev-how-col">
        <p class="ev-how-label">3 — CSS reads the mass; the bar reads the count</p>
        <CodeTabs variants={[{ label: "CSS", lang: "css", code: snippetCss }]} />
        <p class="ev-how-note">
          <code>--w</code> is the log-normalized listen count — real plays in, type weight and
          ink out. <code>--bar</code> is the same count kept linear, so the bar lengths stay an
          honest chart. The rest is CSS. In the browser the counts refresh from the same
          ListenBrainz endpoint <strong>once per visit, on purpose</strong> — the monthly window
          moves daily, so polling would be theater. The snapshot's {tracks.length} recordings
          stay the page's bodies: tracks that fell out of the live top {tracks.length} dim
          rather than vanish, and new entrants wait for the next snapshot.
        </p>
        <div class="ev-how-ctas">
          <a href="/docs" class="ev-how-link">Read the docs →</a>
          <a href="/patterns" class="ev-how-link ev-how-link--dim">See patterns →</a>
        </div>
      </div>
    </div>
  </section>

  <footer class="ev-fineprint">
    <p>
      Listens are <strong>plays, not endorsements</strong> — a sitewide top-30 says what people
      actually queued this {library.range}, not what anyone thinks they should have. The
      committed snapshot ({snapshotDay}) ships in the HTML and is what renders without
      JavaScript; in the browser the page <strong>refreshes the counts once per visit</strong>
      from the same endpoint when the API is reachable — the bars and ranking re-settle, the
      bodies stay the snapshot's {tracks.length}. Data:
      <a href="https://listenbrainz.org" rel="noopener">ListenBrainz</a> sitewide top
      recordings ({library.range} window), CC0 / open data.
    </p>
    <p class="ev-built">
      <a href="/evidence">Back to the Evidence field →</a>
    </p>
  </footer>
</ExampleShell>

<script>
  import "../../components/examples/library-runtime.ts";
</script>
