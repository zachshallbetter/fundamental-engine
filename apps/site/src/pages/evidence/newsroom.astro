---
import { logNormalizeBetween, weightToStrength } from "@field-ui/core";
import ExampleShell from "../../components/examples/ExampleShell.astro";
import CodeTabs from "../../components/CodeTabs.astro";
import newsroom from "../../data/examples/newsroom.json";
import { fmtInt } from "../../lib/fmt.ts";
import "../../styles/docs.css";
import "../../styles/examples/newsroom.css";

// The Newsroom Field — field-ui as an invisible measurement layer over one day of Wikipedia's
// most-read articles. Pageviews are gravitational mass (what the world actually read anchors
// the page); the day-over-day change polarizes — rising warms, falling cools, new entries stay
// neutral. No particle swarm: the attention shows in the type.

// weight: log-normalized pageviews (the evidence trust math, retargeted at attention)
const views = newsroom.articles.map((a) => a.views);
const viewsMin = Math.min(...views);
const viewsMax = Math.max(...views);
const wOf = (v: number): number => logNormalizeBetween(v, viewsMin, viewsMax);

// polarity: the day-over-day move. Direction is hue (warm rising, cool falling), magnitude is
// intensity; articles with no prior-day count are new — neutral gray-blue, no fake direction.
// the runtime re-runs this same ramp when the lens changes.
const pctOf = (a: { views: number; priorViews: number | null }): number | null =>
  a.priorViews ? ((a.views - a.priorViews) / a.priorViews) * 100 : null;
const catFor = (pct: number | null): string => {
  if (pct === null) return "#8a93a6";
  const t = Math.min(1, Math.abs(pct) / 60);
  return pct >= 0
    ? `hsl(${Math.round(32 - t * 10)} ${Math.round(42 + t * 46)}% ${Math.round(56 + t * 8)}%)`
    : `hsl(${Math.round(208 + t * 12)} ${Math.round(34 + t * 46)}% ${Math.round(58 + t * 8)}%)`;
};

const badge = (pct: number | null): string =>
  pct === null ? "new" : `${pct >= 0 ? "▲" : "▼"} ${Math.abs(pct).toFixed(1)}%`;

const dayLabel = new Intl.DateTimeFormat("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
  timeZone: "UTC",
}).format(new Date(`${newsroom.day.replaceAll("/", "-")}T00:00:00Z`));
const snapDate = new Intl.DateTimeFormat("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
  timeZone: "UTC",
}).format(new Date(newsroom.snapshotAt));

const articles = [...newsroom.articles].sort((a, b) => a.rank - b.rank);

// the front page: a lead (rank 1), a two-column deck (ranks 2–7), and a dense
// three-column index for the rest — placement is part of the encoding.
const lead = articles[0]!;
const deck = articles.slice(1, 7);
const index = articles.slice(7);
const leadW = wOf(lead.views);
const leadPct = pctOf(lead);

// How-it's-built snippets — highlighted at build time via CodeTabs (Shiki).
const snippetBody = `<li
  data-body="attract"
  data-strength="1.87"
  data-feedback
  data-hot
  data-views="291972"
  data-prior="303010"
  style="--w: 0.920; --cat: hsl(212 38% 59%);"
>
  <!-- rank · title · views -->
</li>`;

const snippetCss = `.nw-row {
  /* --w = log-normalized views (0..1).
     --d = the engine's LIVE local density —
     data-hot gathers it toward 1 on hold. */
  --live: var(--d, 0);
  opacity: calc(0.58 + var(--w) * 0.42);
  border-left: 3px solid
    color-mix(in srgb,
      var(--cat) calc(18% + var(--w) * 82%),
      var(--line));
}
/* the index item nearest the viewport
   center sharpens — the recipe's eased
   attention metric, written per record */
.nw-index-item .nw-title {
  letter-spacing: calc(-0.01em
    + var(--field-attention, 0) * 0.01em);
}`;

const snippetRamp = `// day-over-day move → --cat:
// direction is hue, magnitude is
// intensity; no prior count = new.
const pct = prior
  ? ((views - prior) / prior) * 100
  : null;
if (pct === null) return "#8a93a6";
const t = Math.min(1, Math.abs(pct) / 60);
return pct >= 0
  ? \`hsl(\${32 - t * 10} …)\`  // warm
  : \`hsl(\${208 + t * 12} …)\`; // cool`;
---

<ExampleShell
  title="field-ui — Newsroom"
  description="One day of Wikipedia's most-read articles run as a field. Pageviews are gravitational mass — what the world actually read anchors the page — and the day-over-day change polarizes: rising warms, falling cools. No particle swarm; the attention shows in the type."
  current="newsroom"
  mainClass="ex-newsroom"
  mainAttrs={{ "data-field": "on", "data-lens": "trend" }}
>
  <header class="ev-hero">
    <p class="ev-kicker">field-ui · invisible fields · newsroom</p>
    <h1>Attention, <span class="accent">measured</span> — not claimed.</h1>
    <p class="ev-lede">
      A trending list asserts importance; a pageview count records it. These are the articles
      English Wikipedia readers <strong>actually read</strong> on <span data-nw-day-text>{dayLabel}</span> — the
      <a href="https://wikimedia.org/api/rest_v1/" rel="noopener">Wikimedia pageviews API</a>'s
      most-read ranking, run as a <strong>field</strong> and laid out like a front page.
      Pageviews become gravitational mass, and mass buys column inches: the most-read article
      takes the lead slot, the next six fill the deck, the rest settle into the index — with
      heavier type, darker ink, a stronger left rule the more the world read.
    </p>
    <p class="ev-lede">
      The day-over-day change <strong>polarizes</strong> each body: rising attention warms,
      falling attention cools, and the magnitude sets the intensity — a 3% drift barely
      registers, a 200% surge burns. Articles that weren't in the prior day's list at all read
      as <strong>new</strong>, in neutral gray — no fake direction. The placement is fixed —
      a front page is set in type — but the <strong>ink is alive</strong>: the engine writes
      its live local density back as <code>--d</code>, so holding a story makes the field
      gather around it, and the index item nearest the center of your view sharpens as you
      scroll. <strong>Toggle the field off</strong> and the ink flattens and the live channels
      go dark: the placement stays (it is the day's ranking), but the field's weighting lets go.
    </p>
  </header>

  <div class="ev-controls" role="group" aria-label="Field controls">
    <div class="ev-ctl">
      <span class="ev-ctl-l">Field</span>
      <button type="button" class="ev-switch" data-nw-field aria-pressed="true">
        <span class="ev-switch-dot" aria-hidden="true"></span>
        <span class="ev-switch-txt">on</span>
      </button>
    </div>
    <div class="ev-ctl">
      <span class="ev-ctl-l">Color by</span>
      <div class="ev-seg" role="group" aria-label="Color lens">
        <button type="button" data-nw-lens="trend" aria-pressed="true">trend</button>
        <button type="button" data-nw-lens="off" aria-pressed="false">off</button>
      </div>
    </div>
    <div class="ev-ctl">
      <span class="ev-ctl-l">Data</span>
      <span class="nw-status" data-nw-status title="checks for a newer edition once per visit">snapshot · {dayLabel}</span>
    </div>
    <p class="ev-ctl-hint">
      <span data-nw-hint><b>size & placement</b> = pageviews — the most-read story leads the page</span>
      <span class="ev-hint-sep">·</span>
      <span data-nw-lens-hint><b>color</b> = the day-over-day move — warm rising, cool falling, gray new</span>
    </p>
  </div>

  <p class="nw-dateline" data-nw-dateline>edition: {dayLabel} (UTC)</p>

  <ul class="ev-legend" aria-label="How to read the field">
    <li><span class="ev-k ev-k-weight">Aa</span> <b>size & placement</b> = pageviews — lead, deck, then the index</li>
    <li><span class="ev-k ev-k-anchor"></span> <b>color</b> = the cycle's direction — warm rising · cool falling</li>
    <li><span class="ev-k nw-k-new">new</span> = absent from the prior day's list</li>
    <li><span class="ev-k ev-k-live"></span> <b>ink</b> = alive — hold a story and the field gathers (<code>--d</code>); placement never moves</li>
  </ul>

  <div class="nw-front" data-nw-list data-nw-day={newsroom.day}>
    <article
      class="nw-row nw-lead"
      data-body="attract"
      data-feedback
      data-hot
      data-range="200"
      data-strength={weightToStrength(leadW).toFixed(2)}
      data-views={lead.views}
      data-prior={lead.priorViews ?? ""}
      style={`--w:${leadW.toFixed(3)}; --cat:${catFor(leadPct)};`}
    >
      <p class="nw-zone-l">The lead · rank 01</p>
      <a class="nw-title" href={lead.url} target="_blank" rel="noopener">
        {lead.title}
      </a>
      <p class="nw-lead-meta">
        <span class="nw-count">{fmtInt(lead.views)}</span>
        <span class="nw-count-l">views</span>
        <span class="nw-chg" data-dir={leadPct === null ? "new" : leadPct >= 0 ? "up" : "down"}>
          {badge(leadPct)}
        </span>
      </p>
    </article>

    <ol class="nw-deck" aria-label="Ranks 2 through 7">
      {
        deck.map((a) => {
          const w = wOf(a.views);
          const pct = pctOf(a);
          return (
            <li
              class="nw-row nw-deck-item"
              data-body="attract"
              data-feedback
              data-hot
              data-range="200"
              data-strength={weightToStrength(w).toFixed(2)}
              data-views={a.views}
              data-prior={a.priorViews ?? ""}
              style={`--w:${w.toFixed(3)}; --cat:${catFor(pct)};`}
            >
              <span class="nw-rank">{String(a.rank).padStart(2, "0")}</span>
              <a class="nw-title" href={a.url} target="_blank" rel="noopener">
                {a.title}
              </a>
              <span class="nw-meta-line">
                <span class="nw-count">{fmtInt(a.views)}</span>
                <span class="nw-count-l">views</span>
                <span class="nw-chg" data-dir={pct === null ? "new" : pct >= 0 ? "up" : "down"}>
                  {badge(pct)}
                </span>
              </span>
            </li>
          );
        })
      }
    </ol>

    <ol class="nw-index" aria-label="Ranks 8 and below">
      {
        index.map((a) => {
          const w = wOf(a.views);
          const pct = pctOf(a);
          return (
            <li
              class="nw-row nw-index-item"
              data-body="attract"
              data-feedback
              data-hot
              data-range="200"
              data-strength={weightToStrength(w).toFixed(2)}
              data-views={a.views}
              data-prior={a.priorViews ?? ""}
              style={`--w:${w.toFixed(3)}; --cat:${catFor(pct)};`}
            >
              <span class="nw-rank">{String(a.rank).padStart(2, "0")}</span>
              <a class="nw-title" href={a.url} target="_blank" rel="noopener">
                {a.title}
              </a>
              <span class="nw-meta-line">
                <span class="nw-count">{fmtInt(a.views)}</span>
                <span class="nw-count-l">views</span>
                <span class="nw-chg" data-dir={pct === null ? "new" : pct >= 0 ? "up" : "down"}>
                  {badge(pct)}
                </span>
              </span>
            </li>
          );
        })
      }
    </ol>
  </div>

  <section class="ev-how" aria-labelledby="nw-how-h">
    <h2 id="nw-how-h">How it's built</h2>
    <p class="ev-how-lede">
      Every article is an ordinary <code>&lt;li&gt;</code> with its raw counts in data
      attributes. field-ui reads them, runs an invisible field over the front page, and the type
      carries the measurement — pageviews as weight and placement, the day's swing as color. No
      canvas, no chart library. Four channels do the work: <code>--w</code> is the server-computed
      weight, <code>--cat</code> the lens color, <code>--d</code> the engine's live local density
      (hold a story and the field gathers), and <code>--field-attention</code> the recipe's eased
      attention metric, which sharpens the index item nearest the viewport center. Placement is
      fixed; only the ink is alive. In the browser the page also checks for a newer edition —
      <strong>once per visit, on purpose</strong>: the pageviews API publishes each finished day
      exactly once, so a polling loop would be theater. If a newer day exists, the front page is
      rebuilt from it — same shaping rules, same markup, same field — and the dateline moves.
    </p>

    <div class="ev-how-cols">
      <div class="ev-how-col">
        <p class="ev-how-label">1 — each article is a field body</p>
        <CodeTabs variants={[{ label: "HTML", lang: "html", code: snippetBody }]} />
        <ul class="ev-how-attrs">
          <li><code>data-strength</code> — gravitational mass from log-normalized pageviews</li>
          <li><code>data-views</code> / <code>data-prior</code> — the raw counts the lens reads</li>
          <li><code>--cat</code> — the polarity color the CSS mixes in</li>
          <li><code>data-hot</code> — the engine's live density (<code>--d</code>) gathers toward 1 while held</li>
        </ul>
      </div>

      <div class="ev-how-col">
        <p class="ev-how-label">2 — CSS reads the field's output</p>
        <CodeTabs variants={[{ label: "CSS", lang: "css", code: snippetCss }]} />
        <p class="ev-how-note">
          Weight, ink, font heft, and border intensity all read from one normalized attention
          score; the lead's headline ink and rule breathe with the live <code>--d</code> — the
          field drives the measurement; CSS drives the presentation.
        </p>
      </div>

      <div class="ev-how-col">
        <p class="ev-how-label">3 — the polarity ramp</p>
        <CodeTabs variants={[{ label: "TS", lang: "ts", code: snippetRamp }]} />
        <div class="ev-how-ctas">
          <a href="/docs" class="ev-how-link">Read the docs →</a>
          <a href="/recipes" class="ev-how-link ev-how-link--dim">See recipes →</a>
        </div>
      </div>
    </div>
  </section>

  <footer class="ev-fineprint">
    <p>
      Pageviews are <strong>attention, not importance</strong> — they say what the world read,
      not what mattered. The committed snapshot is the {dayLabel} edition (trend vs the prior
      day), taken {snapDate} (UTC) — that baseline ships in the HTML and is what renders without
      JavaScript. In the browser the page <strong>upgrades itself once per visit</strong> to the
      latest fully-available day when the API is reachable; the API publishes each finished day
      once, so a single check is the honest cadence. Data:
      <a href="https://wikimedia.org/api/rest_v1/" rel="noopener">Wikimedia pageviews
      API</a> (CC0).
    </p>
    <p class="ev-built">
      <a href="/evidence">← Back to the Evidence field</a>
    </p>
  </footer>
</ExampleShell>

<script>
  import "../../components/examples/newsroom-runtime.ts";
</script>
