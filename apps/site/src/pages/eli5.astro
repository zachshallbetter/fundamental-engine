<!-- Page orchestrator — reuses the home interaction runtime + field-line overlay (both scan the
     document for .stage / [data-body] / [data-drag] / [data-threads] / [data-attention-demo] etc.,
     so this page behaves exactly like the main home). Tears down on navigation so nothing leaks. -->
<script>
  import { initHomeRuntime } from "../components/home/HomeRuntime.ts";
  import { initStageFieldOverlay } from "../components/home/StageFieldOverlay.ts";

  let teardownRuntime: (() => void) | undefined;
  let teardownOverlay: (() => void) | undefined;

  function teardown() {
    teardownRuntime?.();
    teardownOverlay?.();
    teardownRuntime = undefined;
    teardownOverlay = undefined;
  }

  function init() {
    teardown(); // idempotent: drop any prior run before re-wiring
    if (!document.querySelector(".manual-shell")) return;
    teardownRuntime = initHomeRuntime();
    teardownOverlay = initStageFieldOverlay();
  }

  if (document.readyState !== "loading") init();
  else document.addEventListener("DOMContentLoaded", init);
  document.addEventListener("astro:page-load", init);
  document.addEventListener("astro:before-swap", teardown);
</script>

