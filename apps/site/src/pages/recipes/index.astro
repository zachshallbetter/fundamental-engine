---
import Base from '../../layouts/Base.astro';
import SiteNav from '../../components/SiteNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import VocabBadge from '../../components/VocabBadge.astro';
import { RECIPE_TIERS, FIRST_RELEASE_RECIPE_IDS, EXPERIMENTAL_RECIPES, type FieldRecipe } from '@field-ui/core';
import { metricTitle } from '../../lib/metric-lanes.ts';

// The recipes hub — the engine's own catalog of 64 portable `FieldRecipe`s across four tiers
// (RECIPE_TIERS: core/applied/systems/operational). Each card runs the REAL recipe live (lazily, via
// applyRecipe — see lib/recipe-preview.ts) and links to its full page at /recipes/[id]. Replaces the
// old static /recipes listing.
const FIELD_COLOR: Record<string, string> = {
  gravity: '#4da3ff', electromagnetic: '#2dd4bf', strong: '#a78bfa', weak: '#ff9d5c',
  diagnostic: '#9aa7b4', platform: '#9aa7b4',
};
const first = new Set(FIRST_RELEASE_RECIPE_IDS);
const fieldLabelOf = (r: FieldRecipe) =>
  r.naturalField != null ? r.naturalField[0]!.toUpperCase() + r.naturalField.slice(1) : 'Diagnostic / platform';

const total = RECIPE_TIERS.reduce((n, t) => n + t.recipes.length, 0);
const filters = [
  { key: 'all', label: `All (${total})` },
  { key: 'first', label: 'First release' },
  ...RECIPE_TIERS.map((t) => ({ key: t.key, label: t.label })),
  { key: 'gravity', label: 'Gravity' },
  { key: 'electromagnetic', label: 'Electromagnetic' },
  { key: 'strong', label: 'Strong' },
  { key: 'weak', label: 'Weak' },
  { key: 'other', label: 'Diagnostic / platform' },
];
---

<Base
  title="field-ui — Recipes"
  description={`The ${total} field-ui recipes across four tiers — portable field programs you can run live, read, and compose. Live previews, per-recipe pages, copyable HTML / web-component / React / JSON, and a from-scratch composer.`}
>
  <SiteNav />
  <main class="recipes-shell">
    <header class="rx-hero">
      <p class="kicker">field-ui · recipes</p>
      <h1>{total} recipes. Each one runs.</h1>
      <p class="lede">
        Portable <code>FieldRecipe</code>s — the four-field translation model made practical. Every card
        below runs the <i>real, validated</i> recipe (its runtime tokens, render stack, and diagnostics
        are checked against the engine catalog). Filter, watch one run, or open its page.
      </p>
      <p class="lede lede-lanes">
        Each keeps the vocabulary lanes separate: <VocabBadge kind="token" label="runtime tokens" /> execute,
        <VocabBadge kind="concept" label="concepts" /> name behavior,
        <VocabBadge kind="metric" label="metrics" /> measure state,
        <VocabBadge kind="diagnostic" label="diagnostics" /> explain it,
        <VocabBadge kind="condition" label="conditions" /> activate it.
      </p>
    </header>

    <div class="filters" role="group" aria-label="Filter recipes">
      {filters.map((f) => (
        <button
          class:list={['chip', { on: f.key === 'all', 'chip-field': !!FIELD_COLOR[f.key] }]}
          data-filter={f.key}
          type="button"
          style={FIELD_COLOR[f.key] ? `--chip-color: ${FIELD_COLOR[f.key]}` : undefined}
        >{f.label}</button>
      ))}
    </div>

    <div class="recipe-grid">
      {RECIPE_TIERS.flatMap((t) => t.recipes).map((r) => {
        const fieldKey = r.naturalField ?? 'other';
        const color = FIELD_COLOR[fieldKey] ?? '#9aa7b4';
        return (
          <article class="recipe-card" data-field={fieldKey} data-tier={r.tier} data-first={first.has(r.id) ? 'true' : 'false'} style={`--rc: ${color}`}>
            <header>
              <div class="rc-tags">
                <span class="rc-field">{fieldLabelOf(r)}</span>
                <span class="rc-tier">{r.tier}</span>
                {first.has(r.id) && <span class="rc-first">First release</span>}
              </div>
              <h2><a href={`/recipes/${r.id}`}>{r.name}</a></h2>
              <p class="intent">{r.intent}</p>
            </header>

            <div class="rc-preview" data-recipe-preview={r.id} aria-hidden="true"></div>

            <dl class="meta">
              <div><dt>Runtime tokens</dt><dd>{r.primitives.map((p) => <VocabBadge kind="token" label={p} />)}</dd></div>
              <div><dt>Metrics</dt><dd>{r.metrics.map((m) => <VocabBadge kind="metric" label={m} title={metricTitle(m)} />)}</dd></div>
              <div><dt>Render</dt><dd class="rc-render">{r.render.join(' · ')}</dd></div>
            </dl>

            <a class="rc-open" href={`/recipes/${r.id}`}>Open recipe →</a>
          </article>
        );
      })}
    </div>
    <p class="empty" hidden>No recipes match that filter.</p>

    <section class="rx-experimental" aria-labelledby="rx-exp-h">
      <header class="rx-exp-head">
        <h2 id="rx-exp-h">Experimental — Wayfinding</h2>
        <p>
          Two nav-chrome recipes that run the engine <i>signals-only</i> (no canvas) to drive the site's
          own navigation — the invisible-fields family applied to wayfinding (<em>where am I</em> /
          <em>where have I been</em>). Validated and live, but kept <b>outside the canonical {total}</b>
          while they prove out.
        </p>
      </header>
      <div class="recipe-grid">
        {EXPERIMENTAL_RECIPES.map((r) => {
          const fieldKey = r.naturalField ?? 'other';
          const color = FIELD_COLOR[fieldKey] ?? '#9aa7b4';
          return (
            <article class="recipe-card rx-exp-card" data-field={fieldKey} style={`--rc: ${color}`}>
              <header>
                <div class="rc-tags">
                  <span class="rc-field">{fieldLabelOf(r)}</span>
                  <span class="rc-status">{r.status}</span>
                </div>
                <h2><a href={`/recipes/${r.id}`}>{r.name}</a></h2>
                <p class="intent">{r.intent}</p>
              </header>

              <div class="rc-preview" data-recipe-preview={r.id} aria-hidden="true"></div>

              <dl class="meta">
                <div><dt>Runtime tokens</dt><dd>{r.primitives.map((p) => <VocabBadge kind="token" label={p} />)}</dd></div>
                <div><dt>Metrics</dt><dd>{r.metrics.map((m) => <VocabBadge kind="metric" label={m} title={metricTitle(m)} />)}</dd></div>
                <div><dt>Render</dt><dd class="rc-render">{r.render.join(' · ')}</dd></div>
              </dl>

              <a class="rc-open" href={`/recipes/${r.id}`}>Open recipe →</a>
            </article>
          );
        })}
      </div>
    </section>
  </main>
  <SiteFooter />
</Base>

<script>
  import { initRecipePreviews } from '../../lib/recipe-preview.ts';

  let teardown: (() => void) | undefined;
  function init() {
    // filters
    const cards = Array.from(document.querySelectorAll<HTMLElement>('.recipe-card'));
    const chips = Array.from(document.querySelectorAll<HTMLButtonElement>('.chip'));
    const empty = document.querySelector<HTMLElement>('.empty');
    const TIERS = new Set(['core', 'applied', 'systems', 'operational']);
    const apply = (key: string) => {
      let shown = 0;
      for (const card of cards) {
        const f = card.dataset.field ?? '';
        const tier = card.dataset.tier ?? '';
        const match = key === 'all' || (key === 'first' && card.dataset.first === 'true') || (TIERS.has(key) && key === tier) || key === f;
        card.hidden = !match;
        if (match) shown++;
      }
      if (empty) empty.hidden = shown > 0;
    };
    for (const chip of chips) chip.addEventListener('click', () => {
      chips.forEach((c) => c.classList.toggle('on', c === chip));
      apply(chip.dataset.filter ?? 'all');
    });
    // live previews (lazy, in-view, capped)
    teardown?.();
    teardown = initRecipePreviews({ max: 6 });
  }
  if (document.readyState !== 'loading') init();
  else document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('astro:page-load', init);
  document.addEventListener('astro:before-swap', () => { teardown?.(); teardown = undefined; });
</script>

<style>
  .recipes-shell { position: relative; z-index: 2; width: 100%; max-width: 78rem; margin: 0 auto; padding: 5.5rem 1.5rem 4rem; }
  .rx-hero { max-width: 60rem; }
  .kicker { font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted, #9aa); margin: 0; }
  .rx-hero h1 { font-size: clamp(2rem, 5vw, 3.2rem); margin: 0.4rem 0 0.6rem; line-height: 1.05; }
  .lede { color: var(--muted, #9aa); max-width: 70ch; }
  .lede a { color: #4da3ff; }
  .lede-lanes { font-size: 0.9rem; display: flex; flex-wrap: wrap; gap: 0.3rem; align-items: baseline; }
  .filters { display: flex; flex-wrap: wrap; gap: 0.4rem; margin: 1.5rem 0 0.5rem; }
  .chip { display: inline-flex; align-items: center; gap: 0.4rem; border: 1px solid var(--line, #2a2a35); background: transparent; color: var(--text, #e8e8ef); border-radius: 999px; padding: 0.25rem 0.8rem; font-size: 0.82rem; cursor: pointer; }
  .chip.on { background: color-mix(in srgb, var(--chip-color, #4da3ff) 22%, transparent); border-color: var(--chip-color, #4da3ff); }
  /* a field chip carries its natural-field color as a leading dot — the field's identity at a glance */
  .chip-field::before { content: ''; width: 7px; height: 7px; border-radius: 50%; background: var(--chip-color, var(--accent)); flex: none; }
  .recipe-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.1rem; margin-top: 1rem; }
  .recipe-card[hidden] { display: none; }
  .recipe-card { display: flex; flex-direction: column; border: 1px solid var(--line, #2a2a35); border-top: 3px solid var(--rc, #4da3ff); border-radius: 12px; padding: 1rem 1.1rem; background: color-mix(in srgb, var(--text, #fff) 2.5%, transparent); }
  .rc-tags { display: flex; gap: 0.4rem; align-items: center; flex-wrap: wrap; font-size: 0.72rem; }
  .rc-field { color: var(--rc, #4da3ff); font-weight: 600; }
  .rc-tier { color: var(--muted, #9aa); text-transform: capitalize; }
  .rc-first { color: #ffd479; border: 1px solid color-mix(in srgb, #ffd479 40%, transparent); border-radius: 999px; padding: 0 0.4rem; }
  .recipe-card h2 { font-size: 1.15rem; margin: 0.45rem 0 0.2rem; }
  .recipe-card h2 a { text-decoration: none; }
  .recipe-card h2 a:hover { color: var(--rc, #4da3ff); }
  .intent { color: var(--muted, #9aa); font-size: 0.88rem; margin: 0 0 0.7rem; }
  .rc-preview { position: relative; min-height: 116px; border: 1px solid var(--line, #2a2a35); border-radius: 10px; background: radial-gradient(120% 120% at 50% 40%, color-mix(in srgb, var(--rc) 8%, transparent), transparent 70%); display: flex; flex-wrap: wrap; gap: 0.4rem; align-items: center; justify-content: center; padding: 0.7rem; overflow: hidden; }
  .meta { display: grid; gap: 0.4rem; margin: 0.8rem 0 0.6rem; }
  .meta > div { display: grid; grid-template-columns: 8rem 1fr; gap: 0.5rem; align-items: baseline; }
  .meta dt { color: var(--muted, #9aa); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.04em; margin: 0; }
  .meta dd { margin: 0; display: flex; flex-wrap: wrap; gap: 0.25rem; }
  .rc-render { font-family: ui-monospace, monospace; font-size: 0.78rem; color: var(--muted, #c3c9d4); }
  .rc-open { margin-top: auto; font-size: 0.84rem; color: var(--rc, #4da3ff); text-decoration: none; padding-top: 0.4rem; }
  .rc-open:hover { text-decoration: underline; }
  .empty { color: var(--muted, #9aa); margin-top: 1.5rem; }
  .rx-experimental { margin-top: 3rem; border-top: 1px dashed var(--line, #2a2a35); padding-top: 1.6rem; }
  .rx-exp-head { max-width: 60rem; margin-bottom: 1rem; }
  .rx-exp-head h2 { font-size: 1.4rem; margin: 0 0 0.4rem; }
  .rx-exp-head p { color: var(--muted, #9aa); font-size: 0.9rem; max-width: 70ch; }
  .rx-exp-card { border-top-style: dashed; }
  .rc-status { color: #ff9d5c; text-transform: capitalize; }
  @media (max-width: 560px) { .meta > div { grid-template-columns: 1fr; } }
</style>
