---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeTabs from '../../components/CodeTabs.astro';
import SeeAlso from '../../components/SeeAlso.astro';
import VocabLegend from '../../components/VocabLegend.astro';
import VocabBadge from '../../components/VocabBadge.astro';
import { FIELD_RECIPES, RECIPE_TIERS, FIRST_RELEASE_RECIPE_IDS, recipeById, serializeRecipe } from 'field-ui';

// The Recipe Model page: how a FieldRecipe separates the vocabulary lanes, the schema, the strict rule
// (prose expressive, runtime tokens real), and the concept->token mapping. Counts are data-driven.
const schema = `type FieldRecipe = {
  id: string;
  name: string;
  intent: string;
  tier: "core" | "workflow" | "professional" | "enterprise";
  naturalField?: "gravity" | "electromagnetic" | "strong" | "weak";  // FIELD lane (conceptual)
  translation?: string;                  // a short natural-field phrase

  // ── the lanes — a word lives in exactly one ───────────────────────────
  primitives: ForceToken[];   // RUNTIME TOKEN — strict, passported, conformance-gated
  concepts?:  string[];       // CONCEPT       — orbit, spring, trust, staleness
  metrics:    string[];       // METRIC        — mass, attention, pressure, confidence
  diagnostics:string[];       // DIAGNOSTIC    — potential, topology, causality
  conditions?:string[];       // CONDITION     — dwell, threshold, stale, in-view

  bodies: BodyRecipe[];       // how the runtime tokens are authored on elements
  render: RenderLayer[];
  accessibility: {            // required — no recipe is motion-only
    reducedMotion: string;
    meaningWithoutMotion: string;
  };
  status: "shipped" | "experimental" | "planned" | "conceptual";
};`;

const MAPPING: [string, string, string][] = [
  ['mass', 'metric', 'a measured property — use gravity / attract as the token'],
  ['potential', 'diagnostic', 'a field-sampling overlay — never a token'],
  ['spring', 'concept', 'runtime token: tether'],
  ['drag', 'concept', 'runtime token: viscosity'],
  ['reflect', 'concept', 'runtime token: wall'],
  ['absorb', 'concept', 'runtime token: sink'],
  ['threshold', 'condition', 'runtime token: gate (if a gate is intended)'],
  ['orbit', 'concept', 'composed from gravity + magnetism + tether'],
  ['emitter', 'concept', 'runtime token: spawn'],
  ['phase / decay', 'concept', 'runtime token: morph / memory'],
  ['trust / risk / confidence', 'metric', 'measured state — never a token'],
];

const example = serializeRecipe(recipeById('guided-flow')!);
const tokenCount = new Set(FIELD_RECIPES.flatMap((r) => r.primitives)).size;
---

<DocsLayout
  title="field-ui — Recipe model"
  description="The FieldRecipe model: how a recipe separates runtime tokens, concepts, metrics, diagnostics, and conditions into distinct lanes. Recipe prose can be expressive; runtime tokens must be real and conformance-gated."
>
  <header class="docs-hero">
    <p class="kicker">Recipes</p>
    <h1>The <span class="accent">recipe model</span></h1>
    <p class="lede">
      A <code>FieldRecipe</code> is a portable, serializable field program — the reusable unit that
      connects the natural-field model, engine primitives, DOM authoring, platform feedback, diagnostics,
      and the accessibility fallback. The catalog ships
      <b>{FIELD_RECIPES.length}</b> recipes across <b>{RECIPE_TIERS.length}</b> tiers
      (<b>{FIRST_RELEASE_RECIPE_IDS.length}</b> first-release), composed from {tokenCount} distinct runtime
      tokens. See them all in the <a href="/docs/gallery">recipe gallery</a>.
    </p>
  </header>

  <div class="callout">
    <b>Recipe prose can be expressive. Runtime tokens must be real.</b> A recipe may say “completion
    releases pressure and decays into memory,” but its runtime fields stay strict:
    <code>primitives: ["morph", "memory"]</code>. The conformance gate rejects any recipe whose
    primitives are not real passported tokens — or that puts a diagnostic, metric, condition, or concept
    in the token lane.
  </div>

  <section class="docs-sec">
    <h2>The vocabulary lanes</h2>
    <p>A recipe separates these on purpose. A word lives in exactly one lane, and the lane says which:</p>
    <VocabLegend />
  </section>

  <section class="docs-sec">
    <h2>The schema</h2>
    <CodeTabs variants={[{ label: 'FieldRecipe', lang: 'ts', code: schema }]} />
  </section>

  <section class="docs-sec">
    <h2>Concept → token mapping</h2>
    <p>
      When a product word is not a real engine token, it goes to its proper lane — it is never invented
      as a force. No new force tokens are added for recipes.
    </p>
    <table class="rm-table">
      <thead><tr><th>Concept word</th><th>Lane</th><th>Resolution</th></tr></thead>
      <tbody>
        {MAPPING.map(([word, lane, res]) => (
          <tr>
            <td><VocabBadge kind="concept" label={word} /></td>
            <td><VocabBadge kind={lane} /></td>
            <td>{res}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="docs-sec">
    <h2>A worked recipe</h2>
    <p>
      Every recipe is plain, serializable data. This is <code>Guided Flow</code> straight from the
      catalog — note the strict <code>primitives</code> beside the expressive <code>notes</code>:
    </p>
    <CodeTabs variants={[{ label: 'guided-flow.json', lang: 'json', code: example }]} />
  </section>

  <section class="docs-sec">
    <h2>What the conformance gate enforces</h2>
    <ul class="rm-rules">
      <li>Every <VocabBadge kind="token" label="runtime token" /> is a real, passported engine force.</li>
      <li>No token is a <VocabBadge kind="diagnostic" label="diagnostic" />, <VocabBadge kind="metric" label="metric" />, <VocabBadge kind="condition" label="condition" />, or <VocabBadge kind="concept" label="concept" />.</li>
      <li>Declared <code>primitives</code> exactly match the body tokens (no drift).</li>
      <li>Every <VocabBadge kind="diagnostic" label="diagnostic" /> is a real render / inspection mode.</li>
      <li>Every <VocabBadge kind="field" label="natural field" /> is one of gravity / electromagnetic / strong / weak.</li>
      <li>Every recipe declares a reduced-motion equivalent — no recipe is motion-only.</li>
    </ul>
  </section>

  <section class="docs-sec">
    <h2>Data binding — <code>bindData()</code></h2>
    <p>
      Recipes make behavior portable; <code>bindData()</code> makes real records participate in it.
      Records become bodies, mapped metrics become state, mapped relationships become edges, and a
      recipe supplies the behavior. Updates are deterministic and removed records decay rather than pop.
    </p>
    <div class="bd-demo">
      <div class="bd-controls" role="group" aria-label="Data binding demo">
        <button type="button" class="sc-btn" data-bd="add">Add record</button>
        <button type="button" class="sc-btn" data-bd="remove">Remove one</button>
        <button type="button" class="sc-btn" data-bd="shuffle">Shuffle values</button>
        <span class="bd-status" data-bd-status>—</span>
      </div>
      <div class="bd-stage" data-bd-stage></div>
    </div>
  </section>

  <SeeAlso
    links={[
      { href: '/docs/gallery', label: 'Recipe gallery' },
      { href: '/docs/natural-fields', label: 'Natural fields' },
      { href: '/docs/authoring', label: 'Authoring across surfaces' },
    ]}
  />
</DocsLayout>

<script>
  import { bindData } from '@field-ui/platform';

  const stage = document.querySelector<HTMLElement>('[data-bd-stage]');
  const status = document.querySelector<HTMLElement>('[data-bd-status]');
  if (stage) {
    interface Rec { id: string; title: string; relevance: number; confidence: number; }
    const titles = ['Field translation runtime', 'Reciprocal DOM interfaces', 'Reduced-motion equivalence', 'Relationship graph recovery', 'Evidence-aware AI answers', 'Dashboard weather', 'Host-driven core'];
    let seq = 0;
    const rnd = () => Math.round(Math.random() * 100) / 100;
    const make = (): Rec => { const id = `r${seq++}`; return { id, title: titles[seq % titles.length]!, relevance: rnd(), confidence: rnd() }; };
    let records: Rec[] = Array.from({ length: 4 }, make);

    const mapper = (r: Rec) => ({
      id: r.id,
      body: { tokens: ['attract', 'memory'], strength: 0.4 + r.relevance, range: 240, feedback: true },
      metrics: { confidence: r.confidence, priority: r.relevance },
      label: r.title,
    });

    const binding = bindData(stage, records, mapper, { recipe: 'trust-gradient', className: 'bd-rec' });

    const loop = (): void => {
      const ins = binding.inspect();
      if (status) status.textContent = ins ? `${ins.records} records · ${ins.bodies} bodies · ${ins.relationships} relationships` : `${records.length} records`;
      requestAnimationFrame(loop);
    };
    requestAnimationFrame(loop);

    for (const btn of document.querySelectorAll<HTMLButtonElement>('[data-bd]')) {
      btn.addEventListener('click', () => {
        const k = btn.dataset.bd;
        if (k === 'add') records = [...records, make()];
        else if (k === 'remove') records = records.slice(0, -1);
        else if (k === 'shuffle') records = records.map((r) => ({ ...r, relevance: rnd(), confidence: rnd() }));
        binding.update(records);
      });
    }
    document.addEventListener('astro:before-swap', () => binding.destroy(), { once: true });
  }
</script>

<style>
  .bd-demo { border: 1px solid var(--line, #2a2a35); border-radius: 10px; padding: 0.8rem; margin-top: 0.6rem; }
  .bd-controls { display: flex; flex-wrap: wrap; gap: 0.4rem; align-items: center; margin-bottom: 0.7rem; }
  .bd-status { font: 0.76rem ui-monospace, monospace; color: var(--muted, #9aa); margin-left: auto; }
  .bd-stage { display: flex; flex-direction: column; gap: 0.4rem; min-height: 60px; }
  .bd-rec {
    --field-confidence: 0;
    padding: 0.4rem 0.7rem; border-radius: 7px; font-size: 0.9rem;
    border: 1px solid var(--line, #2a2a35);
    border-left: 3px solid color-mix(in srgb, #2dd4bf calc(var(--field-confidence) * 95%), color-mix(in srgb, #ff9d5c 55%, transparent));
    background: color-mix(in srgb, #2dd4bf calc(var(--field-confidence) * 12%), transparent);
    opacity: 1; transition: opacity 0.35s ease, background 0.4s ease, border-color 0.4s ease, transform 0.35s ease;
  }
  .bd-rec[data-bd-entering] { opacity: 0; transform: translateY(-4px); }
  .bd-rec[data-bd-exiting] { opacity: 0; transform: translateX(8px); }
  @media (prefers-reduced-motion: reduce) { .bd-rec { transition: none; } }
</style>
<style>
  .lede { color: var(--text-3, #9aa); max-width: 72ch; }
  .rm-table { width: 100%; border-collapse: collapse; font-size: 0.88rem; margin-top: 0.5rem; }
  .rm-table th, .rm-table td { text-align: left; padding: 0.35rem 0.6rem; border-bottom: 1px solid var(--line, #2a2a35); vertical-align: middle; }
  .rm-table th { color: var(--text-3, #9aa); font-weight: 600; }
  .rm-rules { line-height: 2; font-size: 0.92rem; }
</style>
