---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import SeeAlso from '../../../components/SeeAlso.astro';
import { MANUAL_FORCES, classifyForce } from 'field-ui';
import '../../../styles/force-glyphs.css';

const families = [
  { key: 'canonical', label: 'Canonical nine', blurb: 'The bounded, UI-legible verbs — what a body does to nearby matter. Designed forces, not natural translations.' },
  { key: 'natural', label: 'Natural primitives', blurb: 'Engine expressions of the four fundamental fields — see the Natural Fields model.' },
  { key: 'extended', label: 'Designed extended', blurb: 'Pure per-particle effects — bends, gates, phase changes, modifiers, and strong/weak analogues.' },
] as const;
const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
// Natural-field badge per force, from the engine's classification (config/manual.ts).
const FIELD_COLOR: Record<string, string> = { gravity: '#4da3ff', electromagnetic: '#2dd4bf', strong: '#a78bfa', weak: '#ff9d5c' };
const FIELD_LABEL: Record<string, string> = { gravity: 'gravity', electromagnetic: 'EM', strong: 'strong', weak: 'weak' };
const badgeFor = (token: string) => {
  const { kind, field } = classifyForce(token);
  return field ? { text: FIELD_LABEL[field] ?? field, color: FIELD_COLOR[field], title: `${kind} · ${field} field` } : { text: kind ?? '', color: '', title: kind ?? '' };
};
// The forces the Field Cell poster engine can render live (cell-force.ts).
const CELL_FORCES = new Set(['attract', 'repel', 'swirl', 'gravity', 'stream', 'buoyancy', 'tether']);
---

<DocsLayout
  title="field-ui — Forces reference"
  description="Every force in field-ui, generated from the engine's catalog: the canonical nine, the natural primitives, and the designed-extended forces — each with its per-frame law, the data-* attributes it reads, a description, and a real-world example."
>
  <header class="docs-hero">
    <p class="kicker">API reference</p>
    <h1>The <span class="accent">{MANUAL_FORCES.length} forces</span></h1>
    <p class="lede">
      Compose them on any <code>data-body</code> element, space-separated. Each card is generated
      from the engine's own catalog — the law, the attributes it reads, and a real-world use.
    </p>
  </header>

  <div class="callout">
    <b>Natural fields, not a flat list.</b> Each card carries a badge from the engine's classification:
    a fundamental-field parent (<span class="rc-kind" style="--kc:#4da3ff">gravity</span>
    <span class="rc-kind" style="--kc:#2dd4bf">EM</span>
    <span class="rc-kind" style="--kc:#a78bfa">strong</span>
    <span class="rc-kind" style="--kc:#ff9d5c">weak</span>) or a kind (<span class="rc-kind">designed</span>,
    <span class="rc-kind">derived</span>, <span class="rc-kind">transport</span>, <span class="rc-kind">metric</span>).
    See the <a href="/docs/natural-fields">Natural Fields</a> model.
  </div>

  {
    families.map((fam) => {
      const list = MANUAL_FORCES.filter((f) => f.family === fam.key);
      return (
        <section class="docs-sec">
          <h2>{fam.label}</h2>
          <p>{fam.blurb} <span style="color:var(--text-4)">({list.length})</span></p>
          <div class="ref-grid">
            {list.map((f) => (
              <article class="ref-card" id={`force-${f.token}`} style={`--c:${f.color}`}>
                <div class="rc-head">
                  <i class={`fg fg-${f.token}`} style={`--fc:${f.color}`} />
                  <code>{f.token}</code>
                  {(() => { const b = badgeFor(f.token); return b.text ? <span class="rc-kind" style={b.color ? `--kc:${b.color}` : ''} title={b.title}>{b.text}</span> : null; })()}
                  {CELL_FORCES.has(f.token) && <span class="rc-live">live</span>}
                </div>
                {CELL_FORCES.has(f.token) && (
                  <div class="rc-cell">
                    <field-cell force={f.token} color={f.color} />
                  </div>
                )}
                <code class="rc-formula">{f.formula}</code>
                <p class="rc-desc">{cap(f.desc)}.</p>
                <div class="rc-meta">
                  {f.attrs.length ? (
                    f.attrs.map((a) => <span class="chip">data-{a}</span>)
                  ) : (
                    <span class="chip">no params</span>
                  )}
                </div>
                <p class="rc-eg">{f.example}</p>
              </article>
            ))}
          </div>
        </section>
      );
    })
  }

  <SeeAlso
    links={[
      { href: '/docs/natural-fields', label: 'Natural fields' },
      { href: '/docs/api/attributes', label: 'data-* attributes' },
      { href: '/docs/api/presets', label: 'Presets' },
      { href: '/docs/api/catalog', label: 'Conditions, formations & modes' },
    ]}
  />
</DocsLayout>

<style>
  .rc-kind {
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.04em;
    padding: 0.1rem 0.4rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--kc, var(--text-4)) 55%, var(--line));
    color: var(--kc, var(--text-3));
    background: color-mix(in srgb, var(--kc, transparent) 12%, transparent);
    white-space: nowrap;
  }
  .rc-head { display: flex; align-items: center; gap: 0.45rem; flex-wrap: wrap; }
</style>
