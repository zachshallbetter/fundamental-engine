---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import SeeAlso from '../../../components/SeeAlso.astro';

// Parity matrix — machine-generated from source, regenerated when a new method is added to any plane.
// Source of truth: docs/canonical/parity-matrix.md
// JS methods: packages/core/src/core/types.ts (FieldHandle interface)
// Swift methods: swift/Sources/FundamentalVanilla/FieldEngine.swift
// Kotlin methods: android/fundamental-core/src/main/kotlin/com/fundamental/core/runtime/FieldHandle.kt
// Three.js: packages/three/src/layer.ts (FieldLayer delegates all 44 to the wrapped FieldHandle)

interface ParityRow {
  method: string;
  swift: boolean;
  kotlin: boolean;
  three: boolean;
  note?: string;
}

const METHODS: ParityRow[] = [
  { method: 'scan',                 swift: true,  kotlin: true,  three: true  },
  { method: 'rescan',               swift: true,  kotlin: true,  three: true,  note: 'alias of scan' },
  { method: 'setAccent',            swift: true,  kotlin: true,  three: true  },
  { method: 'setPalette',           swift: true,  kotlin: true,  three: true  },
  { method: 'setFormation',         swift: true,  kotlin: true,  three: true  },
  { method: 'setWaveStyle',         swift: true,  kotlin: true,  three: true  },
  { method: 'setWaveCenter',        swift: true,  kotlin: true,  three: true  },
  { method: 'setSeparation',        swift: true,  kotlin: true,  three: true,  note: 'Kotlin fun setSeparation(Float) coexists with var separation via @JvmName on the property' },
  { method: 'setAttention',         swift: true,  kotlin: true,  three: true  },
  { method: 'setCausality',         swift: true,  kotlin: true,  three: true  },
  { method: 'setHeatmap',           swift: true,  kotlin: true,  three: true  },
  { method: 'setDprCap',            swift: true,  kotlin: true,  three: true,  note: 'Three.js delegates but DPR is renderer-owned; native stores in FieldOptions / FieldHandle' },
  { method: 'setQualityTier',       swift: true,  kotlin: true,  three: true  },
  { method: 'setRender',            swift: true,  kotlin: true,  three: true,  note: 'render surface is host-owned on native + Three.js; Kotlin host reads renderMode' },
  { method: 'setOverlay',           swift: true,  kotlin: true,  three: true,  note: 'use threeBackend() for Three.js diagnostic overlays' },
  { method: 'setBackground',        swift: true,  kotlin: true,  three: true,  note: 'web canvas clearing; native stores in FieldOptions.background' },
  { method: 'threads',              swift: true,  kotlin: true,  three: true,  note: 'visual layer — glowing connector lines' },
  { method: 'burst',                swift: true,  kotlin: true,  three: true  },
  { method: 'flowTo',               swift: true,  kotlin: true,  three: true  },
  { method: 'clearFlow',            swift: true,  kotlin: true,  three: true  },
  { method: 'seed',                 swift: true,  kotlin: true,  three: true  },
  { method: 'addAgent',             swift: true,  kotlin: true,  three: true,  note: 'AgentSpec / AgentHandle; Kotlin init-block wires tickAgents() via onAfterTick; Swift uses UUID-keyed agent list' },
  { method: 'addBody',              swift: true,  kotlin: true,  three: true  },
  { method: 'addEdge',              swift: true,  kotlin: true,  three: true  },
  { method: 'readEdges',            swift: true,  kotlin: true,  three: true  },
  { method: 'addField',             swift: true,  kotlin: true,  three: true  },
  { method: 'sampleField',          swift: true,  kotlin: true,  three: true  },
  { method: 'atomAt',               swift: true,  kotlin: true,  three: true  },
  { method: 'focusAt',              swift: true,  kotlin: true,  three: true  },
  { method: 'clearFocus',           swift: true,  kotlin: true,  three: true  },
  { method: 'particleCount',        swift: true,  kotlin: true,  three: true  },
  { method: 'energy',               swift: true,  kotlin: true,  three: true  },
  // ── substrate read API (critical-path 02/03) — mirrored to the native cores ──
  { method: 'query',                swift: true,  kotlin: true,  three: true,  note: 'structured read of bodies/metrics/relationships; the influences/projections/dimensions lanes stay empty on the ports until an accumulator/registry/dimension lane lands (JS field names kept)' },
  { method: 'snapshot',             swift: true,  kotlin: true,  three: true,  note: 'point-in-time field capture; body data withheld by default (tightest-wins profile)' },
  { method: 'diff',                 swift: true,  kotlin: true,  three: true,  note: 'pure comparison of two snapshots — added/removed/changed bodies, metric deltas, relationship + formation changes' },
  { method: 'replay',               swift: true,  kotlin: true,  three: true,  note: 'causal replay over a snapshot pair; force-attributed steps empty-for-now on the ports (no impulse accumulator yet)' },
  { method: 'projections',          swift: false, kotlin: true,  three: true,  note: 'projection registry — JS core + web + Kotlin (agent-json + callback surfaces); Swift port in progress; css/dom/svg surfaces are web-first' },
  { method: 'forAgent',             swift: true,  kotlin: true,  three: true,  note: 'capability-scoped, redacted, read-only agent view (agent-readable is not agent-writable)' },
  { method: 'sample',               swift: true,  kotlin: true,  three: true,  note: 'force-probe at world point; Swift delegates to forceAt(); Kotlin delegates to controller.sample() → forceAt()' },
  { method: 'sampleScalar',         swift: true,  kotlin: true,  three: true  },
  { method: 'sampleGradient',       swift: true,  kotlin: true,  three: true  },
  { method: 'grid',                 swift: true,  kotlin: true,  three: true,  note: 'named ScalarGrid — lazy get/create, same grid as env.grid in the force system' },
  { method: 'on',                   swift: true,  kotlin: true,  three: true,  note: 'UUID-keyed subscriber bus; FieldEvent enum (tick/bodyAdd/bodyRemove/particleCapture/supernova); returns Subscription' },
  { method: 'readParticles',        swift: true,  kotlin: true,  three: true  },
  { method: 'readParticleIds',      swift: true,  kotlin: true,  three: true,  note: 'Particle.id (stable, auto-incremented by FieldStore.add); fills an Int buffer' },
  { method: 'readParticleChannels', swift: true,  kotlin: true,  three: true,  note: 'samples named ScalarGrids at each particle position; stride = names.count/size' },
  { method: 'registerOverlay',      swift: true,  kotlin: true,  three: true,  note: 'OverlayRenderer protocol/interface; host reads overlayRegistry and calls render() each frame' },
  { method: 'scrollV',              swift: true,  kotlin: true,  three: true,  note: 'DOM/UIKit scroll velocity; Kotlin: scrollV() + feedScrollV(); Three.js returns 0 in headless' },
  { method: 'setVisible',           swift: true,  kotlin: true,  three: true  },
  { method: 'destroy',              swift: true,  kotlin: true,  three: true  },
];

const swiftCount  = METHODS.filter(m => m.swift).length;
const kotlinCount = METHODS.filter(m => m.kotlin).length;
const threeCount  = METHODS.filter(m => m.three).length;
const total = METHODS.length;
---

<DocsLayout
  title="Fundamental — cross-platform parity matrix"
  description="Which FieldHandle methods ship on @fundamental-engine/three (44/44), Swift (44/44), and Kotlin (44/44). Full cross-platform parity achieved. JS is the source of truth; Three.js, Swift, and Kotlin implement all 44 methods."
>
  <header class="docs-hero">
    <p class="kicker">API reference</p>
    <h1>Platform <span class="accent">parity</span> matrix</h1>
    <p class="lede">
      Which <a href="/docs/api/handle">FieldHandle</a> methods ship on each surface.
      JS is the source of truth. <code>@fundamental-engine/three</code> delegates all 44 methods to the
      wrapped engine — 44/44. Swift and Kotlin are native ports at full parity — 44/44. The cross-plane
      <em>physics</em> is identical (the 36-force conformance suite asserts it). This matrix tracks
      <em>API surface</em> parity.
    </p>
    <div class="callout">
      <b>Three distinct axes — don't conflate them.</b>
      <b>API parity</b> (this matrix): the <code>FieldHandle</code> method surface exists — 44/44/44.
      <b>Conformance</b>: the force math matches, asserted by the shared cross-plane golden (the 36-force
      suite). <b>Production readiness</b>: packaging, platform polish, and docs — this is
      <em>Preview</em> and differs by host. Native ports are at <code>FieldHandle</code> API parity, but
      packaging, platform polish, and production-readiness differ by host.
    </div>
  </header>

  <div class="callout">
    <b>How to read this table.</b> A green chip means the method ships on that platform. A grey chip
    means it is not yet implemented (or not applicable for that platform — see the note column for
    context). The counts below each platform header show what fraction is covered.
  </div>

  <section class="docs-sec">
    <h2>FieldHandle coverage</h2>

    <table class="matrix">
      <thead>
        <tr>
          <th>Method</th>
          <th>
            Three.js
            <br />
            <small class="parity-count">{threeCount}/{total} ({Math.round(threeCount/total*100)}%)</small>
          </th>
          <th>
            Swift
            <br />
            <small class="parity-count">{swiftCount}/{total} ({Math.round(swiftCount/total*100)}%)</small>
          </th>
          <th>
            Kotlin
            <br />
            <small class="parity-count">{kotlinCount}/{total} ({Math.round(kotlinCount/total*100)}%)</small>
          </th>
          <th>Notes</th>
        </tr>
      </thead>
      <tbody>
        {METHODS.map(m => (
          <tr>
            <td><code>{m.method}</code></td>
            <td>
              <span class={`parity-chip ${m.three ? 'parity-yes' : 'parity-no'}`}>
                {m.three ? '✓' : '—'}
              </span>
            </td>
            <td>
              <span class={`parity-chip ${m.swift ? 'parity-yes' : 'parity-no'}`}>
                {m.swift ? '✓' : '—'}
              </span>
            </td>
            <td>
              <span class={`parity-chip ${m.kotlin ? 'parity-yes' : 'parity-no'}`}>
                {m.kotlin ? '✓' : '—'}
              </span>
            </td>
            <td class="parity-note">{m.note ?? ''}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="docs-sec">
    <h2>Platform notes</h2>
    <p>
      All three platforms ship 44/44 as of June 2026 (<a href="https://github.com/zachshallbetter/fundamental-engine/pull/822">#822</a> Swift,
      <a href="https://github.com/zachshallbetter/fundamental-engine/pull/823">#823</a> Kotlin).
      Some methods behave differently across platforms by design:
    </p>
    <dl class="api-table">
      <div class="api-row">
        <dt class="k">Three.js — 44/44, host-context notes</dt>
        <dd class="d">
          <code>@fundamental-engine/three</code> delegates all 44 methods to the wrapped
          <code>FieldHandle</code>. Some are contextually different in a 3D scene:
          <code>setRender</code> / <code>setOverlay</code> / <code>setBackground</code>
          are owned by the Three.js renderer — use <code>threeBackend()</code> for diagnostic overlays.
          <code>scrollV</code> returns 0 (no DOM scroll). <code>scan</code> / <code>rescan</code>
          are called internally; in Three.js register bodies via <code>layer.addBody(mesh, spec)</code>.
        </dd>
      </div>
      <div class="api-row">
        <dt class="k">sample — force probe</dt>
        <dd class="d">
          Swift delegates to <code>forceAt(bodies:forces:env:at:)</code> in <code>Streamlines.swift</code>.
          Kotlin delegates to <code>FieldController.sample()</code> which calls the same <code>forceAt()</code>
          function used by the streamlines overlay. Both are safe to call between ticks.
        </dd>
      </div>
      <div class="api-row">
        <dt class="k">on — event bus</dt>
        <dd class="d">
          Both platforms use a UUID-keyed subscriber registry (not closure equality, which doesn't hold
          across captures). <code>FieldEvent.tick</code> fires after every simulation step via an
          <code>onAfterTick</code> hook. <code>bodyAdd</code> / <code>bodyRemove</code> fire from the
          <code>addBody</code> / remove path. Returns a <code>Subscription</code>; call <code>.cancel()</code>
          to unsubscribe.
        </dd>
      </div>
      <div class="api-row">
        <dt class="k">addAgent — autonomous consumers</dt>
        <dd class="d">
          <code>AgentSpec</code> carries a <code>position</code> closure sampled each tick;
          <code>onInfluence</code> receives the net force vector at that point. Agents are ticked via
          the same <code>onAfterTick</code> hook as the event bus, after each force step.
        </dd>
      </div>
      <div class="api-row">
        <dt class="k">readParticleIds / readParticleChannels</dt>
        <dd class="d">
          <code>Particle.id</code> is assigned by <code>FieldStore.add()</code> via a monotonically
          increasing counter — stable for the lifetime of the pool. <code>readParticleChannels</code>
          samples each named <code>ScalarGrid</code> at each particle's position; the output stride
          equals the number of channel names.
        </dd>
      </div>
      <div class="api-row">
        <dt class="k">registerOverlay</dt>
        <dd class="d">
          <code>OverlayRenderer</code> is a protocol (Swift) / interface (Kotlin). The
          <code>FieldHandle</code> keeps a <code>[String: OverlayRenderer]</code> registry the
          platform host frame loop reads to call <code>render()</code> after the underlay draw each
          frame. No deep engine integration — pure registry delegation.
        </dd>
      </div>
    </dl>
  </section>

  <SeeAlso
    links={[
      { href: '/docs/guides/swift', label: 'Swift guide' },
      { href: '/docs/guides/kotlin', label: 'Kotlin guide' },
      { href: '/docs/api/handle', label: 'FieldHandle' },
      { href: '/docs/implementations', label: 'Implementations' },
    ]}
  />
</DocsLayout>

<style>
  .parity-count {
    font-weight: 400;
    color: var(--text-4);
    font-family: var(--mono);
    font-size: 0.72rem;
  }
  .parity-note {
    font-size: 0.82rem;
    color: var(--text-3);
  }
</style>
