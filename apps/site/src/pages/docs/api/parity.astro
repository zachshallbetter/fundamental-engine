---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import SeeAlso from '../../../components/SeeAlso.astro';

// Parity matrix — machine-generated from source, regenerated when a new method is added to any plane.
// Source of truth: docs/canonical/parity-matrix.md
// JS methods: packages/core/src/core/types.ts (FieldHandle interface)
// Swift methods: swift/Sources/FundamentalVanilla/FieldEngine.swift
// Kotlin methods: android/fundamental-core/src/main/kotlin/com/fundamental/core/runtime/FieldHandle.kt

interface ParityRow {
  method: string;
  swift: boolean;
  kotlin: boolean;
  note?: string;
}

const METHODS: ParityRow[] = [
  { method: 'scan',                 swift: true,  kotlin: false, note: 'Kotlin re-scans implicitly on tick' },
  { method: 'rescan',               swift: true,  kotlin: false, note: 'alias of scan' },
  { method: 'setAccent',            swift: true,  kotlin: false, note: 'visual layer — Compose has its own color API' },
  { method: 'setPalette',           swift: true,  kotlin: false, note: 'visual layer' },
  { method: 'setFormation',         swift: true,  kotlin: true  },
  { method: 'setWaveStyle',         swift: true,  kotlin: false, note: 'visual layer' },
  { method: 'setWaveCenter',        swift: true,  kotlin: false, note: 'visual layer' },
  { method: 'setSeparation',        swift: true,  kotlin: false, note: 'Kotlin exposes as var separation' },
  { method: 'setAttention',         swift: true,  kotlin: true  },
  { method: 'setCausality',         swift: true,  kotlin: true  },
  { method: 'setHeatmap',           swift: true,  kotlin: true  },
  { method: 'setDprCap',            swift: false, kotlin: false, note: 'native OSs handle DPR differently' },
  { method: 'setQualityTier',       swift: false, kotlin: false, note: 'adaptive quality governor' },
  { method: 'setRender',            swift: true,  kotlin: false, note: 'render surface is Compose/SwiftUI-owned on native' },
  { method: 'setOverlay',           swift: true,  kotlin: false },
  { method: 'setBackground',        swift: false, kotlin: false, note: 'Web-specific canvas clearing' },
  { method: 'threads',              swift: true,  kotlin: false, note: 'visual layer — glowing connector lines' },
  { method: 'burst',                swift: true,  kotlin: true  },
  { method: 'flowTo',               swift: true,  kotlin: true  },
  { method: 'clearFlow',            swift: true,  kotlin: true  },
  { method: 'seed',                 swift: true,  kotlin: true  },
  { method: 'addAgent',             swift: false, kotlin: false, note: 'engine-stepped agent — planned for native' },
  { method: 'addBody',              swift: true,  kotlin: true  },
  { method: 'addEdge',              swift: true,  kotlin: true  },
  { method: 'readEdges',            swift: true,  kotlin: true  },
  { method: 'addField',             swift: true,  kotlin: true  },
  { method: 'sampleField',          swift: true,  kotlin: true  },
  { method: 'atomAt',               swift: true,  kotlin: true  },
  { method: 'focusAt',              swift: true,  kotlin: false },
  { method: 'clearFocus',           swift: true,  kotlin: false },
  { method: 'particleCount',        swift: true,  kotlin: true  },
  { method: 'energy',               swift: true,  kotlin: true  },
  { method: 'sample',               swift: false, kotlin: false, note: 'Swift uses renderer path' },
  { method: 'sampleScalar',         swift: true,  kotlin: true  },
  { method: 'sampleGradient',       swift: true,  kotlin: true  },
  { method: 'grid',                 swift: false, kotlin: false, note: 'named ScalarGrid — planned for native' },
  { method: 'on',                   swift: false, kotlin: false, note: 'event bus — planned for native' },
  { method: 'readParticles',        swift: true,  kotlin: true  },
  { method: 'readParticleIds',      swift: false, kotlin: false },
  { method: 'readParticleChannels', swift: false, kotlin: false },
  { method: 'registerOverlay',      swift: false, kotlin: false },
  { method: 'scrollV',              swift: true,  kotlin: false, note: 'DOM/UIKit-specific scroll velocity' },
  { method: 'setVisible',           swift: true,  kotlin: false },
  { method: 'destroy',              swift: true,  kotlin: true  },
];

const swiftCount  = METHODS.filter(m => m.swift).length;
const kotlinCount = METHODS.filter(m => m.kotlin).length;
const total = METHODS.length;
---

<DocsLayout
  title="Fundamental — cross-platform parity matrix"
  description="Which FieldHandle methods ship on Swift (Apple platforms: iOS, macOS, visionOS) and Kotlin (Android). JS is the source of truth at 44/44; Swift at 34/44 (77%); Kotlin at 20/44 (45%). Render-layer methods are absent from Kotlin because Compose/View rendering is host-owned."
>
  <header class="docs-hero">
    <p class="kicker">API reference</p>
    <h1>Platform <span class="accent">parity</span> matrix</h1>
    <p class="lede">
      Which <a href="/docs/api/handle">FieldHandle</a> methods ship on each platform.
      JS is the source of truth; Swift and Kotlin are ports that trail by design — the web plane moves
      first. The cross-plane <em>physics</em> is identical (the 36-force golden conformance suite asserts
      it); this matrix tracks <em>API surface</em> parity.
    </p>
  </header>

  <div class="callout">
    <b>How to read this table.</b> A green chip means the method ships on that platform. A grey chip
    means it is not yet implemented (or not applicable for that platform — see the note column for
    context). The counts below each platform header show what fraction is covered.
  </div>

  <section class="docs-sec">
    <h2>FieldHandle coverage</h2>

    <table class="matrix">
      <thead>
        <tr>
          <th>Method</th>
          <th>
            Swift
            <br />
            <small class="parity-count">{swiftCount}/{total} ({Math.round(swiftCount/total*100)}%)</small>
          </th>
          <th>
            Kotlin
            <br />
            <small class="parity-count">{kotlinCount}/{total} ({Math.round(kotlinCount/total*100)}%)</small>
          </th>
          <th>Notes</th>
        </tr>
      </thead>
      <tbody>
        {METHODS.map(m => (
          <tr>
            <td><code>{m.method}</code></td>
            <td>
              <span class={`parity-chip ${m.swift ? 'parity-yes' : 'parity-no'}`}>
                {m.swift ? '✓' : '—'}
              </span>
            </td>
            <td>
              <span class={`parity-chip ${m.kotlin ? 'parity-yes' : 'parity-no'}`}>
                {m.kotlin ? '✓' : '—'}
              </span>
            </td>
            <td class="parity-note">{m.note ?? ''}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="docs-sec">
    <h2>Why the gaps?</h2>
    <p>
      Most absent methods fall into one of three categories:
    </p>
    <dl class="api-table">
      <div class="api-row">
        <dt class="k">Render-layer — host-owned on native</dt>
        <dd class="d">
          Methods like <code>setRender</code>, <code>setOverlay</code>, <code>threads</code>,
          <code>setAccent</code>, and <code>setPalette</code> are absent from Kotlin because
          Compose and the Android <code>View</code>/<code>Canvas</code> host own the draw. The Kotlin
          engine exposes the <em>data pipeline</em> (forces, density, particles, edges) and Compose
          wires the drawing — a deliberate architecture choice, not an oversight. Swift covers these
          because Metal/SwiftUI rendering stays closer to the web canvas model.
        </dd>
      </div>
      <div class="api-row">
        <dt class="k">Platform-specific — not applicable</dt>
        <dd class="d">
          <code>setDprCap</code> and <code>setBackground</code> are web-only concepts (backing-store
          DPR, transparent vs opaque canvas clearing). Native OSs handle DPR at the display layer;
          there is nothing to cap or clear in the same way.
        </dd>
      </div>
      <div class="api-row">
        <dt class="k">Planned — in the native backlog</dt>
        <dd class="d">
          <code>addAgent</code>, <code>grid</code>, <code>on</code>, <code>readParticleIds</code>,
          and <code>readParticleChannels</code> are on the native roadmap — the primitives they
          depend on are present, but the API surface hasn't been ported yet.
        </dd>
      </div>
    </dl>
  </section>

  <SeeAlso
    links={[
      { href: '/docs/guides/swift', label: 'Swift guide' },
      { href: '/docs/guides/kotlin', label: 'Kotlin guide' },
      { href: '/docs/api/handle', label: 'FieldHandle' },
      { href: '/docs/implementations', label: 'Implementations' },
    ]}
  />
</DocsLayout>

<style>
  .parity-count {
    font-weight: 400;
    color: var(--text-4);
    font-family: var(--mono);
    font-size: 0.72rem;
  }
  .parity-note {
    font-size: 0.82rem;
    color: var(--text-3);
  }
</style>
