---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import SeeAlso from '../../../components/SeeAlso.astro';

// Parity matrix — machine-generated from source, regenerated when a new method is added to any plane.
// Source of truth: docs/canonical/parity-matrix.md
// JS methods: packages/core/src/core/types.ts (FieldHandle interface)
// Swift methods: swift/Sources/FundamentalVanilla/FieldEngine.swift
// Kotlin methods: android/fundamental-core/src/main/kotlin/com/fundamental/core/runtime/FieldHandle.kt
// Three.js: packages/three/src/layer.ts (FieldLayer delegates all 44 to the wrapped FieldHandle)

interface ParityRow {
  method: string;
  swift: boolean;
  kotlin: boolean;
  three: boolean;
  note?: string;
}

const METHODS: ParityRow[] = [
  { method: 'scan',                 swift: true,  kotlin: true,  three: true  },
  { method: 'rescan',               swift: true,  kotlin: true,  three: true,  note: 'alias of scan' },
  { method: 'setAccent',            swift: true,  kotlin: true,  three: true  },
  { method: 'setPalette',           swift: true,  kotlin: true,  three: true  },
  { method: 'setFormation',         swift: true,  kotlin: true,  three: true  },
  { method: 'setWaveStyle',         swift: true,  kotlin: true,  three: true  },
  { method: 'setWaveCenter',        swift: true,  kotlin: true,  three: true  },
  { method: 'setSeparation',        swift: true,  kotlin: true,  three: true,  note: 'Kotlin fun setSeparation(Float) coexists with var separation via @JvmName on the property' },
  { method: 'setAttention',         swift: true,  kotlin: true,  three: true  },
  { method: 'setCausality',         swift: true,  kotlin: true,  three: true  },
  { method: 'setHeatmap',           swift: true,  kotlin: true,  three: true  },
  { method: 'setDprCap',            swift: true,  kotlin: true,  three: true,  note: 'Three.js delegates but DPR is renderer-owned; native stores in FieldOptions / FieldHandle' },
  { method: 'setQualityTier',       swift: true,  kotlin: true,  three: true  },
  { method: 'setRender',            swift: true,  kotlin: true,  three: true,  note: 'render surface is host-owned on native + Three.js; Kotlin host reads renderMode' },
  { method: 'setOverlay',           swift: true,  kotlin: true,  three: true,  note: 'use threeBackend() for Three.js diagnostic overlays' },
  { method: 'setBackground',        swift: true,  kotlin: true,  three: true,  note: 'web canvas clearing; native stores in FieldOptions.background' },
  { method: 'threads',              swift: true,  kotlin: true,  three: true,  note: 'visual layer — glowing connector lines' },
  { method: 'burst',                swift: true,  kotlin: true,  three: true  },
  { method: 'flowTo',               swift: true,  kotlin: true,  three: true  },
  { method: 'clearFlow',            swift: true,  kotlin: true,  three: true  },
  { method: 'seed',                 swift: true,  kotlin: true,  three: true  },
  { method: 'addAgent',             swift: false, kotlin: false, three: true,  note: 'native planned — #815' },
  { method: 'addBody',              swift: true,  kotlin: true,  three: true  },
  { method: 'addEdge',              swift: true,  kotlin: true,  three: true  },
  { method: 'readEdges',            swift: true,  kotlin: true,  three: true  },
  { method: 'addField',             swift: true,  kotlin: true,  three: true  },
  { method: 'sampleField',          swift: true,  kotlin: true,  three: true  },
  { method: 'atomAt',               swift: true,  kotlin: true,  three: true  },
  { method: 'focusAt',              swift: true,  kotlin: true,  three: true  },
  { method: 'clearFocus',           swift: true,  kotlin: true,  three: true  },
  { method: 'particleCount',        swift: true,  kotlin: true,  three: true  },
  { method: 'energy',               swift: true,  kotlin: true,  three: true  },
  { method: 'sample',               swift: false, kotlin: false, three: true,  note: 'force-probe; native planned — #816' },
  { method: 'sampleScalar',         swift: true,  kotlin: true,  three: true  },
  { method: 'sampleGradient',       swift: true,  kotlin: true,  three: true  },
  { method: 'grid',                 swift: true,  kotlin: true,  three: true,  note: 'named ScalarGrid — lazy get/create, same grid as env.grid in the force system' },
  { method: 'on',                   swift: false, kotlin: false, three: true,  note: 'event bus; native planned — #817' },
  { method: 'readParticles',        swift: true,  kotlin: true,  three: true  },
  { method: 'readParticleIds',      swift: false, kotlin: false, three: true,  note: 'requires stable particle IDs — #818' },
  { method: 'readParticleChannels', swift: false, kotlin: false, three: true,  note: 'per-particle scalar channel readout — #819' },
  { method: 'registerOverlay',      swift: false, kotlin: false, three: true,  note: 'extensible overlay renderer — #820' },
  { method: 'scrollV',              swift: true,  kotlin: true,  three: true,  note: 'DOM/UIKit scroll velocity; Kotlin: scrollV() + feedScrollV(); Three.js returns 0 in headless' },
  { method: 'setVisible',           swift: true,  kotlin: true,  three: true  },
  { method: 'destroy',              swift: true,  kotlin: true,  three: true  },
];

const swiftCount  = METHODS.filter(m => m.swift).length;
const kotlinCount = METHODS.filter(m => m.kotlin).length;
const threeCount  = METHODS.filter(m => m.three).length;
const total = METHODS.length;
---

<DocsLayout
  title="Fundamental — cross-platform parity matrix"
  description="Which FieldHandle methods ship on @fundamental-engine/three (44/44), Swift (38/44, 86%), and Kotlin (38/44, 86%). JS is the source of truth. Three.js delegates all 44 methods; native ports trail by design."
>
  <header class="docs-hero">
    <p class="kicker">API reference</p>
    <h1>Platform <span class="accent">parity</span> matrix</h1>
    <p class="lede">
      Which <a href="/docs/api/handle">FieldHandle</a> methods ship on each surface.
      JS is the source of truth. <code>@fundamental-engine/three</code> delegates all 44 methods to the
      wrapped engine — 44/44. Swift and Kotlin are native ports that trail by design; the cross-plane
      <em>physics</em> is identical (the 36-force conformance suite asserts it). This matrix tracks
      <em>API surface</em> parity.
    </p>
  </header>

  <div class="callout">
    <b>How to read this table.</b> A green chip means the method ships on that platform. A grey chip
    means it is not yet implemented (or not applicable for that platform — see the note column for
    context). The counts below each platform header show what fraction is covered.
  </div>

  <section class="docs-sec">
    <h2>FieldHandle coverage</h2>

    <table class="matrix">
      <thead>
        <tr>
          <th>Method</th>
          <th>
            Three.js
            <br />
            <small class="parity-count">{threeCount}/{total} ({Math.round(threeCount/total*100)}%)</small>
          </th>
          <th>
            Swift
            <br />
            <small class="parity-count">{swiftCount}/{total} ({Math.round(swiftCount/total*100)}%)</small>
          </th>
          <th>
            Kotlin
            <br />
            <small class="parity-count">{kotlinCount}/{total} ({Math.round(kotlinCount/total*100)}%)</small>
          </th>
          <th>Notes</th>
        </tr>
      </thead>
      <tbody>
        {METHODS.map(m => (
          <tr>
            <td><code>{m.method}</code></td>
            <td>
              <span class={`parity-chip ${m.three ? 'parity-yes' : 'parity-no'}`}>
                {m.three ? '✓' : '—'}
              </span>
            </td>
            <td>
              <span class={`parity-chip ${m.swift ? 'parity-yes' : 'parity-no'}`}>
                {m.swift ? '✓' : '—'}
              </span>
            </td>
            <td>
              <span class={`parity-chip ${m.kotlin ? 'parity-yes' : 'parity-no'}`}>
                {m.kotlin ? '✓' : '—'}
              </span>
            </td>
            <td class="parity-note">{m.note ?? ''}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="docs-sec">
    <h2>Why the gaps?</h2>
    <p>
      Both Swift and Kotlin now ship 38/44 methods. The remaining 6 require deeper engine plumbing and
      are tracked on GitHub:
    </p>
    <dl class="api-table">
      <div class="api-row">
        <dt class="k">Three.js — 44/44, but some are host-context notes</dt>
        <dd class="d">
          <code>@fundamental-engine/three</code> delegates all 44 methods to the wrapped
          <code>FieldHandle</code>, so every method is callable. However, some are contextually
          irrelevant in a 3D scene: <code>setRender</code> / <code>setOverlay</code> / <code>setBackground</code>
          are owned by the Three.js renderer — use <code>threeBackend()</code> for diagnostic overlays
          instead. <code>scrollV</code> returns 0 (no DOM scroll). <code>scan</code> / <code>rescan</code>
          are called internally by the body registry; in Three.js you register bodies via <code>layer.addBody(mesh, spec)</code>.
        </dd>
      </div>
      <div class="api-row">
        <dt class="k">Needs agent infrastructure — addAgent (#815)</dt>
        <dd class="d">
          <code>addAgent</code> attaches autonomous agent consumers to the field. The <code>AgentSpec</code>
          type and consumer loop integration don't yet exist in the native ports. Tracked in
          <a href="https://github.com/zachshallbetter/fundamental-engine/issues/815">#815</a>.
        </dd>
      </div>
      <div class="api-row">
        <dt class="k">Needs read-only force evaluation — sample (#816)</dt>
        <dd class="d">
          <code>sample(x, y)</code> returns the net force vector at a world point without mutating
          particle state. The force-evaluation path needs a read-only pass mode. Tracked in
          <a href="https://github.com/zachshallbetter/fundamental-engine/issues/816">#816</a>.
        </dd>
      </div>
      <div class="api-row">
        <dt class="k">Needs event bus — on (#817)</dt>
        <dd class="d">
          <code>on(event, handler)</code> requires a typed <code>FieldEvent</code> enum and subscriber
          registry not yet present in the native engines. Tracked in
          <a href="https://github.com/zachshallbetter/fundamental-engine/issues/817">#817</a>.
        </dd>
      </div>
      <div class="api-row">
        <dt class="k">Needs stable particle IDs + channel readout — readParticleIds, readParticleChannels (#818, #819)</dt>
        <dd class="d">
          <code>readParticleIds</code> requires a stable per-particle <code>id</code> field (not yet in
          native <code>Particle</code>). <code>readParticleChannels</code> packs scalar-grid values
          sampled at each particle's position — the scalar grids exist but the particle-loop bridge
          does not. Tracked in
          <a href="https://github.com/zachshallbetter/fundamental-engine/issues/818">#818</a> /
          <a href="https://github.com/zachshallbetter/fundamental-engine/issues/819">#819</a>.
        </dd>
      </div>
      <div class="api-row">
        <dt class="k">Needs overlay renderer protocol — registerOverlay (#820)</dt>
        <dd class="d">
          <code>registerOverlay</code> requires an <code>OverlayRenderer</code> protocol/interface
          and a registry handoff between <code>FieldHandle</code> and the platform host frame loop.
          The overlay registry exists in the platform layer but not the FieldHandle bridge. Tracked in
          <a href="https://github.com/zachshallbetter/fundamental-engine/issues/820">#820</a>.
        </dd>
      </div>
    </dl>
  </section>

  <SeeAlso
    links={[
      { href: '/docs/guides/swift', label: 'Swift guide' },
      { href: '/docs/guides/kotlin', label: 'Kotlin guide' },
      { href: '/docs/api/handle', label: 'FieldHandle' },
      { href: '/docs/implementations', label: 'Implementations' },
    ]}
  />
</DocsLayout>

<style>
  .parity-count {
    font-weight: 400;
    color: var(--text-4);
    font-family: var(--mono);
    font-size: 0.72rem;
  }
  .parity-note {
    font-size: 0.82rem;
    color: var(--text-3);
  }
</style>
