---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import SeeAlso from '../../../components/SeeAlso.astro';
import parityData from '../../../../../../data/parity-matrix.json';

// Parity matrix — WIRED to data/parity-matrix.json (the real `pnpm gen:parity-matrix` output), fixed
// 2026-07 after a self-audit found the previous hand-kept array had silently drifted (missing methods)
// AND its own header comment falsely claimed to be machine-generated when it wasn't.
//
// The swift/kotlin/three booleans below are COMPUTED from parityData, never hand-typed — that's the
// actual fix. What stays hand-curated (legitimately editorial, not derivable): the per-method NOTES and
// the display ORDER (grouped by concern, not alphabetical — more readable than the generator's raw
// alpha-sorted list). MEMBERSHIP is enforced at build time below: if ORDERED_METHODS and the generator's
// JS method set ever disagree (a method added/removed from FieldHandle without updating this list), the
// site build throws instead of silently drifting a third time.
//
// `projections` was REMOVED from this table (2026-07 fix) — it is a `readonly projections: ProjectionRegistry`
// PROPERTY on FieldHandle, not a callable method (confirmed by reading packages/core/src/engine/types.ts
// directly); the previous table miscategorized it as a method with swift:false. This table now tracks
// callable methods only, matching the generator's own "field-handle-methods" dimension.
//
// JS methods: packages/core/src/engine/types.ts (FieldHandle interface) — the source of truth
// Swift methods: swift/Sources/FundamentalVanilla/FieldEngine.swift
// Kotlin methods: android/fundamental-core/src/main/kotlin/com/fundamental/core/runtime/FieldHandle.kt
// Three.js: packages/three/src/layer.ts — FieldLayer delegates directly to the wrapped FieldHandle, so
// it is 100% by construction (not separately tracked by the generator; there is no porting lag possible).

const dim = parityData.dimensions.find((d: { id: string }) => d.id === 'field-handle-methods')!;
const swiftSet = new Set<string>(dim.planes.swift);
const kotlinSet = new Set<string>(dim.planes.kotlin);
const jsSet = new Set<string>(dim.planes.js);

interface ParityRow {
  method: string;
  swift: boolean;
  kotlin: boolean;
  three: boolean;
  note?: string;
}

// Curated order + notes only. Grouped by concern (not alphabetical) for readability.
const ORDERED_METHODS: Array<{ method: string; note?: string }> = [
  { method: 'scan' },
  { method: 'rescan',               note: 'alias of scan' },
  { method: 'setAccent' },
  { method: 'setPalette' },
  { method: 'setFormation' },
  { method: 'setWaveStyle' },
  { method: 'setWaveCenter' },
  { method: 'setSeparation',        note: 'Kotlin fun setSeparation(Float) coexists with var separation via @JvmName on the property' },
  { method: 'setAttention' },
  { method: 'setCausality' },
  { method: 'setHeatmap' },
  { method: 'setDprCap',            note: 'Three.js delegates but DPR is renderer-owned; native stores in FieldOptions / FieldHandle' },
  { method: 'setQualityTier' },
  { method: 'setRender',            note: 'render surface is host-owned on native + Three.js; Kotlin host reads renderMode' },
  { method: 'setOverlay',           note: 'use threeBackend() for Three.js diagnostic overlays' },
  { method: 'setBackground',        note: 'web canvas clearing; native stores in FieldOptions.background' },
  { method: 'threads',              note: 'visual layer — glowing connector lines' },
  { method: 'burst' },
  { method: 'flowTo' },
  { method: 'clearFlow' },
  { method: 'seed' },
  { method: 'addAgent',             note: 'AgentSpec / AgentHandle; Kotlin init-block wires tickAgents() via onAfterTick; Swift uses UUID-keyed agent list' },
  { method: 'addBody' },
  { method: 'addEdge' },
  { method: 'readEdges' },
  { method: 'addField' },
  { method: 'sampleField' },
  { method: 'atomAt' },
  { method: 'focusAt' },
  { method: 'clearFocus' },
  { method: 'particleCount' },
  { method: 'energy' },
  // ── substrate read API (critical-path 02/03) — mirrored to the native cores ──
  { method: 'query',                note: 'structured read of bodies/metrics/relationships; the influences/projections/dimensions lanes stay empty on the ports until an accumulator/registry/dimension lane lands (JS field names kept)' },
  { method: 'snapshot',             note: 'point-in-time field capture; body data withheld by default (tightest-wins profile)' },
  { method: 'diff',                 note: 'pure comparison of two snapshots — added/removed/changed bodies, metric deltas, relationship + formation changes' },
  { method: 'replay',               note: 'causal replay over a snapshot pair; force-attributed steps empty-for-now on the ports (no impulse accumulator yet)' },
  { method: 'forAgent',             note: 'capability-scoped, redacted, read-only agent view (agent-readable is not agent-writable)' },
  { method: 'sample',               note: 'force-probe at world point; Swift delegates to forceAt(); Kotlin delegates to controller.sample() → forceAt()' },
  { method: 'sampleScalar' },
  { method: 'sampleGradient' },
  { method: 'grid',                 note: 'named ScalarGrid — lazy get/create, same grid as env.grid in the force system' },
  { method: 'on',                   note: 'UUID-keyed subscriber bus; FieldEvent enum (tick/bodyAdd/bodyRemove/particleCapture/supernova); returns Subscription' },
  { method: 'readParticles' },
  { method: 'readParticleIds',      note: 'Particle.id (stable, auto-incremented by FieldStore.add); fills an Int buffer' },
  { method: 'readParticleChannels', note: 'samples named ScalarGrids at each particle position; stride = names.count/size' },
  { method: 'registerOverlay',      note: 'OverlayRenderer protocol/interface; host reads overlayRegistry and calls render() each frame' },
  { method: 'scrollV',              note: 'DOM/UIKit scroll velocity; Kotlin: scrollV() + feedScrollV(); Three.js returns 0 in headless' },
  { method: 'setVisible' },
  { method: 'destroy' },
  { method: 'setPolicy',            note: 'runtime FieldPolicy (motion/privacy budgets); mirrored on all three planes' },
  { method: 'focus',                note: 'focus/attention substrate (EXPERIMENTAL, shipped 0.9.4) — operator/agent attention write; Swift + Kotlin ports are a batched follow-up' },
  { method: 'focusState',           note: 'focus/attention substrate (EXPERIMENTAL, shipped 0.9.4) — the ranked, thresholded attention read; Swift + Kotlin ports are a batched follow-up' },
];

// ── build-time consistency check — the actual anti-drift mechanism ──────────────────────────────
// If FieldHandle gains/loses a method without this list being updated, the site build FAILS here
// instead of silently rendering a stale table (which is exactly how this page drifted 6 methods
// behind before the 2026-07 fix).
const orderedSet = new Set(ORDERED_METHODS.map((m) => m.method));
const missingFromPage = [...jsSet].filter((m) => !orderedSet.has(m));
const extraOnPage = [...orderedSet].filter((m) => !jsSet.has(m));
if (missingFromPage.length || extraOnPage.length) {
  throw new Error(
    `docs/api/parity.astro: ORDERED_METHODS has drifted from data/parity-matrix.json's FieldHandle set. ` +
    `Run \`pnpm gen:parity-matrix\` and update ORDERED_METHODS in this file.\n` +
    (missingFromPage.length ? `  Missing from this page: ${missingFromPage.join(', ')}\n` : '') +
    (extraOnPage.length ? `  On this page but not in FieldHandle (or miscategorized, like the old 'projections' property): ${extraOnPage.join(', ')}\n` : '')
  );
}

// swift/kotlin are COMPUTED from the generator's live plane data; three is always true (direct
// delegation to the wrapped FieldHandle — see the header comment).
const METHODS: ParityRow[] = ORDERED_METHODS.map((m) => ({
  method: m.method,
  swift: swiftSet.has(m.method),
  kotlin: kotlinSet.has(m.method),
  three: true,
  note: m.note,
}));

const swiftCount  = METHODS.filter(m => m.swift).length;
const kotlinCount = METHODS.filter(m => m.kotlin).length;
const threeCount  = METHODS.filter(m => m.three).length;
const total = METHODS.length;
---

<DocsLayout
  title="Fundamental — cross-platform parity matrix"
  description={`Which FieldHandle methods ship on @fundamental-engine/three (${threeCount}/${total}), Swift (${swiftCount}/${total}), and Kotlin (${kotlinCount}/${total}). JS is the source of truth; the ports are not yet at full parity — see the table for the exact gaps.`}
>
  <header class="docs-hero">
    <p class="kicker">API reference</p>
    <h1>Platform <span class="accent">parity</span> matrix</h1>
    <p class="lede">
      Which <a href="/docs/api/handle">FieldHandle</a> methods ship on each surface.
      JS is the source of truth. <code>@fundamental-engine/three</code> delegates all {total} methods to
      the wrapped engine — {threeCount}/{total}. Swift ({swiftCount}/{total}) and Kotlin ({kotlinCount}/{total})
      are native ports, mirrored but currently trailing the newest additions (see the table below for
      which methods and why). The cross-plane <em>physics</em> is identical (the 36-force conformance
      suite asserts it) regardless of API-surface gaps. This matrix tracks <em>API surface</em> parity.
    </p>
    <div class="callout">
      <b>Three distinct axes — don't conflate them.</b>
      <b>API parity</b> (this matrix): the <code>FieldHandle</code> method surface — {threeCount}/{total} Three.js,
      {swiftCount}/{total} Swift, {kotlinCount}/{total} Kotlin.
      <b>Conformance</b>: the force math matches, asserted by the shared cross-plane golden (the 36-force
      suite). <b>Production readiness</b>: packaging, platform polish, and docs — this is
      <em>Preview</em> and differs by host. Native ports are at <code>FieldHandle</code> API parity, but
      packaging, platform polish, and production-readiness differ by host.
    </div>
  </header>

  <div class="callout">
    <b>How to read this table.</b> A green chip means the method ships on that platform. A grey chip
    means it is not yet implemented (or not applicable for that platform — see the note column for
    context). The counts below each platform header show what fraction is covered.
  </div>

  <section class="docs-sec">
    <h2>FieldHandle coverage</h2>

    <table class="matrix">
      <thead>
        <tr>
          <th>Method</th>
          <th>
            Three.js
            <br />
            <small class="parity-count">{threeCount}/{total} ({Math.round(threeCount/total*100)}%)</small>
          </th>
          <th>
            Swift
            <br />
            <small class="parity-count">{swiftCount}/{total} ({Math.round(swiftCount/total*100)}%)</small>
          </th>
          <th>
            Kotlin
            <br />
            <small class="parity-count">{kotlinCount}/{total} ({Math.round(kotlinCount/total*100)}%)</small>
          </th>
          <th>Notes</th>
        </tr>
      </thead>
      <tbody>
        {METHODS.map(m => (
          <tr>
            <td><code>{m.method}</code></td>
            <td>
              <span class={`parity-chip ${m.three ? 'parity-yes' : 'parity-no'}`}>
                {m.three ? '✓' : '—'}
              </span>
            </td>
            <td>
              <span class={`parity-chip ${m.swift ? 'parity-yes' : 'parity-no'}`}>
                {m.swift ? '✓' : '—'}
              </span>
            </td>
            <td>
              <span class={`parity-chip ${m.kotlin ? 'parity-yes' : 'parity-no'}`}>
                {m.kotlin ? '✓' : '—'}
              </span>
            </td>
            <td class="parity-note">{m.note ?? ''}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="docs-sec">
    <h2>Platform notes</h2>
    <p>
      All three platforms briefly shipped the full 44-method surface as of June 2026 (<a href="https://github.com/zachshallbetter/fundamental-engine/pull/822">#822</a> Swift,
      <a href="https://github.com/zachshallbetter/fundamental-engine/pull/823">#823</a> Kotlin) — the JS-side surface has grown since (now {total} methods; see the live counts above), and the ports have not fully caught up.
      Some methods behave differently across platforms by design:
    </p>
    <dl class="api-table">
      <div class="api-row">
        <dt class="k">Three.js — {threeCount}/{total}, host-context notes</dt>
        <dd class="d">
          <code>@fundamental-engine/three</code> delegates all {total} methods to the wrapped
          <code>FieldHandle</code>. Some are contextually different in a 3D scene:
          <code>setRender</code> / <code>setOverlay</code> / <code>setBackground</code>
          are owned by the Three.js renderer — use <code>threeBackend()</code> for diagnostic overlays.
          <code>scrollV</code> returns 0 (no DOM scroll). <code>scan</code> / <code>rescan</code>
          are called internally; in Three.js register bodies via <code>layer.addBody(mesh, spec)</code>.
        </dd>
      </div>
      <div class="api-row">
        <dt class="k">sample — force probe</dt>
        <dd class="d">
          Swift delegates to <code>forceAt(bodies:forces:env:at:)</code> in <code>Streamlines.swift</code>.
          Kotlin delegates to <code>FieldController.sample()</code> which calls the same <code>forceAt()</code>
          function used by the streamlines overlay. Both are safe to call between ticks.
        </dd>
      </div>
      <div class="api-row">
        <dt class="k">on — event bus</dt>
        <dd class="d">
          Both platforms use a UUID-keyed subscriber registry (not closure equality, which doesn't hold
          across captures). <code>FieldEvent.tick</code> fires after every simulation step via an
          <code>onAfterTick</code> hook. <code>bodyAdd</code> / <code>bodyRemove</code> fire from the
          <code>addBody</code> / remove path. Returns a <code>Subscription</code>; call <code>.cancel()</code>
          to unsubscribe.
        </dd>
      </div>
      <div class="api-row">
        <dt class="k">addAgent — autonomous consumers</dt>
        <dd class="d">
          <code>AgentSpec</code> carries a <code>position</code> closure sampled each tick;
          <code>onInfluence</code> receives the net force vector at that point. Agents are ticked via
          the same <code>onAfterTick</code> hook as the event bus, after each force step.
        </dd>
      </div>
      <div class="api-row">
        <dt class="k">readParticleIds / readParticleChannels</dt>
        <dd class="d">
          <code>Particle.id</code> is assigned by <code>FieldStore.add()</code> via a monotonically
          increasing counter — stable for the lifetime of the pool. <code>readParticleChannels</code>
          samples each named <code>ScalarGrid</code> at each particle's position; the output stride
          equals the number of channel names.
        </dd>
      </div>
      <div class="api-row">
        <dt class="k">registerOverlay</dt>
        <dd class="d">
          <code>OverlayRenderer</code> is a protocol (Swift) / interface (Kotlin). The
          <code>FieldHandle</code> keeps a <code>[String: OverlayRenderer]</code> registry the
          platform host frame loop reads to call <code>render()</code> after the underlay draw each
          frame. No deep engine integration — pure registry delegation.
        </dd>
      </div>
    </dl>
  </section>

  <SeeAlso
    links={[
      { href: '/docs/guides/swift', label: 'Swift guide' },
      { href: '/docs/guides/kotlin', label: 'Kotlin guide' },
      { href: '/docs/api/handle', label: 'FieldHandle' },
      { href: '/docs/implementations', label: 'Implementations' },
    ]}
  />
</DocsLayout>

<style>
  .parity-count {
    font-weight: 400;
    color: var(--text-4);
    font-family: var(--mono);
    font-size: 0.72rem;
  }
  .parity-note {
    font-size: 0.82rem;
    color: var(--text-3);
  }
</style>
