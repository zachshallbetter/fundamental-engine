---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import { MANUAL_FORCES, MANUAL_PRESETS, MANUAL_CONDITIONS, FORMATIONS, PALETTE_NAMES } from '@fundamental-engine/core';
import { RENDER_MODES } from '../../../lib/docs-api.ts';

const cards = [
  { href: '/docs/api/options', t: 'createField & options', d: 'The entry points and every FieldOptions knob. Core requires a host; @fundamental-engine/vanilla and <field-root> wire browserHost() for you.' },
  { href: '/docs/api/handle', t: 'FieldHandle', d: 'The object every entry point returns — drive the field at runtime.' },
  { href: '/docs/api/attributes', t: 'data-* attributes', d: 'Every attribute a body reads, and which force reads which.' },
  { href: '/docs/api/forces', t: `Forces (${MANUAL_FORCES.length})`, d: 'The full catalog — law, attributes, and example per force.' },
  { href: '/docs/api/presets', t: `Presets (${MANUAL_PRESETS.length})`, d: 'Whole compositions as one attribute. No new engine code.' },
  { href: '/docs/api/catalog', t: 'Conditions, formations & modes', d: 'The orthogonal axes — when, field-wide, and how it draws.' },
  { href: '/docs/api/types', t: 'Types', d: 'Core types (Body, Particle, Force, Env) and platform types.' },
  { href: '/docs/api/stability', t: 'API stability', d: 'The frozen 0.x public surface, the experimental surface, and the compatibility rules — enforced by pnpm check:api.' },
  { href: '/docs/platform', t: '@fundamental-engine/platform', d: 'DOM participation: the FrameScheduler + six registries (measurement, state, feedback, relationships, visual bindings, overlays) + lintPlatform().' },
];
---

<DocsLayout
  title="Fundamental — API reference"
  description="The complete Fundamental API: createField & FieldOptions, the FieldHandle, every data-* attribute, all forces, presets, conditions, formations, render modes, and the core types. Generated from the engine's own catalog."
>
  <header class="docs-hero">
    <p class="kicker">API reference</p>
    <h1>The complete <span class="accent">surface</span>.</h1>
    <p class="lede">
      Every option, method, attribute, and catalog entry. The forces, presets, conditions, and
      formations pages are generated from the engine's own catalog, so they can't drift from the
      code you install.
    </p>
  </header>

  <section class="docs-sec">
    <h2>Reference</h2>
    <div class="next-grid">
      {
        cards.map((c) => (
          <a class="next-card" href={c.href}>
            <b>{c.t}</b>
            <span>{c.d}</span>
          </a>
        ))
      }
    </div>
    <div class="callout">
      <b>At a glance.</b> {MANUAL_FORCES.length} forces · {MANUAL_PRESETS.length} presets ·
      {MANUAL_CONDITIONS.length} conditions · {FORMATIONS.length} formations ·
      {RENDER_MODES.length} render modes · {PALETTE_NAMES.length} palettes — one shared field
      runtime, platform-native DOM participation, and a core with zero runtime dependencies.
    </div>
  </section>
</DocsLayout>
