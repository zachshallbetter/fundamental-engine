---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import { ATTRS, WRITEBACK } from '../../../lib/docs-api.ts';
import SeeAlso from '../../../components/SeeAlso.astro';
import { MANUAL_FORCES } from 'forces-ui';
import '../../../styles/force-glyphs.css';

const families = [
  { key: 'canonical', label: 'Canonical' },
  { key: 'natural', label: 'Natural' },
  { key: 'extended', label: 'Extended' },
] as const;
---

<DocsLayout
  title="forces-ui — data-* attributes"
  description="Every data-* attribute a body reads — data-body, data-strength, data-range, data-color, data-when, data-feedback and more — with defaults, plus a per-force matrix of which force reads which."
>
  <header class="docs-hero">
    <p class="kicker">API reference</p>
    <h1><span class="accent">data-*</span> attributes</h1>
    <p class="lede">
      A body is configured entirely in markup. Each force reads only the attributes it uses and
      ignores the rest, so you can set a few and compose freely.
    </p>
  </header>

  <section class="docs-sec">
    <h2>All attributes</h2>
    <dl class="api-table">
      {
        ATTRS.map((a) => (
          <div class="api-row">
            <dt class="k">
              <code>{a.name}</code>
              <span class="ty">{a.type}{a.def ? <> · <b>default {a.def}</b></> : null}</span>
            </dt>
            <dd class="d">{a.desc}</dd>
          </div>
        ))
      }
    </dl>
  </section>

  <section class="docs-sec">
    <h2>Which force reads which</h2>
    <p>
      Beyond the universal <code>data-body</code> / <code>data-when</code> / <code>data-feedback</code>,
      each force reads this subset (declared in the catalog):
    </p>
    {
      families.map((fam) => (
        <>
          <span class="ref-fam">{fam.label}</span>
          <dl class="api-table">
            {MANUAL_FORCES.filter((f) => f.family === fam.key).map((f) => (
              <div class="api-row">
                <dt class="k">
                  <code>{f.token}</code>
                </dt>
                <dd class="d rc-meta">
                  {f.attrs.length ? (
                    f.attrs.map((a) => <span class="chip">data-{a}</span>)
                  ) : (
                    <span class="chip">box-sized — no params</span>
                  )}
                </dd>
              </div>
            ))}
          </dl>
        </>
      ))
    }
  </section>

  <section class="docs-sec">
    <h2>What the field writes back</h2>
    <p>
      Reciprocity has two halves: bodies bend the field through <code>data-*</code>, and the field
      bends them back through CSS custom properties. A body that opts in (<code>data-feedback</code>)
      receives these on its element — read them in your own CSS to make type glow, cards lift, or a
      meter fill. The write target is the element itself, or a body's <code>writeTarget</code>.
    </p>
    <div class="api-table">
      {
        WRITEBACK.map((v) => (
          <div class="api-row">
            <div class="k">
              <code>{v.name}</code>
              <span class="ty">on <b>{v.on}</b></span>
            </div>
            <div class="d">{v.desc}</div>
          </div>
        ))
      }
    </div>
  </section>

  <SeeAlso
    links={[
      { href: '/docs/api/forces', label: 'Forces' },
      { href: '/docs/api/options', label: 'createField & options' },
      { href: '/docs/api/catalog', label: 'Conditions, formations & modes' },
    ]}
  />
</DocsLayout>
