---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import { OPTIONS } from '../../../lib/docs-api.ts';
import CodeTabs from '../../../components/CodeTabs.astro';
import SeeAlso from '../../../components/SeeAlso.astro';

// lowest-level: @field-ui/core is renderer-agnostic, so createField requires an explicit host.
const sig = `import { createField } from '@field-ui/core';
import { browserHost } from '@field-ui/platform';

const field = createField(canvas, { host: browserHost(), ...options });   // → FieldHandle

// browser convenience — @field-ui/vanilla re-exports a createField that wires browserHost() for you:
import { createField } from '@field-ui/vanilla';
const field2 = createField(canvas, options);                              // host wired internally`;

const cfgResting = `// the resting field — an accent and a palette, nothing else
createField(canvas, { accent: '#4da3ff', palette: 'ours' });`;

const cfgDiagnostic = `// draw the force field itself as arrows — a diagnostic view
createField(canvas, { render: 'streamlines' });`;

const cfgAttention = `// focus one thing at a time — one finite strength budget,
// so engaging a body starves the others
createField(canvas, { attention: true });`;

const cfgLowPower = `// a large or low-power surface — half the particles, no wave layer
createField(canvas, { density: 0.5, waves: false });`;

const cfgMass = `// first-class mass — particle mass ∝ size, bodies accelerate by a = F/m
createField(canvas, { mass: true });`;
---

<DocsLayout
  title="field-ui — createField & options"
  description="createField(canvas, options) starts the engine on a canvas and returns the FieldHandle. Every FieldOptions field: accent, density, waves, render, mass, palette, attention, causality — with types and defaults."
>
  <header class="docs-hero">
    <p class="kicker">API reference</p>
    <h1><span class="accent">createField</span> &amp; options</h1>
    <p class="lede">
      The lowest-level entry point. <code>createField(canvas, options)</code> starts the engine on
      a canvas you provide and returns the <a href="/docs/api/handle">FieldHandle</a>. The web
      component, the <code>FieldField</code> class, and <code>mountField()</code> all wrap it.
    </p>
  </header>

  <section class="docs-sec">
    <h2>Signature</h2>
    <CodeTabs variants={[{ label: 'TypeScript', lang: 'ts', code: sig }]} />
    <div class="callout">
      <b>A host is required.</b> <code>@field-ui/core</code> is renderer-agnostic, so
      <code>createField</code> takes a <code>host</code>. In the browser, use <code>createField</code>
      from <a href="/docs/guides/typescript"><code>@field-ui/vanilla</code></a> (it wires
      <code>browserHost()</code> for you) or pass <code>host: browserHost()</code> from
      <a href="/docs/platform"><code>@field-ui/platform</code></a>. The snippets below omit it for brevity.
    </div>
  </section>

  <section class="docs-sec">
    <h2>FieldOptions</h2>
    <p>Every field is optional. Defaults keep the live field unchanged until you opt in.</p>
    <dl class="api-table">
      {
        OPTIONS.map((o) => (
          <div class="api-row">
            <dt class="k">
              <code>{o.name}</code>
              <span class="ty">
                {o.type} · <b>default {o.def}</b>
              </span>
            </dt>
            <dd class="d">{o.desc}</dd>
          </div>
        ))
      }
    </dl>
  </section>

  <section class="docs-sec">
    <h2>Common configurations</h2>
    <p>
      Every option is optional and the defaults keep the field calm. These are the combinations
      worth knowing — each is the whole <code>options</code> object (the <code>host</code> is omitted;
      wire it per the signature above, or use <code>@field-ui/vanilla</code>). Switch tabs to compare.
    </p>
    <CodeTabs
      variants={[
        { label: 'Resting', lang: 'ts', code: cfgResting },
        { label: 'Diagnostic', lang: 'ts', code: cfgDiagnostic },
        { label: 'Attention', lang: 'ts', code: cfgAttention },
        { label: 'Low-power', lang: 'ts', code: cfgLowPower },
        { label: 'Mass', lang: 'ts', code: cfgMass },
      ]}
    />
    <div class="callout">
      <b>These are creation-time.</b> Most have a live counterpart on the
      <a href="/docs/api/handle">FieldHandle</a> — <code>setPalette</code>, <code>setRender</code>,
      <code>setAttention</code>, <code>setCausality</code> — so you can change them after mount too.
    </div>
  </section>

  <SeeAlso
    links={[
      { href: '/docs/api/handle', label: 'FieldHandle' },
      { href: '/docs/api/attributes', label: 'data-* attributes' },
      { href: '/docs/api/types', label: 'Types' },
    ]}
  />
</DocsLayout>
