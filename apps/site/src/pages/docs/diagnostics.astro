---
import DocsLayout from '../../layouts/DocsLayout.astro';
import { RENDER_MODES } from '@fundamental-engine/core';

// Live diagnostic overlays: the C1 renderers draw the diagnostics data onto a canvas. The status
// table below is rendered from the engine catalog so the "shipped vs planned" status stays honest.
const table = RENDER_MODES;
---

<DocsLayout
  title="Fundamental — Diagnostic Overlays"
  description="Live diagnostic render overlays drawn from the Fundamental diagnostics module: contours, potential, force and velocity vectors, energy, topology, inspector, causality, and prediction — all shipped."
>
  <h1>Diagnostic overlays</h1>
  <p class="lede">
    The diagnostics module computes the data; these overlays draw it. Every diagnostic mode now ships
    — contours, potential, force and velocity vectors, energy, topology, inspector, causality, and
    prediction. Toggle a layer — each reads field state and never mutates it.
  </p>

  <div class="diag-controls" role="group" aria-label="Overlay">
    <button data-mode="contours" class="active">Contours</button>
    <button data-mode="potential">Potential</button>
    <button data-mode="force-vectors">Force vectors</button>
    <button data-mode="velocity">Velocity</button>
    <button data-mode="energy">Energy</button>
    <button data-mode="topology">Topology</button>
    <button data-mode="inspector">Inspector</button>
    <button data-mode="causality">Causality</button>
    <button data-mode="prediction">Prediction</button>
  </div>
  <canvas id="diag-canvas" width="520" height="340" aria-label="Diagnostic overlay canvas"></canvas>
  <div class="diag-export" role="group" aria-label="Export">
    <button id="exp-png">Export PNG (current mode)</button>
    <button id="exp-svg" title="The contours mode is the only one with a clean vector form; SVG always exports that potential-field contour set.">Export contours (SVG)</button>
  </div>

  <h2>Runtime observables</h2>
  <p>
    Beyond the canvas overlays above, the engine exposes pull-based data surfaces through
    <code>FieldHandle</code> and <code>@fundamental-engine/core</code>:
  </p>
  <table class="vt-table">
    <thead><tr><th>API</th><th>Returns</th><th>Source</th></tr></thead>
    <tbody>
      <tr>
        <td><code>handle.particleCount()</code></td>
        <td><code>number</code></td>
        <td>Live pool size (<code>store.size</code>). No particle-array walk.</td>
      </tr>
      <tr>
        <td><code>handle.energy()</code></td>
        <td><code>&#123; kinetic, thermal, total, count &#125;</code></td>
        <td>Per-frame energy snapshot. Forwards to <code>energyReport()</code> from <code>diagnostics/energy</code>.</td>
      </tr>
      <tr>
        <td><code>inspectBudget(counts)</code></td>
        <td><code>BudgetFinding[]</code></td>
        <td>Checks supplied counts against <code>DEFAULT_BUDGET</code>. Partial-safe.</td>
      </tr>
      <tr>
        <td><code>systemReport()</code></td>
        <td><code>SystemReport</code></td>
        <td>Force/passport/contract/agent counts + missing-passport list. Stable after mount.</td>
      </tr>
      <tr>
        <td><code>causalityAt(x, y)</code></td>
        <td><code>CausalContribution[]</code></td>
        <td>Per-force Δv decomposition at a point. Powers the <em>causality</em> overlay above.</td>
      </tr>
    </tbody>
  </table>
  <p>
    All are pure — they read state, they do not mutate physics. <code>particleCount()</code> and
    <code>energy()</code> are shipped-but-unfrozen; <code>inspectBudget</code> /
    <code>systemReport</code> / <code>causalityAt</code> are the same. See the
    <a href="/docs/performance">performance docs</a> for the full observable surface and the
    <code>FieldPerf</code> design direction.
  </p>

  <h2>Render-mode status</h2>
  <table class="vt-table">
    <thead><tr><th>Mode</th><th>Type</th><th>Shows</th><th>Status</th></tr></thead>
    <tbody>
      {table.map((m) => (
        <tr>
          <td><code>{m.mode}</code></td>
          <td>{m.type}</td>
          <td>{m.shows}</td>
          <td class={m.status === 'shipped' ? 'ok' : 'planned'}>{m.status}</td>
        </tr>
      ))}
    </tbody>
  </table>
</DocsLayout>

<script>
  import {
    sampleScalarGrid,
    netPotentialAt,
    drawContours,
    drawPotential,
    drawForceVectors,
    drawVelocityVectors,
    drawEnergyBar,
    energyReport,
    attract,
    contourSegments,
    canvasToPng,
    segmentsToSvg,
    drawTopology,
    drawInspector,
    causalityAt,
    drawCausality,
    ghostTrajectory,
    drawPrediction,
  } from '@fundamental-engine/core';
  import { downloadCanvasPng, downloadText } from '@fundamental-engine/platform';

  const canvas = document.getElementById('diag-canvas') as HTMLCanvasElement | null;
  const ctx = canvas?.getContext('2d');
  if (canvas && ctx) {
    const W = canvas.width;
    const H = canvas.height;
    const body = { cx: W / 2, cy: H / 2, M: 4200, strength: 1, range: 240, spin: 1, on: false } as never;
    const particles = Array.from({ length: 70 }, () => ({
      x: Math.random() * W,
      y: Math.random() * H,
      vx: (Math.random() - 0.5) * 5,
      vy: (Math.random() - 0.5) * 5,
      m: 1,
      heat: Math.random() * 0.6,
      size: 1,
      cap: null,
    })) as never[];

    // demo data for the graph/debug modes (topology, causality, prediction, inspector)
    const nodes: Record<string, { x: number; y: number }> = {
      a: { x: 90, y: 90 }, b: { x: 430, y: 90 }, c: { x: 260, y: 250 }, d: { x: 120, y: 290 },
    };
    const agents = [
      { id: 'a~b', from: 'a', to: 'b', type: 'cites', strength: 0.9, tension: 0, memory: 0.7, active: true },
      { id: 'b~c', from: 'b', to: 'c', type: 'references', strength: 0.7, tension: 0, memory: 0.5, active: true },
      { id: 'a~c', from: 'a', to: 'c', type: 'controls', strength: 0.5, tension: 0, memory: 0.3, active: false },
      { id: 'c~d', from: 'c', to: 'd', type: 'describes', strength: 0.3, tension: 0, memory: 0.15, active: false },
    ];
    // a tiny registry: the canonical attractor + a constant wind, so causality has ≥2 sources
    const wind = { apply: (_b: never, p: { vx: number }) => { p.vx += 0.6; } } as never;
    const reg = { attract, wind } as never;

    const draw = (mode: string) => {
      ctx.clearRect(0, 0, W, H);
      const grid = () => sampleScalarGrid((x, y) => netPotentialAt([body], x, y), W, H, mode === 'potential' ? 8 : 14);
      if (mode === 'potential') drawPotential(ctx, grid());
      if (mode === 'contours') drawContours(ctx, grid(), { levels: 11 });
      if (mode === 'force-vectors') drawForceVectors(ctx, attract, body, W, H, { spacing: 34, scale: 9 });
      if (mode === 'velocity') drawVelocityVectors(ctx, particles, { scale: 4 });
      if (mode === 'energy') drawEnergyBar(ctx, energyReport(particles));
      if (mode === 'topology') {
        drawTopology(ctx, agents as never, (id) => nodes[id]);
        for (const id of Object.keys(nodes)) {
          const n = nodes[id]!;
          ctx.fillStyle = '#4da3ff';
          ctx.beginPath();
          ctx.arc(n.x, n.y, 5, 0, Math.PI * 2);
          ctx.fill();
        }
        return; // graph modes don't draw the single source body
      }
      if (mode === 'inspector') {
        drawInspector(ctx, { bodies: 1, particles: particles.length, agents: agents.length, relationships: agents.length, metrics: { coherence: 0.62, mode: 'diagnostic' } });
        return;
      }
      if (mode === 'causality') {
        const origin = { x: 170, y: 180 };
        const contribs = causalityAt(reg, ['attract', 'wind'], body, origin.x, origin.y);
        drawCausality(ctx, contribs, origin, { scale: 12 });
      }
      if (mode === 'prediction') {
        const path = ghostTrajectory(reg, ['attract'], [body], { x: 60, y: 60, vx: 1, vy: 0 }, { steps: 90, forceScale: 0.4 });
        drawPrediction(ctx, path);
      }
      // the source body
      ctx.fillStyle = '#4da3ff';
      ctx.beginPath();
      ctx.arc(body.cx, body.cy, 5, 0, Math.PI * 2);
      ctx.fill();
    };

    let currentMode = 'contours';
    const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('.diag-controls button'));
    for (const b of buttons) {
      b.addEventListener('click', () => {
        buttons.forEach((x) => x.classList.toggle('active', x === b));
        currentMode = b.dataset.mode!;
        draw(currentMode);
      });
    }
    draw(currentMode);

    // Export (C4): PNG raster of the canvas, or SVG vector of the current contour set. Exposed on
    // window for verification; the buttons download.
    const svgDoc = () =>
      segmentsToSvg(
        contourSegments(sampleScalarGrid((x, y) => netPotentialAt([body], x, y), W, H, 14), 11),
        W,
        H,
        { background: '#0b0b10' },
      );
    (window as unknown as { __fieldExport?: unknown }).__fieldExport = {
      png: () => canvasToPng(canvas),
      svg: svgDoc,
    };
    // PNG captures whatever mode is on screen, so name it for that mode. SVG is the potential-field
    // contour vector specifically — the only mode with a clean vector form — so it always exports the
    // contour set (and is labelled as such), regardless of the on-screen mode.
    document.getElementById('exp-png')?.addEventListener('click', () => downloadCanvasPng(canvas, `field-${currentMode}.png`));
    document.getElementById('exp-svg')?.addEventListener('click', () => downloadText(svgDoc(), 'field-contours.svg'));
  }
</script>

<style>
  .lede { color: var(--muted, #9aa); }
  .diag-controls { display: flex; flex-wrap: wrap; gap: 0.4rem; margin: 1rem 0 0.6rem; }
  .diag-controls button, .diag-export button { font: inherit; font-size: 0.85rem; padding: 0.3rem 0.7rem; border: 1px solid var(--line, #2a2a35); border-radius: 7px; background: transparent; color: inherit; cursor: pointer; }
  .diag-export { display: flex; gap: 0.4rem; margin-top: 0.6rem; }
  .diag-controls button.active { border-color: #4da3ff; background: color-mix(in srgb, #4da3ff 18%, transparent); }
  #diag-canvas { width: 100%; max-width: 520px; height: auto; aspect-ratio: 520 / 340; border: 1px solid var(--line, #2a2a35); border-radius: 10px; background: #0b0b10; }
  .vt-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; margin-top: 0.5rem; }
  .vt-table th, .vt-table td { text-align: left; padding: 0.3rem 0.6rem; border-bottom: 1px solid var(--line, #2a2a35); }
  .vt-table th { color: var(--muted, #9aa); }
  .vt-table .ok { color: #2dd4bf; }
  .vt-table .planned { color: var(--muted, #9aa); }
</style>
