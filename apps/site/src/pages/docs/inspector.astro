---
import DocsLayout from '../../layouts/DocsLayout.astro';
import {
  systemReport,
  PASSPORTS,
  CONTRACTS,
  AGENT_CONTRACTS,
  VISUAL_CONTRACTS,
  RECIPE_CONTRACTS,
  SEMANTIC_CONTRACTS,
  FIELD_RECIPES,
} from '@fundamental-engine/core';
import { PHASES } from '@fundamental-engine/platform';

// The Inspector reads the system's own self-description: the system report, every contract, and the
// force passports — plus the LIVE platform runtime (the running <field-root>'s registries, read each
// frame: measurements, state, feedback bindings, relationships, overlays, scheduler, lint) and a live
// reciprocity panel that reads the --field-* write-back the engine emits onto real bodies. The trust
// layer: it answers "why is this moving, what's influencing it, which relationship binds these?".
const report = systemReport();
const contracts = [
  ...CONTRACTS,
  ...AGENT_CONTRACTS,
  ...VISUAL_CONTRACTS,
  ...RECIPE_CONTRACTS,
  ...SEMANTIC_CONTRACTS,
];
const passports = Object.values(PASSPORTS);
const recipeOptions = FIELD_RECIPES.map((r) => ({ id: r.id, name: r.name }));
---

<DocsLayout
  title="field-ui — Inspector"
  description="The field-ui reciprocity inspector: live system report, the full contract catalog, the force passport table, and a live --field-density readback panel."
>
  <h1>Inspector</h1>
  <p class="lede">
    The system inspecting itself — the live platform runtime, coverage, contracts, passports, and a
    reciprocity readout. It proves the field is measured, related, and fed back, not magic.
  </p>

  <section aria-labelledby="sr">
    <h2 id="sr">System report</h2>
    <div class="stat-grid">
      <div class="stat"><b>{report.forces}</b><span>forces</span></div>
      <div class="stat"><b>{report.passports}</b><span>passports</span></div>
      <div class="stat"><b>{report.conformanceExperiments}</b><span>conformance</span></div>
      <div class="stat"><b>{report.contracts}</b><span>contracts</span></div>
      <div class="stat"><b>{report.agentTypes}</b><span>agent types</span></div>
      <div class="stat"><b>{report.recipes}</b><span>recipes</span></div>
    </div>
    <p class="coverage">
      {report.forcesMissingPassport.length === 0 && report.forcesMissingConformance.length === 0
        ? '✓ every force is passported and conformance-covered'
        : `⚠ gaps: ${[...report.forcesMissingPassport, ...report.forcesMissingConformance].join(', ')}`}
    </p>
  </section>

  <section aria-labelledby="lp">
    <h2 id="lp">Live platform runtime</h2>
    <p>
      The running <code>&lt;field-root&gt;</code>'s <a href="/docs/platform">platform</a> registries,
      read live each frame — the actual production runtime (Phase D), not a mock. The six-phase
      scheduler runs <code>discover → read → compute → state → write → render</code>; the counts below
      are the real registered measurements, state, feedback bindings, relationships, visuals, and
      overlays on this page.
    </p>
    <p class="lp-status" data-lp-status>Connecting to the field-root platform…</p>

    <nav class="lp-jump" aria-label="Jump to inspector sections">
      <a href="#sr">System report</a>
      <a href="#lp">Platform</a>
      <a href="#ri">Recipe inspector</a>
      <a href="#rp">Reciprocity</a>
      <a href="#ct">Contracts</a>
      <a href="#pp">Passports</a>
    </nav>

    <div class="lp-phases" aria-label="Frame scheduler phase order">
      {PHASES.map((p) => <span class="lp-phase">{p}</span>)}
      <span class="lp-frame" data-lp-frame>frame —</span>
    </div>

    <div class="stat-grid">
      <div class="stat"><b data-lp="measurements">0</b><span>measurements</span></div>
      <div class="stat"><b data-lp="state">0</b><span>state elements</span></div>
      <div class="stat"><b data-lp="feedback">0</b><span>feedback bindings</span></div>
      <div class="stat"><b data-lp="relationships">0</b><span>relationships</span></div>
      <div class="stat"><b data-lp="visuals">0</b><span>visual bindings</span></div>
      <div class="stat"><b data-lp="overlays">0</b><span>overlays</span></div>
    </div>
    <p class="lp-note">
      These are live, not mocked — and the zeroes are real too. This docs page registers bodies and
      relationships, but declares no visual bindings, overlays, or thresholded state, so the inspector
      shows exactly what is running. The <a href="/docs/reading-field">Reading Field</a> exercises
      state and feedback in full.
    </p>

    <h3 class="lp-h3">Relationship graph <span class="lp-count" data-lp-rel-count></span></h3>
    <ul class="lp-list" data-lp-rels><li class="lp-empty">no relationships discovered yet</li></ul>

    <h3 class="lp-h3">Platform lint <span class="lp-count" data-lp-lint-count></span></h3>
    <ul class="lp-list" data-lp-lint><li class="lp-empty">—</li></ul>
  </section>

  <section aria-labelledby="ri">
    <h2 id="ri">Recipe inspector</h2>
    <p>
      Pick a recipe to see its <b>compiled plan</b> (<code>compileRecipe</code>) and then run it through
      <code>applyRecipe</code> live. This answers <em>why is this moving</em>: which runtime tokens execute,
      which metrics are written, which relationships bind, and what the reduced-motion output is.
    </p>
    <div class="ri-bar">
      <label class="ri-pick">Recipe
        <select data-ri-pick>
          {recipeOptions.map((r) => <option value={r.id}>{r.name}</option>)}
        </select>
      </label>
      <label class="ri-rm"><input type="checkbox" data-ri-reduced /> reduced motion</label>
      <span class="ri-live" data-ri-live>—</span>
    </div>

    <div class="ri-grid">
      <div class="ri-plan">
        <h3 class="lp-h3">Compiled plan</h3>
        <dl class="ri-dl">
          <div><dt>Natural field</dt><dd data-ri="field">—</dd></div>
          <div><dt>Runtime tokens</dt><dd data-ri="tokens">—</dd></div>
          <div><dt>Metrics → vars</dt><dd data-ri="feedback">—</dd></div>
          <div><dt>Diagnostics</dt><dd data-ri="diagnostics">—</dd></div>
          <div><dt>Conditions</dt><dd data-ri="conditions">—</dd></div>
          <div><dt>Reduced-motion</dt><dd data-ri="reduced">—</dd></div>
        </dl>
      </div>
      <div class="ri-run">
        <h3 class="lp-h3">Live application</h3>
        <div class="ri-stage" data-ri-stage></div>
        <ul class="lp-list" data-ri-metrics><li class="lp-empty">run a recipe to see live metrics</li></ul>
      </div>
    </div>
  </section>

  <section aria-labelledby="rp">
    <h2 id="rp">Live reciprocity</h2>
    <p>These are real bodies in the page-wide field. The bars read their live <code>--field-density</code> write-back each frame.</p>
    <div class="insp-bodies">
      <div class="insp-body" data-body="attract" data-strength="1.2" data-range="260" data-feedback data-hot>
        <span class="ib-label">attract</span>
        <span class="ib-meter"><span class="ib-fill"></span></span>
        <span class="ib-val" data-val>0.000</span>
      </div>
      <div class="insp-body" data-body="swirl" data-strength="1" data-range="240" data-feedback data-hot>
        <span class="ib-label">swirl</span>
        <span class="ib-meter"><span class="ib-fill"></span></span>
        <span class="ib-val" data-val>0.000</span>
      </div>
      <div class="insp-body" data-body="sink attract" data-strength="0.9" data-range="240" data-absorb="40" data-feedback data-hot>
        <span class="ib-label">sink attract</span>
        <span class="ib-meter"><span class="ib-fill"></span></span>
        <span class="ib-val" data-val>0.000</span>
      </div>
    </div>
  </section>

  <section aria-labelledby="ct">
    <h2 id="ct">Contracts ({contracts.length})</h2>
    <details class="insp-contracts">
      <summary>Show all contracts</summary>
      <ul>
        {contracts.map((c) => (
          <li><b>{c.name}</b> — <span>{c.mustExist}</span></li>
        ))}
      </ul>
    </details>
  </section>

  <section aria-labelledby="pp">
    <h2 id="pp">Force passports ({passports.length})</h2>
    <div class="table-scroll">
      <table class="passport-table">
        <thead>
          <tr><th>Token</th><th>Family</th><th>Class</th><th>Truth</th><th>field()</th><th>Work</th><th>Cons. speed</th><th>Charge</th><th>Neutral</th></tr>
        </thead>
        <tbody>
          {passports.map((p) => (
            <tr>
              <td><code>{p.token}</code></td>
              <td>{p.family}</td>
              <td>{p.klass}</td>
              <td>{p.truthMode}</td>
              <td>{p.ownsField ? '✓' : '·'}</td>
              <td>{p.doesWork ? '✓' : '·'}</td>
              <td>{p.conservesSpeed ? '✓' : '·'}</td>
              <td>{p.requiresCharge ? '✓' : '·'}</td>
              <td>{p.affectsNeutralMatter ? '✓' : '·'}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</DocsLayout>

<script>
  // Live reciprocity readback: each frame, read the engine's --field-density write-back off each
  // inspected body and reflect it in the meter. Decorative-safe (reads only); respects reduced motion.
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const bodies = Array.from(document.querySelectorAll<HTMLElement>('.insp-body'));
  let raf = 0;
  function tick() {
    for (const el of bodies) {
      const d = parseFloat(getComputedStyle(el).getPropertyValue('--field-density') || '0') || 0;
      const fill = el.querySelector<HTMLElement>('.ib-fill');
      const val = el.querySelector<HTMLElement>('[data-val]');
      if (fill) fill.style.width = `${Math.min(100, d * 100).toFixed(1)}%`;
      if (val) val.textContent = d.toFixed(3);
    }
    raf = requestAnimationFrame(tick);
  }
  if (bodies.length) {
    tick();
    if (reduce) cancelAnimationFrame(raf); // one static read under reduced motion
  }
  document.addEventListener('astro:before-swap', () => cancelAnimationFrame(raf), { once: true });
</script>

<script>
  // Live platform readout: each frame, read the running <field-root>'s platform registries. Reads
  // only (measure.last(), never measure() — no off-phase reads), so the inspector never perturbs the
  // runtime it observes. This is the production Phase-D platform, so the numbers are real. Respects
  // reduced motion (one static read).
  import { lintPlatform, type FieldPlatform } from '@fundamental-engine/platform';

  const reduceP = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const statusEl = document.querySelector<HTMLElement>('[data-lp-status]');
  const frameEl = document.querySelector<HTMLElement>('[data-lp-frame]');
  const relsEl = document.querySelector<HTMLElement>('[data-lp-rels]');
  const relCountEl = document.querySelector<HTMLElement>('[data-lp-rel-count]');
  const lintEl = document.querySelector<HTMLElement>('[data-lp-lint]');
  const lintCountEl = document.querySelector<HTMLElement>('[data-lp-lint-count]');
  const setNum = (k: string, n: number): void => {
    const el = document.querySelector<HTMLElement>(`[data-lp="${k}"]`);
    if (el) el.textContent = String(n);
  };
  const esc = (s: string): string =>
    s.replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' })[c] ?? c);
  const labelOf = (el: Element | null): string => {
    if (!el) return '∅';
    if (el.id) return `#${el.id}`;
    const t = (el.textContent ?? '').trim().replace(/\s+/g, ' ').slice(0, 22);
    return `${el.tagName.toLowerCase()}${t ? ` "${t}"` : ''}`;
  };

  let lraf = 0;
  function lpTick(): void {
    const fr = document.querySelector('field-root') as (HTMLElement & { platform?: FieldPlatform }) | null;
    const p = fr?.platform;
    if (!p) {
      if (statusEl) statusEl.textContent = 'Platform runtime not active on this field-root (legacy path).';
      lraf = requestAnimationFrame(lpTick);
      return;
    }
    if (statusEl) statusEl.textContent = '● live — reading the running platform each frame';
    if (frameEl) frameEl.textContent = `frame ${p.scheduler.frame}`;
    setNum('measurements', p.measure.size);
    setNum('state', p.state.elements().length);
    setNum('feedback', p.feedback.boundVars().length);
    const rels = p.relationships.all();
    setNum('relationships', rels.length);
    setNum('visuals', p.visuals.all().length);
    setNum('overlays', p.overlays.all().length);

    if (relCountEl) relCountEl.textContent = `(${rels.length})`;
    if (relsEl)
      relsEl.innerHTML = rels.length
        ? rels
            .slice(0, 12)
            .map(
              (r) =>
                `<li><code>${esc(labelOf(r.from))}</code> <span class="lp-arrow">→</span> <code>${esc(labelOf(r.to))}</code> <span class="lp-type">${esc(r.type)}</span> <span class="lp-w">${r.strength.toFixed(2)}${r.active ? ' ·active' : ''}</span></li>`,
            )
            .join('') + (rels.length > 12 ? `<li class="lp-empty">+${rels.length - 12} more</li>` : '')
        : '<li class="lp-empty">no relationships discovered yet</li>';

    const warnings = lintPlatform(p);
    if (lintCountEl) lintCountEl.textContent = warnings.length ? `(${warnings.length})` : '✓';
    if (lintEl)
      lintEl.innerHTML = warnings.length
        ? warnings
            .slice(0, 12)
            .map((w) => `<li><span class="lp-code lp-${w.severity}">${esc(w.code)}</span> ${esc(w.message)}</li>`)
            .join('')
        : '<li class="lp-empty">✓ no warnings — relations resolve, state is registered, feedback writes CSS vars, reads stay on-phase</li>';

    lraf = requestAnimationFrame(lpTick);
  }
  lpTick();
  if (reduceP && lraf) cancelAnimationFrame(lraf); // one static read under reduced motion
  document.addEventListener('astro:before-swap', () => cancelAnimationFrame(lraf), { once: true });
</script>

<script>
  // Recipe inspector: compile a chosen recipe (compileRecipe) + run it (applyRecipe), exposing the
  // plan and live metrics — "why is this moving" made answerable from the recipe object.
  import { compileRecipe, recipeById } from '@fundamental-engine/core';
  import { applyRecipe, type AppliedRecipe } from '@fundamental-engine/platform';

  const pick = document.querySelector<HTMLSelectElement>('[data-ri-pick]');
  const reducedRi = document.querySelector<HTMLInputElement>('[data-ri-reduced]');
  const riStage = document.querySelector<HTMLElement>('[data-ri-stage]');
  const riLive = document.querySelector<HTMLElement>('[data-ri-live]');
  const riMetrics = document.querySelector<HTMLElement>('[data-ri-metrics]');
  const setPlan = (k: string, v: string): void => { const e = document.querySelector(`[data-ri="${k}"]`); if (e) e.textContent = v; };
  let riApplied: AppliedRecipe | null = null;
  let riRaf = 0;
  const riStop = (): void => { if (riRaf) cancelAnimationFrame(riRaf); riRaf = 0; };
  const showRecipe = (id: string): void => {
    const r = recipeById(id);
    if (!r || !riStage) return;
    const c = compileRecipe(r);
    setPlan('field', r.naturalField ?? '— (diagnostic / platform)');
    setPlan('tokens', c.bodies.flatMap((b) => b.tokens).join(', '));
    setPlan('feedback', c.feedback.map((f) => `${f.metric} → ${f.var}`).join('   ') || '—');
    setPlan('diagnostics', c.diagnostics.join(', ') || '—');
    setPlan('conditions', c.conditions.join(', ') || '—');
    setPlan('reduced', c.reducedMotion.staticOutputs.join(', '));
    riApplied?.destroy();
    riStage.innerHTML = '';
    riApplied = applyRecipe(riStage, r, { reducedMotion: reducedRi?.checked });
    riStop();
    const loop = (): void => {
      if (riApplied) {
        const ins = riApplied.inspect();
        if (riLive) riLive.textContent = `● ${ins.frame} frames · ${ins.measurements} bodies · ${ins.relationships} rel · lint ${ins.lint || '✓'}`;
        if (riMetrics) {
          const first = Object.values(ins.metrics)[0] ?? {};
          riMetrics.innerHTML = Object.keys(first).length
            ? Object.entries(first).map(([m, v]) => `<li><code>${m}</code> ${(v as number).toFixed(2)}</li>`).join('')
            : '<li class="lp-empty">no metrics for this recipe</li>';
        }
      }
      riRaf = requestAnimationFrame(loop);
    };
    loop();
  };
  if (pick) {
    showRecipe(pick.value);
    pick.addEventListener('change', () => showRecipe(pick.value));
  }
  reducedRi?.addEventListener('change', () => { if (pick) showRecipe(pick.value); });
  document.addEventListener('astro:before-swap', () => { riApplied?.destroy(); riStop(); }, { once: true });
</script>

<style>
  .ri-bar { display: flex; flex-wrap: wrap; gap: 0.8rem; align-items: center; margin: 0.6rem 0; }
  .ri-pick { font-size: 0.82rem; color: var(--muted, #9aa); display: flex; gap: 0.4rem; align-items: center; }
  .ri-pick select { background: var(--panel, #14141b); color: var(--text, #e8e8ef); border: 1px solid var(--line, #2a2a35); border-radius: 6px; padding: 0.2rem 0.4rem; }
  .ri-rm { font-size: 0.78rem; color: var(--muted, #9aa); display: flex; gap: 0.3rem; align-items: center; }
  .ri-live { margin-left: auto; font: 0.76rem ui-monospace, monospace; color: #2dd4bf; }
  .ri-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; align-items: start; }
  @media (max-width: 640px) { .ri-grid { grid-template-columns: 1fr; } }
  .ri-dl { display: grid; gap: 0.4rem; font-size: 0.82rem; }
  .ri-dl > div { display: grid; grid-template-columns: 9rem 1fr; gap: 0.5rem; }
  .ri-dl dt { color: var(--muted, #9aa); margin: 0; }
  .ri-dl dd { margin: 0; font-family: ui-monospace, monospace; font-size: 0.78rem; }
  .ri-stage { display: flex; flex-wrap: wrap; gap: 0.4rem; padding: 0.5rem; border-radius: 8px; background: rgba(0,0,0,0.25); min-height: 44px; }
  .ri-stage [data-recipe-body] { --field-attention: 0; font: 0.74rem ui-monospace, monospace; padding: 0.1rem 0.45rem; border-radius: 5px; background: color-mix(in srgb, #4da3ff calc(14% + var(--field-attention,0) * 50%), transparent); }
  .ri-stage .recipe-static { font-size: 0.78rem; color: var(--muted, #c3c9d4); }
</style>

<style>
  .lede { color: var(--muted, #9aa); }
  .stat-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); gap: 0.75rem; margin: 1rem 0; }
  .stat { border: 1px solid var(--line, #2a2a35); border-radius: 10px; padding: 0.75rem; text-align: center; }
  .stat b { display: block; font-size: 1.6rem; color: #4da3ff; }
  .stat span { font-size: 0.78rem; color: var(--muted, #9aa); }
  .coverage { font-size: 0.9rem; }
  .lp-status { font-size: 0.9rem; color: #2dd4bf; }
  .lp-jump { display: flex; flex-wrap: wrap; gap: 0.4rem; margin: 0.5rem 0 0.75rem; }
  .lp-jump a { font-size: 0.8rem; color: var(--muted, #9aa); border: 1px solid var(--line, #2a2a35); border-radius: 999px; padding: 0.15rem 0.7rem; text-decoration: none; }
  .lp-phases { display: flex; flex-wrap: wrap; align-items: center; gap: 0.35rem; margin: 0.75rem 0; }
  .lp-phase { font-family: ui-monospace, monospace; font-size: 0.74rem; color: var(--muted, #c3c9d4); border: 1px solid var(--line, #2a2a35); border-radius: 5px; padding: 0.1rem 0.45rem; }
  .lp-phase + .lp-phase::before { content: '→'; color: var(--muted, #555); margin: 0 0.35rem 0 -0.2rem; }
  .lp-frame { margin-left: auto; font-family: ui-monospace, monospace; font-size: 0.78rem; color: #4da3ff; }
  .lp-note { font-size: 0.82rem; color: var(--muted, #9aa); margin: 0.5rem 0 0; }
  .lp-h3 { font-size: 0.95rem; margin: 1.1rem 0 0.4rem; }
  .lp-count { color: var(--muted, #9aa); font-weight: 400; font-size: 0.85rem; }
  .lp-list { list-style: none; padding: 0; margin: 0; font-size: 0.82rem; display: grid; gap: 0.25rem; }
  .lp-list code { font-family: ui-monospace, monospace; font-size: 0.78rem; }
  .lp-arrow { color: #4da3ff; }
  .lp-type { color: #2dd4bf; font-size: 0.76rem; }
  .lp-w { color: var(--muted, #9aa); font-size: 0.76rem; }
  .lp-empty { color: var(--muted, #9aa); }
  .lp-code { font-family: ui-monospace, monospace; font-size: 0.74rem; border-radius: 4px; padding: 0.02rem 0.35rem; }
  .lp-warning { background: color-mix(in srgb, #ff9d5c 22%, transparent); color: #ffc99a; }
  .lp-error { background: color-mix(in srgb, #ff5c5c 26%, transparent); color: #ffb0b0; }
  .insp-bodies { display: grid; gap: 0.6rem; margin: 1rem 0; }
  .insp-body { display: grid; grid-template-columns: 10ch 1fr 6ch; align-items: center; gap: 0.6rem; cursor: default; }
  .ib-label { font-family: ui-monospace, monospace; font-size: 0.85rem; }
  .ib-meter { height: 10px; border-radius: 6px; background: rgba(255,255,255,0.06); overflow: hidden; }
  .ib-fill { display: block; height: 100%; width: 0; background: linear-gradient(90deg, #4da3ff, #2dd4bf); transition: width 0.1s linear; }
  .ib-val { font-family: ui-monospace, monospace; font-size: 0.8rem; color: var(--muted, #9aa); text-align: right; }
  .insp-contracts ul { font-size: 0.85rem; line-height: 1.6; padding-left: 1.1rem; }
  .insp-contracts span { color: var(--muted, #9aa); }
  .table-scroll { overflow-x: auto; }
  .passport-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
  .passport-table th, .passport-table td { text-align: left; padding: 0.3rem 0.6rem; border-bottom: 1px solid var(--line, #2a2a35); white-space: nowrap; }
  .passport-table th { color: var(--muted, #9aa); font-weight: 600; }
</style>
