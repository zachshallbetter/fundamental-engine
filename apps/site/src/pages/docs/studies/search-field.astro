---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import RecipesApplied from '../../../components/RecipesApplied.astro';

// Search Field Study — a generic search-results page (no brand assets) driven by real recipes through
// applyRecipe(): results settle by relevance (gravity), source confidence reads as a trust gradient,
// opened results retain memory, and contradictory results carry polarity. Per-result data-field-*
// values are supplied; applyRecipe writes them to --field-* and CSS renders the evidence landscape.

const results = [
  { id: 's1', title: 'Field translation runtime — overview', host: 'docs', confidence: 0.95, recency: 0.9, polarity: 'support' },
  { id: 's2', title: 'Reciprocal DOM interfaces (paper draft)', host: 'research', confidence: 0.8, recency: 0.5, polarity: 'support' },
  { id: 's3', title: 'Why particle backgrounds fail at meaning', host: 'blog', confidence: 0.55, recency: 0.3, polarity: 'neutral' },
  { id: 's4', title: 'Field UI is just a canvas effect (rebuttal)', host: 'forum', confidence: 0.3, recency: 0.7, polarity: 'contradict' },
  { id: 's5', title: 'Accessibility of motion-driven UI', host: 'standards', confidence: 0.85, recency: 0.6, polarity: 'support' },
];
const RECIPES = ['search-relevance-field', 'trust-gradient', 'source-constellation', 'polarity-filter', 'memory-trace'];
const LIVE = ['search-relevance-field', 'trust-gradient'];
---

<DocsLayout
  title="field-ui — Search Field Study"
  description="A concept study: a generic search-results page reinterpreted as a field. Relevance becomes gravity, source confidence a trust gradient, opened results retain memory, and contradictions carry polarity — driven by real recipes through applyRecipe()."
>
  <p class="kicker">Concept study</p>
  <h1>Search Field Study</h1>
  <p class="lede">
    A ranked list becomes an evidence landscape. High-confidence sources gain weight, contradictory
    results separate by polarity, and results you open retain memory — driven by real recipes through
    <code>applyRecipe()</code>, and still a plain list with the field off.
  </p>

  <div class="study-stages">
    <div class="stage"><b>Before</b><span>A plain ranked list of results with sources.</span></div>
    <div class="stage"><b>After</b><span>Confidence reads as a trust gradient, contradictions are flagged, opened results warm with memory.</span></div>
    <div class="stage"><b>Inspect</b><span>Live <code>applyRecipe().inspect()</code> — bodies, relationships, lint.</span></div>
  </div>

  <div class="study-controls" role="group" aria-label="Study controls">
    <button type="button" class="sc-btn on" data-study="field" aria-pressed="true">Field: on</button>
    <button type="button" class="sc-btn" data-study="reduced" aria-pressed="false">Reduce motion</button>
    <span class="sc-readout" data-study-status>starting…</span>
  </div>

  <div class="se">
    <div class="se-query"><span class="se-q">field ui evidence</span><span class="se-count">{results.length} results</span></div>
    <ul class="se-results" id="se-results">
      {results.map((r, i) => (
        <li
          class="se-result"
          id={r.id}
          data-field-confidence={r.confidence}
          data-field-recency={r.recency}
          data-field-priority={(results.length - i) / results.length}
          data-polarity={r.polarity}
          tabindex="0"
        >
          <p class="se-title">{r.title}</p>
          <p class="se-meta">
            <span class="se-host">{r.host}</span>
            <span class="se-conf">confidence {Math.round(r.confidence * 100)}%</span>
            {r.polarity === 'contradict' && <span class="se-contra">contradicts</span>}
          </p>
        </li>
      ))}
    </ul>
  </div>

  <RecipesApplied ids={RECIPES} live={LIVE} />
</DocsLayout>

<script>
  import { mountStudy } from '../../../lib/study.ts';
  const root = document.getElementById('se-results');
  if (root) {
    const items = Array.from(root.querySelectorAll<HTMLElement>('.se-result'));
    // opening a result deposits memory (data-active boosts attention → memory accrues)
    for (const el of items) {
      el.addEventListener('click', () => el.toggleAttribute('data-active'));
      el.addEventListener('keydown', (e) => { if ((e as KeyboardEvent).key === 'Enter') el.toggleAttribute('data-active'); });
    }
    // search-relevance-field drives relevance/memory; trust-gradient drives the confidence gradient
    mountStudy([
      { root, recipeId: 'search-relevance-field', items },
      { root, recipeId: 'trust-gradient', items },
    ]);
  }
</script>

<style>
  .kicker { font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted, #9aa); margin: 0; }
  .lede { color: var(--muted, #9aa); max-width: 72ch; }
  .study-stages { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); gap: 0.6rem; margin: 1rem 0; }
  .stage { border: 1px solid var(--line, #2a2a35); border-radius: 10px; padding: 0.6rem 0.8rem; }
  .stage b { display: block; color: #4da3ff; font-size: 0.82rem; }
  .stage span { font-size: 0.82rem; color: var(--muted, #9aa); }
  .study-controls { display: flex; flex-wrap: wrap; gap: 0.4rem; align-items: center; margin: 0.5rem 0 1rem; }
  .sc-btn { border: 1px solid var(--line, #2a2a35); background: transparent; color: var(--text, #e8e8ef); border-radius: 999px; padding: 0.25rem 0.8rem; font-size: 0.82rem; cursor: pointer; }
  .sc-btn.on { background: color-mix(in srgb, #4da3ff 22%, transparent); border-color: #4da3ff; }
  .sc-readout { font: 0.76rem ui-monospace, monospace; color: var(--muted, #9aa); margin-left: auto; }

  .se-query { display: flex; align-items: baseline; gap: 0.6rem; border-bottom: 1px solid var(--line, #2a2a35); padding-bottom: 0.4rem; margin-bottom: 0.8rem; }
  .se-q { font-size: 1.05rem; font-weight: 600; }
  .se-count { font-size: 0.8rem; color: var(--muted, #9aa); }
  .se-results { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .se-result {
    --field-confidence: 0; --field-recency: 0; --field-memory: 0;
    padding: 0.5rem 0.7rem; border-radius: 8px; cursor: pointer;
    border: 1px solid var(--line, #2a2a35);
    border-left: 3px solid color-mix(in srgb, #2dd4bf calc(var(--field-confidence) * 95%), color-mix(in srgb, #ff9d5c 60%, transparent));
    background: color-mix(in srgb, #2dd4bf calc(var(--field-memory) * 16%), transparent);
    transition: background 0.4s ease, border-color 0.4s ease;
  }
  .se-result[data-polarity='contradict'] { border-left-color: #ff5c5c; }
  .se-result[data-active] { background: color-mix(in srgb, #4da3ff 14%, transparent); }
  .se-title { margin: 0; font-size: 0.95rem; color: color-mix(in srgb, var(--text, #e8e8ef) calc(60% + var(--field-confidence) * 40%), var(--muted, #9aa)); }
  .se-meta { margin: 0.2rem 0 0; display: flex; gap: 0.8rem; font-size: 0.78rem; color: var(--muted, #9aa); }
  .se-conf { color: color-mix(in srgb, #2dd4bf calc(40% + var(--field-confidence) * 60%), var(--muted, #9aa)); }
  .se-contra { color: #ff5c5c; }
  [data-recipe-reduced] .se-result { transition: none; }
</style>
