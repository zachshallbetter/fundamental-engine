---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import PatternsApplied from '../../../components/PatternsApplied.astro';
import StatusChip from '../../../components/StatusChip.astro';
import DataHonesty from '../../../components/DataHonesty.astro';

// Review Field Study — data-driven via bindData(). Changed files and reviewers are records, bound
// through two bindData() groups (Dependency Tension + Review Constellation). Comments link to the
// data-bound file elements by id. No hand-wired behavior — the page comes from data.
const comments = [
  { text: 'This branch in the integrator looks unguarded.', target: 'f-core' },
  { text: 'Nit: prefer the bound helper here.', target: 'f-feedback' },
  { text: 'Can we add a case for the empty render stack?', target: 'f-gallery' },
];
const checks = [
  { name: 'typecheck', ok: true },
  { name: 'tests', ok: true },
  { name: 'build', ok: true },
  { name: 'a11y lint', ok: false },
];
const RECIPES = ['review-constellation', 'dependency-tension', 'consensus-well', 'change-shockwave', 'completion-release'];
const LIVE = ['dependency-tension', 'review-constellation'];
const coherent = checks.filter((c) => c.ok).length / checks.length;
---

<DocsLayout
  title="Fundamental — Review Field Study"
  description="A concept study driven by data through bindData(): a pull request becomes a field — changed files carry heat and tension, reviewers a constellation, comments bind to files. Driven by the dependency-tension + review-constellation recipes."
>
  <p class="kicker">Concept study · data-bound</p>
  <h1>Review Field Study</h1>
  <StatusChip label="Concept study" tone="concept" />
  <p class="lede">
    A generic pull request, reinterpreted as a field. Changed files and reviewers are <b>records</b>
    bound through <code>bindData()</code> — the <a href="/patterns/dependency-tension">Dependency
    Tension</a> and <a href="/patterns/review-constellation">Review Constellation</a> patterns turn
    them into heat, tension, and attention; comments bind to the files they touch. Usable with the field off.
  </p>

  <DataHonesty
    source="Synthetic. The changed files, reviewers, comments, and CI checks are hand-authored sample records standing in for a generic pull request — not a real PR."
    snapshot="Fixed sample data defined in-page; no committed snapshot and no snapshot script feeds this study."
    liveRefresh="No external data, so no live refresh. The field re-settles as you toggle it or reduce motion."
    notClaimed="The field turns impact and dependencies into heat and tension. It does not review the code or decide whether the PR should merge — the heat and check values are illustrative inputs."
  />

  <div class="study-stages">
    <div class="stage"><b>Before</b><span>A plain PR: files, comments, reviewers, checks, a merge box.</span></div>
    <div class="stage"><b>After</b><span>Files heat by impact, blocked files hold tension, reviewers' attention shows.</span></div>
    <div class="stage"><b>Inspect</b><span>Live <code>bindData().inspect()</code> — records · bodies · edges.</span></div>
  </div>

  <div class="study-controls" role="group" aria-label="Study controls">
    <button type="button" class="sc-btn on" data-study="field" aria-pressed="true">Field: on</button>
    <button type="button" class="sc-btn" data-study="reduced" aria-pressed="false">Reduce motion</button>
    <span class="sc-readout" data-study-status>starting…</span>
  </div>

  <p class="study-hint">
    <b>Field off</b> stops the simulation and the PR reads as a plain list — different from turning a
    single <em>projection</em> off, where the field keeps running and only one drawn expression stops.
  </p>

  <div class="rv">
    <header class="rv-head">
      <h2 class="rv-title">Make the pattern runtime executable</h2>
      <p class="rv-branch"><code>feat/recipe-runtime</code> → <code>main</code></p>
      <div class="rv-merge" style={`--field-coherence:${coherent}`}>
        <b>Merge readiness</b><span class="rv-coh">{Math.round(coherent * 100)}% coherent</span>
      </div>
    </header>

    <section>
      <h3>Changed files <span class="rv-dim">Dependency Tension</span></h3>
      <div class="rv-files" id="rv-files"></div>
    </section>

    <section>
      <h3>Reviewers <span class="rv-dim">Review Constellation</span></h3>
      <div class="rv-reviewers" id="rv-reviewers"></div>
    </section>

    <section>
      <h3>Review comments</h3>
      <ul class="rv-comments">
        {comments.map((c) => (
          <li>{c.text} <a href={`#${c.target}`} data-field-relation="affects" data-field-target={`#${c.target}`}>affected file</a></li>
        ))}
      </ul>
    </section>

    <section>
      <h3>Checks</h3>
      <ul class="rv-checks">
        {checks.map((c) => <li class={c.ok ? 'ok' : 'bad'}>{c.ok ? '✓' : '✕'} {c.name}</li>)}
      </ul>
    </section>
  </div>

  <PatternsApplied ids={RECIPES} live={LIVE} />
</DocsLayout>

<script>
  import { mountBindStudy } from '../../../lib/study.ts';
  import { bindData } from '@fundamental-engine/dom';

  interface File { id: string; name: string; delta: string; heat: number; tension: number; blocked?: boolean; }
  interface Reviewer { id: string; name: string; attention: number; }
  const files: File[] = [
    { id: 'f-core', name: 'engine/field.ts', delta: '+82 −14', heat: 0.9, tension: 0.8, blocked: true },
    { id: 'f-feedback', name: 'platform/feedback.ts', delta: '+20 −3', heat: 0.45, tension: 0.35 },
    { id: 'f-schema', name: 'recipes/schema.ts', delta: '+11 −2', heat: 0.3, tension: 0.2 },
    { id: 'f-gallery', name: 'site/gallery.astro', delta: '+60 −1', heat: 0.55, tension: 0.4 },
    { id: 'f-test', name: 'recipes/recipes.test.ts', delta: '+24 −0', heat: 0.15, tension: 0.1 },
  ];
  const reviewers: Reviewer[] = [
    { id: 'r-ada', name: '@ada', attention: 0.9 },
    { id: 'r-lin', name: '@lin', attention: 0.5 },
    { id: 'r-rob', name: '@rob', attention: 0.2 },
  ];
  const esc = (s: string) => s.replace(/[&<>]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' })[c]!);
  const filesRoot = document.getElementById('rv-files');
  const reviewersRoot = document.getElementById('rv-reviewers');
  if (filesRoot && reviewersRoot) {
    const fileMapper = (f: File) => ({
      id: f.id,
      body: { tokens: ['link', 'tether', 'charge'], strength: 0.5 + f.heat, range: 320, feedback: true },
      metrics: { heat: f.heat, tension: f.tension },
      label: f.name,
    });
    const fileContent = (f: File) =>
      `<code>${esc(f.name)}</code><span class="rv-delta">${esc(f.delta)}</span>${f.blocked ? '<span class="rv-flag">blocked</span>' : ''}`;
    const reviewerMapper = (r: Reviewer) => ({
      id: r.id,
      body: { tokens: ['charge', 'link'], strength: 0.5 + r.attention, range: 280, feedback: true, spin: 1 },
      metrics: { attention: r.attention },
      label: r.name,
    });
    mountBindStudy((reduced, on) => [
      bindData(filesRoot, files, fileMapper, { pattern: on ? 'dependency-tension' : undefined, className: 'rv-file', content: fileContent, reducedMotion: reduced }),
      bindData(reviewersRoot, reviewers, reviewerMapper, { pattern: on ? 'review-constellation' : undefined, className: 'rv-reviewer', reducedMotion: reduced }),
    ]);
  }
</script>

<style>
  .kicker { font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted, #9aa); margin: 0; }
  .lede { color: var(--muted, #9aa); max-width: 72ch; }
  .study-stages { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); gap: 0.6rem; margin: 1rem 0; }
  .stage { border: 1px solid var(--line, #2a2a35); border-radius: 10px; padding: 0.6rem 0.8rem; }
  .stage b { display: block; color: #4da3ff; font-size: 0.82rem; }
  .stage span { font-size: 0.82rem; color: var(--muted, #9aa); }
  .study-controls { display: flex; flex-wrap: wrap; gap: 0.4rem; align-items: center; margin: 0.5rem 0 1rem; }
  .sc-btn { border: 1px solid var(--line, #2a2a35); background: transparent; color: var(--text, #e8e8ef); border-radius: 999px; padding: 0.25rem 0.8rem; font-size: 0.82rem; cursor: pointer; }
  .sc-btn.on { background: color-mix(in srgb, #4da3ff 22%, transparent); border-color: #4da3ff; }
  .sc-readout { font: 0.76rem ui-monospace, monospace; color: var(--muted, #9aa); margin-left: auto; }
  .study-hint { font-size: 0.84rem; color: var(--muted, #9aa); max-width: 72ch; margin: 0 0 1rem; }

  .rv { display: grid; gap: 1.2rem; }
  .rv-head { display: flex; flex-wrap: wrap; align-items: center; gap: 0.6rem; border-bottom: 1px solid var(--line, #2a2a35); padding-bottom: 0.6rem; }
  .rv-title { margin: 0; font-size: 1.15rem; }
  .rv-branch { margin: 0; color: var(--muted, #9aa); font-size: 0.82rem; }
  .rv-merge { --field-coherence: 0; margin-left: auto; text-align: right; }
  .rv-merge b { display: block; font-size: 0.78rem; }
  .rv-coh { font-size: 0.82rem; color: color-mix(in srgb, #2dd4bf calc(40% + var(--field-coherence) * 60%), var(--muted, #9aa)); }
  .rv h3 { font-size: 0.95rem; margin: 0 0 0.5rem; }
  .rv-dim { font-size: 0.7rem; color: var(--muted, #9aa); border: 1px solid var(--line, #2a2a35); border-radius: 5px; padding: 0.02rem 0.4rem; margin-left: 0.4rem; }
  .rv-files { display: flex; flex-direction: column; gap: 0.35rem; min-height: 40px; }
  .rv-reviewers { display: flex; flex-wrap: wrap; gap: 0.5rem; min-height: 28px; }
  .rv-comments, .rv-checks { list-style: none; margin: 0; padding: 0; display: flex; gap: 0.5rem; }
  .rv-comments { flex-direction: column; gap: 0.35rem; }
  .rv-checks { flex-wrap: wrap; }
  .rv-file {
    --field-heat: 0; --field-tension: 0;
    display: flex; align-items: center; gap: 0.6rem; padding: 0.35rem 0.6rem; border-radius: 7px;
    border: 1px solid color-mix(in srgb, #ff9d5c calc(var(--field-heat) * 75%), var(--line, #2a2a35));
    background: color-mix(in srgb, #ff9d5c calc(var(--field-heat) * 12%), transparent);
    border-left: 3px solid color-mix(in srgb, #ff5c5c calc(var(--field-tension) * 90%), transparent);
    transition: border-color 0.4s ease, background 0.4s ease;
  }
  .rv-file code { font-family: ui-monospace, monospace; font-size: 0.82rem; }
  .rv-delta { font-family: ui-monospace, monospace; font-size: 0.78rem; color: var(--muted, #9aa); margin-left: auto; }
  .rv-flag { font-size: 0.68rem; color: #ff5c5c; border: 1px solid #ff5c5c; border-radius: 4px; padding: 0.02rem 0.35rem; }
  .rv-reviewer {
    --field-attention: 0;
    padding: 0.2rem 0.6rem; border-radius: 999px; font-size: 0.85rem;
    border: 1px solid color-mix(in srgb, #4da3ff calc(40% + var(--field-attention) * 60%), var(--line, #2a2a35));
    background: color-mix(in srgb, #4da3ff calc(var(--field-attention) * 22%), transparent);
    transition: border-color 0.4s ease, background 0.4s ease;
  }
  .rv-comments a { color: #4da3ff; }
  .rv-comments li { font-size: 0.9rem; }
  .rv-checks .ok { color: #2dd4bf; }
  .rv-checks .bad { color: #ff9d5c; }
  .rv-checks li { font-size: 0.85rem; }
  [data-recipe-reduced] .rv-file, [data-recipe-reduced] .rv-reviewer { transition: none; }
</style>
