---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import RecipesApplied from '../../../components/RecipesApplied.astro';

// System Weather Study — data-driven via bindData(). Dashboard metric cards are records; the
// attention-weather recipe turns supplied heat/pressure into --field-* the CSS renders as weather.
// Calm regions stay quiet, hot regions warm. No hand-wired behavior — the cards come from data.
const RECIPES = ['attention-weather', 'anomaly-bloom', 'risk-horizon', 'dependency-tension', 'system-pulse'];
const LIVE = ['attention-weather'];
---

<DocsLayout
  title="Fundamental — System Weather Study"
  description="A concept study driven by data through bindData(): dashboard metric cards become a field — heat, pressure, anomalies — while healthy regions stay calm. Driven by the attention-weather recipe."
>
  <p class="kicker">Concept study · data-bound</p>
  <h1>System Weather Study</h1>
  <p class="lede">
    A dashboard read as weather. Metric cards are <b>records</b> bound through <code>bindData()</code>;
    the <a href="/recipes/attention-weather">Attention Weather</a> recipe turns each card's heat and
    pressure into field state, so hot or overloaded metrics gain weight and calm regions stay quiet —
    still a legible grid with the field off.
  </p>

  <div class="study-stages">
    <div class="stage"><b>Before</b><span>A plain grid of metric cards.</span></div>
    <div class="stage"><b>After</b><span>Cards develop heat and pressure by activity; anomalies stand out; calm regions stay quiet.</span></div>
    <div class="stage"><b>Inspect</b><span>Live <code>bindData().inspect()</code> — records · bodies · edges.</span></div>
  </div>

  <div class="study-controls" role="group" aria-label="Study controls">
    <button type="button" class="sc-btn on" data-study="field" aria-pressed="true">Field: on</button>
    <button type="button" class="sc-btn" data-study="reduced" aria-pressed="false">Reduce motion</button>
    <span class="sc-readout" data-study-status>starting…</span>
  </div>

  <div class="sw-pulse"><span class="sw-dot"></span><b>System pulse</b><span class="sw-health" data-sw-health>—</span></div>
  <div class="sw-grid" id="sw-grid"></div>

  <RecipesApplied ids={RECIPES} live={LIVE} />
</DocsLayout>

<script>
  import { mountBindStudy } from '../../../lib/study.ts';
  import { bindData } from '@fundamental-engine/dom';

  interface Card { id: string; label: string; value: string; heat: number; pressure: number; anomaly?: boolean; }
  const cards: Card[] = [
    { id: 'w-traffic', label: 'Requests / s', value: '12.4k', heat: 0.2, pressure: 0.15 },
    { id: 'w-errors', label: 'Error rate', value: '4.8%', heat: 0.9, pressure: 0.8, anomaly: true },
    { id: 'w-latency', label: 'p99 latency', value: '820ms', heat: 0.6, pressure: 0.55 },
    { id: 'w-queue', label: 'Queue depth', value: '1,203', heat: 0.5, pressure: 0.7 },
    { id: 'w-cpu', label: 'CPU', value: '38%', heat: 0.15, pressure: 0.1 },
    { id: 'w-disputes', label: 'Disputes', value: '7', heat: 0.75, pressure: 0.4, anomaly: true },
  ];
  const grid = document.getElementById('sw-grid');
  const healthEl = document.querySelector<HTMLElement>('[data-sw-health]');
  if (grid) {
    const health = 1 - cards.reduce((s, c) => s + c.heat, 0) / cards.length;
    if (healthEl) healthEl.textContent = `${Math.round(health * 100)}% calm`;
    const esc = (s: string) => s.replace(/[&<>]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' })[c]!);
    const mapper = (c: Card) => ({
      id: c.id,
      body: { tokens: ['gravity', 'thermal', 'pressure'], strength: 0.5 + c.heat, range: 300, feedback: true },
      metrics: { heat: c.heat, pressure: c.pressure },
      label: c.label,
    });
    const content = (c: Card) =>
      `<p class="sw-label">${esc(c.label)}${c.anomaly ? '<span class="sw-bloom">anomaly</span>' : ''}</p>` +
      `<p class="sw-value">${esc(c.value)}</p><span class="sw-meter"><span class="sw-fill"></span></span>`;
    mountBindStudy((reduced, on) => [
      bindData(grid, cards, mapper, { recipe: on ? 'attention-weather' : undefined, className: 'sw-card', content, reducedMotion: reduced }),
    ]);
  }
</script>

<style>
  .kicker { font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted, #9aa); margin: 0; }
  .lede { color: var(--muted, #9aa); max-width: 72ch; }
  .study-stages { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); gap: 0.6rem; margin: 1rem 0; }
  .stage { border: 1px solid var(--line, #2a2a35); border-radius: 10px; padding: 0.6rem 0.8rem; }
  .stage b { display: block; color: #4da3ff; font-size: 0.82rem; }
  .stage span { font-size: 0.82rem; color: var(--muted, #9aa); }
  .study-controls { display: flex; flex-wrap: wrap; gap: 0.4rem; align-items: center; margin: 0.5rem 0 1rem; }
  .sc-btn { border: 1px solid var(--line, #2a2a35); background: transparent; color: var(--text, #e8e8ef); border-radius: 999px; padding: 0.25rem 0.8rem; font-size: 0.82rem; cursor: pointer; }
  .sc-btn.on { background: color-mix(in srgb, #4da3ff 22%, transparent); border-color: #4da3ff; }
  .sc-readout { font: 0.76rem ui-monospace, monospace; color: var(--muted, #9aa); margin-left: auto; }

  .sw-pulse { display: flex; align-items: center; gap: 0.5rem; margin: 0 0 1rem; }
  .sw-pulse b { font-size: 0.9rem; }
  .sw-health { font-size: 0.82rem; color: var(--muted, #9aa); }
  .sw-dot { width: 10px; height: 10px; border-radius: 50%; background: #2dd4bf; animation: sw-beat 2.4s ease-in-out infinite; }
  @keyframes sw-beat { 0%, 100% { opacity: 0.5; transform: scale(0.9); } 50% { opacity: 1; transform: scale(1.15); } }

  .sw-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 0.7rem; min-height: 80px; }
  .sw-card {
    --field-heat: 0; --field-pressure: 0;
    padding: 0.7rem 0.8rem; border-radius: 10px;
    border: 1px solid color-mix(in srgb, #ff9d5c calc(var(--field-heat) * 80%), var(--line, #2a2a35));
    background: color-mix(in srgb, #ff9d5c calc(var(--field-heat) * 12%), transparent);
    opacity: 1; transition: border-color 0.5s ease, background 0.5s ease, opacity 0.35s ease;
  }
  .sw-card[data-bd-entering] { opacity: 0; }
  .sw-label { margin: 0; font-size: 0.78rem; color: var(--muted, #9aa); display: flex; align-items: center; gap: 0.4rem; }
  .sw-bloom { font-size: 0.64rem; color: #ff5c5c; border: 1px solid #ff5c5c; border-radius: 4px; padding: 0.02rem 0.3rem; }
  .sw-value { margin: 0.2rem 0 0.4rem; font-size: 1.4rem; font-weight: 600; }
  .sw-meter { display: block; height: 6px; border-radius: 4px; background: rgba(255, 255, 255, 0.08); overflow: hidden; }
  .sw-fill { display: block; height: 100%; width: calc(var(--field-pressure) * 100%); background: linear-gradient(90deg, #4da3ff, #ff9d5c); transition: width 0.5s ease; }
  @media (prefers-reduced-motion: reduce) { .sw-dot { animation: none; } .sw-card, .sw-fill { transition: none; } }
  [data-recipe-reduced] .sw-card, [data-recipe-reduced] .sw-fill { transition: none; }
</style>
