---
import DocsLayout from '../../layouts/DocsLayout.astro';
import { DOCS_NAV } from '../../lib/docs-nav.ts';
import { INVISIBLE_FIELDS } from '../../lib/invisible-fields.ts';

// The docs index as a living map. The body of this page renders FROM the same sources the
// rest of the site reads — DOCS_NAV (the sidebar tree) and INVISIBLE_FIELDS (the example
// roster) — so the map cannot drift from the navigation or the family. The cards are
// bodies (data-body + data-feedback + data-hot): the index itself demonstrates the system
// it indexes — engage a card and the page field gathers on it; its ink answers via --d.

// One-line hooks per route. Keyed by href so a nav reorganization can't mispair them;
// a page the map doesn't know yet simply renders without a hook (no drift, no lies).
const HOOKS: Record<string, string> = {
  '/docs': 'this page — the map',
  '/docs/tutorial': 'npm install to a glowing, reacting headline, step by step',
  '/docs/concepts': 'bodies, the shared field context, reciprocity — the mental model',
  '/docs/natural-fields': 'gravity → priority, EM → polarity, strong → binding, weak → transformation',
  '/docs/platform': 'six registries on a six-phase scheduler — the DOM participation layer',
  '/docs/narrative': 'one ordinary element, revealed as a field participant layer by layer',
  '/docs/reading-field': 'the flagship platform demo — a content page that measures your attention',
  '/docs/guides/web-component': '<field-root> in any framework or plain HTML',
  '/docs/guides/typescript': 'the typed FieldField class — no custom elements, no framework',
  '/docs/guides/react': 'the <FieldField> component and the useFieldField hook',
  '/docs/guides/core': 'createField on a canvas you own, host injected',
  '/docs/api': 'the whole surface, generated from the engine catalog',
  '/docs/api/options': 'createField(canvas, opts) and every FieldOptions field',
  '/docs/api/handle': 'the FieldHandle every entry point returns',
  '/docs/api/attributes': 'the data-* contract bodies are written in',
  '/docs/api/metrics': 'every --field-* variable the field writes back, with ranges and cadence',
  '/docs/api/types': 'the exported TypeScript contracts, core and platform',
  '/docs/api/stability': 'the frozen 0.x surface — the same data CI enforces',
  '/docs/api/forces': 'all 36 forces: law, attributes, example — from the catalog',
  '/docs/api/presets': 'blackhole, galaxy, tornado — composites, not new engine code',
  '/docs/api/catalog': 'conditions, formations, render modes, palettes',
  '/docs/studies/reading-field': 'a long-form article reinterpreted as a field',
  '/docs/studies/review-field': 'a pull request as heat, tension, and a reviewer constellation',
  '/docs/studies/search-field': 'search results as a trust gradient with polarity',
  '/docs/studies/system-weather': 'a dashboard as weather — heat, pressure, anomalies',
  '/docs/studies/evidence-field': 'claims, sources, and contradiction as a deterministic field',
  '/docs/studies/visual-binding': 'an SVG bound to its semantic source, linted and inspected',
  '/docs/recipes': 'the FieldRecipe model — lanes composed, never blurred',
  '/docs/authoring': 'three surfaces, one [data-body] contract',
  '/docs/showcase': 'live examples driven by the real field, with copy-paste source',
  '/recipes': 'the recipe gallery, applied live',
  '/docs/inspector': 'the live system report and a --field-density readback panel',
  '/docs/snapshots': 'deterministic fingerprints per force — the physics-drift baseline',
  '/docs/diagnostics': 'potential, topology, causality — explanation as a render mode',
  '/docs/troubleshooting': 'the quiet failures and their fixes',
  '/docs/performance': 'the scheduler, the hot path, and the cost of beauty',
  '/docs/accessibility': 'reduced motion loses no meaning; meaning lives in semantic DOM',
  '/docs/accessibility-preview': 'the animated field and its static fallback, side by side',
};

// render only what the sidebar renders — ready pages, non-empty groups
const groups = DOCS_NAV.map((g) => ({ ...g, items: g.items.filter((i) => i.ready) })).filter(
  (g) => g.items.length > 0,
);

// an external deep-link into the example family borrows its hook from the roster
const hookFor = (href: string): string | undefined =>
  HOOKS[href] ?? INVISIBLE_FIELDS.find((f) => f.href === href)?.hook;
---

<DocsLayout
  title="Fundamental — Developer docs"
  description="The map of the Fundamental documentation: getting started, concepts, guides, the API reference, concept studies, and the twelve invisible-field examples — plus llms.txt for agents. A renderer-agnostic core (zero runtime deps) with a platform layer for DOM participation."
>
  <header class="docs-hero">
    <p class="kicker">Documentation</p>
    <h1>Build with <span class="accent">Fundamental</span>.</h1>
    <p class="lede">
      A platform-native relational field runtime for the DOM — framework-agnostic, with a
      renderer-agnostic core. This page is the map; every card below is drawn from the same
      source as the sidebar, and every card is a body in this page's field. Engage one.
    </p>
  </header>

  <section class="docs-sec">
    <h2>Install</h2>
    <p>
      Most projects want <b><code>@fundamental-engine/vanilla</code></b> — the framework-free door, host-bundled
      so <code>createField</code> works with no wiring. React users want <code>@fundamental-engine/react</code>.
      The other packages are there when you need them; the core engine has zero runtime dependencies.
    </p>
    <div class="pkg-grid">
      <div class="pkg">
        <code class="install" data-copy="npm i @fundamental-engine/vanilla">npm i @fundamental-engine/vanilla</code>
        <span>the framework-free <code>FieldField</code> class, <code>mountField()</code>, and host-bundled <code>createField</code>. <b>The recommended starting point.</b></span>
      </div>
      <div class="pkg">
        <code class="install" data-copy="npm i @fundamental-engine/react">npm i @fundamental-engine/react</code>
        <span>the <code>&lt;FieldField&gt;</code> React component + <code>useFieldField</code> hook</span>
      </div>
      <div class="pkg">
        <code class="install" data-copy="npm i @fundamental-engine/elements">npm i @fundamental-engine/elements</code>
        <span>the <code>&lt;field-root&gt;</code> web component — drops into any framework or plain HTML</span>
      </div>
      <div class="pkg">
        <code class="install" data-copy="npm i @fundamental-engine/core">npm i @fundamental-engine/core</code>
        <span>the renderer-agnostic engine — when you own the canvas and wire your own host</span>
      </div>
    </div>
    <p class="pkg-note">
      No build step? Import straight from a CDN:
      <code>import {'{'} createField {'}'} from 'https://esm.sh/@fundamental-engine/vanilla'</code>.
      Install the specific package you need — the umbrella packages were retired in 0.7.0.
      In a hurry? <a href="/docs/tutorial">Your first field</a> goes from install to a reacting
      headline in eight steps.
    </p>
  </section>

  <section class="docs-sec" data-map>
    <h2>The map</h2>
    <p>
      The documentation, whole. These groups mirror the sidebar exactly — both render from one
      navigation tree, so this map cannot drift from it.
    </p>
    <div class="map-grid">
      {
        groups.map((g) => (
          <article class="map-card" data-body="attract" data-strength="0.4" data-range="240" data-feedback data-hot>
            <h3 class="map-title">{g.title}</h3>
            <ul class="map-list">
              {g.items.map((i) => (
                <li>
                  <a href={i.href}>{i.label}{i.external && <span class="map-ext" aria-hidden="true"> ↗</span>}</a>
                  {hookFor(i.href) && <span class="map-hook">{hookFor(i.href)}</span>}
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </section>

  <section class="docs-sec" data-examples id="the-examples">
    <h2>The examples</h2>
    <p>
      The applied tier. Twelve ordinary page types — an inbox, a market, a backlog, a front page —
      run as fields over <strong>real data</strong>, with no particle swarm: the field's
      measurements come back as type, ink, and anchor. Each ships a committed data snapshot,
      upgrades itself to live counts when its source is reachable, and says which mode it is in.
    </p>
    <div class="ex-grid">
      {
        INVISIBLE_FIELDS.map((f) => (
          <a class="ex-item" href={f.href} data-body="attract" data-strength="0.4" data-range="220" data-feedback data-hot>
            <b class="ex-name">{f.name}</b>
            <span class="ex-hook">{f.hook}</span>
          </a>
        ))
      }
    </div>
    <p class="ex-more"><a href="/evidence">Start with Evidence — the family's front door →</a></p>
  </section>

  <footer class="for-agents" data-for-agents>
    <span class="fa-label">For agents</span>
    <p>
      The docs ship as plain text too — <a href="/llms.txt">/llms.txt</a> is this map in the
      llms.txt format, and <a href="/llms-full.txt">/llms-full.txt</a> is the full canonical
      documentation concatenated; the field's agent consumption model, applied to its own docs.
    </p>
  </footer>
</DocsLayout>

<style>
  /* the map — group cards drawn from DOCS_NAV */
  .map-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 0.9rem;
    margin-top: 0.8rem;
  }
  .map-card {
    padding: 1rem 1.1rem;
    border: 1px solid var(--line, rgba(255, 255, 255, 0.08));
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.015);
    /* living ink: the field's gathered density returns as a quiet glow */
    box-shadow: 0 0 calc(var(--d, 0) * 24px) rgba(77, 163, 255, calc(var(--d, 0) * 0.18));
    transition: border-color 0.3s ease;
  }
  .map-card:hover {
    border-color: color-mix(in srgb, var(--accent, #4da3ff) 35%, var(--line, rgba(255, 255, 255, 0.08)));
  }
  .map-title {
    margin: 0 0 0.55rem;
    font-family: var(--mono, ui-monospace, monospace);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--accent, #4da3ff) calc(35% + var(--d, 0) * 65%), var(--text-3, #9aa0ad));
  }
  .map-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .map-list a {
    font-size: 0.9rem;
    font-weight: 550;
    text-decoration: none;
  }
  .map-list a:hover {
    text-decoration: underline;
  }
  .map-hook {
    display: block;
    font-size: 0.78rem;
    line-height: 1.45;
    color: var(--text-4, #8a8fa0);
  }
  .map-ext {
    font-size: 0.75em;
    color: var(--text-4, #8a8fa0);
  }

  /* the examples — the roster, in the family's sidebar voice */
  .ex-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.7rem;
    margin-top: 0.8rem;
  }
  .ex-item {
    display: flex;
    flex-direction: column;
    gap: 0.18rem;
    padding: 0.75rem 0.9rem;
    border: 1px solid var(--line, rgba(255, 255, 255, 0.08));
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.015);
    text-decoration: none;
    box-shadow: 0 0 calc(var(--d, 0) * 22px) rgba(77, 163, 255, calc(var(--d, 0) * 0.18));
    transition: border-color 0.3s ease;
  }
  .ex-item:hover {
    border-color: color-mix(in srgb, var(--accent, #4da3ff) 40%, var(--line, rgba(255, 255, 255, 0.08)));
  }
  .ex-name {
    font-size: 0.9rem;
    color: color-mix(in srgb, var(--accent, #4da3ff) calc(35% + var(--d, 0) * 65%), var(--text-2, #cfd3df));
  }
  .ex-hook {
    font-size: 0.76rem;
    line-height: 1.45;
    color: var(--text-4, #8a8fa0);
  }
  .ex-more {
    margin-top: 0.9rem;
    font-size: 0.88rem;
  }

  /* for agents */
  .for-agents {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.9rem;
    align-items: baseline;
    margin: 2.2rem 0 0.6rem;
    padding: 0.8rem 1rem;
    border: 1px dashed var(--line-2, rgba(255, 255, 255, 0.16));
    border-radius: 10px;
  }
  .fa-label {
    font-family: var(--mono, ui-monospace, monospace);
    font-size: 0.64rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-4, #8a8fa0);
    white-space: nowrap;
  }
  .for-agents p {
    margin: 0;
    font-size: 0.84rem;
    line-height: 1.55;
    color: var(--text-3, #9aa0ad);
  }
  @media (max-width: 560px) {
    .for-agents {
      grid-template-columns: 1fr;
      gap: 0.3rem;
    }
  }
</style>
