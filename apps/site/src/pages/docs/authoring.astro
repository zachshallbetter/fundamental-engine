---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeTabs from '../../components/CodeTabs.astro';
import ApiStamp from '../../components/ApiStamp.astro';
import SeeItLive from '../../components/SeeItLive.astro';

// Authoring across surfaces — the three-surfaces-one-contract standard. Native HTML, the web
// component, and the React adapter all funnel into the same authoring contract the scanner reads
// (`[data-body]` + its data-* params), so a body authored any of the three ways is the same body in
// the field. The cards lower down are live: the site's persistent <field-root> reacts to them.

const bodyHtml = `<!-- the page is the medium; any element can be a body -->
<canvas id="field"></canvas>

<article data-body="attract" data-strength="0.8">
  Pulls matter inward
</article>

<script type="module">
  import { createField } from '@fundamental-engine/vanilla'; // wires the browser host for you
  // mounts the field and scans the page for [data-body] elements
  createField(document.getElementById('field'));
</script>`;

const bodyWc = `<!-- <field-root> is the singleton field; it scans [data-body] for you -->
<script type="module">import '@fundamental-engine/elements';</script>

<field-root accent="#4da3ff"></field-root>

<article data-body="attract" data-strength="0.8">
  Pulls matter inward
</article>`;

const bodyReact = `import { FieldField } from '@fundamental-engine/react';

export function Page() {
  return (
    <>
      <FieldField accent="#4da3ff" />
      {/* the same [data-body] contract — the field reacts to it */}
      <article data-body="attract" data-strength="0.8">
        Pulls matter inward
      </article>
    </>
  );
}`;

const bodyThree = `import * as THREE from 'three';
import { createFieldLayer, PlaneProjection } from '@fundamental-engine/three';

const renderer = new THREE.WebGLRenderer({ antialias: true });
const scene    = new THREE.Scene();
const camera   = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 1000);

const layer = createFieldLayer({
  projection: new PlaneProjection({ relief: 2 }),  // field on a plane; z lifted from heat
  renderer,
  accent: '#4da3ff',
});
scene.add(layer.object);   // a THREE.Points swarm

// any THREE.Object3D becomes a body — the analogue of [data-body="attract" data-strength="0.8"]
const mesh = new THREE.Mesh(geometry, material);
scene.add(mesh);
layer.addBody(mesh, { tokens: 'attract', strength: 0.8, range: 260 });

renderer.setAnimationLoop(() => {
  layer.tick();                        // engine self-steps; tick() pulls the latest swarm
  renderer.render(scene, camera);
});`;

const platformExample = `import { createFieldPlatform } from '@fundamental-engine/dom';

// the substrate beneath every surface: measure → state → write, on one scheduler
const platform = createFieldPlatform(document.querySelector('article'));
const card = document.querySelector('[data-body]');

platform.measure.register(card);                          // read phase
platform.feedback.bind(card, { attention: '--field-attention' }); // write phase
platform.on('compute', () => {                            // compute phase
  const m = platform.measure.for(card);
  if (m) platform.state.set(card, 'attention', m.visibilityRatio);
});

const tick = (t) => { platform.tick(t); requestAnimationFrame(tick); };
requestAnimationFrame(tick);`;

const feedbackHtml = `<!-- 1. Add data-feedback to receive --d and the other engine vars -->
<h1 data-body="attract" data-feedback class="hero-mass">
  The field is here
</h1>`;

const feedbackCss = `/* 2. Scale the raw [0,1] fraction before driving reactions */
[data-feedback] {
  --d-amp: clamp(0, calc(var(--d, 0) * 12), 1);
}

/* 3. React off the amplified value */
.hero-mass {
  transform:   translateY(calc(var(--d-amp) * -6px));
  text-shadow: 0 0 calc(var(--d-amp) * 20px) color-mix(in srgb, var(--accent) 60%, transparent);
}`;

const sinkHtml = `<!-- a sink body; data-absorb starts accretion, data-max caps it -->
<ul data-body="sink" data-absorb data-max="40" data-feedback class="queue">
  <!-- items dock here when captured -->
</ul>`;

const sinkCss = `/* --load fills from 0 (empty) to 1 (saturated) as matter accretes */
.queue {
  outline: 2px solid color-mix(in srgb, var(--accent) calc(var(--load, 0) * 60%), transparent);
}`;

const condHtml = `<!-- data-when gates the force on a named condition -->
<nav data-body="attract" data-when="active">
  <!-- force activates only while this element is hovered / focused -->
</nav>

<!-- 'slow' = --field-scroll-v < 2 (reading pace); force sleeps during fast scroll -->
<section data-body="swirl" data-strength="0.5" data-when="slow">
  ...
</section>

<!-- combine data-hot + data-when: hover triggers, condition gates -->
<button data-hot data-body="attract" data-spin="1" data-when="active">
  hover me
</button>`;

const formationHtml = `<!-- divide the page into named sections; a formation snaps particles to each -->
<section data-formation="arc">
  <h2>chapter one</h2>
</section>

<section data-formation="ring">
  <h2>chapter two</h2>
</section>`;

const formationJs = `// switch formations from code — smooth transition, same particles
import { mountField } from '@fundamental-engine/vanilla';

const { handle } = mountField(canvas);

// on route change, on scroll into section, or on user action:
handle.setFormation('wells');    // a stable multi-well attractor grid
handle.setFormation('cascade');  // a downward pour
handle.setFormation('ring');     // a closed orbit`;

const CONTRACT = [
  ['data-body', 'force tokens, space-separated', 'attract repel swirl'],
  ['data-strength', 'source mass / pull (default 0.5)', '0.8'],
  ['data-range', 'reach in px (default 280)', '220'],
  ['data-preset', 'a named bundle of virtual bodies', 'dipole'],
  ['data-intent', 'authored intent, compiled to forces', 'gather'],
  ['data-field-role', 'semantic role → a default force', 'source, sink, anchor'],
];

// Element consumers — the element doesn't push the field, it REACTS to it (the element side of the
// Body Matter Interaction model). Each needs data-move so the engine may relocate/collapse the node.
const CONSUMERS = [
  ['data-dock', 'collapse into a sink when captured; fires field:captured / field:released', 'data-move data-dock'],
  ['data-warp', 'teleport to a paired body through a warp throat; fires field:relocated', 'data-warp data-pair="#exit" data-twist="0.5" data-scale="0.8"'],
  ['data-emit', 'clone a decorative template node as matter is emitted', 'data-emit'],
];

const consumers = `<!-- capture: a chip that collapses into a sink when the field pulls it in -->
<span class="chip" data-move data-dock>tag</span>

<!-- relocate: an element that teleports to its paired exit through a warp throat -->
<div data-move data-warp data-pair="#exit" data-twist="0.5" data-scale="0.8">in</div>
<div id="exit"></div>

<!-- emit: clone this template node as the body emits matter -->
<button data-body="spawn" data-emit>
  <template><span class="spark">·</span></template>
</button>`;
---

<DocsLayout
  title="Fundamental — Authoring across surfaces"
  description="Three surfaces, one contract. Author a field body in native HTML, the web component, or the React adapter — all compile to the same [data-body] contract the scanner reads."
>
  <h1>Authoring across surfaces</h1>
  <p class="lede">
    Four surfaces, one contract. A body authored in plain HTML, as a web component, in React, or in a
    Three.js scene is the <em>same</em> body in the field — each is a different way to reach the same
    <code>[data-body]</code> <ApiStamp name="data-body" /> contract. Pick the surface your stack uses;
    Fundamental does not ask you to adopt a framework.
  </p>

  <h2>A body, four ways</h2>
  <p>Each of these authors one attractor of strength 0.8. They produce identical bodies in the engine.</p>
  <CodeTabs
    variants={[
      { label: 'Native HTML', lang: 'html', code: bodyHtml },
      { label: 'Web component', lang: 'html', code: bodyWc },
      { label: 'React', lang: 'tsx', code: bodyReact },
      { label: 'Three.js', lang: 'js', code: bodyThree },
    ]}
    caption="The same body — <code>attract</code>, strength 0.8 — across all four surfaces. The Three.js door uses <code>layer.addBody(mesh, spec)</code> instead of <code>data-body</code> markup."
  />

  <h2>Live</h2>
  <p>
    These cards carry real <code>data-body</code> attributes, so the page's field reacts to them right
    now. Move your pointer near one and watch the field gather around it.
  </p>
  <div class="au-live">
    <article class="au-card" data-body="attract" data-strength="0.8" data-range="220">
      <strong>attract</strong><span>pulls matter inward</span>
    </article>
    <article class="au-card" data-body="repel" data-strength="0.7" data-range="200">
      <strong>repel</strong><span>pushes matter away</span>
    </article>
    <article class="au-card" data-body="swirl" data-strength="0.6" data-range="240">
      <strong>swirl</strong><span>orbits matter around</span>
    </article>
  </div>

  <SeeItLive
    slug="calendar"
    why="the contract's payoff: the same bodies authored once, rendered as day, week, and month — three geometries, one [data-body] contract"
  />

  <h2>The shared contract</h2>
  <p>Every surface writes the same <code>data-*</code> attributes. This is the contract:</p>
  <table class="au-table">
    <thead><tr><th>Attribute</th><th>Meaning</th><th>Example</th></tr></thead>
    <tbody>
      {CONTRACT.map(([attr, meaning, ex]) => (
        <tr><td><code>{attr}</code></td><td>{meaning}</td><td><code>{ex}</code></td></tr>
      ))}
    </tbody>
  </table>

  <h2>Element consumers — react to the field</h2>
  <p>
    The contract above makes an element a <em>force source</em>. An element can instead <em>consume</em>
    the field — react to the matter around it (the element side of the Body Matter Interaction model).
    Each pairs with <code>data-move</code> so the engine may relocate or collapse the node.
  </p>
  <CodeTabs variants={[{ label: 'HTML', lang: 'html', code: consumers }]} />
  <table class="au-table">
    <thead><tr><th>Attribute</th><th>Behavior</th><th>Example</th></tr></thead>
    <tbody>
      {CONSUMERS.map(([attr, meaning, ex]) => (
        <tr><td><code>{attr}</code></td><td>{meaning}</td><td><code>{ex}</code></td></tr>
      ))}
    </tbody>
  </table>
  <p class="note">
    <code>data-warp</code> needs a paired body (<code>data-pair</code>) to relocate to — a single body
    can't show relocation. See the <a href="/docs/api/handle">agent consumption model</a> for the
    captured / relocated / emitted events.
  </p>

  <h2 id="feedback">Reading the field — CSS feedback channels</h2>
  <p>
    The engine writes CSS custom properties onto elements during the <code>write</code> phase of
    every frame. Add <code>data-feedback</code> to receive them; consume them in CSS to make an
    element visually react. No polling, no event listeners — the engine is a CSS property writer.
  </p>
  <CodeTabs
    variants={[
      { label: 'HTML', lang: 'html', code: feedbackHtml },
      { label: 'CSS', lang: 'css', code: feedbackCss },
    ]}
    caption="<code>--d</code> is the canonical density var ∈ [0,1]. Scale it before driving properties — the raw fraction is small by design."
  />
  <p>
    The full set of feedback channels — <code>--d</code>, <code>--load</code>, <code>--lit</code>,
    <code>--entropy</code>, <code>--coherence</code>, <code>--temperature</code> — is in the
    <a href="/docs/api/attributes#writeback">writeback reference</a>. Sink accretion is a common
    pattern — <code>--load</code> fills from 0 (empty) to 1 (saturated):
  </p>
  <CodeTabs
    variants={[
      { label: 'HTML', lang: 'html', code: sinkHtml },
      { label: 'CSS', lang: 'css', code: sinkCss },
    ]}
  />
  <p class="note">
    <strong>Correctness note:</strong> drive reactions off <code>--d</code>, not
    <code>--field-density</code>. When a recipe's metric pipeline runs, it also writes
    <code>--field-density</code> as a recipe output — so on recipe elements,
    <code>--field-density</code> holds the recipe metric, not the engine's raw particle density.
    <code>--d</code> is always the engine value.
  </p>

  <h2 id="conditions">Conditional forces — <code>data-when</code></h2>
  <p>
    A force can activate only while a named condition holds, by adding <code>data-when</code> to
    the body element. The condition is evaluated by the engine each frame; the force is
    multiplied by 0 when the condition is false, 1 when true. No JavaScript required.
  </p>
  <CodeTabs variants={[{ label: 'HTML', lang: 'html', code: condHtml }]} />
  <p>
    Built-in conditions: <strong>active</strong> (the element is hovered/focused), <strong>slow</strong>
    (<code>--field-scroll-v &lt; 2</code> — reading pace), <strong>idle</strong> (no pointer
    activity in the last second), <strong>visible</strong> (intersection &gt; 0.1). The full list
    is on the <a href="/docs/api/catalog#conditions">conditions reference</a>.
  </p>

  <h2 id="formations">Formations — <code>setFormation</code> + <code>data-formation</code></h2>
  <p>
    A formation shapes <em>where</em> the field&apos;s particles want to be — a global geometry
    imposed on top of the local force field. Formations are page-scope and transition smoothly.
  </p>
  <CodeTabs
    variants={[
      { label: 'HTML (declarative)', lang: 'html', code: formationHtml },
      { label: 'JS (imperative)', lang: 'ts', code: formationJs },
    ]}
    caption="Declarative: scroll drives formation changes. Imperative: <code>setFormation()</code> switches on any event."
  />
  <p>
    The built-in formations — <strong>arc</strong>, <strong>ring</strong>, <strong>wells</strong>,
    <strong>cascade</strong>, <strong>drift</strong>, and more — are on the
    <a href="/docs/api/catalog#formations">formations reference</a>. Formations coexist with local
    body forces; the field blends both.
  </p>

  <h2>Beneath the surfaces: the platform</h2>
  <p>
    The surfaces above author <em>bodies</em>. When you need the page itself to participate — to
    measure elements, hold state, and write feedback on a disciplined loop — reach for
    <code>createFieldPlatform()</code> <ApiStamp name="createFieldPlatform" /> from
    <code>@fundamental-engine/dom</code> directly. It is framework-agnostic; the same code runs under any
    surface.
  </p>
  <CodeTabs
    variants={[{ label: 'TypeScript', lang: 'ts', code: platformExample }]}
    caption="The measure → state → write loop, on the six-phase scheduler. See the <a href='/docs/reading-field'>Reading Field</a> demo for a full page built on it."
  />
</DocsLayout>

<style>
  .lede { color: var(--muted, #9aa); }
  .au-live { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 0.8rem; margin: 1rem 0 1.5rem; }
  .au-card {
    display: flex; flex-direction: column; gap: 0.2rem; padding: 1rem; border-radius: 10px;
    border: 1px solid var(--line, #2a2a35); background: color-mix(in srgb, #4da3ff 6%, transparent);
  }
  .au-card strong { color: #4da3ff; font: 600 0.95rem ui-monospace, monospace; }
  .au-card span { font-size: 0.82rem; color: var(--muted, #9aa); }
  .au-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; margin: 0.5rem 0 1.5rem; }
  .au-table th, .au-table td { text-align: left; padding: 0.35rem 0.6rem; border-bottom: 1px solid var(--line, #2a2a35); vertical-align: top; }
  .au-table th { color: var(--muted, #9aa); }
</style>
