---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeTabs from '../../components/CodeTabs.astro';

// These demos are LIVE — the real <field-root> on this page (from Base.astro)
// reacts to the [data-body] elements below, and writes density back as --d. This
// is the actual reciprocal system, not a poster.

const heroSrc = `<span
  class="hero"
  data-body="attract"
  data-strength="1"
  data-range="340"
  data-feedback
>gravity</span>

<style>
  .hero {
    --d: 0;  /* the field eases this in ∈ [0,1] */
    font-weight: 700;
    font-variation-settings: 'wght' calc(380 + var(--d) * 420);
    color: color-mix(in srgb, #4da3ff calc(40% + var(--d) * 55%), #fff);
    text-shadow: 0 0 calc(var(--d) * 44px) rgba(77, 163, 255, var(--d));
  }
</style>`;

const gridSrc = `<article class="card" data-body="attract" data-strength="0.6" data-range="220" data-feedback>
  …card…
</article>

<style>
  .card {
    --d: 0;
    transform: scale(calc(1 + var(--d) * 0.03));
    border-color: color-mix(in srgb, #4da3ff calc(var(--d) * 75%), rgba(255,255,255,0.1));
    box-shadow: 0 0 calc(var(--d) * 30px) rgba(77, 163, 255, calc(var(--d) * 0.5));
    transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s;
  }
</style>`;

const burstSrc = `const field = document.querySelector('field-root');

stage.addEventListener('click', (e) => {
  field.burst(e.clientX, e.clientY, '#4da3ff');  // shove + heat at the cursor
});`;

const burstReact = `import { FieldField } from '@fundamental-engine/react';

// onReady hands you the same FieldHandle once the field mounts
<FieldField
  onReady={(field) => {
    stage.addEventListener('click', (e) => {
      field.burst(e.clientX, e.clientY, '#4da3ff');  // shove + heat at the cursor
    });
  }}
/>`;
---

<DocsLayout
  title="Fundamental — Showcase"
  description="Live examples driven by the real field: a glowing hero word, a reacting card grid, and a click-to-burst stage — each running on this page, paired with its copy-paste source."
>
  <header class="docs-hero">
    <p class="kicker">Resources</p>
    <h1>Live <span class="accent">showcase</span></h1>
    <p class="lede">
      Every demo here is real. The field behind this page reacts to the elements below and writes
      density back into them — move your cursor near one and watch it answer. Each comes with its
      source.
    </p>
  </header>

  <section class="docs-sec">
    <h2>A glowing hero word</h2>
    <p>
      The canonical reciprocity effect. The word is an <code>attract</code> body with
      <code>data-feedback</code>; its <code>--d</code> drives weight and glow, so it grows where
      matter gathers. Sweep your cursor across it.
    </p>
    <div class="sc-stage">
      <span class="sc-hero" data-body="attract" data-strength="1" data-range="340" data-feedback
        >gravity</span
      >
    </div>
    <CodeTabs variants={[{ label: 'HTML + CSS', lang: 'html', code: heroSrc }]} />
  </section>

  <section class="docs-sec">
    <h2>A reacting card grid</h2>
    <p>
      Each card is a gentle attractor. Its <code>--d</code> drives a subtle lift, edge glow, and
      shadow — the grid breathes as the field moves through it.
    </p>
    <div class="sc-cards">
      <article class="sc-card" data-body="attract" data-strength="0.6" data-range="220" data-feedback>
        <b>Reciprocal</b>
        <span>the field bends to elements; elements bend back</span>
      </article>
      <article class="sc-card" data-body="attract" data-strength="0.6" data-range="220" data-feedback>
        <b>Conserved</b>
        <span>nothing is created from nothing — matter is moved</span>
      </article>
      <article class="sc-card" data-body="attract" data-strength="0.6" data-range="220" data-feedback>
        <b>Physical</b>
        <span>one field, not a pool of decorative particles</span>
      </article>
    </div>
    <CodeTabs variants={[{ label: 'HTML + CSS', lang: 'html', code: gridSrc }]} />
  </section>

  <section class="docs-sec">
    <h2>Click to burst</h2>
    <p>
      Drive the field from your own events. The <a href="/docs/api/handle">FieldHandle</a>'s
      <code>burst</code> takes viewport coordinates — click anywhere in the stage to shove and heat
      the matter there.
    </p>
    <div class="sc-stage sc-burst" data-field-burst="#4da3ff" role="presentation">
      <span class="sc-burst-hint">click anywhere in here</span>
    </div>
    <CodeTabs
      variants={[
        { label: 'Web component', lang: 'js', code: burstSrc },
        { label: 'React', lang: 'tsx', code: burstReact },
      ]}
    />
    <div class="callout">
      <b>Want the recipes as a reference?</b> The copy-paste-first versions live on the
      <a href="/docs/recipes">Recipes</a> page; this showcase is the same patterns, running.
    </div>
  </section>
</DocsLayout>

<style>
  .sc-stage {
    display: grid;
    place-items: center;
    min-height: 200px;
    margin: 1.1rem 0 0;
    padding: 2rem;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.015);
  }
  .sc-hero {
    --d: 0;
    font-family: var(--display);
    font-size: clamp(2.5rem, 9vw, 5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    font-variation-settings: 'wght' calc(380 + var(--d) * 420);
    color: color-mix(in srgb, var(--accent) calc(40% + var(--d) * 55%), #fff);
    text-shadow: 0 0 calc(var(--d) * 44px) rgba(77, 163, 255, var(--d));
  }
  .sc-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.8rem;
    margin: 1.1rem 0 0;
  }
  .sc-card {
    --d: 0;
    padding: 1.2rem 1.1rem;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: var(--bg-card, #0b0e16);
    transform: scale(calc(1 + var(--d) * 0.03));
    border-color: color-mix(in srgb, var(--accent) calc(var(--d) * 75%), var(--line));
    box-shadow: 0 0 calc(var(--d) * 30px) rgba(77, 163, 255, calc(var(--d) * 0.5));
    transition:
      transform 0.25s var(--ease),
      border-color 0.25s,
      box-shadow 0.25s;
  }
  .sc-card b {
    display: block;
    font-family: var(--display);
    font-size: 1.05rem;
    color: var(--text);
    margin-bottom: 0.3rem;
  }
  .sc-card span {
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--text-3);
  }
  .sc-burst {
    cursor: crosshair;
    user-select: none;
  }
  .sc-burst-hint {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-4);
  }
  @media (max-width: 620px) {
    .sc-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
