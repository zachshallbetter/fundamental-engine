---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import CodeTabs from '../../../components/CodeTabs.astro';

const basic = `import { FieldField } from '@fundamental-engine/react';

export function App() {
  return (
    <>
      <FieldField accent="#4da3ff" />
      <a data-body="attract" data-strength="0.9" data-range="320" data-feedback>
        pull me
      </a>
    </>
  );
}`;

const onReady = `// the field reacts to [data-body] elements anywhere on the page.
// after rendering new bodies, rescan from onReady:
<FieldField
  palette="heatmap"
  attention
  onReady={(field) => field.scan()}
/>`;

const hook = `import { useFieldField } from '@fundamental-engine/react';

function Background() {
  // own the canvas element yourself
  const { canvasRef, fieldRef } = useFieldField({ accent: '#4da3ff' });
  return <canvas ref={canvasRef} className="my-field" />;
}`;
---

<DocsLayout
  title="Fundamental — React guide"
  description="Use Fundamental in React: the <FieldField> component (every FieldOptions prop + onReady) and the useFieldField hook. React is a peer dependency; the core engine stays zero-dependency."
>
  <header class="docs-hero">
    <p class="kicker">Guides</p>
    <h1>The <span class="accent">React</span> adapter</h1>
    <p class="lede">
      A reciprocal field as a React component. React is a <strong>peer dependency</strong> — the
      one approved framework dep; the core engine stays zero-dependency.
    </p>
  </header>

  <div class="callout">
    <b>An authoring surface over the same contracts.</b> <code>&lt;FieldField&gt;</code> mounts the
    visible field surface; DOM-facing behavior belongs to the <a href="/docs/api">platform layer</a>
    (measurement, state, feedback, relationships, visual bindings, overlays). Reach the runtime handle
    — including <code>flowTo</code> / <code>clearFlow</code> — through <code>onReady</code>.
  </div>

  <section class="docs-sec">
    <h2>Install</h2>
    <div class="pkg">
      <code class="install" data-copy="npm i @fundamental-engine/react">npm i @fundamental-engine/react</code>
    </div>
  </section>

  <section class="docs-sec">
    <h2>&lt;FieldField&gt;</h2>
    <p>
      Mounts a fixed, full-viewport canvas behind your app and runs the engine — the same field
      the web component and <code>mountField()</code> wrap. Bodies are still plain
      <code>[data-body]</code> elements anywhere in your tree.
    </p>
    <CodeTabs variants={[{ label: 'React', lang: 'tsx', code: basic }]} />
    <p>
      It accepts every <a href="/docs/api/options">FieldOptions</a> prop
      (<code>accent</code>, <code>density</code>, <code>waves</code>, <code>waveStyle</code>, <code>waveCenter</code>, <code>render</code>,
      <code>palette</code>, <code>mass</code>, <code>attention</code>, <code>causality</code>, <code>separation</code>) plus
      <code>className</code> / <code>style</code>.
    </p>
  </section>

  <section class="docs-sec">
    <h2>onReady — get the handle</h2>
    <p>
      Because React renders bodies after the field mounts, call <code>field.scan()</code> once
      your elements are in the DOM. <code>onReady</code> hands you the live
      <a href="/docs/api/handle">FieldHandle</a>:
    </p>
    <CodeTabs variants={[{ label: 'React', lang: 'tsx', code: onReady }]} />
  </section>

  <section class="docs-sec">
    <h2>useFieldField — own the canvas</h2>
    <p>
      For full control of the canvas element, use the hook form. It returns a
      <code>canvasRef</code> to attach and a <code>fieldRef</code> holding the handle.
    </p>
    <CodeTabs variants={[{ label: 'React', lang: 'tsx', code: hook }]} />
  </section>
</DocsLayout>
