---
import DocsLayout from '../../layouts/DocsLayout.astro';
import VocabBadge from '../../components/VocabBadge.astro';
import VocabLegend from '../../components/VocabLegend.astro';
import CodeTabs from '../../components/CodeTabs.astro';
import FieldLoopDemo from '../../components/FieldLoopDemo.astro';
import { NATURAL_FIELDS, MANUAL_FORCES, FORCE_KIND, FORCE_FIELD } from 'field-ui';

// The data-attribute pattern per field — honest runtime tokens only. A token's field is its
// classification, not a separate API; you author with data attributes on semantic HTML.
const patGravity = `<!-- Gravity → priority: the element converges attention -->
<section data-body="gravity" data-field-role="priority" data-strength="0.9">
  <h2>What matters most</h2>
</section>`;
const patEm = `<!-- Electromagnetic → polarity / signal. Electric pushes, magnetic bends. -->
<button data-body="charge" data-spin="1" data-range="280">positive</button>
<button data-body="charge" data-spin="-1" data-range="280">negative</button>
<!-- magnetism bends matter along the field; fieldflow carries it along the lines -->`;
const patStrong = `<!-- Strong → binding. A native link IS the relationship — no new API. -->
<p id="claim">The runtime is renderer-agnostic.</p>
<a href="#claim" data-field-relation="supports" data-field-target="#claim">
  Evidence: the boundary test
</a>`;
const patWeak = `<!-- Weak → transformation / decay. Not a fake force — state that ages. -->
<article data-body="morph" data-field-role="revising">
  <!-- or: a memory metric that decays, or a recipe that releases over time -->
</article>`;

// The Natural Field Translation System — the canonical explanation of how field-ui translates the
// four fundamental fields into interface behavior. Data-driven from config/manual.ts (NATURAL_FIELDS
// + FORCE_KIND + FORCE_FIELD), so it can't drift from the catalog. No engine behavior is described
// here that the classification doesn't back.

const FIELD_COLOR: Record<string, string> = {
  gravity: '#4da3ff', electromagnetic: '#2dd4bf', strong: '#a78bfa', weak: '#ff9d5c',
};
const KIND_LABEL: Record<string, string> = {
  designed: 'Designed UI verb', primitive: 'Field primitive', derived: 'Derived behavior',
  analogue: 'Material analogue', transport: 'Transport', metric: 'Metric',
};
const KIND_ORDER = ['primitive', 'analogue', 'transport', 'derived', 'metric', 'designed'] as const;
// group every catalog token by its translation kind (from the engine's classification)
const byKind = KIND_ORDER.map((kind) => ({
  kind,
  label: KIND_LABEL[kind],
  tokens: MANUAL_FORCES.filter((f) => FORCE_KIND[f.token] === kind).map((f) => ({ token: f.token, field: FORCE_FIELD[f.token] })),
})).filter((g) => g.tokens.length);

// Each row separates the lanes: runtime tokens (strict), metrics (measured state), diagnostics
// (inspection modes). They are deliberately NOT merged into one "primitives" column.
const TRANSLATION: [string, string, string, string, string][] = [
  ['Show importance', 'Gravity', 'gravity, attract', 'mass, priority, attention', 'potential, prediction'],
  ['Route signal', 'Electromagnetic', 'charge, propagate, fieldflow, stream', 'signal, strength', 'field-lines, force-vectors'],
  ['Show relationship', 'Strong + EM', 'link, cohesion', 'relation-strength', 'topology, causality'],
  ['Keep things grouped', 'Strong', 'cohesion, crystallize, align', 'cluster, density', 'topology, heatmap'],
  ['Show change / decay', 'Weak', 'morph, memory', 'decay, age', 'causality, contours'],
  ['Show flow through structure', 'EM + transport', 'fieldflow, stream', 'flow, velocity', 'field-lines, prediction'],
  ['Show reading history', 'Memory (metric)', 'memory', 'attention, recency', 'heatmap, inspector'],
];
const DIAG = [
  ['Potential', 'wells and energy landscape', 'Gravity'],
  ['Field lines', 'electromagnetic structure', 'Electromagnetic'],
  ['Topology', 'binding and relationships', 'Strong'],
  ['Causality', 'which primitive caused change', 'any'],
  ['Prediction', 'near-future path', 'Gravity / flow'],
  ['Contours', 'scalar fields', 'derived'],
];
---

<DocsLayout
  title="field-ui — Natural Fields"
  description="How field-ui translates the four fundamental fields into interface behavior: gravity becomes priority, electromagnetism becomes polarity and signal, strong interaction becomes binding, weak interaction becomes transformation. Natural fields are conceptual; engine primitives are translations."
>
  <header class="docs-hero">
    <p class="kicker">Concepts</p>
    <h1>Natural <span class="accent">fields</span></h1>
    <p class="lede">
      field-ui does not copy physics into the interface. It <strong>translates</strong> the four
      fundamental fields into interface behavior. Every interface already has priority, polarity,
      binding, and transformation — physics already has a language for those relations.
    </p>
  </header>

  <section class="docs-sec">
    <p class="nf-doctrine">
      Natural fields are conceptual. Engine primitives are translations. Canonical forces are designed
      verbs. <strong>Natural fields are not tokens; tokens are translations.</strong> This reframe
      changes nothing the particles do — it only gives each behavior a clean place in the hierarchy:
    </p>
    <div class="formula" style="--c:#4da3ff">field → translation → runtime token → metric → diagnostic → recipe</div>
  </section>

  <section class="docs-sec">
    <h2>The vocabulary lanes</h2>
    <p>
      field-ui keeps these categories separate on purpose. A reader should never have to guess whether a
      word is a runtime token, a metric, or a diagnostic — the lane says so:
    </p>
    <VocabLegend />
  </section>

  <h2>The four fields</h2>
  <div class="nf-grid">
    {NATURAL_FIELDS.map((f) => (
      <article class="nf-card" style={`--fc:${FIELD_COLOR[f.field]}`}>
        <h3>{f.title}</h3>
        <p class="nf-translation">{f.translation}</p>
        <p class="nf-summary">{f.summary}</p>
        <p class="nf-uses"><b>Use for</b> {f.interfaceUses.join(' · ')}</p>
        <p class="nf-expr">
          <b>Expressions</b>{' '}
          {f.expressions.length ? f.expressions.map((t) => <code>{t}</code>) : <span class="nf-none">conceptual — closest shipped analogue is <code>memory</code> decay</span>}
        </p>
      </article>
    ))}
  </div>

  <div class="callout">
    <b>Electric fields push. Magnetic fields bend. Fieldflow carries.</b> Do not make
    <code>magnetism.apply()</code> follow magnetic field lines — field-aligned transport belongs to
    <code>fieldflow</code>. And <code>attract</code> is not gravity; <code>repel</code> is not charge —
    those are designed UI verbs.
  </div>

  <h2>Author each field — the data-attribute patterns</h2>
  <p>
    You express a field's translation with <strong>data attributes on semantic HTML</strong>, using
    honest runtime tokens only. A token's field is its classification, not a separate API — there is no
    <code>&lt;gravity&gt;</code> element, only <code>data-body="gravity"</code>. Strong binding is the
    clearest case: a native <code>href</code> (or <code>data-field-relation</code> /
    <code>data-field-target</code>) <em>is</em> the relationship — the graph is discovered from the DOM,
    not declared in code.
  </p>
  <CodeTabs
    variants={[
      { label: 'Gravity → priority', lang: 'html', code: patGravity },
      { label: 'EM → polarity', lang: 'html', code: patEm },
      { label: 'Strong → binding', lang: 'html', code: patStrong },
      { label: 'Weak → decay', lang: 'html', code: patWeak },
    ]}
  />
  <p>
    Live — gravity bodies carrying a supplied <code>priority</code>; <code>applyRecipe()</code> writes
    it back as <code>--field-priority</code> and the CSS reads it (gravity's interface translation,
    running):
  </p>
  <FieldLoopDemo
    token="gravity"
    recipe="priority-well"
    metric="priority"
    items={[
      { text: 'Headline — converges attention', value: 0.9, role: 'priority' },
      { text: 'Supporting detail', value: 0.45, role: 'priority' },
      { text: 'Fine print', value: 0.15, role: 'priority' },
    ]}
  />

  <h2>Fields vs primitives vs forces</h2>
  <p>Every catalog token has a place. This grouping is read straight from the engine's classification:</p>
  <div class="nf-kinds">
    {byKind.map((g) => (
      <div class="nf-kind">
        <span class="nf-kind-label">{g.label}</span>
        <div class="nf-tokens">
          {g.tokens.map((t) => (
            <code class="nf-token" style={t.field ? `--fc:${FIELD_COLOR[t.field]}` : ''} data-field={t.field ?? ''}>{t.token}</code>
          ))}
        </div>
      </div>
    ))}
  </div>

  <h2>Interface translation table</h2>
  <p>One need, separated into lanes: the runtime tokens that execute it, the metrics it measures, and the diagnostics that reveal it.</p>
  <table class="nf-table">
    <thead><tr><th>Interface need</th><th>Natural field</th><th>Runtime tokens</th><th>Metrics</th><th>Diagnostics</th></tr></thead>
    <tbody>
      {TRANSLATION.map(([need, field, tokens, metrics, diags]) => (
        <tr>
          <td>{need}</td>
          <td>{field}</td>
          <td class="nf-lane">{tokens.split(', ').map((t) => <VocabBadge kind="token" label={t} />)}</td>
          <td class="nf-lane">{metrics.split(', ').map((m) => <VocabBadge kind="metric" label={m} />)}</td>
          <td class="nf-lane">{diags.split(', ').map((d) => <VocabBadge kind="diagnostic" label={d} />)}</td>
        </tr>
      ))}
    </tbody>
  </table>

  <h2>Diagnostics by field</h2>
  <p>Each diagnostic answers “which invisible relation am I revealing?” — all shipped (<a href="/docs/diagnostics">see them live</a>). Diagnostics are inspection modes, not runtime tokens.</p>
  <table class="nf-table">
    <thead><tr><th>Diagnostic</th><th>Reveals</th><th>Field</th></tr></thead>
    <tbody>
      {DIAG.map(([d, reveals, field]) => (<tr><td><VocabBadge kind="diagnostic" label={d} /></td><td>{reveals}</td><td>{field}</td></tr>))}
    </tbody>
  </table>

  <div class="callout nf-final">
    <b>Four fields. Many expressions. One DOM runtime.</b> Every interface has priority, polarity,
    binding, and transformation. field-ui gives those relations a field model.
  </div>
</DocsLayout>

<style>
  .lede { color: var(--text-3); }
  .nf-doctrine { color: var(--text-2); }
  .nf-lane { display: flex; flex-wrap: wrap; gap: 0.25rem; }
  .nf-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 0.9rem; margin: 0.8rem 0 1.4rem; }
  .nf-card { padding: 1.1rem; border-radius: 12px; border: 1px solid var(--line); border-left: 3px solid var(--fc); background: color-mix(in srgb, var(--fc) 5%, transparent); }
  .nf-card h3 { margin: 0 0 0.15rem; color: var(--fc); }
  .nf-translation { margin: 0 0 0.5rem; font-family: var(--mono); font-size: 0.8rem; color: var(--text-2); }
  .nf-summary { font-size: 0.86rem; line-height: 1.5; color: var(--text-3); margin: 0 0 0.6rem; }
  .nf-uses, .nf-expr { font-size: 0.78rem; color: var(--text-3); margin: 0.3rem 0 0; }
  .nf-uses b, .nf-expr b { color: var(--text-2); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.06em; display: block; margin-bottom: 0.2rem; }
  .nf-expr code { margin-right: 0.3rem; }
  .nf-none { font-style: italic; }
  .nf-kinds { display: flex; flex-direction: column; gap: 0.7rem; margin: 0.8rem 0 1.4rem; }
  .nf-kind { display: grid; grid-template-columns: 150px 1fr; gap: 0.8rem; align-items: baseline; }
  .nf-kind-label { font-family: var(--mono); font-size: 0.72rem; letter-spacing: 0.06em; color: var(--text-3); }
  .nf-tokens { display: flex; flex-wrap: wrap; gap: 0.35rem; }
  .nf-token { font-size: 0.78rem; padding: 0.15rem 0.5rem; border-radius: 6px; border: 1px solid var(--line); }
  .nf-token[data-field]:not([data-field=""]) { border-color: color-mix(in srgb, var(--fc) 55%, var(--line)); color: var(--fc); background: color-mix(in srgb, var(--fc) 10%, transparent); }
  .nf-table { width: 100%; border-collapse: collapse; font-size: 0.84rem; margin: 0.5rem 0 1.4rem; }
  .nf-table th, .nf-table td { text-align: left; padding: 0.35rem 0.6rem; border-bottom: 1px solid var(--line); vertical-align: top; }
  .nf-table th { color: var(--text-3); font-size: 0.74rem; text-transform: uppercase; letter-spacing: 0.06em; }
  .nf-final b { color: var(--accent); }
  @media (max-width: 620px) { .nf-kind { grid-template-columns: 1fr; gap: 0.3rem; } }
</style>
