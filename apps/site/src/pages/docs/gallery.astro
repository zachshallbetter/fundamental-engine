---
import DocsLayout from '../../layouts/DocsLayout.astro';
import VocabBadge from '../../components/VocabBadge.astro';
import { RECIPE_TIERS, FIRST_RELEASE_RECIPE_IDS, explainScene, serializeRecipe, recipeAuthoring, type FieldRecipe } from 'field-ui';

// The gallery renders the engine's own catalog — 64 `FieldRecipe`s across four tiers (RECIPE_TIERS)
// that map the four-field translation model onto practical interface patterns. Each card carries the
// recipe's natural field, primitives, render stack, metrics, diagnostics, a live reciprocity demo (the
// page-wide field writes --field-density back into the demo chip), the reduced-motion equivalent, and
// copyable JSON. Nothing here adds engine behavior; recipes compose existing primitives.

const FIELD_COLOR: Record<string, string> = {
  gravity: '#4da3ff', electromagnetic: '#2dd4bf', strong: '#a78bfa', weak: '#ff9d5c',
  diagnostic: '#9aa7b4', platform: '#9aa7b4',
};
const first = new Set(FIRST_RELEASE_RECIPE_IDS);

const buildCard = (r: FieldRecipe, tierKey: string, tierLabel: string) => {
  const fieldKey = r.naturalField ?? 'other';
  const fieldLabel =
    r.naturalField != null
      ? r.naturalField[0]!.toUpperCase() + r.naturalField.slice(1)
      : 'Diagnostic / platform';
  // the demo chip uses the recipe's first feedback body (or first body), forced to feed back so the
  // page-wide field's reciprocity is visible.
  const demoBody = r.bodies.find((b) => b.feedback) ?? r.bodies[0]!;
  const auth = recipeAuthoring(r);
  return {
    recipe: r,
    explain: explainScene(r),
    exports: { html: auth.html, wc: auth.webComponent, react: auth.react, json: serializeRecipe(r) },
    fieldKey,
    fieldLabel,
    tierKey,
    tierLabel,
    color: FIELD_COLOR[fieldKey] ?? '#9aa7b4',
    isFirst: first.has(r.id),
    demo: demoBody,
  };
};
const recipes = RECIPE_TIERS.flatMap((t) => t.recipes.map((r) => buildCard(r, t.key, t.label)));

const filters = [
  { key: 'all', label: `All (${recipes.length})` },
  { key: 'first', label: 'First release' },
  ...RECIPE_TIERS.map((t) => ({ key: t.key, label: t.label })),
  { key: 'gravity', label: 'Gravity' },
  { key: 'electromagnetic', label: 'Electromagnetic' },
  { key: 'strong', label: 'Strong' },
  { key: 'weak', label: 'Weak' },
  { key: 'other', label: 'Diagnostic / platform' },
];
---

<DocsLayout
  title="field-ui — Recipe Gallery"
  description={`The ${recipes.length} field-ui recipes across four tiers: portable field programs mapped to the four fundamental fields. Each is executable — natural field, primitives, render stack, metrics, diagnostics, a live reciprocity demo, the reduced-motion equivalent, and copyable JSON.`}
>
  <h1>Recipe gallery</h1>
  <p class="lede">
    {recipes.length} portable <code>FieldRecipe</code>s across four tiers — the four-field translation
    model made practical. Each is a real, validated recipe: every runtime token, render layer, and
    diagnostic is checked against the engine catalog, and recipes only ever <i>compose existing
    primitives</i> (no new engine behavior). The eight <b>first-release</b> recipes explain the system
    quickly; the full set gives it range. Filter by tier or field; copy the JSON, read the plain-language
    explanation, or watch the live reciprocity demo.
  </p>
  <p class="lede lede-lanes">
    Each card keeps the vocabulary lanes separate: <VocabBadge kind="token" label="runtime tokens" />
    execute, <VocabBadge kind="concept" label="concepts" /> name product behavior,
    <VocabBadge kind="metric" label="metrics" /> measure state,
    <VocabBadge kind="diagnostic" label="diagnostics" /> explain it, and
    <VocabBadge kind="condition" label="conditions" /> activate it.
  </p>

  <div class="filters" role="group" aria-label="Filter recipes by field">
    {filters.map((f) => (
      <button class:list={['chip', { on: f.key === 'all' }]} data-filter={f.key} type="button">{f.label}</button>
    ))}
  </div>

  <div class="recipe-grid">
    {recipes.map(({ recipe, explain, exports, fieldKey, fieldLabel, tierKey, tierLabel, color, isFirst, demo }) => (
      <article class="recipe-card" data-field={fieldKey} data-tier={tierKey} data-first={isFirst ? 'true' : 'false'} style={`--rc: ${color}`}>
        <header>
          <div class="rc-tags">
            <span class="rc-field">{fieldLabel}</span>
            <span class="rc-tier" title={tierLabel}>{tierLabel}</span>
            {isFirst && <span class="rc-first">First release</span>}
          </div>
          <h2>{recipe.name}</h2>
          <p class="intent">{recipe.intent}</p>
        </header>

        <div class="rc-demo-row">
          <span
            class="rc-demo"
            data-body={demo.body}
            data-strength={demo.strength ?? 1}
            data-range={demo.range ?? 280}
            data-feedback
            data-hot
          >{recipe.name}</span>
          <button type="button" class="rc-run" data-run={recipe.id}>▶ Run</button>
        </div>

        <p class="explain">{explain}</p>

        <dl class="meta">
          <div>
            <dt>Runtime tokens</dt>
            <dd>{recipe.primitives.map((p) => <VocabBadge kind="token" label={p} />)}</dd>
          </div>
          {recipe.concepts && recipe.concepts.length > 0 && (
            <div>
              <dt>Concepts</dt>
              <dd>{recipe.concepts.map((c) => <VocabBadge kind="concept" label={c} />)}</dd>
            </div>
          )}
          <div>
            <dt>Metrics</dt>
            <dd>{recipe.metrics.map((m) => <VocabBadge kind="metric" label={m} />)}</dd>
          </div>
          <div>
            <dt>Diagnostics</dt>
            <dd>{recipe.diagnostics.map((d) => <VocabBadge kind="diagnostic" label={d} />)}</dd>
          </div>
          {recipe.conditions && recipe.conditions.length > 0 && (
            <div>
              <dt>Conditions</dt>
              <dd>{recipe.conditions.map((c) => <VocabBadge kind="condition" label={c} />)}</dd>
            </div>
          )}
          <div>
            <dt>Render</dt>
            <dd class="rc-render">{recipe.render.join(' · ')}</dd>
          </div>
          <div>
            <dt>Reduced motion</dt>
            <dd class="rc-a11y">{recipe.accessibility.reducedMotion}</dd>
          </div>
          <div>
            <dt>Without motion</dt>
            <dd class="rc-a11y">{recipe.accessibility.meaningWithoutMotion}</dd>
          </div>
        </dl>

        {recipe.notes && <p class="notes">{recipe.notes}</p>}

        <details class="rc-export">
          <summary>Copy this recipe</summary>
          <div class="rc-ex" data-ex>
            <div class="rc-ex-tabs" role="tablist">
              <button type="button" class="on" data-ex-tab="html">HTML</button>
              <button type="button" data-ex-tab="wc">Web component</button>
              <button type="button" data-ex-tab="react">React</button>
              <button type="button" data-ex-tab="json">JSON</button>
              <button type="button" class="rc-ex-copy" data-ex-copy>Copy</button>
            </div>
            <pre class="rc-ex-pre"><code>{exports.html}</code></pre>
            <script type="application/json" data-ex-data set:html={JSON.stringify(exports).split('</').join('<\\/')}></script>
          </div>
        </details>
      </article>
    ))}
  </div>

  <p class="empty" hidden>No recipes match that field.</p>

  <aside class="rg-runner" data-runner hidden aria-label="Recipe runner">
    <div class="rr-head">
      <b data-rr-name>Recipe</b>
      <span class="rr-sub">running via <code>applyRecipe()</code> — the actual recipe object, not a mock</span>
      <label class="rr-rm"><input type="checkbox" data-rr-reduced /> reduced motion</label>
      <button type="button" class="rr-close" data-rr-close aria-label="Close runner">✕</button>
    </div>
    <div class="rr-stage" data-rr-stage></div>
    <div class="rr-inspect">
      <span>frame <b data-rr="frame">—</b></span>
      <span>bodies <b data-rr="measurements">0</b></span>
      <span>relationships <b data-rr="relationships">0</b></span>
      <span>lint <b data-rr="lint">✓</b></span>
    </div>
    <div class="rr-metrics" data-rr-metrics></div>
  </aside>
</DocsLayout>

<script>
  import { recipeById } from 'field-ui';
  import { applyRecipe, type AppliedRecipe } from '@field-ui/platform';

  // Self-contained filter: chips toggle which cards show, by fundamental field / first-release. Reads
  // data-field + data-first off each card. No framework; decorative-safe.
  const grid = document.querySelector<HTMLElement>('.recipe-grid');
  const chips = Array.from(document.querySelectorAll<HTMLButtonElement>('.chip'));
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.recipe-card'));
  const empty = document.querySelector<HTMLElement>('.empty');
  const TIERS = new Set(['core', 'applied', 'systems', 'operational']);
  function apply(key: string) {
    let shown = 0;
    for (const card of cards) {
      const f = card.dataset.field ?? '';
      const tier = card.dataset.tier ?? '';
      const isFirst = card.dataset.first === 'true';
      const match =
        key === 'all' ||
        (key === 'first' && isFirst) ||
        (TIERS.has(key) && key === tier) ||
        key === f;
      card.hidden = !match;
      if (match) shown++;
    }
    if (empty) empty.hidden = shown > 0;
  }
  for (const chip of chips) {
    chip.addEventListener('click', () => {
      chips.forEach((c) => c.classList.toggle('on', c === chip));
      apply(chip.dataset.filter ?? 'all');
    });
  }
  // re-scan the page-wide field so the new demo bodies participate
  const field = document.querySelector('field-root') as (HTMLElement & { rescan?: () => void }) | null;
  field?.rescan?.();
  void grid;

  // ── recipe runner: a shared stage that executes the ACTUAL recipe object via applyRecipe() ──
  const runner = document.querySelector<HTMLElement>('[data-runner]');
  const stage = document.querySelector<HTMLElement>('[data-rr-stage]');
  const nameEl = document.querySelector<HTMLElement>('[data-rr-name]');
  const reducedCb = document.querySelector<HTMLInputElement>('[data-rr-reduced]');
  const metricsEl = document.querySelector<HTMLElement>('[data-rr-metrics]');
  const rrSet = (k: string, v: string) => { const e = document.querySelector(`[data-rr="${k}"]`); if (e) e.textContent = v; };
  let applied: AppliedRecipe | null = null;
  let pollRaf = 0;
  let currentId = '';
  const stopPoll = () => { if (pollRaf) cancelAnimationFrame(pollRaf); pollRaf = 0; };
  const poll = () => {
    if (applied) {
      const ins = applied.inspect();
      rrSet('frame', String(ins.frame));
      rrSet('measurements', String(ins.measurements));
      rrSet('relationships', String(ins.relationships));
      rrSet('lint', ins.lint ? String(ins.lint) : '✓');
      if (metricsEl) {
        const first = Object.values(ins.metrics)[0] ?? {};
        metricsEl.innerHTML = Object.entries(first)
          .map(([m, v]) => `<span class="rr-metric">${m} <b>${(v as number).toFixed(2)}</b></span>`)
          .join('');
      }
    }
    pollRaf = requestAnimationFrame(poll);
  };
  const run = (id: string) => {
    const recipe = recipeById(id);
    if (!recipe || !stage || !runner) return;
    applied?.destroy();
    stage.innerHTML = '';
    currentId = id;
    if (nameEl) nameEl.textContent = recipe.name;
    applied = applyRecipe(stage, recipe, { reducedMotion: reducedCb?.checked });
    runner.hidden = false;
    stopPoll();
    poll();
  };
  for (const b of document.querySelectorAll<HTMLButtonElement>('[data-run]')) {
    b.addEventListener('click', () => run(b.dataset.run!));
  }
  reducedCb?.addEventListener('change', () => { if (currentId) run(currentId); });
  document.querySelector('[data-rr-close]')?.addEventListener('click', () => {
    applied?.destroy(); applied = null; stopPoll();
    if (runner) runner.hidden = true;
  });
  document.addEventListener('astro:before-swap', () => { applied?.destroy(); stopPoll(); }, { once: true });

  // ── copy-this-recipe: HTML / Web component / React / JSON per card ──────────────────────────
  for (const ex of document.querySelectorAll<HTMLElement>('[data-ex]')) {
    let data: Record<string, string> = {};
    try { data = JSON.parse(ex.querySelector('[data-ex-data]')?.textContent ?? '{}'); } catch { data = {}; }
    const pre = ex.querySelector<HTMLElement>('.rc-ex-pre code');
    const tabs = Array.from(ex.querySelectorAll<HTMLButtonElement>('[data-ex-tab]'));
    const copyBtn = ex.querySelector<HTMLButtonElement>('[data-ex-copy]');
    let current = 'html';
    for (const t of tabs) {
      t.addEventListener('click', () => {
        current = t.dataset.exTab ?? 'html';
        tabs.forEach((x) => x.classList.toggle('on', x === t));
        if (pre) pre.textContent = data[current] ?? '';
      });
    }
    copyBtn?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(data[current] ?? '');
        copyBtn.textContent = 'Copied';
        setTimeout(() => { copyBtn.textContent = 'Copy'; }, 1200);
      } catch { copyBtn.textContent = 'Copy failed'; }
    });
  }
</script>

<style>
  .lede { color: var(--muted, #9aa); max-width: 70ch; }
  .lede-lanes { font-size: 0.9rem; display: flex; flex-wrap: wrap; gap: 0.3rem; align-items: baseline; }
  .rc-render { font-family: ui-monospace, monospace; font-size: 0.78rem; color: var(--muted, #c3c9d4); }
  .filters { display: flex; flex-wrap: wrap; gap: 0.4rem; margin: 1.25rem 0 0.5rem; }
  .chip {
    border: 1px solid var(--line, #2a2a35);
    background: transparent;
    color: var(--text, #e8e8ef);
    border-radius: 999px;
    padding: 0.25rem 0.8rem;
    font-size: 0.82rem;
    cursor: pointer;
  }
  .chip.on { background: color-mix(in srgb, #4da3ff 22%, transparent); border-color: #4da3ff; }
  .recipe-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.25rem;
    margin-top: 1rem;
  }
  .recipe-card[hidden] { display: none; }
  .recipe-card {
    border: 1px solid var(--line, #2a2a35);
    border-top: 3px solid var(--rc, #4da3ff);
    border-radius: 12px;
    padding: 1.1rem 1.2rem;
    background: var(--panel, rgba(255, 255, 255, 0.02));
  }
  .rc-tags { display: flex; gap: 0.4rem; align-items: center; flex-wrap: wrap; }
  .rc-field {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--rc, #4da3ff);
    border: 1px solid color-mix(in srgb, var(--rc, #4da3ff) 50%, transparent);
    border-radius: 5px;
    padding: 0.05rem 0.4rem;
  }
  .rc-first {
    font-size: 0.72rem;
    color: #0b0b10;
    background: var(--rc, #4da3ff);
    border-radius: 5px;
    padding: 0.05rem 0.4rem;
    font-weight: 600;
  }
  .rc-tier {
    font-size: 0.68rem;
    color: var(--muted, #9aa);
    border: 1px solid var(--line, #2a2a35);
    border-radius: 5px;
    padding: 0.05rem 0.4rem;
  }
  .recipe-card h2 { margin: 0.5rem 0 0; font-size: 1.1rem; }
  .recipe-card .intent { margin: 0.2rem 0 0.75rem; color: var(--muted, #9aa); font-size: 0.9rem; }
  .rc-demo-row { display: flex; align-items: baseline; gap: 0.6rem; margin: 0.25rem 0 0.75rem; }
  .rc-demo {
    --field-density: 0; /* the page-wide field writes this back */
    display: inline-block;
    font-size: 1.1rem;
    font-variation-settings: 'wght' calc(420 + var(--field-density, 0) * 460);
    color: color-mix(in srgb, var(--rc, #4da3ff) calc(35% + var(--field-density, 0) * 60%), var(--text, #fff));
    text-shadow: 0 0 calc(var(--field-density, 0) * 30px) color-mix(in srgb, var(--rc, #4da3ff) 80%, transparent);
    cursor: default;
  }
  .rc-demo-note { font-size: 0.72rem; color: var(--muted, #9aa); }
  .recipe-card .explain { font-size: 0.9rem; line-height: 1.5; }
  .recipe-card .meta { display: grid; gap: 0.4rem; margin: 0.75rem 0; font-size: 0.84rem; }
  .recipe-card .meta div { display: grid; grid-template-columns: 11ch 1fr; gap: 0.5rem; align-items: start; }
  .recipe-card dt { color: var(--muted, #9aa); }
  .recipe-card dd { margin: 0; display: flex; flex-wrap: wrap; gap: 0.3rem; }
  .recipe-card dd.rc-a11y { display: block; color: var(--muted, #c3c9d4); }
  .recipe-card .token {
    background: color-mix(in srgb, var(--rc, #4da3ff) 16%, transparent);
    border-radius: 5px;
    padding: 0.05rem 0.4rem;
    font-size: 0.8rem;
  }
  .recipe-card .diag {
    font-size: 0.78rem;
    color: var(--muted, #c3c9d4);
    border-bottom: 1px dotted var(--line, #3a3a45);
    text-decoration: none;
  }
  .recipe-card .notes {
    font-size: 0.82rem;
    color: var(--muted, #9aa);
    border-left: 2px solid var(--line, #2a2a35);
    padding-left: 0.7rem;
  }
  .recipe-card details { margin-top: 0.5rem; font-size: 0.85rem; }
  .rc-ex-tabs { display: flex; flex-wrap: wrap; gap: 0.25rem; margin: 0.4rem 0; }
  .rc-ex-tabs button { border: 1px solid var(--line, #2a2a35); background: transparent; color: var(--muted, #9aa); border-radius: 5px; padding: 0.1rem 0.5rem; font-size: 0.74rem; cursor: pointer; }
  .rc-ex-tabs button.on { background: color-mix(in srgb, #4da3ff 20%, transparent); border-color: #4da3ff; color: var(--text, #e8e8ef); }
  .rc-ex-copy { margin-left: auto; color: #2dd4bf !important; border-color: color-mix(in srgb, #2dd4bf 50%, var(--line)) !important; }
  .rc-ex-pre { max-height: 260px; overflow: auto; font-size: 0.76rem; background: rgba(0, 0, 0, 0.25); padding: 0.75rem; border-radius: 8px; white-space: pre; }
  .recipe-card pre {
    max-height: 260px;
    overflow: auto;
    font-size: 0.76rem;
    background: rgba(0, 0, 0, 0.25);
    padding: 0.75rem;
    border-radius: 8px;
  }
  .empty { color: var(--muted, #9aa); margin-top: 1.5rem; }

  .rc-run {
    margin-left: auto;
    border: 1px solid color-mix(in srgb, var(--rc, #4da3ff) 55%, var(--line, #2a2a35));
    background: color-mix(in srgb, var(--rc, #4da3ff) 14%, transparent);
    color: var(--rc, #4da3ff);
    border-radius: 999px; padding: 0.1rem 0.6rem; font-size: 0.74rem; cursor: pointer;
  }

  .rg-runner {
    position: fixed; right: 1rem; bottom: 1rem; width: min(360px, calc(100vw - 2rem)); z-index: 50;
    background: var(--panel-solid, #14141b); border: 1px solid var(--line, #2a2a35);
    border-radius: 12px; padding: 0.8rem 0.9rem; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.45);
  }
  .rg-runner[hidden] { display: none; }
  .rr-head { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
  .rr-head b { font-size: 0.95rem; }
  .rr-sub { font-size: 0.7rem; color: var(--muted, #9aa); flex: 1 1 100%; order: 3; }
  .rr-rm { font-size: 0.72rem; color: var(--muted, #9aa); display: flex; align-items: center; gap: 0.25rem; }
  .rr-close { margin-left: auto; background: none; border: none; color: var(--muted, #9aa); cursor: pointer; font-size: 0.9rem; }
  .rr-stage {
    position: relative; min-height: 64px; margin: 0.6rem 0; padding: 0.5rem; border-radius: 8px;
    background: rgba(0, 0, 0, 0.25); display: flex; flex-wrap: wrap; gap: 0.4rem; align-items: center;
  }
  .rr-stage [data-recipe-body] {
    --field-attention: 0; --field-density: 0;
    font-family: ui-monospace, monospace; font-size: 0.74rem; padding: 0.1rem 0.45rem; border-radius: 5px;
    background: color-mix(in srgb, #4da3ff calc(14% + var(--field-attention, 0) * 50%), transparent);
    color: color-mix(in srgb, #4da3ff calc(40% + var(--field-attention, 0) * 55%), var(--text, #e8e8ef));
    transition: background 0.3s ease, color 0.3s ease;
  }
  .rr-stage .recipe-static { font-size: 0.78rem; color: var(--muted, #c3c9d4); }
  .rr-stage .recipe-static p { margin: 0.2rem 0; }
  .rr-stage .recipe-static span { color: #2dd4bf; }
  .rr-inspect { display: flex; flex-wrap: wrap; gap: 0.8rem; font-size: 0.76rem; color: var(--muted, #9aa); }
  .rr-inspect b { color: var(--text, #e8e8ef); font-family: ui-monospace, monospace; }
  .rr-metrics { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-top: 0.5rem; }
  .rr-metric { font-size: 0.7rem; color: var(--muted, #9aa); border: 1px solid var(--line, #2a2a35); border-radius: 5px; padding: 0.05rem 0.4rem; }
  .rr-metric b { color: #7bd88f; }
  [data-reduced='on'] .rr-stage [data-recipe-body] { transition: none; }
</style>
