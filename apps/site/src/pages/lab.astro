        const samples: { sx: number; sy: number; ux: number; uy: number; mag: number }[] = [];
        let maxMag = 0;
        for (let sx = stepPx / 2; sx < w; sx += stepPx)
          for (let sy = stepPx / 2; sy < h; sy += stepPx) {
            const wx = (sx - view.ox) / view.scale, wy = (sy - view.oy) / view.scale;
            const { fx, fy } = forceAt([b as any], forces, fenv, wx, wy);
            const mag = Math.hypot(fx, fy);
