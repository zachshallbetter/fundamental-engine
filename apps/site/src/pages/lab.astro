            ctx.beginPath(); ctx.arc(sx, sy, r, 0, 7); ctx.fill();
            if (i === 0) { ctx.strokeStyle = col; ctx.lineWidth = 1.5; ctx.beginPath(); ctx.arc(sx, sy, r + 2, 0, 7); ctx.stroke(); }
          }
          // expected frame-0 Δv (gold)
          const p0 = traj[0][0], d = result.applyDelta?.[0];
          if (d && Math.hypot(d.dvx, d.dvy) > 1e-6) {
            const k = 60, [ex, ey] = w2s(p0.x, p0.y), [ex2, ey2] = w2s(p0.x + d.dvx * k, p0.y + d.dvy * k);
            arrow(ex, ey, ex2, ey2, 'rgba(255,206,107,0.9)', 4);
          }
        }

        updateHud();
        updateTimeline();
        paintChecklist();
      }

      function updateHud() {
        const hud = $('hud'); if (!hud) return;
        const traj = result.trajectory, nP = traj[0].length;
        if (nP === 0) { hud.innerHTML = `<div class="hud-row"><span class="k">frame</span><b>${frame}</b></div>`; return; }
        const b = result.body;
        const p = traj[Math.min(frame, traj.length - 1)][0];
        const prev = frame > 0 ? traj[Math.min(frame, traj.length - 1) - 1][0] : null;
        const dist = Math.hypot(p.x - b.cx, p.y - b.cy);
        const speed = p.speed ?? Math.hypot(p.vx, p.vy);
        const fmag = prev && !p.cap ? Math.hypot((p.vx / 0.95) - prev.vx, (p.vy / 0.95) - prev.vy) : 0;
        let html = `<div class="hud-row"><span class="k">dist</span><b>${dist.toFixed(0)}</b><span class="u">px</span></div>`;
        html += `<div class="hud-row"><span class="k">speed</span><b>${speed.toFixed(2)}</b><span class="u">px/f</span></div>`;
        html += `<div class="hud-row"><span class="k">force</span><b>${fmag.toFixed(3)}</b><span class="u">|Δv|</span></div>`;
        if ((p.heat ?? 0) > 0.01) html += `<div class="hud-row"><span class="k">heat</span><b>${p.heat.toFixed(2)}</b></div>`;
        if (p.cap) html += `<div class="hud-row captured"><span class="k">state</span><b>captured</b></div>`;
        hud.innerHTML = html;
      }

      function paintChecklist() {
        const active = checks.filter((c) => c.active);
        const live = active.map((c) => ({ ...c, satisfied: c.passFrame >= 0 && frame >= c.passFrame, fails: c.passFrame < 0 && frame >= 0 }));
        const passedNow = live.filter((c) => c.satisfied).length;
        const anyFail = live.some((c) => c.passFrame < 0 && frame >= (result.trajectory.length - 1));
        const allPass = passedNow === active.length && active.length > 0;
        const v = $('verdict')!;
        if (anyFail) { v.className = 'verdict mismatch'; v.textContent = `Mismatch — ${active.length - passedNow} failed`; }
        else if (allPass) { v.className = 'verdict confirmed'; v.textContent = `Confirmed — ${passedNow}/${active.length} passed`; }
        else { v.className = 'verdict resolving'; v.textContent = `Resolving — ${passedNow}/${active.length} passed`; }
        const sum = $('passSummary'); if (sum) sum.textContent = active.length ? `${passedNow}/${active.length}` : '';
        const tc = $('tabCount'); if (tc) tc.textContent = active.length ? `${passedNow}/${active.length}` : '';

        const list = $('checklist')!;
        list.innerHTML = checks.map((c) => {
          if (!c.active) return checkRow('pending', '–', c, 'default-only');
          if (c.passFrame < 0) {
            const failedNow = frame >= (result.trajectory.length - 1);
            return checkRow(failedNow ? 'fail' : 'pending', failedNow ? '✕' : '○', c, failedNow ? 'failed' : `resolves @ frame ${result.trajectory.length - 1}`);
          }
          const satisfied = frame >= c.passFrame;
          return checkRow(satisfied ? 'pass' : 'pending', satisfied ? '✓' : '○', c, satisfied ? `passed @ frame ${c.passFrame}` : `resolves @ frame ${c.passFrame}`);
        }).join('');
      }
      function checkRow(cls: string, mark: string, c: Any, when: string) {
        return `<div class="check ${cls}">
          <div class="row1"><span class="mark">${mark}</span><span class="label">${esc(c.label)}</span><span class="kind">${c.kind}</span></div>
          <div class="nums"><span>measured <b>${esc(String(c.measured))}</b></span><span>expected <b>${esc(String(c.expected))}</b></span><span class="when">${esc(when)}</span></div>
        </div>`;
      }

      function buildTimeline() {
        const max = result.trajectory.length - 1;
        const tl = $('timeline'); if (tl) tl.setAttribute('aria-valuemax', String(max));
        const markers = $('tlMarkers');
        if (markers) {
          const active = checks.filter((c: Any) => c.active && c.passFrame >= 0);
          markers.innerHTML = active.map((c: Any) => {
            const pct = max ? (c.passFrame / max) * 100 : 0;
            return `<div class="tl-marker${c.kind === 'exact' ? ' exact' : ''}" data-pf="${c.passFrame}" style="left:${pct}%" title="${esc(c.label)} — passes @ frame ${c.passFrame}"></div>`;
          }).join('');
        }
        buildWaveform();
        updateTimeline();
      }
      function buildWaveform() {
        const cv = $('tlWave') as HTMLCanvasElement | null;
        if (!cv || !result) return;
        const w = cv.clientWidth || 600, h = 46;
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        cv.width = Math.floor(w * dpr); cv.height = Math.floor(h * dpr);
        const c = cv.getContext('2d')!; c.setTransform(dpr, 0, 0, dpr, 0, 0);
        c.clearRect(0, 0, w, h);
        const traj = result.trajectory, N = traj.length - 1, col = color();
        let maxV = 1e-6; for (const fr of traj) for (const p of fr) maxV = Math.max(maxV, p.speed);
        const X = (i: number) => (N > 0 ? (i / N) * w : 0), Y = (v: number) => h - 3 - (v / maxV) * (h - 8);
        const spd = (i: number) => traj[i][0]?.speed ?? 0;
        // full curve area (dim)
        c.beginPath(); c.moveTo(0, h); for (let i = 0; i <= N; i++) c.lineTo(X(i), Y(spd(i))); c.lineTo(w, h); c.closePath();
        c.fillStyle = hexA(col, 0.08); c.fill();
        // played area (bright)
        const pf = Math.min(frame, N);
        c.beginPath(); c.moveTo(0, h); for (let i = 0; i <= pf; i++) c.lineTo(X(i), Y(spd(i))); c.lineTo(X(pf), h); c.closePath();
        c.fillStyle = hexA(col, 0.22); c.fill();
        // line
        c.beginPath(); for (let i = 0; i <= N; i++) { const sx = X(i), sy = Y(spd(i)); i ? c.lineTo(sx, sy) : c.moveTo(sx, sy); }
        c.strokeStyle = hexA(col, 0.5); c.lineWidth = 1.5; c.stroke();
      }
      function updateTimeline() {
        if (!result) return;
        const max = result.trajectory.length - 1 || 1;
        const pct = (frame / max) * 100;
        const fill = $('tlFill'); if (fill) fill.style.width = pct + '%';
        const ph = $('tlPlayhead'); if (ph) ph.style.left = pct + '%';
        const tl = $('timeline'); if (tl) tl.setAttribute('aria-valuenow', String(frame));
        const markers = $('tlMarkers');
        if (markers) markers.querySelectorAll('.tl-marker').forEach((m: Any) => m.classList.toggle('pass', frame >= +m.dataset.pf));
        const fr = $('frameReadout'); if (fr) fr.textContent = `frame ${frame} / ${max}`;
        buildWaveform();
      }

      // ── parameter sweep ──
      function populateSweep() {
        const sel = $('sweepParam') as HTMLSelectElement | null; if (!sel) return;
        const opts = sweepableOf(cur);
        const prev = sel.value;
        sel.innerHTML = opts.map((k: string) => `<option value="${k}">${PMETA[k].label}</option>`).join('');
        sel.value = opts.includes(prev) ? prev : (SIG[cur] && opts.includes(SIG[cur]) ? SIG[cur] : opts[0]);
        const lbl = $('sweepLabel'); if (lbl) lbl.textContent = PMETA[sel.value]?.label ?? sel.value;
      }
      function runSweep() {
        if (!result) return;
        const sel = $('sweepParam') as HTMLSelectElement | null;
        const key = (sel && sel.value) || sweepableOf(cur)[0];
        const m = PMETA[key]; if (!m) return;
        const N = 44, pts: [number, number][] = [];
        for (let i = 0; i <= N; i++) {
          const v = m.min + (m.max - m.min) * (i / N);
          const res = runScenario(buildScenario({ ...overrides, [key]: v, count: 1 }), forces);
          const last = res.trajectory[res.trajectory.length - 1][0];
          pts.push([v, last ? Math.hypot(last.x - res.body.cx, last.y - res.body.cy) : 0]);
        }
        drawSweep(pts, m, valOf(key));
        const lbl = $('sweepLabel'); if (lbl) lbl.textContent = m.label;
      }
      function drawSweep(pts: [number, number][], m: Any, curVal: number) {
        const cv = $('sweepCanvas') as HTMLCanvasElement | null; if (!cv) return;
        const w = cv.clientWidth || 300, h = 96;
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        cv.width = Math.floor(w * dpr); cv.height = Math.floor(h * dpr);
        const c = cv.getContext('2d')!; c.setTransform(dpr, 0, 0, dpr, 0, 0); c.clearRect(0, 0, w, h);
        const col = color(); const span = (m.max - m.min) || 1;
        let maxM = 1e-6; pts.forEach((p) => (maxM = Math.max(maxM, p[1])));
        const X = (x: number) => ((x - m.min) / span) * w, Y = (y: number) => h - 4 - (y / maxM) * (h - 10);
        // current-value marker
        c.strokeStyle = hexA('#ffffff', 0.45); c.setLineDash([3, 3]);
        c.beginPath(); c.moveTo(X(curVal), 0); c.lineTo(X(curVal), h); c.stroke(); c.setLineDash([]);
        // curve
        c.strokeStyle = hexA(col, 0.85); c.lineWidth = 1.5; c.beginPath();
        pts.forEach((p, i) => { const sx = X(p[0]), sy = Y(p[1]); i ? c.lineTo(sx, sy) : c.moveTo(sx, sy); }); c.stroke();
      }

      // ── tune panel ──
      const esc = (t: string) => String(t).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      function renderParams() {
        const keys: string[] = SCHEMA[cur] || ['strength', 'range'];
        const rows = keys.map((key) => {
          const m = PMETA[key]; const cv = valOf(key); const def = defOf(key);
          const frac = Math.max(0, Math.min(1, (def - m.min) / (m.max - m.min || 1)));
          const sym = m.sym ? `<span class="sym">${m.sym}</span>` : '';
          const unit = m.unit ? `<span class="unit">${m.unit}</span>` : '';
          return `<div class="param">
            <label>${m.label}${sym}${unit}</label>
            <input class="num" type="number" data-param="${key}" min="${m.min}" max="${m.max}" step="${m.step}" value="${round(cv, m.step)}">
            <div class="track-wrap"><span class="tick" title="default" style="left:${(frac * 100).toFixed(1)}%"></span>
            <input type="range" data-param="${key}" min="${m.min}" max="${m.max}" step="${m.step}" value="${cv}"></div>
          </div>`;
        }).join('');
        $('params')!.innerHTML = rows;
        $('params')!.querySelectorAll('input[data-param]').forEach((el) =>
          el.addEventListener('input', () => {
            const inp = el as HTMLInputElement, key = inp.dataset.param!, val = parseFloat(inp.value);
            if (Number.isNaN(val)) return;
            overrides[key] = val;
            $('params')!.querySelectorAll(`input[data-param="${key}"]`).forEach((o) => { if (o !== inp) (o as HTMLInputElement).value = String(val); });
            setPreset('custom');
            evaluate();
          }),
        );
        const note = $('note'); if (note) note.textContent = scenarioBase().label + '.';
      }

      const PRESETS = [
        { id: 'default', label: 'Default' }, { id: 'strong', label: 'Strong force' }, { id: 'weak', label: 'Weak force' },
        { id: 'far', label: 'Long range' }, { id: 'near', label: 'Short range' }, { id: 'fast', label: 'Fast particle' },
        { id: 'burst', label: 'Particle burst (×14)' },
      ];
      function setPreset(id: string) {
        const sel = $('preset') as HTMLSelectElement | null; if (!sel) return;
        if (id === 'custom' && !Array.from(sel.options).some((o) => o.value === 'custom')) sel.add(new Option('Custom', 'custom'), 0);
        sel.value = id;
      }
      function applyPreset(id: string) {
        const b = scenarioBase().body;
        overrides = {};
        if (id === 'strong' && b.strength != null) overrides.strength = round(b.strength * 2.2, 0.01);
        else if (id === 'weak' && b.strength != null) overrides.strength = round(b.strength * 0.4, 0.01);
        else if (id === 'far' && b.range > 0) overrides.range = Math.round(b.range * 1.5);
        else if (id === 'near' && b.range > 0) overrides.range = Math.round(b.range * 0.55);
        else if (id === 'fast') overrides.vx = 6;
        else if (id === 'burst') overrides.count = 14;
        stopPlay(); evaluate();
      }

      // ── transport ──
      function stopPlay() { if (W.__labTimer) clearInterval(W.__labTimer); W.__labTimer = 0; const pb = $('play'); if (pb) pb.textContent = '▶ Play'; }
      function play() {
        if (W.__labTimer) return stopPlay();
        if (frame >= result.trajectory.length - 1) frame = 0;
        const pb = $('play'); if (pb) pb.textContent = '⏸ Pause';
        W.__labTimer = window.setInterval(() => {
          frame++;
          if (frame >= result.trajectory.length - 1) {
            if (mode === 'loop') { frame = 0; draw(); return; }
            frame = result.trajectory.length - 1; draw(); stopPlay(); return;
          }
          draw();
        }, 33);
      }

      // ── select a force ──
      function selectForce(force: string, keepOverrides = false) {
        cur = force;
        if (!keepOverrides) overrides = {};
        document.querySelectorAll('.force-tile').forEach((t) => t.classList.toggle('on', (t as HTMLElement).dataset.force === force));
        lab!.style.setProperty('--fc', color());
        updateAbout();
        stopPlay();
        const cal = calibrated();
        $('detector')!.hidden = !cal;
        $('tabs')!.hidden = !cal;
        $('veil')!.hidden = cal;
        $('hud')!.style.display = cal ? '' : 'none';
        if (!cal) {
          const v = $('verdict')!; v.className = 'verdict resolving'; v.textContent = 'Awaiting calibration';
          ($('veilName') as HTMLElement).textContent = META[cur]?.label ?? cur;
          ($('veilMeta') as HTMLElement).textContent = `${famLabel(cur)} · awaiting calibration`;
          ctx.clearRect(0, 0, canvas!.clientWidth, canvas!.clientHeight);
          $('expectPanel')!.hidden = true; $('tunePanel')!.hidden = true;
          return;
        }
        setPreset('default');
        showTab(tab);
        evaluate();
      }
      function famLabel(id: string) { const f = META[id]; return f ? cap(f.family === 'extended' ? 'designed-extended' : f.family) : ''; }
      function updateAbout() {
        const m = META[cur]; if (!m) return;
        const sym = $('aboutSym')!; sym.innerHTML = `<i class="fg fg-${cur}"></i>`; sym.style.setProperty('--fc', m.color);
        ($('aboutName') as HTMLElement).textContent = m.label;
        ($('aboutMeta') as HTMLElement).textContent = `${famLabel(cur)} · ${m.symbol} · No. ${z2(forceNoJS(cur))} · ${m.calibrated && byForce[cur] ? 'calibrated' : 'awaiting calibration'}`;
        ($('aboutDesc') as HTMLElement).textContent = m.summary;
        ($('aboutEffect') as HTMLElement).textContent = m.effect;
        const ff = $('aboutFormula')!; ff.textContent = m.formula; ff.style.display = calibrated() ? '' : 'none';
        ($('chamberForce') as HTMLElement).textContent = m.label;
      }
      const forceNoJS = (token: string) => (MANUAL_FORCES as Any[]).findIndex((f) => f.token === token) + 1;

      function showTab(t: 'expect' | 'tune') {
        tab = t;
        document.querySelectorAll('#tabs button').forEach((b) => b.classList.toggle('on', (b as HTMLElement).dataset.tab === t));
        $('expectPanel')!.hidden = t !== 'expect';
        $('tunePanel')!.hidden = t !== 'tune';
      }

      // ── export ──
      function buildHash() {
        const parts = [cur];
        for (const k of ['strength', 'range', 'spin', 'angle', 'box', 'absorbR', 'vx', 'vy', 'count']) if (overrides[k] != null) parts.push(`${k}=${overrides[k]}`);
        return parts.join(';');
      }
      function buildRecord() {
        const active = checks.filter((c: Any) => c.active);
        return {
          tool: 'forces-ui · the Lab', force: cur, symbol: META[cur].symbol,
          scenario: { label: scenarioBase().label, family: META[cur].family, frames: result.trajectory.length - 1 },
          inputs: { overrides: { ...overrides } },
          outputs: {
            verdict: active.every((c: Any) => c.passFrame >= 0) ? 'confirmed' : 'unresolved',
            expectedDelta: result.applyDelta?.[0],
            finalState: result.trajectory[result.trajectory.length - 1][0],
            checks: checks.map((c: Any) => ({ label: c.label, kind: c.kind, active: c.active, pass: c.passFrame >= 0, passFrame: c.passFrame, measured: c.measured, expected: c.expected })),
          },
          link: location.href.split('#')[0] + '#' + buildHash(),
        };
      }
      function flash(msg: string) {
        let el = document.querySelector('.lab-flash') as HTMLElement | null;
        if (!el) { el = document.createElement('div'); el.className = 'lab-flash'; document.body.appendChild(el); }
        el.textContent = msg; el.classList.add('show');
        clearTimeout((el as Any)._t); (el as Any)._t = setTimeout(() => el!.classList.remove('show'), 1300);
      }
      function exportJSON() {
        const blob = new Blob([JSON.stringify(buildRecord(), null, 2)], { type: 'application/json' });
        const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = `forces-lab-${cur}.json`; a.click(); URL.revokeObjectURL(a.href); flash('JSON exported');
      }
      function copyReport() {
        const r = buildRecord();
        const lines = [`forces-ui Lab — ${META[cur].label} (${META[cur].symbol})`, META[cur].formula, '', ...r.outputs.checks.map((c: Any) => `${c.active ? (c.pass ? '✓' : '✗') : '–'} ${c.label} — measured ${c.measured}, expected ${c.expected}${c.active && c.pass ? ` (@ frame ${c.passFrame})` : ''}`), '', r.link];
        navigator.clipboard?.writeText(lines.join('\n')); flash('Report copied');
      }

      // ── wiring ──
      function initBrowserToggle() {
        const seg = document.querySelector('.lab-picker .seg-toggle');
        const br = document.querySelector('.lab-picker [data-force-browser]') as HTMLElement | null;
        if (!seg || !br) return;
        seg.addEventListener('click', (e) => {
          const btn = (e.target as HTMLElement).closest('button[data-view]') as HTMLButtonElement | null; if (!btn) return;
          pickView = btn.dataset.view as any;
          br.classList.remove('view-icon', 'view-symbol', 'view-name'); br.classList.add('view-' + pickView);
          seg.querySelectorAll('button').forEach((b) => b.classList.toggle('on', b === btn));
        }, { signal: _ac.signal });
      }

      function init() {
        document.querySelectorAll('.force-tile').forEach((t) =>
          t.addEventListener('click', () => selectForce((t as HTMLElement).dataset.force!), { signal: _ac.signal }));
        initBrowserToggle();
        $('fire')?.addEventListener('click', () => { stopPlay(); frame = 0; play(); }, { signal: _ac.signal });
        $('play')?.addEventListener('click', play, { signal: _ac.signal });
        $('stepb')?.addEventListener('click', () => { stopPlay(); frame = Math.min(frame + 1, result.trajectory.length - 1); draw(); }, { signal: _ac.signal });
        $('reset')?.addEventListener('click', () => { stopPlay(); frame = 0; draw(); }, { signal: _ac.signal });
        $('mode')?.addEventListener('click', () => {
          mode = mode === 'once' ? 'loop' : 'once';
          const mb = $('mode')!; mb.textContent = mode === 'loop' ? '↻ Loop' : '↦ Once'; mb.dataset.mode = mode; mb.classList.toggle('on', mode === 'loop');
        }, { signal: _ac.signal });
        $('ghost')?.addEventListener('click', () => { ghostOn = !ghostOn; if (!ghostOn) ghostTraj = null; $('ghost')!.classList.toggle('on', ghostOn); draw(); }, { signal: _ac.signal });
        document.querySelectorAll('#tabs button').forEach((b) => b.addEventListener('click', () => showTab((b as HTMLElement).dataset.tab as any), { signal: _ac.signal }));
        $('sweepParam')?.addEventListener('change', () => runSweep(), { signal: _ac.signal });
        $('export')?.addEventListener('click', exportJSON, { signal: _ac.signal });
        $('report')?.addEventListener('click', copyReport, { signal: _ac.signal });
        $('resetParams')?.addEventListener('click', () => { overrides = {}; setPreset('default'); evaluate(); }, { signal: _ac.signal });
        $('share')?.addEventListener('click', () => { location.hash = buildHash(); navigator.clipboard?.writeText(location.href); flash('Link copied'); }, { signal: _ac.signal });
        const presetSel = $('preset') as HTMLSelectElement | null;
        if (presetSel) { presetSel.innerHTML = PRESETS.map((p) => `<option value="${p.id}">${p.label}</option>`).join(''); presetSel.addEventListener('change', () => applyPreset(presetSel.value), { signal: _ac.signal }); }

        const help = $('help'), legend = $('legend');
        help?.addEventListener('click', () => { const open = legend!.hidden; legend!.hidden = !open; help!.classList.toggle('on', open); help!.setAttribute('aria-expanded', String(open)); help!.textContent = open ? '×' : '?'; }, { signal: _ac.signal });

        // timeline scrub
        const tl = $('timeline');
        if (tl) {
          const frameFromX = (clientX: number) => { const r = tl.getBoundingClientRect(); const t = Math.max(0, Math.min(1, (clientX - r.left) / r.width)); return Math.round(t * (result.trajectory.length - 1)); };
          let dragging = false;
          const scrubTo = (clientX: number) => { stopPlay(); frame = frameFromX(clientX); draw(); };
          tl.addEventListener('pointerdown', (e: Any) => { dragging = true; try { tl.setPointerCapture(e.pointerId); } catch {} scrubTo(e.clientX); }, { signal: _ac.signal });
          tl.addEventListener('pointermove', (e: Any) => { if (dragging) scrubTo(e.clientX); }, { signal: _ac.signal });
          tl.addEventListener('pointerup', () => { dragging = false; }, { signal: _ac.signal });
        }

        window.addEventListener('keydown', (e: Any) => {
          if (e.target.tagName === 'INPUT' || e.target.tagName === 'SELECT' || !calibrated()) return;
          if (e.key === ' ') { e.preventDefault(); play(); }
          else if (e.key === 'f') { stopPlay(); frame = 0; play(); }
          else if (e.key === 'r') { stopPlay(); frame = 0; draw(); }
          else if (e.key === 'ArrowRight') { e.preventDefault(); stopPlay(); frame = Math.min(result.trajectory.length - 1, frame + 1); draw(); }
          else if (e.key === 'ArrowLeft') { e.preventDefault(); stopPlay(); frame = Math.max(0, frame - 1); draw(); }
          else if (e.key === 'l') $('mode')?.dispatchEvent(new Event('click'));
        }, { signal: _ac.signal });
        window.addEventListener('resize', () => { if (result && calibrated()) { computeView(); draw(); } }, { passive: true, signal: _ac.signal });

        // restore from hash, else default
        const hash = decodeURIComponent(location.hash.replace(/^#/, ''));
        if (hash) {
          const [force, ...kv] = hash.split(';');
          if (byForce[force] && META[force]?.calibrated) {
            for (const pair of kv) { const [k, v] = pair.split('='); if (v != null) overrides[k] = parseFloat(v); }
            selectForce(force, true);
            return;
          }
        }
        selectForce('attract');
      }

      init();
    }

    document.addEventListener('astro:page-load', setup);
  </script>
</Base>
