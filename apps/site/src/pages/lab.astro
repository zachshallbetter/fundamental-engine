          try { if (exp.check(partial).pass) return f; } catch {}
        }
        return -1;
      }

      function compute(resetFrame: boolean) {
        const s = buildScenario();
        // ghost: capture the prior setting's trajectory on a fresh run (not on a free-run extend)
        if (resetFrame) {
          if (result && ghostOn && ghostForce === cur) ghostTraj = result.trajectory;
          else if (ghostForce !== cur) ghostTraj = null;
        }
        result = runScenario(s, forces);
        ghostForce = cur;
        const tuned = ['strength', 'range', 'spin', 'angle', 'box', 'absorbR', 'vx', 'vy'].some((k) => overrides[k] != null);
        checks = byForce[cur].expectations.map((e: Any) => {
          const r = e.check(result);
          return {
            label: e.label, kind: e.kind, pass: r.pass, measured: r.measured, expected: r.expected,
            active: !(tuned && e.kind === 'exact'),
            passFrame: r.pass ? firstPassFrame(e, result) : -1,
