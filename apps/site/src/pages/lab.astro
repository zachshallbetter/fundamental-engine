<script is:inline>
  // Natural-field filter for the force picker — self-contained, independent of the detector logic.
  (() => {
    const setupFilter = () => {
      const bar = document.querySelector('[data-field-filter]');
      const browser = document.querySelector('[data-force-browser]');
      if (!bar || !browser) return;
      const chips = [...bar.querySelectorAll('.fbf')];
      const tiles = [...browser.querySelectorAll('.force-tile')];
      const groups = [...browser.querySelectorAll('.fb-group')];
      const apply = (filter) => {
        const [type, value] = filter ? filter.split(':') : ['', ''];
        for (const t of tiles) {
          const show = !filter || t.dataset[type] === value;
          t.classList.toggle('fb-hidden', !show);
        }
        for (const g of groups) {
          const anyVisible = [...g.querySelectorAll('.force-tile')].some((t) => !t.classList.contains('fb-hidden'));
          g.classList.toggle('fb-hidden', !anyVisible);
        }
      };
      for (const c of chips) {
        c.addEventListener('click', () => {
          chips.forEach((x) => x.classList.toggle('on', x === c));
          apply(c.dataset.filter || '');
        });
      }
    };
    if (document.readyState !== 'loading') setupFilter();
    else document.addEventListener('DOMContentLoaded', setupFilter);
    document.addEventListener('astro:page-load', setupFilter);
  })();
</script>

<style>
