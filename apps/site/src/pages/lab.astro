---
import Base from '../layouts/Base.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { EXPERIMENTS, MANUAL_FORCES } from 'forces-ui';
import '../styles/force-glyphs.css';
import '../styles/instrument.css';
import '../styles/lab.css';

// The Lab — a physics detector, rebuilt as an instrument. Fire a known particle
// into a force with known attributes; the chamber shows its track + the field
// structure, and the readout checks the measured behaviour against the conformance
// catalog (the same EXPERIMENTS the test suite runs) — frame by frame. The eight
// not-yet-calibrated forces are browsable but locked (no detector run).

// every force that has a conformance experiment (the detector can run it)
const HAS_EXP = new Set(EXPERIMENTS.map((e) => e.scenario.force));
const families = [
  { key: 'canonical', label: 'Canonical' },
  { key: 'natural', label: 'Natural' },
  { key: 'extended', label: 'Designed-extended' },
] as const;
const inFamily = (k: string) => MANUAL_FORCES.filter((f) => f.family === k);
const forceNo = (token: string) => MANUAL_FORCES.findIndex((f) => f.token === token) + 1;
const z2 = (n: number) => String(n).padStart(2, '0');
const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
const calibratedCount = MANUAL_FORCES.filter((f) => f.calibrated).length;
const awaitingCount = MANUAL_FORCES.length - calibratedCount;
---

<Base
  title="forces-ui — the Lab (physics detector)"
  description="Fire known particles into a force with known attributes and watch what happens — their tracks, the field structure, the measured behaviour checked against what the math predicts, frame by frame. The Lab is a conformance instrument."
>
  <main class="lab" id="lab">
    <a class="lab-back" href="/design">← Forces Design System</a>

    <div class="lab-grid">
      <!-- ── force picker — a periodic table of forces ── -->
      <aside class="lab-picker" aria-label="Force picker">
        <div class="force-browser view-icon" data-force-browser>
          <div class="fb-head">
            <span class="fb-label">{MANUAL_FORCES.length} forces</span>
            <div class="seg-toggle" role="group" aria-label="Tile display">
              <button type="button" data-view="icon" class="on">Icon</button>
              <button type="button" data-view="symbol">Symbol</button>
              <button type="button" data-view="name">Name</button>
            </div>
          </div>
          {families.map((fam) => (
            <div class="fb-group">
              <span class="glabel">{fam.label}</span>
              <div class="force-grid">
                {inFamily(fam.key).map((f) => (
                  <button
                    type="button"
                    class={`force-tile ${f.calibrated && HAS_EXP.has(f.token) ? 'calib' : 'locked'}`}
                    data-force={f.token}
                    data-calibrated={f.calibrated && HAS_EXP.has(f.token) ? '1' : '0'}
                    style={`--fc:${f.color}`}
                    title={`${cap(f.label)} — ${f.effect}${f.calibrated ? '' : ' (awaiting calibration)'}`}
                  >
                    <span class="z">{z2(forceNo(f.token))}</span>
                    <span class="picon as-icon"><i class={`fg fg-${f.token}`} aria-hidden="true" /></span>
                    <span class="sym as-symbol">{f.symbol}</span>
                    <span class="nameBig as-name">{cap(f.label)}</span>
                    <span class="pname">{cap(f.label)}</span>
                  </button>
                ))}
              </div>
            </div>
          ))}
          <p class="fb-foot"><b>{calibratedCount} calibrated</b> · {awaitingCount} awaiting<br />fire any lit force</p>
        </div>
      </aside>

      <!-- ── center — chamber, timeline, transport, sweep ── -->
      <section class="lab-center">
        <div class="lab-chamber">
          <span class="stage-label">detector chamber</span>
          <span class="chamber-force"><span class="dot"></span><span id="chamberForce">Attract</span></span>
          <canvas id="chamber"></canvas>
          <div class="chamber-hud ds-readout" id="hud" aria-hidden="true"></div>
          <button class="chamber-help" id="help" aria-label="What am I looking at?" aria-expanded="false">?</button>
          <div class="chamber-legend" id="legend" role="dialog" aria-label="Legend" hidden>
            <p class="info-title">What am I looking at?</p>
            <ul class="legend-list">
              <li><span class="legend-key body"></span>The body — the force, fixed at the chamber centre.</li>
              <li><span class="legend-line"></span>The particle track — one frame of motion per segment.</li>
              <li><span class="legend-key ring"></span>The range ring — beyond it the force reads zero.</li>
              <li><span class="legend-key pass"></span>A passed expectation marker on the timeline.</li>
              <li><span class="legend-key head"></span>The particle head + its velocity vector.</li>
              <li><span class="legend-line dim"></span>Drag the timeline to scrub frame by frame.</li>
            </ul>
            <p class="info-title" style="margin-top:0.9rem">Keyboard</p>
            <ul class="key-list">
              <li><kbd class="kbd sm">Space</kbd><span>play / pause</span></li>
              <li><kbd class="kbd sm">F</kbd><span>fire</span><kbd class="kbd sm">R</kbd><span>reset</span></li>
              <li><kbd class="kbd sm">←</kbd><kbd class="kbd sm">→</kbd><span>step frames</span></li>
              <li><kbd class="kbd sm">L</kbd><span>loop / once</span></li>
            </ul>
          </div>
          <div class="uncalib-veil" id="veil" hidden>
            <div class="big" id="veilName">—</div>
            <div class="sub" id="veilMeta">awaiting calibration</div>
            <div class="sub" style="color:var(--text-4)">physics &amp; expectations not yet pinned</div>
          </div>
        </div>

        <div class="lab-detector" id="detector">
          <div
            class="lab-timeline"
            id="timeline"
            role="slider"
            tabindex="0"
            aria-label="Timeline — drag to scrub; markers show where each test passes"
            aria-valuemin="0"
            aria-valuenow="0"
          >
            <div class="tl-wave-wrap">
              <span class="tl-wave-label">particle speed</span>
              <canvas class="tl-wave" id="tlWave"></canvas>
            </div>
            <div class="tl-track">
              <div class="tl-rail"></div>
              <div class="tl-fill" id="tlFill"></div>
              <div class="tl-markers" id="tlMarkers"></div>
              <div class="tl-playhead" id="tlPlayhead"></div>
            </div>
          </div>

          <div class="lab-transport">
            <button type="button" id="fire" class="tbtn primary">↯ Fire</button>
            <button type="button" id="play" class="tbtn">▶ Play</button>
            <button type="button" id="stepb" class="tbtn">⏭ Step</button>
            <button type="button" id="reset" class="tbtn">⟲ Reset</button>
            <button type="button" id="mode" class="tbtn" data-mode="once">↦ Once</button>
            <button type="button" id="ghost" class="tbtn on">◌ Ghost</button>
            <span class="frame-readout" id="frameReadout">frame 0 / 60</span>
          </div>

          <div class="lab-info">
            <div class="info-col">
              <div class="info-title sweep-head">
                <span>Parameter sweep</span>
                <span class="lab-select sweep-select"><select id="sweepParam"></select></span>
              </div>
              <canvas id="sweepCanvas"></canvas>
              <p class="sweep-note">End distance vs <b id="sweepLabel">strength</b> across its range. Each point re-runs
                the experiment; the dashed line marks the current value.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- ── readout — verdict, force card, expectations / tune ── -->
      <aside class="lab-readout" aria-label="Readout">
        <div class="verdict resolving" id="verdict">Resolving</div>

        <div class="panel force-about">
          <div class="about-head">
            <span class="about-sym" id="aboutSym"><i class="fg fg-attract" aria-hidden="true"></i></span>
            <div class="about-id">
              <div class="about-name" id="aboutName">Attract</div>
              <div class="about-meta" id="aboutMeta">Canonical · At · No. 01 · calibrated</div>
            </div>
          </div>
          <p class="about-desc" id="aboutDesc"></p>
          <div class="about-effect"><span class="k">Effect</span><span id="aboutEffect"></span></div>
          <div class="param-formula" id="aboutFormula" style="margin-top:0.9rem;margin-bottom:0"></div>
        </div>

        <div class="readout-tabs" id="tabs" role="tablist" hidden>
          <button type="button" role="tab" data-tab="expect" class="on">Expectations<i id="tabCount"></i></button>
          <button type="button" role="tab" data-tab="tune">Tune</button>
        </div>

        <div class="panel" id="expectPanel" hidden>
          <p class="panel-title">Expectations <span class="pass-summary" id="passSummary"></span></p>
          <div class="checklist" id="checklist"></div>
        </div>

        <div class="panel" id="tunePanel" hidden>
          <p class="panel-title">Tune &amp; refire</p>
          <label class="preset-row">
            <span>Preset</span>
            <span class="lab-select"><select id="preset"></select></span>
          </label>
          <div class="params" id="params"></div>
          <div class="export-row">
            <button type="button" id="share" class="xbtn">⎘ Copy link</button>
            <button type="button" id="export" class="xbtn">↧ Export JSON</button>
            <button type="button" id="report" class="xbtn">≡ Copy report</button>
            <button type="button" id="resetParams" class="xbtn">⟲ Defaults</button>
          </div>
          <p class="scenario-note" id="note"></p>
        </div>
      </aside>
    </div>
  </main>
  <SiteFooter />

  <script>
    import { EXPERIMENTS, runScenario, allForces, MANUAL_FORCES } from 'forces-ui';

    type Any = Record<string, any>;
    const forces = allForces();
    const byForce: Any = {};
    for (const e of EXPERIMENTS as Any[]) byForce[e.scenario.force] = e;
    const META: Any = {};
    for (const f of MANUAL_FORCES as Any[]) META[f.token] = f;

    const $ = (id: string) => document.getElementById(id);
    const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
    const z2 = (n: number) => String(n).padStart(2, '0');
    const round = (n: number, step = 0.01) => {
      const d = step < 1 ? (String(step).split('.')[1] || '').length : 0;
      return Number(n.toFixed(d));
    };

    // param metadata — label · symbol · unit · slider range (ported from the design)
    const PMETA: Any = {
      strength: { label: 'strength', sym: 'S', min: 0, max: 3, step: 0.03 },
      range: { label: 'range', sym: 'd', unit: 'px', min: 50, max: 500, step: 5 },
      spin: { label: 'spin', sym: 'σ', min: -2, max: 2, step: 0.1 },
      angle: { label: 'heading', sym: 'θ', unit: 'deg', min: 0, max: 359, step: 1 },
      vx: { label: 'initial v', sym: 'ₓ', min: -8, max: 8, step: 0.2 },
      vy: { label: 'initial v', sym: 'ᵧ', min: -8, max: 8, step: 0.2 },
      box: { label: 'wall size', sym: 'w', unit: 'px', min: 24, max: 100, step: 2 },
      absorbR: { label: 'capture radius', sym: 'r', unit: 'px', min: 30, max: 140, step: 2 },
      count: { label: 'particles', sym: 'n', min: 1, max: 14, step: 1 },
    };
    // which knobs each force exposes (matches the body fields its scenario reads)
    const SCHEMA: Any = {
      attract: ['strength', 'range', 'vx', 'vy', 'count'],
      repel: ['strength', 'range', 'vx', 'vy', 'count'],
      swirl: ['strength', 'range', 'spin', 'vx', 'vy', 'count'],
      stream: ['strength', 'range', 'angle', 'vx', 'vy', 'count'],
      viscosity: ['strength', 'range', 'vx', 'vy', 'count'],
      jet: ['strength', 'range', 'angle', 'vx', 'count'],
      tether: ['strength', 'range', 'vx', 'vy', 'count'],
      wall: ['box', 'vx', 'vy', 'count'],
      sink: ['absorbR', 'vx', 'count'],
      gravity: ['strength', 'range', 'vx', 'vy', 'count'],
      charge: ['strength', 'range', 'vx', 'vy', 'count'],
      magnetism: ['strength', 'range', 'vx', 'vy', 'count'],
      thermal: ['strength', 'range', 'count'],
      lens: ['strength', 'range', 'spin', 'vx', 'vy', 'count'],
      gate: ['range', 'angle', 'vx', 'vy', 'count'],
      buoyancy: ['strength', 'range', 'vx', 'vy', 'count'],
      shear: ['strength', 'range', 'angle', 'vx', 'vy', 'count'],
      crystallize: ['strength', 'range', 'vx', 'vy', 'count'],
      wind: ['strength', 'range', 'vx', 'vy', 'count'],
      collide: ['strength', 'range'],
      cohesion: ['strength', 'range'],
      pressure: ['strength', 'range'],
      link: ['strength', 'range'],
      hunt: ['strength', 'range'],
      align: ['strength', 'range'],
    };
    // the most characteristic axis to sweep, per force
    const SIG: Any = { swirl: 'spin', stream: 'angle', jet: 'angle', shear: 'angle', gate: 'angle', wall: 'box', sink: 'absorbR' };
    const sweepableOf = (id: string) => (SCHEMA[id] || ['strength']).filter((k: string) => !['vx', 'vy', 'count'].includes(k));

    // re-runs on each client-side navigation to /lab (ClientRouter); no-op elsewhere.
    function setup() {
      const lab = $('lab');
      const canvas = $('chamber') as HTMLCanvasElement | null;
      if (!lab || !canvas) return;
      const W = window as Any;
      W.__labAbort?.abort();
      const _ac = new AbortController();
      W.__labAbort = _ac;
      if (W.__labTimer) { clearInterval(W.__labTimer); W.__labTimer = 0; }
      const ctx = canvas.getContext('2d')!;

      let cur = 'attract';
      let overrides: Any = {};
      let result: Any = null;
      let checks: Any[] = [];
      let frame = 0;
      let mode: 'once' | 'loop' = 'once';
      let view = { scale: 1, ox: 0, oy: 0 };
      let pickView: 'icon' | 'symbol' | 'name' = 'icon';
      let tab: 'expect' | 'tune' = 'expect';
      let ghostOn = true;
      let ghostTraj: Any = null; // previous setting's trajectory (same force)
      let ghostForce = '';

      const clone = (o: any) => JSON.parse(JSON.stringify(o));
      const hexA = (h: string, a: number) => {
        if (h[0] !== '#') return h;
        const n = parseInt(h.slice(1), 16);
        return `rgba(${(n >> 16) & 255},${(n >> 8) & 255},${n & 255},${a})`;
      };
      const color = () => META[cur]?.color ?? '#4da3ff';
      const calibrated = () => !!META[cur]?.calibrated && !!byForce[cur];
      const isPair = (id: string) => ['collide', 'cohesion', 'pressure', 'link', 'hunt', 'align'].includes(id);

      function scenarioBase() { return byForce[cur].scenario; }
      // the default value of a tunable key, read from the force's scenario
      function defOf(key: string): number {
        const s = scenarioBase(), b = s.body, p0 = s.particles[0];
        switch (key) {
          case 'strength': return b.strength ?? 1;
          case 'range': return b.range ?? 300;
          case 'spin': return b.spin ?? 1;
          case 'angle': return Math.round(((b.angle ?? 0) * 180) / Math.PI);
          case 'box': return b.hw ?? 40;
          case 'absorbR': return b.absorbR ?? 64;
          case 'vx': return p0?.vx ?? 0;
          case 'vy': return p0?.vy ?? 0;
          case 'count': return s.particles.length || 1;
          default: return 0;
        }
      }
      const valOf = (key: string) => (overrides[key] != null ? overrides[key] : defOf(key));

      function buildScenario(ov: Any = overrides) {
        const s = clone(scenarioBase());
        const B: Any = s.body;
        if (ov.strength != null && B.strength != null) B.strength = ov.strength;
        if (ov.range != null && B.range != null) B.range = ov.range;
        if (ov.spin != null) B.spin = ov.spin;
        if (ov.angle != null) B.angle = (ov.angle * Math.PI) / 180;
        if (ov.box != null) { B.hw = ov.box; B.hh = ov.box; }
        if (ov.absorbR != null) B.absorbR = ov.absorbR;
        if (ov.vx != null && s.particles[0]) s.particles[0].vx = ov.vx;
        if (ov.vy != null && s.particles[0]) s.particles[0].vy = ov.vy;
        if (ov.frames != null) s.frames = ov.frames;
        if (s.particles.length === 0) return s;
        if (!isPair(cur)) {
          const count = Math.max(1, Math.min(14, Math.round(ov.count ?? s.particles.length)));
          if (count > s.particles.length) {
            const base = s.particles[0];
            const extra = count - s.particles.length;
            const spread = (s.body.range || 200) * 0.9;
            for (let i = 0; i < extra; i++) {
              const t = extra === 1 ? 0 : i / (extra - 1) - 0.5;
              s.particles.push({ ...base, x: base.x, y: base.y + t * spread, vx: base.vx, vy: base.vy });
            }
          }
        }
        return s;
      }

      function firstPassFrame(exp: Any, res: Any) {
        const N = res.trajectory.length;
        for (let f = 0; f < N; f++) {
          const partial = { ...res, trajectory: res.trajectory.slice(0, f + 1) };
          try { if (exp.check(partial).pass) return f; } catch {}
        }
        return -1;
      }

      function compute(resetFrame: boolean) {
        const s = buildScenario();
        // ghost: keep the prior trajectory if the force is unchanged + ghost on
        if (result && ghostOn && ghostForce === cur) ghostTraj = result.trajectory;
        else if (ghostForce !== cur) ghostTraj = null;
        result = runScenario(s, forces);
        ghostForce = cur;
        const tuned = ['strength', 'range', 'spin', 'angle', 'box', 'absorbR', 'vx', 'vy'].some((k) => overrides[k] != null);
        checks = byForce[cur].expectations.map((e: Any) => {
          const r = e.check(result);
          return {
            label: e.label, kind: e.kind, pass: r.pass, measured: r.measured, expected: r.expected,
            active: !(tuned && e.kind === 'exact'),
            passFrame: r.pass ? firstPassFrame(e, result) : -1,
          };
        });
        if (resetFrame) frame = 0;
        buildTimeline();
        computeView();
        if (resetFrame) { renderParams(); populateSweep(); runSweep(); }
        draw();
      }
      const evaluate = () => compute(true);

      function computeView() {
        const b = result.body;
        const ext = b.range > 0 && b.range < 1200 ? b.range : 70;
        let minX = b.cx - ext, maxX = b.cx + ext, minY = b.cy - ext, maxY = b.cy + ext;
        for (const fr of result.trajectory)
          for (const p of fr) {
            minX = Math.min(minX, p.x); maxX = Math.max(maxX, p.x);
            minY = Math.min(minY, p.y); maxY = Math.max(maxY, p.y);
          }
        const w = canvas!.clientWidth, h = canvas!.clientHeight;
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        canvas!.width = Math.floor(w * dpr); canvas!.height = Math.floor(h * dpr);
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        const pad = 60;
        const spanX = maxX - minX || 1, spanY = maxY - minY || 1;
        const scale = Math.min((w - 2 * pad) / spanX, (h - 2 * pad) / spanY) * 0.72;
        const cx = (minX + maxX) / 2, cy = (minY + maxY) / 2;
        view = { scale, ox: w / 2 - cx * scale, oy: h / 2 - cy * scale };
      }
      const w2s = (x: number, y: number): [number, number] => [x * view.scale + view.ox, y * view.scale + view.oy];

      function arrow(x1: number, y1: number, x2: number, y2: number, col: string, head = 4) {
        const a = Math.atan2(y2 - y1, x2 - x1);
        ctx.strokeStyle = col; ctx.lineWidth = 1.4;
        ctx.beginPath();
        ctx.moveTo(x1, y1); ctx.lineTo(x2, y2);
        ctx.moveTo(x2, y2); ctx.lineTo(x2 - Math.cos(a - 0.4) * head, y2 - Math.sin(a - 0.4) * head);
        ctx.moveTo(x2, y2); ctx.lineTo(x2 - Math.cos(a + 0.4) * head, y2 - Math.sin(a + 0.4) * head);
        ctx.stroke();
      }

      function draw() {
        if (!result) return;
        const w = canvas!.clientWidth, h = canvas!.clientHeight;
        ctx.clearRect(0, 0, w, h);
        const b = result.body;
        const col = color();
        const pair = isPair(cur);

        // faint dot grid
        ctx.fillStyle = 'rgba(255,255,255,0.05)';
        const gs = 26;
        for (let gx = (view.ox % gs + gs) % gs; gx < w; gx += gs)
          for (let gy = (view.oy % gs + gs) % gs; gy < h; gy += gs) { ctx.beginPath(); ctx.arc(gx, gy, 0.8, 0, 7); ctx.fill(); }

        // range / structure ring
        const [bx, by] = w2s(b.cx, b.cy);
        if (!pair && cur !== 'wall' && cur !== 'sink' && b.range > 0 && b.range < 1200) {
          ctx.strokeStyle = hexA(col, 0.32); ctx.setLineDash([4, 5]); ctx.lineWidth = 1;
          ctx.beginPath(); ctx.arc(bx, by, b.range * view.scale, 0, 7); ctx.stroke(); ctx.setLineDash([]);
        }
        if (cur === 'sink' && b.absorbR) {
          ctx.strokeStyle = hexA(col, 0.5); ctx.setLineDash([3, 4]); ctx.lineWidth = 1;
          ctx.beginPath(); ctx.arc(bx, by, b.absorbR * view.scale, 0, 7); ctx.stroke(); ctx.setLineDash([]);
        }
        if (cur === 'wall') {
          const hw = (b.hw ?? 40) * view.scale, hh = (b.hh ?? 40) * view.scale;
          ctx.strokeStyle = hexA(col, 0.6); ctx.lineWidth = 1.5; ctx.fillStyle = hexA(col, 0.07);
          ctx.beginPath(); ctx.rect(bx - hw, by - hh, hw * 2, hh * 2); ctx.fill(); ctx.stroke();
        }
        if (cur === 'stream' || cur === 'jet') {
          const a = (b.angle ?? 0);
          ctx.strokeStyle = hexA(col, 0.55); ctx.lineWidth = 1.5;
          const ax = bx + Math.cos(a) * 42, ay = by + Math.sin(a) * 42;
          ctx.beginPath(); ctx.moveTo(bx, by); ctx.lineTo(ax, ay); ctx.stroke();
          ctx.beginPath(); ctx.moveTo(ax, ay);
          ctx.lineTo(ax - Math.cos(a - 0.5) * 8, ay - Math.sin(a - 0.5) * 8);
          ctx.lineTo(ax - Math.cos(a + 0.5) * 8, ay - Math.sin(a + 0.5) * 8);
          ctx.closePath(); ctx.fillStyle = col; ctx.fill();
        }

        // body — radial glow + white core
        if (!pair && cur !== 'wall') {
          const grd = ctx.createRadialGradient(bx, by, 0, bx, by, 16);
          grd.addColorStop(0, col); grd.addColorStop(1, hexA(col, 0));
          ctx.fillStyle = grd; ctx.beginPath(); ctx.arc(bx, by, 16, 0, 7); ctx.fill();
          ctx.fillStyle = '#fff'; ctx.beginPath(); ctx.arc(bx, by, 3.2, 0, 7); ctx.fill();
        }

        // ghost — the previous setting's full path (dashed, faint)
        if (ghostOn && ghostTraj && ghostForce === cur) {
          ctx.save(); ctx.setLineDash([3, 4]); ctx.lineWidth = 1.4; ctx.strokeStyle = hexA('#9aa7c7', 0.34);
          const nP = ghostTraj[0].length;
          for (let i = 0; i < nP; i++) {
            ctx.beginPath();
            for (let f = 0; f < ghostTraj.length; f++) { const [sx, sy] = w2s(ghostTraj[f][i].x, ghostTraj[f][i].y); f ? ctx.lineTo(sx, sy) : ctx.moveTo(sx, sy); }
            ctx.stroke();
          }
          ctx.restore();
        }

        const traj = result.trajectory;
        const nP = traj[0].length;
        // pair connector
        if (pair && nP >= 2) {
          const a = traj[frame][0], bb = traj[frame][1];
          ctx.save(); ctx.setLineDash([3, 4]); ctx.strokeStyle = hexA(col, 0.4); ctx.lineWidth = 1;
          const [ax, ay] = w2s(a.x, a.y), [bx2, by2] = w2s(bb.x, bb.y);
          ctx.beginPath(); ctx.moveTo(ax, ay); ctx.lineTo(bx2, by2); ctx.stroke(); ctx.restore();
        }

        if (nP === 0) {
          const here = traj[frame] || [];
          for (const p of here) { const [sx, sy] = w2s(p.x, p.y); ctx.fillStyle = hexA(col, 0.7); ctx.beginPath(); ctx.arc(sx, sy, 2.2, 0, 7); ctx.fill(); }
        } else {
          for (let i = 0; i < nP; i++) {
            // fading trail to the current frame
            ctx.lineJoin = 'round';
            for (let f = 1; f <= frame && f < traj.length; f++) {
              const a = (i === 0 ? 0.14 : 0.06) + (i === 0 ? 0.6 : 0.2) * (f / Math.max(1, frame));
              ctx.strokeStyle = i === 0 ? hexA(col, a) : hexA('#c8d2e6', a);
              ctx.lineWidth = i === 0 ? 1.7 : 1;
              const [px, py] = w2s(traj[f - 1][i].x, traj[f - 1][i].y), [cx2, cy2] = w2s(traj[f][i].x, traj[f][i].y);
              ctx.beginPath(); ctx.moveTo(px, py); ctx.lineTo(cx2, cy2); ctx.stroke();
            }
            const p = traj[Math.min(frame, traj.length - 1)][i];
            const [sx, sy] = w2s(p.x, p.y);
            // heat halo
            if ((p.heat ?? 0) > 0.1) { const g = ctx.createRadialGradient(sx, sy, 0, sx, sy, 14); g.addColorStop(0, hexA('#fff', 0.5 * p.heat)); g.addColorStop(1, hexA(col, 0)); ctx.fillStyle = g; ctx.beginPath(); ctx.arc(sx, sy, 14, 0, 7); ctx.fill(); }
            // velocity vector
            if (i === 0 && !p.cap && (Math.abs(p.vx) > 0.05 || Math.abs(p.vy) > 0.05)) {
              ctx.strokeStyle = hexA('#ffffff', 0.55); ctx.lineWidth = 1;
              ctx.beginPath(); ctx.moveTo(sx, sy); ctx.lineTo(sx + p.vx * 6, sy + p.vy * 6); ctx.stroke();
            }
            // head
