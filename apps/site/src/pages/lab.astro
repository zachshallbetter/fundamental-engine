        const pct = (frame / max) * 100;
        const fill = $('tlFill'); if (fill) fill.style.width = pct + '%';
        const ph = $('tlPlayhead'); if (ph) ph.style.left = pct + '%';
        const tl = $('timeline'); if (tl) tl.setAttribute('aria-valuenow', String(frame));
        const markers = $('tlMarkers');
        if (markers) markers.querySelectorAll('.tl-marker').forEach((m: Any) => m.classList.toggle('pass', frame >= +m.dataset.pf));
        const fr = $('frameReadout'); if (fr) fr.textContent = `frame ${frame} / ${max}`;
        buildWaveform();
      }

      // ── parameter sweep (over any body knob the force exposes; excludes count) ──
      const sweepSpecs = () => paramSpecs().filter((s: Any) => s.key !== 'count');
      function populateSweep() {
        const sel = $('sweepParam') as HTMLSelectElement | null; if (!sel) return;
        const specs = sweepSpecs();
        const prev = sel.value;
        sel.innerHTML = specs.map((s: Any) => `<option value="${s.key}">${s.label}${s.sym ? ' ' + s.sym : ''}</option>`).join('');
        sel.value = specs.some((s: Any) => s.key === prev) ? prev : (specs[0]?.key ?? 'strength');
        const sp = specs.find((s: Any) => s.key === sel.value);
        const lbl = $('sweepLabel'); if (lbl) lbl.textContent = sp ? sp.label : sel.value;
      }
      function runSweep() {
        if (!result) return;
        const specs = sweepSpecs();
        const sel = $('sweepParam') as HTMLSelectElement | null;
        const key = (sel && sel.value) || specs[0]?.key;
        const m = specs.find((s: Any) => s.key === key) || specs[0]; if (!m) return;
        const metric = ($('sweepMetric') as HTMLSelectElement | null)?.value || 'finalDist';
        const N = 44, pts: [number, number][] = [];
        for (let i = 0; i <= N; i++) {
          const v = m.min + (m.max - m.min) * (i / N);
          const res = runScenario(buildScenario({ ...overrides, [m.key]: v, count: 1 }), forces);
          let y = 0;
          if (metric === 'delta') { const d = res.applyDelta?.[0]; y = d ? Math.hypot(d.dvx, d.dvy) : 0; }
          else if (metric === 'passes') { y = byForce[cur].expectations.filter((e: Any) => { try { return e.check(res).pass; } catch { return false; } }).length; }
          else { const last = res.trajectory[res.trajectory.length - 1][0]; y = last ? Math.hypot(last.x - res.body.cx, last.y - res.body.cy) : 0; }
