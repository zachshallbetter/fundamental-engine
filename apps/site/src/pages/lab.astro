---
import Base from '../layouts/Base.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { MANUAL_FORCES, MANUAL_PRESETS } from 'forces-ui';
import '../styles/force-glyphs.css';

// The Lab (§14) — place real force bodies AND presets on the page and watch the ONE
// background field react (the field-reacts law, not foreground particles). The
// palette is the whole catalog. Shareable via the URL hash.

// Sensible placement attrs per force (forces ignore attrs they don't read).
const DEFAULTS = { strength: 1.5, range: 280, spin: 1, angle: -90 };
const OVERRIDES: Record<string, Record<string, number>> = {
  gravity: { strength: 320, range: 360 },
  thermal: { strength: 2.5, range: 240 },
  absorb: { strength: 0.8, range: 320, absorb: 60, max: 40 },
  emitter: { strength: 1.3, range: 280 },
  spring: { strength: 1, range: 240 },
  drag: { strength: 1, range: 300 },
};
const PRESET_COLORS: Record<string, string> = {
  blackhole: '#fbbf24',
  whitehole: '#e0f2fe',
  star: '#6366f1',
  quasar: '#fbbf24',
  galaxy: '#a78bfa',
  nebula: '#38bdf8',
  tornado: '#2dd4bf',
};

const FORCE_DATA = Object.fromEntries(
  MANUAL_FORCES.map((f) => [
    f.token,
    { color: f.color, attrs: { ...DEFAULTS, ...(OVERRIDES[f.token] ?? {}) } },
  ]),
);
const PRESET_DATA = Object.fromEntries(
  MANUAL_PRESETS.map((p) => [p.name, { color: PRESET_COLORS[p.name] ?? '#4da3ff' }]),
);

const families = [
  { key: 'canonical', label: 'canonical' },
  { key: 'natural', label: 'natural' },
  { key: 'extended', label: 'extended' },
] as const;
const byFamily = (k: string) => MANUAL_FORCES.filter((f) => f.family === k);
---

<Base
  title="forces-ui — the Lab"
  description="The Lab — place any force or preset on the page and watch the single field react. Drag to move, double-click to remove, and share your field by URL."
>
  <SiteNav current="lab" />
  <main class="lab">
    <header class="head">
      <h1>The Lab</h1>
      <p class="lede">
        Place any force or preset on the page and watch the single field react. Pick one, click
        the stage to drop it, drag to move, double-click to remove. Presets drop a whole composite.
        Share your field with the link button — the layout lives in the URL.
      </p>
    </header>

    <div class="catalog" role="group" aria-label="Force palette">
      {
        families.map((fam) => (
          <div class="group">
            <span class="glabel">{fam.label}</span>
            {byFamily(fam.key).map((f) => (
              <button
                type="button"
                data-kind="force"
                data-token={f.token}
                style={`--c:${f.color}`}
                class={f.token === 'attract' ? 'on' : ''}
                title={f.desc}
              >
                <i class={`fg fg-${f.token}`} aria-hidden="true" />
                {f.token}
              </button>
            ))}
          </div>
        ))
      }
      <div class="group presets">
        <span class="glabel">presets</span>
        {
          MANUAL_PRESETS.map((p) => (
            <button
              type="button"
              data-kind="preset"
              data-token={p.name}
              style={`--c:${PRESET_COLORS[p.name]}`}
              title={p.desc}
            >
              <i class={`fg fg-${p.name}`} aria-hidden="true" />
              {p.name}
            </button>
          ))
        }
      </div>
    </div>

    <div class="bar">
      <div class="palettes" role="group">
        <span class="plabel">palette</span>
        {
          ['ours', 'heatmap', 'infrared', 'spectrum'].map((p) => (
            <button type="button" data-palette={p} class={p === 'ours' ? 'on' : ''}>
              {p}
            </button>
          ))
        }
      </div>
      <div class="views" role="group">
        <span class="plabel">view</span>
        {
          ['dots', 'streamlines', 'trails', 'links'].map((v) => (
            <button type="button" data-render={v} class={v === 'dots' ? 'on' : ''}>
              {v}
            </button>
          ))
        }
      </div>
      <div class="actions">
        <button type="button" id="share">Copy link</button>
        <button type="button" id="clear">Clear</button>
      </div>
    </div>

    <div class="stage" id="stage">
      <p class="hint">Pick a force or preset, then click here to place it.</p>
    </div>
  </main>
  <SiteFooter />
</Base>

<script is:inline define:vars={{ FORCE_DATA, PRESET_DATA }}>
  (() => {
    const stage = document.getElementById('stage');
    const field = document.querySelector('forces-field');
    const meta = (kind, token) => (kind === 'preset' ? PRESET_DATA[token] : FORCE_DATA[token]);
    let current = { kind: 'force', token: 'attract' };
    let nodes = [];
    const rescan = () => field && field.rescan && field.rescan();
    const hideHint = () => {
      const h = stage.querySelector('.hint');
      if (h) h.style.display = 'none';
    };
    const clamp = (v) => Math.max(2, Math.min(98, v));

    document.querySelectorAll('.catalog button').forEach((b) =>
      b.addEventListener('click', () => {
        current = { kind: b.dataset.kind, token: b.dataset.token };
        document.querySelectorAll('.catalog button').forEach((x) => x.classList.toggle('on', x === b));
      }),
    );

    document.querySelectorAll('.palettes button').forEach((b) =>
      b.addEventListener('click', () => {
        if (field && field.setPalette) field.setPalette(b.dataset.palette);
        document.querySelectorAll('.palettes button').forEach((x) => x.classList.toggle('on', x === b));
      }),
    );

    document.querySelectorAll('.views button').forEach((b) =>
      b.addEventListener('click', () => {
        if (field && field.setRender) field.setRender(b.dataset.render);
        document.querySelectorAll('.views button').forEach((x) => x.classList.toggle('on', x === b));
      }),
    );

    function makeEl(node) {
      const m = meta(node.kind, node.token);
      if (!m) return;
      const el = document.createElement('div');
      el.className = 'node';
      if (node.kind === 'preset') {
        el.dataset.preset = node.token;
      } else {
        el.dataset.body = node.token;
        for (const k in m.attrs) el.dataset[k] = m.attrs[k];
      }
      el.style.setProperty('--c', m.color);
      el.style.left = node.x + '%';
      el.style.top = node.y + '%';
      el.innerHTML = '<i class="fg fg-' + node.token + '"></i><span>' + node.token + '</span>';
      el.title = 'drag to move · double-click to remove';
      el.addEventListener('pointerdown', (e) => startDrag(e, node, el));
      el.addEventListener('dblclick', (e) => {
        e.stopPropagation();
        el.remove();
        nodes = nodes.filter((n) => n !== node);
        rescan();
        save();
      });
      stage.appendChild(el);
      node.el = el;
    }

    function add(kind, token, x, y) {
      const node = { kind, token, x, y };
      nodes.push(node);
      makeEl(node);
      rescan();
      save();
      hideHint();
    }

    function startDrag(e, node, el) {
      e.preventDefault();
      el.setPointerCapture(e.pointerId);
      const onMove = (ev) => {
        const r = stage.getBoundingClientRect();
        node.x = clamp(((ev.clientX - r.left) / r.width) * 100);
        node.y = clamp(((ev.clientY - r.top) / r.height) * 100);
        el.style.left = node.x + '%';
        el.style.top = node.y + '%';
        rescan();
      };
      const onUp = () => {
        el.removeEventListener('pointermove', onMove);
        el.removeEventListener('pointerup', onUp);
        save();
      };
      el.addEventListener('pointermove', onMove);
      el.addEventListener('pointerup', onUp);
    }

    stage.addEventListener('click', (e) => {
      if (e.target !== stage) return; // ignore clicks that land on a node
      const r = stage.getBoundingClientRect();
      add(
        current.kind,
        current.token,
        clamp(((e.clientX - r.left) / r.width) * 100),
        clamp(((e.clientY - r.top) / r.height) * 100),
      );
    });

    // share: presets are prefixed '@'; e.g. "attract,30,40;@blackhole,60,55"
    function save() {
      const s = nodes
        .map((n) => (n.kind === 'preset' ? '@' : '') + n.token + ',' + n.x.toFixed(1) + ',' + n.y.toFixed(1))
        .join(';');
      history.replaceState(null, '', s ? '#' + encodeURIComponent(s) : location.pathname);
    }

    function restore() {
      const h = decodeURIComponent(location.hash.slice(1));
      if (!h) return;
      h.split(';').forEach((part) => {
        const [raw, x, y] = part.split(',');
        if (!raw) return;
        const kind = raw[0] === '@' ? 'preset' : 'force';
        const token = raw[0] === '@' ? raw.slice(1) : raw;
        if (meta(kind, token)) {
          const node = { kind, token, x: +x, y: +y };
          nodes.push(node);
          makeEl(node);
        }
      });
      if (nodes.length) {
        hideHint();
        rescan();
        setTimeout(rescan, 120); // the field may still be mounting on first paint
      }
    }

    document.getElementById('clear').addEventListener('click', () => {
      nodes.forEach((n) => n.el.remove());
      nodes = [];
      rescan();
      save();
    });
    document.getElementById('share').addEventListener('click', async () => {
      save();
      const btn = document.getElementById('share');
      try {
        await navigator.clipboard.writeText(location.href);
        const t = btn.textContent;
        btn.textContent = 'Copied!';
        setTimeout(() => (btn.textContent = t), 1200);
      } catch {
        /* clipboard blocked — the URL is still updated to share manually */
      }
    });

    restore();
  })();
</script>

<style>
  .lab {
    position: relative;
    z-index: 2;
    align-self: flex-start;
    width: 100%;
    max-width: 1120px;
    margin: 0 auto;
    padding: calc(58px + clamp(1.4rem, 4vh, 2.6rem)) clamp(1.2rem, 5vw, 3.5rem) 5rem;
  }
  :global(body:has(.lab)) {
    align-items: flex-start;
  }
  h1 {
    font-size: clamp(2.4rem, 7vw, 4rem);
    font-weight: 700;
    margin: 0.6rem 0 0.8rem;
    letter-spacing: -0.03em;
  }
  .lede {
    max-width: 56ch;
    color: var(--text-2);
    line-height: 1.55;
  }

  .catalog {
    margin: clamp(1.5rem, 4vh, 2.5rem) 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .group {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
  }
  .glabel {
    font-family: var(--mono);
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-3);
    width: 5rem;
    flex: none;
  }
  .catalog button {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--mono);
    font-size: 0.74rem;
    color: var(--text-3);
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 7px;
    padding: 0.32rem 0.6rem;
    cursor: pointer;
    transition:
      color 0.15s ease,
      border-color 0.15s ease;
  }
  .catalog button:hover {
    color: var(--text);
  }
  .catalog button.on {
    color: var(--text);
    border-color: var(--c);
    box-shadow: 0 0 0 1px var(--c) inset;
  }
  .catalog .fg {
    --fc: var(--c);
    width: 13px;
    height: 13px;
  }

  .bar {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: space-between;
    align-items: center;
    margin: 0 0 1rem;
  }
  .palettes,
  .views,
  .actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
  }
  .plabel {
    font-family: var(--mono);
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-3);
    margin-right: 0.2rem;
  }
  .palettes button,
  .views button,
  .actions button {
    font-family: var(--mono);
    font-size: 0.74rem;
    color: var(--text-3);
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 0.34rem 0.7rem;
    cursor: pointer;
  }
  .palettes button:hover,
  .views button:hover,
  .actions button:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .palettes button.on,
  .views button.on {
    color: var(--accent);
    border-color: var(--accent);
  }

  .stage {
    position: relative;
    height: clamp(360px, 58vh, 620px);
    border: 1px dashed var(--line);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.012);
    overflow: hidden;
    cursor: crosshair;
  }
  .hint {
    position: absolute;
    inset: 0;
    margin: 0;
    display: grid;
    place-items: center;
    color: var(--text-3);
    font-family: var(--mono);
    font-size: 0.82rem;
    pointer-events: none;
  }

  /* nodes are created at runtime → global rules */
  :global(.stage .node) {
    position: absolute;
    transform: translate(-50%, -50%);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--text);
    background: color-mix(in oklab, var(--c) 22%, #0a0c12);
    border: 1px solid var(--c);
    border-radius: 999px;
    padding: 0.28rem 0.7rem;
    cursor: grab;
    user-select: none;
    white-space: nowrap;
    box-shadow: 0 0 16px -2px var(--c);
    touch-action: none;
  }
  :global(.stage .node .fg) {
    --fc: var(--c);
    width: 13px;
    height: 13px;
  }
  :global(.stage .node:active) {
    cursor: grabbing;
  }
</style>
