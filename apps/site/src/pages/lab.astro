---
import Base from '../layouts/Base.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { EXPERIMENTS, MANUAL_FORCES, classifyForce } from '@fundamental-engine/core';
import '../styles/force-glyphs.css';
import '../styles/instrument.css';
import '../styles/lab.css';

// The Lab — a physics detector, rebuilt as an instrument. Fire a known particle
// into a force with known attributes; the chamber shows its track + the field
// structure, and the readout checks the measured behaviour against the conformance
// catalog (the same EXPERIMENTS the test suite runs) — frame by frame. Every force
// in the catalog has a conformance experiment, so all of them fire here.

// every force that has a conformance experiment (the detector can run it — all 36 do)
const HAS_EXP = new Set(EXPERIMENTS.map((e) => e.scenario.force));
const families = [
  { key: 'canonical', label: 'Canonical' },
  { key: 'natural', label: 'Natural' },
  { key: 'extended', label: 'Designed-extended' },
] as const;
const inFamily = (k: string) => MANUAL_FORCES.filter((f) => f.family === k);
const forceNo = (token: string) => MANUAL_FORCES.findIndex((f) => f.token === token) + 1;
const z2 = (n: number) => String(n).padStart(2, '0');
const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
const liveCount = MANUAL_FORCES.filter((f) => HAS_EXP.has(f.token)).length;
// natural-field badge per tile (from the engine's classification) — gravity/EM/strong/weak get a
// colored marker; designed/derived/transport/metric get none. A second, conceptual axis over the
// family grouping (Natural Fields model).
const NF_COLOR: Record<string, string> = { gravity: '#4da3ff', electromagnetic: '#2dd4bf', strong: '#a78bfa', weak: '#ff9d5c' };
const NF_ABBR: Record<string, string> = { gravity: 'G', electromagnetic: 'EM', strong: 'S', weak: 'W' };
const fieldOf = (token: string) => classifyForce(token).field;
const kindOf = (token: string) => classifyForce(token).kind;
// the filter chips: by fundamental field, then by kind. `f` is "type:value"; "" clears.
const FIELD_FILTERS = [
  { f: '', label: 'All' },
  { f: 'field:gravity', label: 'Gravity' },
  { f: 'field:electromagnetic', label: 'EM' },
  { f: 'field:strong', label: 'Strong' },
  { f: 'field:weak', label: 'Weak' },
  { f: 'kind:designed', label: 'Designed' },
  { f: 'kind:derived', label: 'Derived' },
  { f: 'kind:transport', label: 'Transport' },
] as const;
// per-filter wayfinding color — the natural fields share the site-wide palette; the kinds get
// their own. Carried as a leading dot so a filter's identity reads at a glance.
const FILTER_COLOR: Record<string, string> = {
  'field:gravity': '#4da3ff',
  'field:electromagnetic': '#2dd4bf',
  'field:strong': '#a78bfa',
  'field:weak': '#ff9d5c',
  'kind:designed': '#f472b6',
  'kind:derived': '#7dd3fc',
  'kind:transport': '#fbbf24',
};
---

<Base
  title="Fundamental — the Lab (physics detector)"
  description="Fire known particles into a force with known attributes and watch what happens — their tracks, the field structure, the measured behaviour checked against what the math predicts, frame by frame. The Lab is a conformance instrument."
>
  <SiteNav current="lab" />
  <main class="lab" id="main">
    <h1 class="lab-title">the lab — force conformance explorer</h1>
    <a class="lab-back" href="/design">← Forces Design System</a>

    <div class="lab-grid">
      <!-- ── force picker — a periodic table of forces ── -->
      <aside class="lab-picker" aria-label="Force picker">
        <div class="force-browser view-icon" data-force-browser>
          <div class="fb-head">
            <span class="fb-label">{MANUAL_FORCES.length} forces</span>
            <div class="seg-toggle" role="group" aria-label="Tile display">
              <button type="button" data-view="icon" class="on">Icon</button>
              <button type="button" data-view="symbol">Symbol</button>
              <button type="button" data-view="name">Name</button>
            </div>
          </div>
          <div class="fb-fields" role="group" aria-label="Filter by natural field" data-field-filter>
            {FIELD_FILTERS.map((ff) => (
              <button
                type="button"
                class:list={['fbf', { on: ff.f === '', 'fbf-color': !!FILTER_COLOR[ff.f] }]}
                data-filter={ff.f}
                style={FILTER_COLOR[ff.f] ? `--chip-color: ${FILTER_COLOR[ff.f]}` : undefined}
              >{ff.label}</button>
            ))}
          </div>
          {families.map((fam) => (
            <div class="fb-group">
              <span class="glabel">{fam.label}</span>
              <div class="force-grid">
                {inFamily(fam.key).map((f) => {
                  const nf = fieldOf(f.token);
                  return (
                  <button
                    type="button"
                    class={`force-tile ${HAS_EXP.has(f.token) ? 'calib' : 'locked'}`}
                    data-force={f.token}
                    data-field={nf ?? ''}
                    data-kind={kindOf(f.token) ?? ''}
                    style={`--fc:${f.color}`}
                    title={`${cap(f.label)} — ${f.effect}${nf ? ` · ${nf} field` : ''}`}
                  >
                    <span class="z">{z2(forceNo(f.token))}</span>
                    {nf && <span class="nf-mark" style={`--nfc:${NF_COLOR[nf]}`} title={`${nf} field`}>{NF_ABBR[nf]}</span>}
                    <span class="picon as-icon"><i class={`fg fg-${f.token}`} aria-hidden="true" /></span>
                    <span class="sym as-symbol">{f.symbol}</span>
                    <span class="nameBig as-name">{cap(f.label)}</span>
                    <span class="pname">{cap(f.label)}</span>
                  </button>
                  );
                })}
              </div>
            </div>
          ))}
          <p class="fb-foot"><b>{liveCount} forces</b> · conformance-backed<br />fire any force</p>
          <p class="fb-legend">
            <a href="/docs/natural-fields">Natural fields</a>:
            <span class="nf-mark" style="--nfc:#4da3ff">G</span> gravity
            <span class="nf-mark" style="--nfc:#2dd4bf">EM</span> electromagnetic
            <span class="nf-mark" style="--nfc:#a78bfa">S</span> strong
            <span class="nf-mark" style="--nfc:#ff9d5c">W</span> weak
          </p>
        </div>
      </aside>

      <!-- ── center — chamber, timeline, transport, sweep ── -->
      <section class="lab-center">
        <div class="lab-chamber">
          <span class="stage-label">detector chamber</span>
          <span class="chamber-force"><span class="dot"></span><span id="chamberForce">Attract</span></span>
          <canvas id="chamber"></canvas>
          <div class="chamber-hud ds-readout" id="hud" aria-hidden="true"></div>
          <button class="chamber-help" id="help" aria-label="What am I looking at?" aria-expanded="false">?</button>
          <div class="chamber-legend" id="legend" role="dialog" aria-label="Legend" hidden>
            <p class="info-title">What am I looking at?</p>
            <ul class="legend-list">
              <li><span class="legend-key body"></span>The body — the force, fixed at the chamber centre.</li>
              <li><span class="legend-line"></span>The particle track — one frame of motion per segment.</li>
              <li><span class="legend-key ring"></span>The range ring — beyond it the force reads zero.</li>
              <li><span class="legend-key pass"></span>A passed expectation marker on the timeline.</li>
              <li><span class="legend-key head"></span>The particle head + its velocity vector.</li>
              <li><span class="legend-line dim"></span>Drag the timeline to scrub frame by frame.</li>
            </ul>
            <p class="info-title" style="margin-top:0.9rem">Keyboard</p>
            <ul class="key-list">
              <li><kbd class="kbd sm">Space</kbd><span>play / pause</span></li>
              <li><kbd class="kbd sm">F</kbd><span>fire</span><kbd class="kbd sm">R</kbd><span>reset</span></li>
              <li><kbd class="kbd sm">←</kbd><kbd class="kbd sm">→</kbd><span>step frames</span></li>
              <li><kbd class="kbd sm">L</kbd><span>cycle run mode (once / loop / free)</span></li>
            </ul>
          </div>
          <div class="uncalib-veil" id="veil" hidden>
            <div class="big" id="veilName">—</div>
            <div class="sub" id="veilMeta">awaiting calibration</div>
            <div class="sub" style="color:var(--text-4)">physics &amp; expectations not yet pinned</div>
          </div>
        </div>

        <div class="lab-detector" id="detector">
          <div
            class="lab-timeline"
            id="timeline"
            role="slider"
            tabindex="0"
            aria-label="Timeline — drag to scrub; markers show where each test passes"
            aria-valuemin="0"
            aria-valuenow="0"
          >
            <div class="tl-wave-wrap">
              <span class="tl-wave-label">particle speed</span>
              <canvas class="tl-wave" id="tlWave"></canvas>
            </div>
            <div class="tl-track">
              <div class="tl-rail"></div>
              <div class="tl-fill" id="tlFill"></div>
              <div class="tl-markers" id="tlMarkers"></div>
              <div class="tl-playhead" id="tlPlayhead"></div>
            </div>
          </div>

          <div class="lab-transport">
            <button type="button" id="fire" class="tbtn primary">↯ Fire</button>
            <button type="button" id="play" class="tbtn">▶ Play</button>
            <button type="button" id="stepb" class="tbtn">⏭ Step</button>
            <button type="button" id="reset" class="tbtn">⟲ Reset</button>
            <button type="button" id="mode" class="tbtn" data-mode="once">↦ Once</button>
            <button type="button" id="ghost" class="tbtn on">◌ Ghost</button>
            <button type="button" id="field" class="tbtn" title="Overlay the force field across the chamber">▦ Field</button>
            <span class="frame-readout" id="frameReadout">frame 0 / 60</span>
          </div>

          <div class="lab-info">
            <div class="info-col">
              <div class="info-title sweep-head">
                <span>Parameter sweep</span>
                <span class="sweep-selects">
                  <span class="lab-select sweep-select"><select id="sweepMetric" aria-label="Sweep measure">
                    <option value="finalDist">final distance</option>
                    <option value="delta">frame-0 |Δv|</option>
                    <option value="passes">tests passed</option>
                  </select></span>
                  <span class="lab-select sweep-select"><select id="sweepParam" aria-label="Sweep axis"></select></span>
                </span>
              </div>
              <canvas id="sweepCanvas"></canvas>
              <p class="sweep-note"><span id="sweepMetricLabel">Final distance</span> vs <b id="sweepLabel">strength</b> across its range. Each point
                re-runs the experiment; the dashed line marks the current value.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- ── readout — verdict, force card, expectations / tune ── -->
      <aside class="lab-readout" aria-label="Readout">
        <div class="verdict resolving" id="verdict">Resolving</div>

        <div class="panel force-about">
          <div class="about-head">
            <span class="about-sym" id="aboutSym"><i class="fg fg-attract" aria-hidden="true"></i></span>
            <div class="about-id">
              <div class="about-name" id="aboutName">Attract</div>
              <div class="about-meta" id="aboutMeta">Canonical · At · No. 01</div>
            </div>
          </div>
          <p class="about-desc" id="aboutDesc"></p>
          <div class="about-effect"><span class="k">Effect</span><span id="aboutEffect"></span></div>
          <div class="param-formula" id="aboutFormula" style="margin-top:0.9rem;margin-bottom:0"></div>
        </div>

        <div class="readout-tabs" id="tabs" role="tablist" hidden>
          <button type="button" role="tab" data-tab="expect" class="on">Expectations<i id="tabCount"></i></button>
          <button type="button" role="tab" data-tab="tune">Tune</button>
        </div>

        <div class="panel" id="expectPanel" hidden>
          <p class="panel-title">Expectations <span class="pass-summary" id="passSummary"></span></p>
          <div class="checklist" id="checklist"></div>
        </div>

        <div class="panel" id="tunePanel" hidden>
          <p class="panel-title">Tune &amp; refire</p>
          <label class="preset-row">
            <span>Preset</span>
            <span class="lab-select"><select id="preset"></select></span>
          </label>
          <div class="params" id="params"></div>
          <div class="export-row">
            <button type="button" id="share" class="xbtn">⎘ Copy link</button>
            <button type="button" id="export" class="xbtn">↧ Export JSON</button>
            <button type="button" id="report" class="xbtn">≡ Copy report</button>
            <button type="button" id="resetParams" class="xbtn">⟲ Defaults</button>
          </div>
          <p class="scenario-note" id="note"></p>
        </div>
      </aside>
    </div>
  </main>
  <SiteFooter />

  <script>
    import { EXPERIMENTS, runScenario, allForces, forceAt, MANUAL_FORCES } from '@fundamental-engine/core';

    type Any = Record<string, any>;
    const forces = allForces();
    const byForce: Any = {};
    for (const e of EXPERIMENTS as unknown as Any[]) byForce[e.scenario.force] = e;
    const META: Any = {};
    for (const f of MANUAL_FORCES as unknown as Any[]) META[f.token] = f;

    const $ = (id: string) => document.getElementById(id);
    const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
    const z2 = (n: number) => String(n).padStart(2, '0');
    const round = (n: number, step = 0.01) => {
      const d = step < 1 ? (String(step).split('.')[1] || '').length : 0;
      return Number(n.toFixed(d));
    };

    // Tunable body-attribute specs — symbol · unit · slider range — derived live from the
    // selected force's scenario body. `angle` is shown in degrees and converted to radians
    // in buildScenario. Which knobs appear is driven by the catalog `attrs` (so each force
    // shows only the knobs that matter), plus box/absorbR auto-added when the body has them,
    // plus the injected particle's vx/vy/count. This covers all 36 forces with no per-force
    // table to drift.
    const ATTR: Any = {
      strength: (b: Any) => { const v = b.strength ?? 1, mx = Math.max(0.5, v * 3); return { key: 'strength', label: 'strength', sym: 'S', val: v, def: v, min: 0, max: mx, step: mx / 100 }; },
      range: (b: Any) => ({ key: 'range', label: 'range', sym: 'd', unit: 'px', val: b.range ?? 300, def: b.range ?? 300, min: 50, max: 500, step: 5 }),
      spin: (b: Any) => ({ key: 'spin', label: 'spin', sym: 'σ', val: b.spin ?? 1, def: b.spin ?? 1, min: -2, max: 2, step: 0.1 }),
      angle: (b: Any) => { const d = Math.round(((b.angle ?? 0) * 180) / Math.PI); return { key: 'angle', label: 'heading', sym: 'θ', unit: 'deg', val: d, def: d, min: -180, max: 180, step: 5 }; },
      box: (b: Any) => ({ key: 'box', label: 'wall size', sym: 'w', unit: 'px', val: b.hw ?? 40, def: b.hw ?? 40, min: 20, max: 120, step: 2 }),
      absorbR: (b: Any) => ({ key: 'absorbR', label: 'capture radius', sym: 'r', unit: 'px', val: b.absorbR ?? 64, def: b.absorbR ?? 64, min: 24, max: 160, step: 2 }),
    };
    // named quick-pick chips per control — click a meaningful value instead of dragging.
    function bands(sp: Any): [string, number][] {
      const d = sp.def;
      switch (sp.key) {
        case 'strength': return [['weak', round(d * 0.4)], ['default', d], ['strong', round(d * 2.2)], ['max', round(sp.max)]];
        case 'range': return [['near', Math.round(d * 0.55)], ['default', d], ['far', Math.min(sp.max, Math.round(d * 1.6))]];
        case 'spin': return [['ccw', -1], ['off', 0], ['cw', 1]];
        case 'angle': return [['0', 0], ['45', 45], ['90', 90], ['180', 180]];
        case 'box': return [['tight', Math.round(d * 0.6)], ['default', d], ['wide', Math.min(sp.max, Math.round(d * 1.6))]];
        case 'absorbR': return [['small', Math.round(d * 0.6)], ['default', d], ['large', Math.min(sp.max, Math.round(d * 1.6))]];
        case 'vx': case 'vy': return [['0', 0], ['slow', 2], ['fast', 6]];
        case 'count': return [['1', 1], ['8', 8], ['24', 24]];
        default: return [];
      }
    }

    // re-runs on each client-side navigation to /lab (ClientRouter); no-op elsewhere.
    function setup() {
      // the content landmark is id="main" since the a11y skip-link pass (#401) — select the
      // lab root by class, not the old id (the old `$('lab')` guard bailed and killed setup).
      const lab = document.querySelector('main.lab') as HTMLElement | null;
      const canvas = $('chamber') as HTMLCanvasElement | null;
      if (!lab || !canvas) return;
      const W = window as Any;
      W.__labAbort?.abort();
      const _ac = new AbortController();
      W.__labAbort = _ac;
      if (W.__labTimer) { clearInterval(W.__labTimer); W.__labTimer = 0; }
      const ctx = canvas.getContext('2d')!;
      // a minimal env for the optional field-vector probe (forceAt samples the field at a point)
      const fenv: any = {
        dx: 0, dy: 0, dist: 1,
        form: { driftX: 0, wander: 0, orbit: 0, spread: 0, conv: 0 },
        W: 1200, H: 800, t: 0, frameN: 0, dt: 1, c: 12, G: 1,
        spark() {}, supernova() {}, spawn() {},
        neighbors: () => [],
        grid: () => ({ sample: () => 0, deposit() {}, gradient: () => ({ x: 0, y: 0 }) }),
      };

      let cur = 'attract';
      let overrides: Any = {};
      let result: any = null;
      let checks: any[] = [];
      let frame = 0;
      let mode: 'once' | 'loop' | 'unlocked' = 'once';
      const MODE_LABEL: Any = { once: '↦ Once', loop: '↻ Loop', unlocked: '∞ Free' };
      const MAX_FRAMES = 1800; // upper bound for the unlocked / continuous free-run
      let view = { scale: 1, ox: 0, oy: 0 };
      let pickView: 'icon' | 'symbol' | 'name' = 'icon';
      let tab: 'expect' | 'tune' = 'expect';
      let ghostOn = true;
      let ghostTraj: any = null; // previous setting's trajectory (same force)
      let ghostForce = '';
      let fieldOn = false; // optional force-field vector overlay

      const clone = (o: any) => JSON.parse(JSON.stringify(o));
      const hexA = (h: string, a: number) => {
        if (h[0] !== '#') return h;
        const n = parseInt(h.slice(1), 16);
        return `rgba(${(n >> 16) & 255},${(n >> 8) & 255},${n & 255},${a})`;
      };
      const color = () => META[cur]?.color ?? '#4da3ff';
      const calibrated = () => !!byForce[cur]; // every catalogued force has a conformance experiment
      const isPair = (id: string) => ['collide', 'cohesion', 'pressure', 'link', 'hunt', 'align'].includes(id);

      function scenarioBase() { return byForce[cur].scenario; }
      // the default value of a tunable key, read from the force's scenario
      function defOf(key: string): number {
        const s = scenarioBase(), b = s.body, p0 = s.particles[0];
        switch (key) {
          case 'strength': return b.strength ?? 1;
          case 'range': return b.range ?? 300;
          case 'spin': return b.spin ?? 1;
          case 'angle': return Math.round(((b.angle ?? 0) * 180) / Math.PI);
          case 'box': return b.hw ?? 40;
          case 'absorbR': return b.absorbR ?? 64;
          case 'vx': return p0?.vx ?? 0;
          case 'vy': return p0?.vy ?? 0;
          case 'count': return s.particles.length || 1;
          default: return 0;
        }
      }
      const valOf = (key: string) => (overrides[key] != null ? overrides[key] : defOf(key));

      function buildScenario(ov: Any = overrides) {
        const s = clone(scenarioBase());
        const B: Any = s.body;
        if (ov.strength != null && B.strength != null) B.strength = ov.strength;
        if (ov.range != null && B.range != null) B.range = ov.range;
        if (ov.spin != null) B.spin = ov.spin;
        if (ov.angle != null) B.angle = (ov.angle * Math.PI) / 180;
        if (ov.box != null) { B.hw = ov.box; B.hh = ov.box; }
        if (ov.absorbR != null) B.absorbR = ov.absorbR;
        if (ov.vx != null && s.particles[0]) s.particles[0].vx = ov.vx;
        if (ov.vy != null && s.particles[0]) s.particles[0].vy = ov.vy;
        if (ov.frames != null) s.frames = ov.frames;
        // Scenario.seed — the runner's determinism seam: runScenario swaps Math.random for a
        // seeded PRNG during the run, so RNG forces (thermal, jet, spawn scatter) replay
        // exactly. RNG-force experiments carry a catalog seed; this override replaces it.
        if (ov.seed != null) s.seed = ov.seed;
        if (s.particles.length === 0) return s;
        if (!isPair(cur)) {
          const count = Math.max(1, Math.min(40, Math.round(ov.count ?? s.particles.length)));
          if (count > s.particles.length) placeExtras(s, count, ov);
        }
        return s;
      }

      // ── particle placement (Tune → placement) ──
      // Placement is consumer-side by design: ScenarioParticle takes explicit coordinates.
      // The injected extras are laid out by the selected mode; particles[0] — the tracked
      // test particle — is never moved, so the conformance expectations keep measuring the
      // canonical track. `scatter` draws from the same PRNG family the runner seeds
      // Math.random with, so one seed pins both the layout and any RNG force in the run.
      const PLACEMENTS = ['fan', 'clone', 'ring', 'scatter'];
      const PLACE_TIP: Any = {
        fan: 'a curtain of parallel tracks across the field axis',
        clone: 'exact copies of the test particle (RNG forces fan them apart)',
        ring: 'evenly around the body at the test particle’s radius',
        scatter: 'seeded-random positions and headings around the body',
      };
      const placementOf = (ov: Any) => (PLACEMENTS.includes(ov.placement) ? ov.placement : 'fan');
      const rollSeed = () => 1 + Math.floor(Math.random() * 99998);
      // mulberry32 — the PRNG family runScenario uses for Scenario.seed
      function mulberry32(seed: number): () => number {
        let a = seed >>> 0;
        return () => {
          a |= 0;
          a = (a + 0x6d2b79f5) | 0;
          let t = Math.imul(a ^ (a >>> 15), 1 | a);
          t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
          return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
        };
      }
      function placeExtras(s: Any, count: number, ov: Any) {
        const base = s.particles[0];
        const extra = count - s.particles.length;
        const spread = (s.body.range || 200) * 0.9;
        const mode = placementOf(ov);
        const bx = s.body.cx ?? 0, by = s.body.cy ?? 0;
        const bvx = base.vx ?? 0, bvy = base.vy ?? 0;
        const rand = mulberry32(ov.seed != null ? ov.seed : 1);
        for (let i = 0; i < extra; i++) {
          if (mode === 'clone') {
            s.particles.push({ ...base });
          } else if (mode === 'ring') {
            // evenly around the body at the test particle's radius; velocities rotate with
            // the positions so the pattern stays rotationally symmetric
            const r0 = Math.hypot(base.x - bx, base.y - by);
            const r = r0 > 8 ? r0 : spread * 0.4;
            const a0 = r0 > 8 ? Math.atan2(base.y - by, base.x - bx) : 0;
            const da = (2 * Math.PI * (i + 1)) / count;
            s.particles.push({
              ...base,
              x: bx + Math.cos(a0 + da) * r,
              y: by + Math.sin(a0 + da) * r,
              vx: bvx * Math.cos(da) - bvy * Math.sin(da),
              vy: bvx * Math.sin(da) + bvy * Math.cos(da),
            });
          } else if (mode === 'scatter') {
            // seeded-random positions in the disc around the body, headings randomised at
            // the test particle's speed — same seed, same layout
            const a = rand() * 2 * Math.PI;
            const r = Math.sqrt(rand()) * spread;
            const sp = Math.hypot(bvx, bvy);
            const h = rand() * 2 * Math.PI;
            s.particles.push({
              ...base,
              x: bx + Math.cos(a) * r,
              y: by + Math.sin(a) * r,
              vx: Math.cos(h) * sp,
              vy: Math.sin(h) * sp,
            });
          } else {
