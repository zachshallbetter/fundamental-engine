      }

      // optional: a faint arrow-grid sampling the force field across the whole chamber,
      // not just along the particle path (toggled by the Field button). forceAt probes the
      // field at each world point; pair/grid forces have no point-field so it reads ~0.
      function drawField(b: any) {
        const w = canvas!.clientWidth, h = canvas!.clientHeight, col = color(), stepPx = 34;
        // Sample first, then scale arrows RELATIVE to the field's own max magnitude — so a
        // force shows whatever its absolute scale (the dipole field() of magnetism/charge is
