---
import Base from './Base.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Breadcrumbs, { type Crumb } from '../components/Breadcrumbs.astro';
import { DOCS_NAV, DOCS_FLAT } from '../lib/docs-nav.ts';
import '../styles/ds-tokens.css';
import '../styles/docs.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;

// current page (normalise trailing slash) → sidebar active + prev/next
const path = Astro.url.pathname.replace(/\/$/, '') || '/docs';
const groups = DOCS_NAV.map((g) => ({ ...g, items: g.items.filter((i) => i.ready) })).filter(
  (g) => g.items.length > 0,
);
const idx = DOCS_FLAT.findIndex((i) => i.href === path);
const prev = idx > 0 ? DOCS_FLAT[idx - 1] : null;
const next = idx >= 0 && idx < DOCS_FLAT.length - 1 ? DOCS_FLAT[idx + 1] : null;

// breadcrumb trail: Home › Docs › <Group> › <Page> (Docs alone is the Overview page itself)
const crumbs: Crumb[] = [{ label: 'Home', href: '/' }];
if (path === '/docs') {
  crumbs.push({ label: 'Docs' });
} else {
  crumbs.push({ label: 'Docs', href: '/docs' });
  for (const g of DOCS_NAV) {
    const item = g.items.find((i) => (i.href.replace(/\/$/, '') || '/') === path);
    if (item) {
      crumbs.push({ label: g.title, color: g.color });
      crumbs.push({ label: item.label, color: g.color });
      break;
    }
  }
}
---

<Base title={title} description={description}>
  <SiteNav current="docs" />
  <div class="docs-shell">
    <aside class="docs-sidebar" aria-label="Docs navigation" data-pagefind-ignore>
      <div class="docs-side-head">
        <button class="docs-side-toggle" aria-expanded="false" aria-controls="docsSide">
          Menu
        </button>
        <button
          class="docs-search-btn"
          type="button"
          data-docs-search-open
          aria-keyshortcuts="Meta+K Control+K /"
        >
          <span>Search</span>
          <kbd aria-hidden="true">⌘K</kbd>
        </button>
      </div>
      <nav id="docsSide">
        {
          groups.map((g) => (
            <div
              class="docs-group"
              style={[g.color && `--group-color: ${g.color}`, g.glyph && `--group-glyph: '${g.glyph}'`]
                .filter(Boolean)
                .join('; ') || undefined}
            >
              <span class="docs-group-title">{g.title}</span>
              <ul>
                {g.items.map((i) => (
                  <li>
                    <a
                      href={i.href}
                      class={i.external ? 'ext' : undefined}
                      aria-current={i.href === path ? 'page' : undefined}
                    >
                      {i.label}
                      {i.external && <span class="ext-mark" aria-hidden="true">↗</span>}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </nav>
      <div class="docs-side-foot">
        <!-- the docs-field toggle — the runtime restores the persisted choice, wires the
             click, and keeps main[data-field-docs] honest (off under reduced motion). -->
        <button
          class="docs-field-toggle"
          type="button"
          role="switch"
          aria-checked="true"
          data-docs-field-toggle
        >
          <span class="dft-label">docs field</span>
          <span class="dft-state" data-docs-field-state>on</span>
        </button>
      </div>
    </aside>

    <main class="docs-content" data-pagefind-body>
      <Breadcrumbs crumbs={crumbs} />
      <slot />
      <nav class="docs-prevnext" aria-label="Pagination" data-pagefind-ignore>
        {
          prev ? (
            <a class="pn prev" href={prev.href}>
              <span>← Previous</span>
              <b>{prev.label}</b>
            </a>
          ) : (
            <span />
          )
        }
        {idx >= 0 && (
          <span class="pn-progress" aria-hidden="true">
            {idx + 1} / {DOCS_FLAT.length}
          </span>
        )}
        {
          next && (
            <a class="pn next" href={next.href}>
              <span>Next →</span>
              <b>{next.label}</b>
            </a>
          )
        }
      </nav>
    </main>

    <aside class="docs-toc" aria-label="On this page" data-pagefind-ignore>
      <span class="docs-toc-title">On this page</span>
      <nav id="docsToc"></nav>
      <div class="docs-toc-foot">
        <!-- reference integrity, self-measured (DocsRuntime): the page's own internal
             anchors, verified at init — the honest-data chip pattern from the examples. -->
        <span class="docs-integrity" data-docs-integrity role="status" hidden></span>
      </div>
    </aside>
  </div>
  <SiteFooter />

  <!-- search — Pagefind over the docs content (data-pagefind-body above), custom UI on
       ds-tokens. The runtime imports /pagefind/pagefind.js lazily on first open; in dev
       (no built index) the dialog says so instead of pretending. -->
  <dialog class="docs-search" aria-label="Search documentation" data-docs-search>
    <div class="ds-head">
      <input
        type="search"
        placeholder="Search the docs…"
        aria-label="Search the docs"
        autocomplete="off"
        spellcheck="false"
        role="combobox"
        aria-expanded="true"
        aria-controls="dsResults"
        data-docs-search-input
      />
      <button type="button" class="ds-close" data-docs-search-close aria-label="Close search">
        esc
      </button>
    </div>
    <div class="ds-status" data-docs-search-status aria-live="polite"></div>
    <div
      class="ds-results"
      id="dsResults"
      role="listbox"
      aria-label="Search results"
      data-docs-search-results
    >
    </div>
  </dialog>

  <script>
    // the docs shell runtime: invisible page field over the headings, the attention TOC,
    // reference integrity, search, and the persisted docs-field toggle.
    import '../components/DocsRuntime.ts';
  </script>

  <script is:inline data-astro-rerun>
    (() => {
      // re-runs on each client-side navigation into a docs page; tear down the
      // previous run's scroll listener so it doesn't stack.
      if (window.__docsTeardown) window.__docsTeardown();
      const _ac = new AbortController();
      const _sig = _ac.signal;
      window.__docsTeardown = () => _ac.abort();

      // copy-on-click for any [data-copy] (install chips, code snippets)
      document.querySelectorAll('[data-copy]').forEach((el) => {
        el.addEventListener('click', () => {
          const text = el.getAttribute('data-copy') || el.textContent || '';
          navigator.clipboard &&
            navigator.clipboard.writeText(text).then(() => {
              el.classList.add('copied');
              setTimeout(() => el.classList.remove('copied'), 1100);
            });
        });
      });

      // CodeTabs tab-switching moved into CodeTabs.astro's own module script (it now
      // syncs every instance + persists the framework choice as ?code=). Only the
      // copy button and the burst demo stay delegated here, bound under _sig so the
      // previous page's binding is torn down (no double-fire).
      document.addEventListener(
        'click',
        (e) => {
          // live demo: burst the persisted page field at the click point
          const burst = e.target.closest && e.target.closest('[data-field-burst]');
          if (burst) {
            const field = document.querySelector('field-root');
            const color = burst.getAttribute('data-field-burst') || undefined;
            if (field && field.burst) field.burst(e.clientX, e.clientY, color || undefined);
            return;
          }
          // CodeTabs copy moved into CodeTabs.astro's own module script (it works on
          // every page now, including the example family).
        },
        { signal: _sig },
      );

      // build the "On this page" TOC from the content's h2/h3
      const content = document.querySelector('.docs-content');
      const toc = document.getElementById('docsToc');
      if (content && toc) {
        const slug = (s) =>
          s
            .toLowerCase()
            .trim()
            .replace(/[^a-z0-9]+/g, '-')
            .replace(/^-|-$/g, '');
        const heads = [...content.querySelectorAll('h2, h3')];
        const links = [];
        for (const h of heads) {
          if (!h.id) h.id = slug(h.textContent || '');
          const a = document.createElement('a');
          a.href = '#' + h.id;
          a.textContent = h.textContent;
          a.className = h.tagName === 'H3' ? 'lvl3' : 'lvl2';
          a.dataset.for = h.id;
          toc.appendChild(a);
          links.push({ a, h });
        }
        if (links.length < 2) toc.closest('.docs-toc').style.visibility = 'hidden';
        // scroll-spy — the discrete signal; the live --att (DocsRuntime) is the continuous one
        const spy = () => {
          let cur = links[0];
          for (const l of links) {
            if (l.h.getBoundingClientRect().top < 120) cur = l;
          }
          links.forEach((l) => l.a.classList.toggle('active', l === cur));
        };
        window.addEventListener('scroll', spy, { passive: true, signal: _sig });
        spy();
      }

      // mobile sidebar toggle
      const toggle = document.querySelector('.docs-side-toggle');
      const side = document.getElementById('docsSide');
      if (toggle && side) {
        toggle.addEventListener('click', () => {
          const open = side.classList.toggle('open');
          toggle.setAttribute('aria-expanded', String(open));
        });
      }

      // The docs' own chrome participates in the field (the field-reacts law).
      // Curated: prominent buttons become `wall` bodies (the field bounces off
      // their box); prominent text becomes `shear` bodies (currents flow along
      // their edges). The content headings are NOT tagged here — DocsRuntime owns
      // them (attract bodies + the scoped attention pipeline, gated by the toggle).
      const tagBodies = (sel, force) =>
        document.querySelectorAll(sel).forEach((el) => {
          if (!el.hasAttribute('data-body')) el.setAttribute('data-body', force);
        });
      tagBodies('.next-card, .install, .see-also a, .docs-prevnext .pn', 'wall');
      tagBodies('.docs-hero .lede', 'shear');
      const taggedField = document.querySelector('field-root');
      if (taggedField && taggedField.rescan) taggedField.rescan();
    })();
  </script>
</Base>
