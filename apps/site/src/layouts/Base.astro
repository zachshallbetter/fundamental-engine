---
import { ClientRouter } from 'astro:transitions';
// The design system's tokens are the single, global source of truth — load them
// on every page (the homepage and Lab included), not just the docs surfaces.
import '../styles/ds-tokens.css';
import DataConsole from '../components/DataConsole.astro';
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  /** override the OG image alt (defaults to the title). */
  ogImageAlt?: string;
  /** robots directive — pass 'noindex, follow' for redirect stubs / thin pages. */
  robots?: string;
  /** the OG type — 'article' on writing pages, 'website' elsewhere. */
  ogType?: string;
  /** page-specific Schema.org JSON-LD (object or array), emitted alongside the site WebSite graph. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}
const {
  title = 'Fundamental — a reciprocal DOM-physics field',
  description = "Fundamental — elements bend the field; the field's density bends them back. A medium your interface lives inside, not a backdrop it sits on.",
  ogImage = '/og.jpg',
  ogImageAlt,
  robots = 'index, follow',
  ogType = 'website',
  jsonLd,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://fundamental-engine.com').href;
const ogImageUrl = new URL(ogImage, Astro.site ?? 'https://fundamental-engine.com').href;
const pageJsonLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '/eli5' || Astro.url.pathname.endsWith('/eli5/');
---

<!doctype html>
<!-- transition:animate="none" disables the view-transition snapshot/cross-fade for
     the whole document. ClientRouter still does no-reload navigation, but with no
     animation the persisted <field-root> canvas keeps rendering live instead of
     being snapshotted (canvas snapshots come out blank → a flash). Content swaps
     instantly over one continuous, uninterrupted field. -->
<html lang="en" transition:animate="none">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Zach Shallbetter" />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="Fundamental — Writings" href="/rss.xml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <meta name="theme-color" content="#04050a" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Fundamental" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt ?? title} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt ?? title} />
    <meta name="twitter:site" content="@usefundamental" />
    <meta name="twitter:creator" content="@zachshallbetter" />
    <!-- self-hosted fonts (perf: no third-party request; prerequisite for glyph-outline
         generation — scripts/gen-contours.mjs parses the same family). display=swap in
         /fonts/fonts.css means text paints in fallback fonts immediately. -->
    <link rel="preload" href="/fonts/bricolage-grotesque-02.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="stylesheet" href="/fonts/fonts.css" />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: 'Fundamental',
        url: 'https://fundamental-engine.com/',
        description:
          'A platform-native relational field runtime — on the web, elements become bodies in an invisible physics field that bends them back.',
        sameAs: [
          'https://github.com/zachshallbetter/fundamental-engine',
          'https://x.com/usefundamental',
          'https://www.npmjs.com/org/fundamental-engine',
        ],
        author: {
          '@type': 'Person',
          name: 'Zach Shallbetter',
          url: 'https://zachshallbetter.com',
          sameAs: [
            'https://zachshallbetter.com',
            'https://x.com/zachshallbetter',
            'https://github.com/zachshallbetter',
          ],
        },
        publisher: {
          '@type': 'Person',
          name: 'Zach Shallbetter',
          url: 'https://zachshallbetter.com',
          sameAs: [
            'https://zachshallbetter.com',
            'https://x.com/zachshallbetter',
            'https://github.com/zachshallbetter',
          ],
        },
      })}
    />
    {/* page-specific structured data (SoftwareApplication on home, BreadcrumbList on docs, etc.) */}
    {
      pageJsonLd.map((ld) => (
        <script type="application/ld+json" is:inline set:html={JSON.stringify(ld)} />
      ))
    }

    <!-- client-side navigation: no full reload, so the field below runs continuously -->
    <ClientRouter />
  </head>
  <body>
    <!-- skip navigation: the first focusable element on every page. Visually hidden
         until focused so keyboard users can jump past the nav/sidebar directly to the
         main content landmark. The #main anchor is placed on the primary <main> (or
         the home page's manual-shell <div>) by each layout/page. -->
    <a class="skip-link" href="#main">Skip to content</a>
    <!-- the CSS gradient is color ambiance; the live <field-root> renders the
         particle field over it, reacting to [data-body] elements on the page.
         transition:persist keeps the engine running across client-side navigation —
         the field is one continuous medium, never reset between pages. -->
    <div class="field" aria-hidden="true" transition:persist></div>
    <field-root
      render="dots"
      overlay="off"
      grid-warp="3"
      grid-intensity="0.5"
      accent="#4da3ff"
      density="3.6"
      waves="false"
      data-nav-flow="off"
      data-nav-grid="off"
      data-nav-heatmap="off"
      transition:persist
    ></field-root>
    <!-- Ambient resting energy (#liveliness): an invisible, viewport-scale swirl body so the
         resting field keeps circulating instead of settling into the attract wells and freezing.
         Draws nothing (swirl is a force, not a render layer — no visible waves); low strength so it
         reads as gentle drift, not a vortex. Matter circulates through the page's content bodies,
         so it stays alive AND keeps interacting with them. Reduced-motion freezes the integrator
         (dt=0), so this contributes no motion for users who opt out — no extra guard needed. -->
    <div
      class="field-ambient"
      aria-hidden="true"
      data-body="swirl"
      data-strength="0.32"
      data-range="1500"
      data-spin="1"
      style="position: fixed; left: 50%; top: 45%; width: 2px; height: 2px; pointer-events: none; opacity: 0"
    ></div>
    <script is:inline>
      // Reduced motion: the carrier-wave renderer advances its geometry from wall-clock time even
      // when particle motion is frozen (the engine sets env.dt = 0 under prefers-reduced-motion), so
      // leaving waves on would keep the background animating for users who asked for none. Turn the
      // waves off before the engine upgrades — this runs during parse, ahead of the deferred
      // <field-root> boot, so it constructs waves-off — matching the layout's other reduced-motion
      // opt-outs (the .field drift). Non-reduced-motion users keep the live wave currents.
      if (window.matchMedia && matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.querySelector('field-root')?.setAttribute('waves', 'false');
      }
    </script>
    <div class="scrim" aria-hidden="true" transition:persist></div>
    <slot />
    <DataConsole />

    <script>
      // Idle-until-urgent engine boot. The field is ambiance — a slightly late start is
      // invisible — so the '@fundamental-engine/elements' module (which registers <field-root>; the
      // engine mounts on connect) loads OFF the critical path via a deferred dynamic
      // import. Until it runs, <field-root> is an unknown element: inert, invisible, zero
      // layout (the canvas is position:fixed/z-index:0 inside its shadow root), so the
      // page renders and paints fine without it and no layout shift happens when the
      // engine arrives. Bundled by Astro, so this runs once — the perfect place to wire
      // the persisted field into the navigation lifecycle.

      // The navigation wiring registers up front (it must exist before the first
      // client-side swap, booted or not). After each content swap, re-scan so the
      // continuous field reacts to the new page's [data-body] bodies (scan re-binds
      // engagement). Optional chaining keeps it a no-op until the element upgrades.
      document.addEventListener('astro:after-swap', () => {
        const field = document.querySelector('field-root') as
          | (HTMLElement & { rescan?: () => void; setFormation?: (n: string) => void; setOverlay?: (o: string | string[]) => void })
          | null;
        field?.rescan?.();
        field?.setFormation?.('ambient'); // settle to the resting state on arrival

        // Dynamically toggle grid overlay based on page type
        if (field) {
          const isHome = !!document.querySelector('.manual-shell');
          if (isHome) {
            field.dataset.navGrid = 'off';
            field.setOverlay?.('off');
          } else {
            field.dataset.navGrid = 'off';
            field.dataset.navFlow = 'off';
            field.setOverlay?.('off');
          }
        }
      });

      // Boot when the main thread first goes idle, or after ~1.5s — whichever comes
      // first. Safari has no requestIdleCallback; a short fixed delay clears the
      // critical path there the same way.
      // the one field switch: only boot the engine when the field is on (off → a static site)
      const boot = () => void import('@fundamental-engine/elements');
      if (document.documentElement.dataset.field !== 'off') {
        if ('requestIdleCallback' in window) {
          requestIdleCallback(boot, { timeout: 1500 });
        } else {
          setTimeout(boot, 300);
        }
      }
    </script>

    <style is:global>
      /* Design tokens come from ds-tokens.css (imported above), the single source
         of truth. Only page-frame styles live here. */
      * {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        min-height: 100%;
      }
      body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--display);
        letter-spacing: -0.015em;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        min-height: 100svh;
        display: flex;
        flex-direction: column;
        align-items: center;
        overflow-x: hidden;
      }
      a {
        color: inherit;
      }
      /* the one field switch (off): hide the particle field-root entirely. The engine also skips
         booting when off, so this is belt-and-suspenders + covers a live toggle before reload. The
         .field colour gradient stays — it's ambiance, not the field. */
      html[data-field='off'] field-root {
        display: none !important;
      }
      .field {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background:
          radial-gradient(40vw 40vw at 18% 22%, rgba(77, 163, 255, 0.16), transparent 70%),
          radial-gradient(36vw 36vw at 82% 28%, rgba(167, 139, 250, 0.14), transparent 70%),
          radial-gradient(46vw 46vw at 70% 86%, rgba(45, 212, 191, 0.12), transparent 70%),
          radial-gradient(40vw 40vw at 24% 82%, rgba(255, 110, 156, 0.1), transparent 70%);
        filter: saturate(1.1);
        animation: drift 26s ease-in-out infinite alternate;
      }
      @keyframes drift {
        from {
          transform: translate3d(-2%, -1%, 0) scale(1.05);
        }
        to {
          transform: translate3d(2%, 1%, 0) scale(1.12);
        }
      }
      .scrim {
        position: fixed;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        /* Two layers: (1) the original top-anchored vignette that darkens the edges/bottom, kept so the
           hero stays bright; (2) a faint flat floor so the field dims just enough behind body copy to lift
           text legibility everywhere — without hiding the field (particles/streamlines still read through). */
        background:
          radial-gradient(120% 80% at 50% -10%, transparent 55%, rgba(0, 0, 0, 0.55)),
          rgba(0, 0, 0, 0.12);
      }
      @media (prefers-reduced-motion: reduce) {
        .field {
          animation: none;
        }
      }

      /* ============================================================
         KEYBOARD ACCESSIBILITY — skip-link + :focus-visible indicators
         All rules use :focus-visible so mouse/touch users are unaffected.
         Outline style matches the accent palette from ds-tokens.css.
         ============================================================ */

      /* Skip-to-content link — first focusable element in <body>.
         Visually hidden until it receives keyboard focus; revealed inline
         at the top of the viewport so it doesn't fight the fixed nav. */
      .skip-link {
        position: fixed;
        top: -100%;
        left: 1rem;
        z-index: 999;
        padding: 0.5rem 1.1rem;
        background: rgba(10, 13, 20, 0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        color: var(--accent, #4da3ff);
        border: 1px solid rgba(77, 163, 255, 0.35);
        border-radius: var(--r-sm, 6px);
        font-family: var(--mono);
        font-size: 0.75rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        text-decoration: none;
        white-space: nowrap;
        transition: top 0.2s cubic-bezier(0.16, 1, 0.3, 1), background-color 0.2s, border-color 0.2s;
      }
      .skip-link:focus-visible {
        top: 1rem;
        outline: 2px solid var(--accent, #4da3ff);
        outline-offset: 2px;
      }

      @keyframes focus-glow {
        0%, 100% {
          box-shadow: 0 0 4px rgba(77, 163, 255, 0.2);
        }
        50% {
          box-shadow: 0 0 12px rgba(77, 163, 255, 0.6);
        }
      }

      /* Keyboard accessibility: apply the focus-glow pulse to active focus states */
      :focus-visible {
        animation: focus-glow 2s infinite ease-in-out;
      }

      /* Nav links (SiteNav .sn-dest a, .sn-mark) */
      .sn-dest a:focus-visible,
      .sn-mark:focus-visible {
        outline: 2px solid var(--accent, #4da3ff);
        outline-offset: 3px;
        border-radius: 2px;
      }

      /* Nav icon buttons (stream-toggle, heatmap-toggle, field-toggle) */
      .sn-field-btn:focus-visible {
        outline: 2px solid var(--accent, #4da3ff);
        outline-offset: 2px;
      }

      /* Docs sidebar: Menu disclosure button, Search button, sidebar links */
      .docs-side-toggle:focus-visible,
      .docs-search-btn:focus-visible {
        outline: 2px solid var(--accent, #4da3ff);
        outline-offset: 2px;
        border-radius: var(--r-sm, 6px);
      }
      #docsSide a:focus-visible,
      #writingsSide a:focus-visible {
        outline: 2px solid var(--accent, #4da3ff);
        outline-offset: 2px;
        border-radius: 2px;
      }

      /* Docs field toggle (switch) */
      .docs-field-toggle:focus-visible {
        outline: 2px solid var(--accent, #4da3ff);
        outline-offset: 2px;
        border-radius: var(--r-sm, 6px);
      }

      /* General buttons (.btn covers CTA + ghost variants used in home/docs) */
      .btn:focus-visible {
        outline: 2px solid var(--accent, #4da3ff);
        outline-offset: 3px;
      }

      /* Home render-tour buttons and other pill/chip controls */
      .rt-modes button:focus-visible,
      .rt-readings button:focus-visible,
      .force-card:focus-visible {
        outline: 2px solid var(--accent, #4da3ff);
        outline-offset: 2px;
      }

      /* Breadcrumb + pagination links */
      .breadcrumb a:focus-visible,
      .docs-prevnext a:focus-visible {
        outline: 2px solid var(--accent, #4da3ff);
        outline-offset: 2px;
        border-radius: 2px;
      }

      /* Evidence/example sidebar links */
      .ev-side-item:focus-visible {
        outline: 2px solid var(--accent, #4da3ff);
        outline-offset: 2px;
        border-radius: var(--r-sm, 6px);
      }

      /* TOC links */
      #docsToc a:focus-visible {
        outline: 2px solid var(--accent, #4da3ff);
        outline-offset: 2px;
        border-radius: 2px;
      }
    </style>
  </body>
</html>
