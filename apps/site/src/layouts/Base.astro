---
import { ClientRouter } from 'astro:transitions';
// The design system's tokens are the single, global source of truth — load them
// on every page (the homepage and Lab included), not just the docs surfaces.
import '../styles/ds-tokens.css';
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}
const {
  title = 'field-ui — a reciprocal DOM-physics field',
  description = "field-ui — elements bend the field; the field's density bends them back. A medium your interface lives inside, not a backdrop it sits on.",
  ogImage = '/og.jpg',
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://field-ui.com').href;
const ogImageUrl = new URL(ogImage, Astro.site ?? 'https://field-ui.com').href;
---

<!doctype html>
<!-- transition:animate="none" disables the view-transition snapshot/cross-fade for
     the whole document. ClientRouter still does no-reload navigation, but with no
     animation the persisted <field-root> canvas keeps rendering live instead of
     being snapshotted (canvas snapshots come out blank → a flash). Content swaps
     instantly over one continuous, uninterrupted field. -->
<html lang="en" transition:animate="none">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <meta name="theme-color" content="#04050a" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="field-ui" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,300..800&family=Martian+Mono:wght@300..600&display=swap"
      rel="stylesheet"
    />
    <!-- client-side navigation: no full reload, so the field below runs continuously -->
    <ClientRouter />
  </head>
  <body>
    <!-- the CSS gradient is colour ambiance; the live <field-root> renders the
         particle field over it, reacting to [data-body] elements on the page.
         transition:persist keeps the engine running across client-side navigation —
         the field is one continuous medium, never reset between pages. -->
    <div class="field" aria-hidden="true" transition:persist></div>
    <field-root accent="#4da3ff" transition:persist></field-root>
    <div class="scrim" aria-hidden="true" transition:persist></div>
    <slot />

    <script>
      // registers <field-root> (the engine mounts on connect). Bundled by Astro,
      // so this runs once — the perfect place to wire the persisted field into the
      // navigation lifecycle. After each content swap, re-scan so the continuous
      // field reacts to the new page's [data-body] bodies (scan re-binds engagement).
      import '@field-ui/elements';
      document.addEventListener('astro:after-swap', () => {
        const field = document.querySelector('field-root') as
          | (HTMLElement & { rescan?: () => void; setFormation?: (n: string) => void })
          | null;
        field?.rescan?.();
        field?.setFormation?.('ambient'); // settle to the resting state on arrival
      });
    </script>

    <style is:global>
      /* Design tokens come from ds-tokens.css (imported above), the single source
         of truth. Only page-frame styles live here. */
      * {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        min-height: 100%;
      }
      body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--display);
        letter-spacing: -0.015em;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        min-height: 100svh;
        display: flex;
        flex-direction: column;
        align-items: center;
        overflow-x: hidden;
      }
      a {
        color: inherit;
      }
      .field {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background:
          radial-gradient(40vw 40vw at 18% 22%, rgba(77, 163, 255, 0.16), transparent 70%),
          radial-gradient(36vw 36vw at 82% 28%, rgba(167, 139, 250, 0.14), transparent 70%),
          radial-gradient(46vw 46vw at 70% 86%, rgba(45, 212, 191, 0.12), transparent 70%),
          radial-gradient(40vw 40vw at 24% 82%, rgba(255, 110, 156, 0.1), transparent 70%);
        filter: saturate(1.1);
        animation: drift 26s ease-in-out infinite alternate;
      }
      @keyframes drift {
        from {
          transform: translate3d(-2%, -1%, 0) scale(1.05);
        }
        to {
          transform: translate3d(2%, 1%, 0) scale(1.12);
        }
      }
      .scrim {
        position: fixed;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        background: radial-gradient(120% 80% at 50% -10%, transparent 55%, rgba(0, 0, 0, 0.55));
      }
      @media (prefers-reduced-motion: reduce) {
        .field {
          animation: none;
        }
      }
    </style>
  </body>
</html>
