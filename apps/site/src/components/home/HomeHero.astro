---
// The home hero — leads with the authoring contract (semantic HTML + data attributes),
// not the physics metaphor. The flow toggle and install-copy are wired by HomeRuntime.ts
// (looked up by id/selector), so this component is pure markup.
interface Props {
  /** number of forces in the catalog, shown in the meta row. */
  forcesCount: number;
}
const { forcesCount } = Astro.props;
---

<header class="manual-hero" id="top">
  <div class="wrap">
    <p class="kicker">field-ui · semantic HTML in one shared field</p>
    <h1>Semantic HTML can <span class="accent">participate.</span></h1>
    <p class="standfirst">
      Words, links, and cards stay ordinary semantic HTML — but with a single
      <code>data-*</code> attribute they register as participants in one shared
      field. The runtime measures each one — its gathered density, and metrics like
      attention, priority, and memory — then writes them back as <code>--field-*</code>
      CSS variables you style with. Here’s exactly how it works, live over the real
      engine behind every example.
    </p>
    <p class="thesis">
      <strong>You author meaning; the field returns measurement</strong> —
      <code>data-*</code> in, <code>--field-*</code> out. The physics is how it feels;
      the contract is how you use it.
    </p>
    <div class="hero-cta">
      <code class="install" data-copy="npm i @field-ui/elements">npm i @field-ui/elements</code>
      <a class="btn primary" href="/docs">Read the docs →</a>
      <a class="btn" href="/lab">Open the Lab →</a>
    </div>
    <div class="meta">
      <span><b>Contract</b> &nbsp;data-* in · --field-* out</span>
      <span
        ><b>Forces</b> &nbsp;{forcesCount}, composable · gated by conditions</span
      >
      <span
        ><b>Platform</b> &nbsp;measurement · state · feedback · relationships · overlays</span
      >
      <span><b>Law</b> &nbsp;nothing created from nothing</span>
    </div>
    <div class="hero-flow">
      <button id="flowToggle" class="flow-toggle" type="button" aria-pressed="false">
        <span class="ft-dot" aria-hidden="true"></span>Flow follows pointer
      </button>
      <span class="flow-hint"
        >drives <code>field.flowTo(x, y)</code> — the whole field bends to your cursor</span
      >
    </div>
  </div>
</header>
