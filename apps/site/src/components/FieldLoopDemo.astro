---
// A LIVE, deterministic demonstration of the core loop, built on the PRIMARY contract: data
// attributes on semantic HTML, driven by the recipe runtime (applyPattern). No <field-cell>, no
// canvas widget. The loop, made provable:
//
//   semantic element → [data-body] + supplied data-field-* → applyPattern() registers it →
//   the metric becomes --field-<metric> → the demo reflects it
//
// Each body carries a real runtime token (data-body) and a supplied metric value; applyPattern writes
// that metric back as a --field-* custom property. The reactive styling is applied inline from the
// value the FIELD wrote (read back after the tick), because Astro's scoped <style> rules do not reach
// set:html content and scoped calc(var()) is unreliable — inline styling renders everywhere. The text
// stays real and accessible; the value originates from the field, not from the markup.
interface Item {
  text: string;
  /** supplied metric value 0..1 (becomes --field-<metric>) */
  value: number;
  /** data-field-role — the element's semantic role */
  role?: string;
}
interface Props {
  items: Item[];
  /** the runtime token every body carries (any real token: attract, gravity, tether, …) */
  token?: string;
  /** the recipe whose metric lane drives the feedback var (must track `metric`) */
  recipe?: string;
  /** the metric these bodies supply + the recipe tracks (→ --field-<metric>) */
  metric?: string;
  /** the semantic tag the bodies live on */
  tag?: 'h3' | 'p' | 'li' | 'section';
}
const { items, token = 'attract', recipe = 'priority-well', metric = 'priority', tag = 'p' } = Astro.props;
const Tag = tag as any;
---

<figure class="field-loop" data-field-root data-recipe={recipe} data-metric={metric}>
  <div class="fl-bodies">
    {items.map((it) => (
      <Tag
        class="fl-body"
        data-body={token}
        data-field-role={it.role ?? 'concept'}
        data-field-strength={it.value}
        set:html={`<span class="fl-text">${it.text}</span><span class="fl-readout" aria-hidden="true">--field-${metric}: <b>${it.value.toFixed(2)}</b></span>`}
      />
    ))}
  </div>
  <figcaption>
    <span class="fl-loop">
      <code>data-body="{token}"</code> + supplied <code>{metric}</code> → <code>applyPattern()</code> →
      <code>--field-{metric}</code> → this element
    </span>
    <span class="fl-cap">Each row supplies a different value, so the field's feedback is visible at a glance — the readout shows what the field actually wrote back.</span>
  </figcaption>
</figure>

<script>
  import { applyPattern } from '@fundamental-engine/dom';
  import { patternById } from '@fundamental-engine/core';
  import { pageRuntime } from '../lib/page-runtime';

  // applyPattern registers bodies and a scoped platform per .field-loop and writes --field-* back.
  // pageRuntime owns the lifecycle: init on first load and every astro:page-load (the previous
  // run's teardown always runs first), teardown on astro:before-swap — so applied-recipe state
  // never accumulates across client-side navigation. One init handles EVERY .field-loop on the
  // page (the selector only gates whether there is at least one).
  pageRuntime('.field-loop[data-field-root]', () => {
    const applied: Array<{ destroy?: () => void }> = [];
    const reduced = typeof matchMedia !== 'undefined' && matchMedia('(prefers-reduced-motion: reduce)').matches;
    for (const root of document.querySelectorAll<HTMLElement>('.field-loop[data-field-root]')) {
      const recipe = patternById(root.dataset.recipe || 'priority-well');
      const metric = root.dataset.metric || 'priority';
      const bodies = [...root.querySelectorAll<HTMLElement>('.fl-body')];
      // the supplied value lives on data-field-strength for authoring clarity; applyPattern reads the
      // metric from data-field-<metric>, so mirror it across before applying.
      for (const b of bodies) {
        const v = b.getAttribute('data-field-strength');
        if (v != null) b.setAttribute(`data-field-${metric}`, v);
      }
      if (!recipe || !bodies.length) continue;
      // Deterministic: drive manually (drive:false) + tick to flush compute → state → write, so
      // --field-<metric> is written without depending on requestAnimationFrame (background tabs pause it).
      const a = applyPattern(root, recipe, { bodies, annotateBodies: false, drive: false, reducedMotion: reduced });
      a.tick();
      a.tick();
      applied.push(a);
      // Reflect the value the FIELD wrote, inline (the path that renders through Astro's scoping):
      // weight and presence rise with the metric, and the readout shows the field's actual value.
      for (const b of bodies) {
        const v = parseFloat(getComputedStyle(b).getPropertyValue(`--field-${metric}`)) || 0;
        const t = b.querySelector<HTMLElement>('.fl-text');
        if (t) t.style.fontWeight = String(Math.round(400 + v * 340));
        const ro = b.querySelector<HTMLElement>('.fl-readout');
        if (ro) ro.innerHTML = `--field-${metric}: <b>${v.toFixed(2)}</b>`;
      }
    }
    return () => {
      for (const a of applied) a.destroy?.();
    };
  });
</script>

<style>
  .field-loop {
    margin: 1.1rem 0;
    padding: 1.3rem 1.2rem;
    border: 1px solid var(--line, #2a2a35);
    border-radius: 12px;
    background: color-mix(in srgb, #0e121b 72%, transparent);
  }
  .fl-bodies { display: flex; flex-direction: column; gap: 0.55rem; }
  .fl-body {
    display: flex; align-items: baseline; justify-content: space-between; gap: 1rem;
    margin: 0; padding: 0.5rem 0.8rem; border-radius: 8px;
    border: 1px solid var(--line, #2a2a35);
    color: var(--text, #e8e8ef);
    transition: opacity 0.4s ease;
  }
  .fl-body :global(.fl-text) { font-size: 1.05rem; }
  .fl-body :global(.fl-readout) { font: 0.72rem ui-monospace, SFMono-Regular, monospace; color: var(--muted, #9aa); }
  .fl-body :global(.fl-readout b) { color: var(--accent, #4da3ff); }
  .field-loop figcaption { display: flex; flex-direction: column; gap: 0.25rem; margin-top: 0.9rem; }
  .fl-loop { font: 0.74rem ui-monospace, SFMono-Regular, monospace; color: var(--muted, #9aa); }
  .fl-loop code { color: var(--accent, #4da3ff); }
  .fl-cap { font-size: 0.8rem; color: var(--muted, #9aa); }
  @media (prefers-reduced-motion: reduce) { .fl-body { transition: none; } }
</style>
