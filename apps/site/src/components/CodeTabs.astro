---
// A highlighted, copyable code block. Pass one variant for a plain block, or
// several (vanilla / web component / react) to get framework tabs. Highlighting
// is Shiki at BUILD time via astro:components <Code/> — zero runtime JS ships;
// the only client work is tab-switch + copy, delegated from DocsLayout's script.
import { Code } from 'astro:components';

export interface CodeVariant {
  /** tab label — 'Vanilla', 'Web component', 'React', or a bare language name */
  label: string;
  /** Shiki language id — ts, js, tsx, html, css, bash, json … */
  lang: string;
  code: string;
}
interface Props {
  variants: CodeVariant[];
  /** optional caption under the block */
  caption?: string;
  /** Shiki theme — defaults to the site's night-owl */
  theme?: string;
}
const { variants, caption, theme = 'night-owl' } = Astro.props;
const multi = variants.length > 1;
---

<figure class="code-tabs" data-codetabs>
  <div class="ct-head">
    {
      multi ? (
        <div class="ct-tabs" role="tablist">
          {variants.map((v, i) => (
            <button
              type="button"
              class="ct-tab"
              data-i={i}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
            >
              {v.label}
            </button>
          ))}
        </div>
      ) : (
        <span class="ct-lang">{variants[0].label}</span>
      )
    }
    <button type="button" class="ct-copy" aria-label="Copy code to clipboard">
      <span class="ct-copy-label">Copy</span>
    </button>
  </div>
  <div class="ct-bodies">
    {
      variants.map((v, i) => (
        <div class="ct-body" data-i={i} role="tabpanel" hidden={i !== 0}>
          <Code code={v.code} lang={v.lang as any} theme={theme as any} />
        </div>
      ))
    }
  </div>
  {caption && <figcaption class="ct-caption" set:html={caption} />}
</figure>

<script>
  // Tab behavior lives with the component (module script — runs once, deduped across
  // instances and pages). Picking a framework tab switches every CodeTabs on the page
  // with that label, persists the choice, and reflects it as ?code=<slug> in the URL,
  // so docs links can deep-link a framework. Restored on every page-load. The copy
  // button stays in the page layouts' delegated handlers.
  import {
    slugifyLabel,
    applyCodeTab,
    rememberCodeTab,
    restoreCodeTab,
  } from "../lib/codetabs-state.ts";

  document.addEventListener("click", (e) => {
    const t = e.target as HTMLElement | null;
    const tab = t?.closest?.(".ct-tab") as HTMLElement | null;
    if (tab) {
      const slug = slugifyLabel(tab.textContent || "");
      applyCodeTab(slug); // switches the clicked instance + every label-matched sibling
      rememberCodeTab(slug); // framework tabs only — language tabs stay per-page
      return;
    }
    // copy the active panel — owned here so CodeTabs works on any page, not just
    // the layouts that used to provide a delegated handler.
    const copy = t?.closest?.(".ct-copy") as HTMLElement | null;
    if (!copy) return;
    const wrap = copy.closest(".code-tabs");
    const body = wrap?.querySelector(".ct-body:not([hidden])") as HTMLElement | null;
    const text = body ? body.innerText : "";
    if (!navigator.clipboard || !text) return;
    navigator.clipboard.writeText(text).then(() => {
      copy.classList.add("copied");
      const lbl = copy.querySelector(".ct-copy-label");
      const prev = lbl?.textContent ?? "Copy";
      if (lbl) lbl.textContent = "Copied";
      setTimeout(() => {
        copy.classList.remove("copied");
        if (lbl) lbl.textContent = prev;
      }, 1100);
    });
  });

  document.addEventListener("astro:page-load", restoreCodeTab);
  if (document.readyState !== "loading") restoreCodeTab();
  else document.addEventListener("DOMContentLoaded", restoreCodeTab);
</script>

<!-- Styles travel with the component (is:global) so CodeTabs renders identically on ANY page —
     the docs/evidence pages and the Base-layout recipe pages alike — not just where docs.css loads. -->
<style is:global>
  .code-tabs {
    margin: 1rem 0 0;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: var(--bg-canvas, #07090e);
    overflow: hidden;
  }
  .code-tabs .ct-head {
    display: flex;
    align-items: stretch;
    justify-content: space-between;
    gap: 0.5rem;
    border-bottom: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.02);
  }
  .code-tabs .ct-tabs {
    display: flex;
    flex-wrap: wrap;
  }
  .code-tabs .ct-tab {
    appearance: none;
    background: transparent;
    border: 0;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    padding: 0.55rem 0.95rem;
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-3);
    cursor: pointer;
    transition:
      color 0.18s,
      border-color 0.18s;
  }
  .code-tabs .ct-tab:hover {
    color: var(--text-2);
  }
  .code-tabs .ct-tab[aria-selected='true'] {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  .code-tabs .ct-lang {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 0.95rem;
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-4);
  }
  .code-tabs .ct-copy {
    appearance: none;
    align-self: center;
    margin: 0 0.5rem 0 0;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--line-2);
    border-radius: 6px;
    padding: 0.3rem 0.6rem;
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-3);
    cursor: copy;
    transition:
      color 0.18s,
      border-color 0.18s,
      background 0.18s;
  }
  .code-tabs .ct-copy:hover {
    color: var(--text);
    border-color: var(--accent);
  }
  .code-tabs .ct-copy.copied {
    color: var(--ok);
    border-color: var(--ok);
  }
  .code-tabs .ct-body[hidden] {
    display: none;
  }
  /* Shiki sets its own bg + inline span colors; strip the bg so the panel shows
     through and the block matches the site's --bg-canvas. */
  .code-tabs pre.astro-code,
  .code-tabs pre.astro-code code {
    margin: 0;
    background: transparent !important;
    font-family: var(--mono);
    font-size: 0.8rem;
    line-height: 1.7;
    tab-size: 2;
  }
  .code-tabs pre.astro-code {
    padding: 1rem 1.15rem;
    overflow-x: auto;
  }
  .code-tabs .ct-caption {
    padding: 0.55rem 1.15rem 0.7rem;
    border-top: 1px solid var(--line);
    font-size: 0.82rem;
    color: var(--text-3);
  }
  .code-tabs .ct-caption code {
    font-family: var(--mono);
    font-size: 0.92em;
    color: var(--text-2);
  }
</style>
