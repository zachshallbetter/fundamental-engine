---
// The shared site navigation — one fixed top bar on every public page. The wordmark
// links home (the Field Manual). Position-fixed so it sits out of flow and never
// disturbs a page's own layout.
// (GitHub + npm links are added at launch, once the repo is public and packages ship.)
import { currentVersion } from '../lib/changelog';
interface Props {
  current?: 'home' | 'docs' | 'tour' | 'lab' | 'examples' | 'writings' | 'use-cases' | 'recipes';
  /** when false, the nav is not fixed — it sits at the top and scrolls away with the page
   *  (for content-dense pages where a pinned translucent nav over the scroll reads as noise). */
  sticky?: boolean;
}
const { current, sticky = true } = Astro.props;
const version = currentVersion();
const dest = [
  { href: '/docs', label: 'Docs', key: 'docs' },
  { href: '/engine-tour', label: 'Tour', key: 'tour' },
  { href: '/use-cases', label: 'Use Cases', key: 'use-cases' },
  // Examples tab hidden for the time being — /examples page still exists, just unlinked from the header.
  { href: '/recipes', label: 'Recipes', key: 'recipes' },
  { href: '/evidence', label: 'Evidence', key: 'evidence' },
  { href: '/writings', label: 'Writings', key: 'writings' },
  { href: '/lab', label: 'Lab', key: 'lab' },
] as const;
---

<header class={`site-nav${sticky ? '' : ' is-flow'}`}>
  <div class="sn-inner">
    <a
      class="sn-mark"
      href="/"
      aria-label="Fundamental — home"
      aria-current={current === 'home' ? 'page' : undefined}
    >
      <svg viewBox="0 0 441 421" aria-hidden="true">
        <g fill="none" stroke="currentColor" stroke-width="22" stroke-linecap="round">
          <circle cx="230" cy="211" r="89"></circle>
          <path d="M393 327c30-50 36-130-20-180-44-40-110-40-160-10"></path>
          <circle cx="370" cy="355" r="34"></circle>
          <circle cx="45" cy="286" r="34"></circle>
          <path d="M62 318c44 70 128 105 209 88"></path>
        </g>
        <circle cx="139" cy="315" r="16" fill="currentColor"></circle>
        <circle cx="92" cy="66" r="22" fill="currentColor"></circle>
      </svg>
      <span class="sn-name">Fundamental</span>
    </a>
    <a class="sn-version" href="/changelog" title={`What's new — v${version}`}>v{version}</a>
    <nav class="sn-dest" aria-label="Primary">
      {
        dest.map((d) => (
          <a
            href={d.href}
            aria-current={current === d.key ? 'page' : undefined}
            data-field-attention={current === d.key ? '1' : undefined}
          >
            {d.label}
          </a>
        ))
      }
      <span class="sn-toggles">
        {/* Global field flow — switch the whole background field between particles and streamline arrows */}
        <button
          id="sn-stream-toggle"
          class="sn-field-btn"
          type="button"
          aria-label="Toggle field-flow arrows"
          title="Show field flow"
          aria-pressed="false"
        >
          <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M1 4.5 Q5 2.5 9 4.5 T15 4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
            <path d="M1 8 Q5 6 9 8 T15 8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
            <path d="M1 11.5 Q5 9.5 9 11.5 T15 11.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
            <polyline points="13,6.5 15,8 13,9.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" fill="none" />
          </svg>
        </button>
        {/* Density heatmap — a glow underlay of where matter pools, sampled back to bodies */}
        <button
          id="sn-heatmap-toggle"
          class="sn-field-btn"
          type="button"
          aria-label="Toggle density heatmap"
          title="Show density heatmap"
          aria-pressed="false"
        >
          <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="2.2" fill="currentColor" />
            <circle cx="8" cy="8" r="4.2" stroke="currentColor" stroke-width="1.2" opacity="0.6" />
            <circle cx="8" cy="8" r="6.3" stroke="currentColor" stroke-width="1" opacity="0.35" />
          </svg>
        </button>
        {/* Field grid — the reference lattice displaced by the field: deformation around mass */}
        <button
          id="sn-grid-toggle"
          class="sn-field-btn"
          type="button"
          aria-label="Toggle field grid"
          title="Show field grid"
          aria-pressed="false"
        >
          <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M1 5.5 Q8 3.6 15 5.5 M1 10.5 Q8 12.4 15 10.5 M5.5 1 Q3.6 8 5.5 15 M10.5 1 Q12.4 8 10.5 15" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" opacity="0.85" />
          </svg>
        </button>
        {/* Per-stage field lines (home): show/hide the traced overlays */}
        {
          current === 'home' && (
            <button
              id="sn-field-toggle"
              class="sn-field-btn"
              type="button"
              aria-label="Toggle field lines"
              title="Hide field lines"
              aria-pressed="true"
            >
              <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <circle cx="8" cy="8" r="1.7" fill="currentColor" />
                <path d="M8 2.4 A5.6 5.6 0 0 1 13.6 8" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" />
                <polyline points="11.8,6.2 13.6,8 11.7,9.4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" fill="none" />
                <path d="M8 13.6 A5.6 5.6 0 0 1 2.4 8" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" />
                <polyline points="4.2,9.8 2.4,8 4.3,6.6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" fill="none" />
              </svg>
            </button>
          )
        }

      </span>
    </nav>
  </div>
</header>

<script>
  // Field toggles — three buttons drive the persisted <field-root>:
  //   1. Flow: additive streamline overlay (on/off via setOverlay — particles always stay)
  //   2. Heatmap: density glow underlay
  //   3. Field lines: per-stage traced overlays (home page only)
  //
  // The field-root survives client-side navigation (transition:persist) while the nav
  // buttons are re-rendered fresh on every page — so the source of truth is the
  // persisted field-root element itself (data-nav-flow / data-nav-heatmap), and the
  // freshly rendered buttons re-sync from the field's real state on every astro:page-load.

  type FieldEl = HTMLElement & {
    setRender?: (m: string) => void;
    setOverlay?: (m: string | string[]) => void;
    setHeatmap?: (on: boolean) => void;
  };
  const fieldEl = () => document.querySelector('field-root') as FieldEl | null;

  // Overlays are an ADDITIVE stack (the engine composes them), so flow + grid coexist. Compose the
  // surface from each overlay toggle's persisted state on the field rather than letting one replace
  // the other.
  function applyOverlays() {
    const field = fieldEl();
    if (!field) return;
    const stack: string[] = [];
    if (field.dataset.navFlow === 'on') stack.push('streamlines');
    if (field.dataset.navGrid === 'on') stack.push('grid');
    field.setOverlay?.(stack.length ? stack : 'off');
  }



  // 1) Global field flow: additive streamline overlay, read back from the persisted field.
  function syncStreamBtn() {
    const btn = document.getElementById('sn-stream-toggle');
    if (!btn) return;
    const on = fieldEl()?.dataset.navFlow === 'on';
    btn.setAttribute('aria-pressed', String(on));
    btn.title = on ? 'Hide field flow' : 'Show field flow';
  }
  // 1b) Field grid: the deformation lattice overlay, read back from the persisted field.
  function syncGridBtn() {
    const btn = document.getElementById('sn-grid-toggle');
    if (!btn) return;
    const on = fieldEl()?.dataset.navGrid === 'on';
    btn.setAttribute('aria-pressed', String(on));
    btn.title = on ? 'Hide field grid' : 'Show field grid';
  }
  // 2) Density heatmap: the glow underlay, read back from the persisted field.
  function syncHeatmapBtn() {
    const btn = document.getElementById('sn-heatmap-toggle');
    if (!btn) return;
    const on = fieldEl()?.dataset.navHeatmap === 'on';
    btn.setAttribute('aria-pressed', String(on));
    btn.title = on ? 'Hide density heatmap' : 'Show density heatmap';
  }
  // 3) Per-stage field lines (home): show/hide the traced overlays.
  function syncFieldBtn() {
    const btn = document.getElementById('sn-field-toggle');
    if (!btn) return;
    const shown = !document.documentElement.classList.contains('hide-field-lines');
    btn.setAttribute('aria-pressed', String(shown));
    btn.title = shown ? 'Hide field lines' : 'Show field lines';
  }


  document.addEventListener('click', (e) => {
    const t = e.target as HTMLElement | null;
    if (!t) return;
    if (t.closest('#sn-stream-toggle')) {
      const field = fieldEl();
      const next = field?.dataset.navFlow !== 'on';
      if (field) field.dataset.navFlow = next ? 'on' : 'off';
      applyOverlays(); // recompose the additive stack (flow + grid coexist)
      syncStreamBtn();
    } else if (t.closest('#sn-grid-toggle')) {
      const field = fieldEl();
      const next = field?.dataset.navGrid !== 'on';
      if (field) field.dataset.navGrid = next ? 'on' : 'off';
      applyOverlays();
      syncGridBtn();
    } else if (t.closest('#sn-heatmap-toggle')) {
      const field = fieldEl();
      const next = field?.dataset.navHeatmap !== 'on';
      field?.setHeatmap?.(next);
      if (field) field.dataset.navHeatmap = next ? 'on' : 'off';
      syncHeatmapBtn();
    } else if (t.closest('#sn-field-toggle')) {
      document.documentElement.classList.toggle('hide-field-lines');
      syncFieldBtn();
    }
  });

  function syncAll() {
    syncStreamBtn();
    syncGridBtn();
    syncHeatmapBtn();
    syncFieldBtn();
  }
  document.addEventListener('astro:page-load', syncAll);
  syncAll();
</script>

<script>
  // The Wayfinding Field (recipe `wayfinding-field`, experimental) — the invisible-fields family
  // applied to the nav's own chrome. The engine runs SIGNALS-ONLY (render: []): the metric pipeline
  // measures each destination's engagement + visibility and writes `--field-attention` back onto the
  // link every frame; the current route is pinned as the well via data-field-attention="1" in the
  // markup. Nothing is drawn — the only output is a CSS custom property the styles below consume.
  //
  // Progressive enhancement: with the engine off, the import skipped (reduced motion), or before it
  // loads, `--field-attention` is simply unset → the links render exactly as plain chrome. The engine
  // is lazy-imported so non-interactive / reduced-motion visitors never download it for the nav.
  let navField: { destroy(): void } | null = null;
  let navGen = 0;
  const navReduceMotion = () =>
    typeof matchMedia !== 'undefined' && matchMedia('(prefers-reduced-motion: reduce)').matches;

  async function startNavField() {
    const mine = ++navGen;
    navField?.destroy();
    navField = null;
    if (navReduceMotion() || document.documentElement.dataset.field === 'off') return; // the one field switch
    const nav = document.querySelector<HTMLElement>('.sn-dest');
    const links = nav ? [...nav.querySelectorAll<HTMLElement>('a')] : [];
    if (!nav || !links.length) return;
    try {
      const [{ recipeById }, { applyPattern }] = await Promise.all([
        import('@fundamental-engine/core'),
        import('@fundamental-engine/dom'),
      ]);
      if (mine !== navGen) return; // a newer start / a teardown superseded this async boot
      const base = recipeById('wayfinding-field');
      if (!base) return;
      navField = applyPattern(nav, base, {
        renderless: true,
        bodies: links,
        annotateBodies: false, // don't write data-body — keep these out of the global field-root scan
      });
    } catch {
      /* the plain-link nav stands on its own */
    }
  }
  function stopNavField() {
    navGen++;
    navField?.destroy();
    navField = null;
  }

  document.addEventListener('astro:page-load', startNavField);
  document.addEventListener('astro:before-swap', stopNavField);
  if (document.readyState !== 'loading') startNavField();
  else document.addEventListener('DOMContentLoaded', startNavField);
</script>

<style>
  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 60;
    display: flex;
    justify-content: center;
    /* No panel: the nav sits directly over the field. A whisper-thin top scrim keeps the links
       legible against bright particles/grid without reading as a bar (no blur, no border). */
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, var(--bg, #04050a) 38%, transparent),
      transparent 90%
    );
  }
  /* Non-pinned variant (sticky={false}): absolute, so it stays at the document top and scrolls
     away with the page — out of flow, so pages keep the same top spacing as the fixed nav. */
  .site-nav.is-flow { position: absolute; }
  .sn-inner {
    width: 100%;
    /* align the wordmark + links with the page content column (--content-max) so the nav
       doesn't sprawl wider than the body it sits over. */
    max-width: var(--content-max);
    height: 58px;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 0 clamp(1rem, 4vw, 2.5rem);
  }
  .sn-mark {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--text, #f3f6fc);
  }
  .sn-mark svg {
    width: 20px;
    height: 20px;
    color: var(--accent, #4da3ff);
    flex: none;
  }
  .sn-name {
    font-family: var(--display);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: -0.02em;
  }
  .sn-dim {
    color: var(--text-3, rgba(200, 212, 230, 0.46));
    font-weight: 600;
  }
  .sn-version {
    align-self: center;
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    color: var(--text-3, rgba(200, 212, 230, 0.55));
    text-decoration: none;
    padding: 0.12rem 0.45rem;
    border: 1px solid var(--line);
    border-radius: var(--r-pill, 999px);
    transition: color 140ms var(--ease, ease), border-color 140ms var(--ease, ease);
  }
  .sn-version:hover {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 50%, transparent);
  }
  .sn-dest {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2.4vw, 1.6rem);
  }
  .sn-dest a {
    /* Wayfinding Field (signals-only): the engine writes --field-attention (0..1, eased per frame)
       onto each link from its engagement + visibility; the current route is pinned to 1. Absent
       (engine off / reduced motion / pre-boot) it resolves to 0 → the plain chrome below. */
    --att: var(--field-attention, 0);
    position: relative;
    font-family: var(--mono);
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: color-mix(
      in srgb,
      var(--text, #f3f6fc) calc(var(--att) * 100%),
      var(--text-3, rgba(200, 212, 230, 0.46))
    );
    text-shadow: 0 0 calc(var(--att) * 9px)
      color-mix(in srgb, var(--accent, #4da3ff) calc(var(--att) * 55%), transparent);
    text-decoration: none;
    padding: 0.2rem 0;
    transition: color 0.2s ease, text-shadow 0.2s ease;
  }
  .sn-dest a:hover {
    color: var(--text, #f3f6fc);
  }
  .sn-dest a[aria-current='page'] {
    color: var(--accent, #4da3ff);
  }
  .sn-dest a[aria-current='page']::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -3px;
    height: 1px;
    background: var(--accent, #4da3ff);
    box-shadow: 0 0 8px var(--accent, #4da3ff);
  }
  .sn-toggles {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .sn-field-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    padding: 0;
    border: 1px solid var(--line, rgba(255, 255, 255, 0.12));
    border-radius: 6px;
    background: transparent;
    color: var(--text-3, rgba(200, 212, 230, 0.46));
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
    flex: none;
  }
  .sn-field-btn svg {
    width: 14px;
    height: 14px;
  }
  .sn-field-btn:hover {
    color: var(--text, #f3f6fc);
    border-color: rgba(255, 255, 255, 0.24);
  }
  .sn-field-btn[aria-pressed='true'] {
    color: var(--accent, #4da3ff);
    border-color: var(--accent, #4da3ff);
    background: color-mix(in srgb, var(--accent, #4da3ff) 10%, transparent);
  }

  /* narrow viewports: the destinations become a scrollable strip (the field toggles are
     desktop affordances — the persisted field keeps its state either way). */
  @media (max-width: 720px) {
    .sn-inner {
      gap: 0.9rem;
      height: 54px;
      padding: 0 1rem;
    }
    .sn-dest {
      overflow-x: auto;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
      gap: 1rem;
      padding-right: 1.25rem;
      mask-image: linear-gradient(to right, black 88%, transparent);
      -webkit-mask-image: linear-gradient(to right, black 88%, transparent);
    }
    .sn-dest::-webkit-scrollbar {
      display: none;
    }
    .sn-dest a {
      flex: none;
    }
    .sn-toggles {
      display: none;
    }
  }

  /* very narrow viewports (<420px): hide the version pill so the wordmark + scrollable
     strip fit without the inner row itself overflowing. */
  @media (max-width: 420px) {
    .sn-version {
      display: none;
    }
    .sn-inner {
      gap: 0.6rem;
      padding: 0 0.75rem;
    }
  }
</style>
