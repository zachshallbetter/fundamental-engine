---
// A design-system button/link. Renders an <a> when `href` is set, otherwise a <button>.
// Emits the manual.css `.btn` / `.btn.primary` / `.btn.ghost` classes — customize on declaration.
//
// Mass by default: a button is a focal control, so it's a body — `attract` (a designed UI well)
// that gathers the page field's matter, engaged on hover/focus (data-hot) and reporting its own
// gathered density back (data-feedback → --d). The field thesis applied to its own controls.
// Pass mass={false} to opt a button out; any explicit data-* on the instance overrides (rest is
// spread last).
interface Props {
  href?: string;
  variant?: "primary" | "ghost";
  class?: string;
  /** participate in the page field as an `attract` body (default true). */
  mass?: boolean;
  [key: string]: unknown;
}
const { href, variant, class: cls, mass = true, ...rest } = Astro.props;
const className = ["btn", variant, cls].filter(Boolean).join(" ");
// a gentle local well — modest range so buttons are focal points, not page-dominating attractors.
const bodyAttrs = mass
  ? { "data-body": "attract", "data-hot": "", "data-feedback": "", "data-strength": "0.6", "data-range": "150" }
  : {};
---

{
  href ? (
    <a class={className} href={href} {...bodyAttrs} {...rest}>
      <slot />
    </a>
  ) : (
    <button class={className} type="button" {...bodyAttrs} {...rest}>
      <slot />
    </button>
  )
}
