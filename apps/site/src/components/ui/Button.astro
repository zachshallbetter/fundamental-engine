---
// A design-system button/link. Renders an <a> when `href` is set, otherwise a <button>.
// Emits the manual.css `.btn` / `.btn.primary` / `.btn.ghost` classes ŌĆö customize on declaration.
//
// Mass by default: a button is a focal control, so it's a body ŌĆö a `sink attract` VESSEL. attract
// gathers the page field's matter, sink captures it. The vessel is ATTENTION-GATED (`data-when="active"`):
// it stays inert at rest and only acts while engaged (hover/focus via data-hot), so the control absorbs
// matter as you reach for it and RELEASES it in a burst when attention leaves (the engine's
// `dischargeDisengaged` supernova) ŌĆö absorb-and-release on interaction, not a permanent resting
// accretion. It reports its load/density back (data-feedback ŌåÆ --d / --load ŌåÆ the charge glow).
// `data-shaped` makes the forces reference the button's BOX, not its centre, so matter gathers in a
// shell around the control. The field thesis applied to its own controls ŌĆö driven purely by data-*
// attributes (the public body contract), the way any consumer would.
// Pass mass={false} to opt out; any explicit data-* on the instance overrides (rest is spread last).
interface Props {
  href?: string;
  variant?: "primary" | "ghost";
  class?: string;
  /** participate in the page field as a `sink attract` vessel (default true). */
  mass?: boolean;
  [key: string]: unknown;
}
const { href, variant, class: cls, mass = true, ...rest } = Astro.props;
const className = ["btn", variant, cls].filter(Boolean).join(" ");
// a shaped vessel: attract gathers matter around the box, sink absorbs it; modest range so the
// button is a local well, and data-shaped keeps the gathering off-centre (the button's outline,
// not a hot dot at its middle).
const bodyAttrs = mass
  ? {
      "data-body": "sink attract",
      "data-shaped": "",
      "data-hot": "",
      "data-feedback": "",
      // attention-gated: only gathers/captures while engaged (hover/focus), so the button is calm
      // at rest and absorbs as you reach for it. On the falling edge of engagement the sink
      // discharges what it captured in a burst (dischargeDisengaged) ŌĆö absorb on hover, release on
      // leave. A modest capacity keeps the accreted matter reading as a high --load (a visible
      // charge glow) within a single hover.
      "data-when": "active",
      "data-strength": "0.8",
      "data-range": "175",
      "data-absorb": "95",
      "data-max": "40",
    }
  : {};
---

{
  href ? (
    <a class={className} href={href} {...bodyAttrs} {...rest}>
      <slot />
    </a>
  ) : (
    <button class={className} type="button" {...bodyAttrs} {...rest}>
      <slot />
    </button>
  )
}
