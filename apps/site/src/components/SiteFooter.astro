---
// The shared site footer — one consistent close on every public page: the
// wordmark + thesis line, the destinations, and contact.
import corePkg from '@fundamental-engine/core/package.json';
const version = corePkg.version; // single source of truth — never goes stale
const dest = [
  { href: '/docs', label: 'Docs' },
  { href: '/lab', label: 'Lab' },
  { href: 'mailto:hi@zachshallbetter.com', label: 'Contact' },
];
---

<footer class="site-foot">
  <div class="sf-inner">
    <div class="sf-brand">
      <span class="sf-name">Fundamental</span>
      <span class="sf-note">A readable behavior layer for host objects · v{version} · Created by <a href="https://zachshallbetter.com" target="_blank" rel="noopener noreferrer" class="sf-author">Zach Shallbetter</a></span>
    </div>
    <nav class="sf-links" aria-label="Footer">
      {dest.map((d) => <a href={d.href}>{d.label}</a>)}
    </nav>
  </div>
</footer>

<script>
  // A light Wayfinding Field over the footer destinations — same signals-only pattern as the top
  // nav: the engine writes --field-attention back onto each link (the current section pinned),
  // lazy-imported and reduced-motion-guarded so it costs nothing for plain/RM visitors.
  let footField: { destroy(): void } | null = null;
  let footGen = 0;
  const footReduce = () =>
    typeof matchMedia !== 'undefined' && matchMedia('(prefers-reduced-motion: reduce)').matches;

  async function startFootField() {
    const mine = ++footGen;
    footField?.destroy();
    footField = null;
    if (footReduce() || document.documentElement.dataset.field === 'off') return; // the one field switch
    const nav = document.querySelector<HTMLElement>('.sf-links');
    const links = nav ? [...nav.querySelectorAll<HTMLElement>('a[href^="/"]')] : [];
    if (!nav || !links.length) return;
    // pin the current section's footer link as the well
    const here = location.pathname.replace(/\/$/, '') || '/';
    for (const a of links) {
      const r = (a.getAttribute('href') || '').replace(/\/$/, '') || '/';
      if (r === here || (r !== '/' && here.startsWith(`${r}/`))) a.setAttribute('data-field-attention', '1');
    }
    try {
      const [{ recipeById }, { applyPattern }] = await Promise.all([
        import('@fundamental-engine/core'),
        import('@fundamental-engine/dom'),
      ]);
      if (mine !== footGen) return;
      const base = recipeById('wayfinding-field');
      if (!base) return;
      footField = applyPattern(nav, base, {
        renderless: true,
        bodies: links,
        annotateBodies: false,
      });
    } catch {
      /* the plain footer links stand on their own */
    }
  }
  function stopFootField() {
    footGen++;
    footField?.destroy();
    footField = null;
  }
  document.addEventListener('astro:page-load', startFootField);
  document.addEventListener('astro:before-swap', stopFootField);
  if (document.readyState !== 'loading') startFootField();
  else document.addEventListener('DOMContentLoaded', startFootField);
</script>

<style>
  .site-foot {
    position: relative;
    z-index: 2;
    width: 100%;
    margin-top: auto;
    border-top: 1px solid var(--line, rgba(255, 255, 255, 0.1));
  }
  .sf-inner {
    max-width: 1360px;
    margin: 0 auto;
    padding: clamp(1.6rem, 4vh, 2.4rem) clamp(1.25rem, 3vw, 2.75rem);
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem 1.6rem;
  }
  .sf-brand {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .sf-name {
    font-family: var(--display);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: -0.02em;
    color: var(--text, #f3f6fc);
  }
  .sf-dim {
    color: var(--text-3, rgba(200, 212, 230, 0.46));
    font-weight: 600;
  }
  .sf-note {
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-3, rgba(200, 212, 230, 0.46));
  }
  .sf-author {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s ease;
  }
  .sf-author:hover {
    color: var(--accent, #4da3ff);
  }
  .sf-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.4rem;
  }
  .sf-links a {
    /* Wayfinding Field (signals-only): --field-attention eases ink + glow; unset → plain. */
    --att: var(--field-attention, 0);
    font-family: var(--mono);
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: color-mix(
      in srgb,
      var(--text, #f3f6fc) calc(var(--att) * 80%),
      var(--text-3, rgba(200, 212, 230, 0.46))
    );
    text-shadow: 0 0 calc(var(--att) * 8px)
      color-mix(in srgb, var(--accent, #4da3ff) calc(var(--att) * 50%), transparent);
    text-decoration: none;
    transition:
      color 0.2s ease,
      text-shadow 0.2s ease;
  }
  .sf-links a:hover {
    color: var(--accent, #4da3ff);
  }
</style>
