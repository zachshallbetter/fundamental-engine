{
  "name": "field-ui-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.1",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "check:dist": "node scripts/check-dist.mjs",
    "check:api": "tsc -p scripts/tsconfig.api.json --noEmit && node scripts/check-api-surface.mjs",
    "dev": "pnpm --filter @field-ui/site dev",
    "build:site": "pnpm --filter @field-ui/site build",
    "docs:dev": "pnpm --filter @field-ui/docs dev",
    "docs:build": "pnpm --filter @field-ui/docs build"
  }
}