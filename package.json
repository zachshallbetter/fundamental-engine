{
  "name": "fundamental-engine-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.1",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "check:dist": "node scripts/check-dist.mjs",
    "check:packaging": "node scripts/check-packaging.mjs",
    "check:api": "tsc -p scripts/tsconfig.api.json --noEmit && node scripts/check-api-surface.mjs",
    "check:readme": "node scripts/check-readme.mjs",
    "check:links": "node scripts/check-doc-links.mjs",
    "gen:recipes": "node --experimental-strip-types scripts/export-recipes.mjs",
    "check:recipes": "node --experimental-strip-types scripts/export-recipes.mjs && git diff --exit-code data/recipes.json",
    "gen:cem": "pnpm --filter @fundamental-engine/elements exec cem analyze",
    "check:cem": "pnpm gen:cem && git diff --exit-code packages/elements/custom-elements.json",
    "gen:golden": "node --experimental-strip-types scripts/gen-conformance-golden.mjs",
    "check:golden": "pnpm gen:golden && git diff --exit-code swift/Tests/FundamentalCoreTests/Fixtures/conformance-golden.json",
    "gen:atoms": "node scripts/gen-atoms.mjs > apps/site/src/data/atoms.json",
    "check:atoms": "node scripts/gen-atoms.mjs > apps/site/src/data/atoms.json && git diff --exit-code apps/site/src/data/atoms.json",
    "dev": "pnpm --filter @fundamental-engine/site dev",
    "build:site": "pnpm --filter @fundamental-engine/site build",
    "docs:dev": "pnpm --filter @fundamental-engine/docs dev",
    "docs:build": "pnpm --filter @fundamental-engine/docs build"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.0",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "publint": "^0.3.12"
  }
}