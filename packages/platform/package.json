{
  "name": "@fundamental-engine/platform",
  "version": "0.9.0",
  "description": "DEPRECATED — renamed to @fundamental-engine/dom. A thin alias that re-exports it so existing installs keep working; switch your imports to @fundamental-engine/dom.",
  "type": "module",
  "license": "MIT",
  "author": "Zach Shallbetter <hi@zachshallbetter.com> (https://zachshallbetter.com)",
  "homepage": "https://fundamental-engine.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zachshallbetter/fundamental-engine.git",
    "directory": "packages/platform"
  },
  "bugs": {
    "url": "https://github.com/zachshallbetter/fundamental-engine/issues"
  },
  "keywords": [
    "Fundamental",
    "deprecated"
  ],
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test"
  },
  "dependencies": {
    "@fundamental-engine/dom": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
