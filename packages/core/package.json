{
  "name": "@fundamental-engine/core",
  "version": "0.9.4",
  "description": "A reciprocal DOM-physics field — elements bend the field; the field's density bends them back.",
  "type": "module",
  "license": "MIT",
  "author": "Zach Shallbetter <hi@zachshallbetter.com> (https://zachshallbetter.com)",
  "homepage": "https://fundamental-engine.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zachshallbetter/fundamental-engine.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/zachshallbetter/fundamental-engine/issues"
  },
  "keywords": [
    "particles",
    "physics",
    "canvas",
    "forces",
    "field",
    "reciprocal",
    "dom",
    "animation",
    "interaction",
    "generative",
    "zero-dependency"
  ],
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test",
    "bench": "node bench/field-bench.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3"
  }
}
