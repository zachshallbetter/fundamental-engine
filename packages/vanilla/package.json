{
  "name": "@fundamental-engine/vanilla",
  "version": "0.9.5",
  "description": "Framework-free TypeScript wrapper for Fundamental — the reciprocal DOM-physics field as a typed FieldField class + mountField(), with no custom-element registration and no framework dependency.",
  "type": "module",
  "license": "MIT",
  "author": "Zach Shallbetter <hi@zachshallbetter.com> (https://zachshallbetter.com)",
  "homepage": "https://fundamental-engine.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zachshallbetter/fundamental-engine.git",
    "directory": "packages/vanilla"
  },
  "bugs": {
    "url": "https://github.com/zachshallbetter/fundamental-engine/issues"
  },
  "keywords": [
    "Fundamental",
    "typescript",
    "vanilla",
    "particles",
    "physics",
    "canvas",
    "field",
    "reciprocal",
    "dom"
  ],
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./standalone": {
      "types": "./dist/index.d.ts",
      "import": "./dist/standalone.js"
    },
    "./standalone.global.js": "./dist/standalone.global.js",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/build-standalone.mjs",
    "build:standalone": "node scripts/build-standalone.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test"
  },
  "dependencies": {
    "@fundamental-engine/dom": "workspace:*",
    "@fundamental-engine/core": "workspace:*"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.9.3"
  }
}
