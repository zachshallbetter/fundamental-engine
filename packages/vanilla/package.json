{
  "name": "@field-ui/vanilla",
  "version": "0.2.0",
  "description": "Framework-free TypeScript wrapper for forces-ui — the reciprocal DOM-physics field as a typed ForcesField class + mountField(), with no custom-element registration and no framework dependency.",
  "type": "module",
  "license": "MIT",
  "author": "Zach Shallbetter <hi@zachshallbetter.com> (https://zachshallbetter.com)",
  "homepage": "https://field-ui.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zachshallbetter/forces-ui.git",
    "directory": "packages/vanilla"
  },
  "bugs": {
    "url": "https://github.com/zachshallbetter/forces-ui/issues"
  },
  "keywords": [
    "field-ui",
    "typescript",
    "vanilla",
    "particles",
    "physics",
    "canvas",
    "field",
    "reciprocal",
    "dom"
  ],
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test"
  },
  "dependencies": {
    "field-ui": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
