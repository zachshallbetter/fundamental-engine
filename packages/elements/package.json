{
  "name": "@field-ui/elements",
  "version": "0.2.2",
  "description": "Web-component keystone for field-ui — the <forces-field> custom element + declarative data-body bodies.",
  "type": "module",
  "license": "MIT",
  "author": "Zach Shallbetter <hi@zachshallbetter.com> (https://zachshallbetter.com)",
  "homepage": "https://field-ui.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zachshallbetter/field-ui.git",
    "directory": "packages/elements"
  },
  "bugs": {
    "url": "https://github.com/zachshallbetter/field-ui/issues"
  },
  "keywords": [
    "field-ui",
    "web-components",
    "custom-elements",
    "particles",
    "physics",
    "canvas",
    "field"
  ],
  "sideEffects": [
    "./dist/index.js"
  ],
  "files": [
    "dist",
    "custom-elements.json",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test"
  },
  "dependencies": {
    "@field-ui/platform": "workspace:*",
    "@field-ui/vanilla": "workspace:*",
    "@field-ui/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "customElements": "custom-elements.json"
}
